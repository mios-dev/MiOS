{
  "_comment_": "MiOS hardened seccomp profile for per-session agent sandboxes. Per the FS+OS Control guide §4 + §15. Default DENY (ERRNO); allowlist of syscalls a sandboxed agent actually needs. clone3 -> ENOSYS so glibc falls back to clone(2). socket() restricted to AF_UNIX (1) -- combined with Network=none in the Quadlet, this is belt-and-braces network deny.",
  "defaultAction": "SCMP_ACT_ERRNO",
  "defaultErrnoRet": 1,
  "architectures": [
    "SCMP_ARCH_X86_64",
    "SCMP_ARCH_X86",
    "SCMP_ARCH_X32"
  ],
  "syscalls": [
    {
      "_comment_": "Core process + file IO (read/write/openat/close/stat/seek/mmap family + signal handling). Required by every libc-linked binary.",
      "names": [
        "read", "write", "open", "openat", "openat2", "close", "close_range",
        "stat", "lstat", "fstat", "lseek", "mmap", "mprotect", "munmap", "brk",
        "rt_sigaction", "rt_sigprocmask", "rt_sigreturn", "rt_sigpending",
        "rt_sigtimedwait", "rt_sigqueueinfo", "rt_sigsuspend",
        "ioctl", "pread64", "pwrite64", "readv", "writev", "preadv", "pwritev",
        "preadv2", "pwritev2",
        "access", "faccessat", "faccessat2",
        "pipe2", "select", "pselect6", "sched_yield",
        "mremap", "msync", "mincore", "madvise", "mlock", "munlock",
        "dup", "dup2", "dup3",
        "nanosleep", "clock_nanosleep",
        "getpid", "gettid", "tkill", "tgkill",
        "fork", "vfork", "execve", "execveat",
        "exit", "exit_group", "wait4", "waitid", "kill",
        "uname",
        "fcntl",
        "fchmod", "fchmodat", "fchown", "fchownat", "lchown",
        "statx", "newfstatat", "getdents64",
        "getcwd", "chdir", "fchdir",
        "renameat", "renameat2",
        "mkdirat", "unlinkat", "symlinkat", "linkat", "readlinkat",
        "umask",
        "gettimeofday", "clock_gettime", "clock_getres", "clock_settime",
        "getuid", "getgid", "geteuid", "getegid",
        "setuid", "setgid", "setresuid", "setresgid",
        "getgroups", "setgroups",
        "getpgrp", "getpgid", "setpgid", "setsid", "getsid", "getppid",
        "getrandom", "prctl", "arch_prctl",
        "sigaltstack", "futex", "futex_waitv",
        "set_robust_list", "get_robust_list", "set_tid_address",
        "epoll_create1", "epoll_ctl", "epoll_pwait", "epoll_pwait2",
        "eventfd2", "poll", "ppoll",
        "timerfd_create", "timerfd_settime", "timerfd_gettime",
        "inotify_init1", "inotify_add_watch", "inotify_rm_watch",
        "membarrier",
        "sched_getaffinity", "sched_setaffinity",
        "sched_getparam", "sched_setparam", "sched_getscheduler", "sched_setscheduler",
        "sched_get_priority_max", "sched_get_priority_min",
        "getrusage", "setrlimit", "getrlimit", "prlimit64",
        "sysinfo", "times",
        "capget", "capset",
        "clone", "rseq",
        "landlock_create_ruleset", "landlock_add_rule", "landlock_restrict_self",
        "memfd_create", "memfd_secret",
        "copy_file_range", "splice", "tee", "vmsplice",
        "sendfile",
        "ftruncate", "fallocate", "fsync", "fdatasync", "sync_file_range", "syncfs"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment_": "clone3 -> ENOSYS forces glibc to fall back to clone(2). clone3 takes its args in a struct (not registers), so arg-filtering is unreliable; failing it cleanly is the safe move.",
      "names": ["clone3"],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 38
    },
    {
      "_comment_": "Socket syscalls allowed (Network=none in the Quadlet enforces isolation).",
      "names": [
        "socket", "socketpair", "bind", "listen", "accept", "accept4",
        "connect", "sendto", "recvfrom", "sendmsg", "recvmsg", "sendmmsg", "recvmmsg",
        "shutdown", "getsockname", "getpeername", "setsockopt", "getsockopt"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "_comment_": "Explicit deny -- escalation gadgets called out in the guide §4. These are blocked by default already (default ERRNO) but enumerating them makes the deny auditable in audit.log.",
      "names": [
        "keyctl", "add_key", "request_key",
        "kexec_load", "kexec_file_load",
        "bpf", "perf_event_open", "userfaultfd",
        "io_uring_setup", "io_uring_enter", "io_uring_register",
        "ptrace",
        "process_vm_readv", "process_vm_writev",
        "setns", "unshare",
        "delete_module", "init_module", "finit_module",
        "mount", "umount", "umount2", "pivot_root",
        "swapon", "swapoff",
        "settimeofday", "stime", "clock_adjtime", "adjtimex",
        "reboot",
        "_sysctl", "syslog",
        "vhangup", "modify_ldt",
        "lookup_dcookie", "quotactl",
        "set_mempolicy", "mbind", "migrate_pages", "move_pages",
        "fanotify_init", "fanotify_mark",
        "open_by_handle_at", "name_to_handle_at"
      ],
      "action": "SCMP_ACT_ERRNO",
      "errnoRet": 1
    }
  ]
}
