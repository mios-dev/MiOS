# /etc/containers/systemd/mios-open-webui.container
# 'MiOS' Open WebUI - rich LLM interface.
#
# Open WebUI provides a ChatGPT-like browser UI fronting the MiOS AI
# stack. AI chain (2026-05-13 architecture):
#   ollama container (:11434)  -- raw inference + embeddings
#     -> Hermes-Agent (:8642/v1) -- DIRECT host install (NOT a
#        container; automation/38-hermes-agent.sh + hermes-agent.service),
#        OpenAI gateway + agent layer
#       -> Open WebUI (this container, :3030) -- browser UI
#
# Open WebUI's OPENAI_API_BASE_URL points at Hermes-Agent so the AGENT
# (with tool-calling / sessions / kanban / skills), not raw ollama, is
# the model Open WebUI serves -- Architectural Law 5 (UNIFIED-AI-REDIRECTS).

[Unit]
Description='MiOS' Open WebUI
# hermes-agent.service is the DIRECT host install (the mios-hermes
# CONTAINER Quadlet is shelved in mios.toml [quadlets.enable]). Open
# WebUI Wants= it but doesn't hard-Require= it -- the UI still starts
# and shows a connection error rather than refusing to boot if the
# agent is mid-restart.
After=network-online.target hermes-agent.service
Wants=network-online.target hermes-agent.service
ConditionPathExists=/etc/mios/hermes/api.env

[Container]
# Image / Port / Network placeholders rendered by automation/15-render-quadlets.sh
Image=${MIOS_OPEN_WEBUI_IMAGE:-ghcr.io/open-webui/open-webui:main}
ContainerName=mios-open-webui
Network=ai-net.network
Network=mios.network
PublishPort=${MIOS_PORT_OPEN_WEBUI:-3030}:8080
AutoUpdate=registry

# Persistent state.
Volume=/var/lib/mios/open-webui:/app/backend/data:Z

# FHS-direct knowledge corpus (operator directive 2026-05-15:
# "use the files directly from the FHS--and refine the files
# themselves"). The mios-owui-apply-knowledge helper registers each
# file in /usr/share/mios/{ai,docs,cookbooks,hermes,prompts} and
# /etc/mios/system-prompts as an OWUI `file` row with its absolute
# FHS path.  When OWUI re-vectorises (e.g. after `file.hash` drift
# detected by the helper), the storage provider returns the path
# verbatim and the loader reads from /usr/share/mios directly --
# requires the bind mounts below.  Read-only because /usr is the
# immutable bootc tree on a real MiOS host (chmod here doesn't
# survive WSL restart anyway -- see
# mios-additionalimagestores-perms.path).
Volume=/usr/share/mios:/usr/share/mios:ro
Volume=/etc/mios:/etc/mios:ro

# API key + server settings, shared with Hermes-Agent. api.env defines
# OPENAI_API_KEY=<API_SERVER_KEY> as a plain scalar -- that IS the
# bearer Open WebUI sends to the Hermes gateway at OPENAI_API_BASE_URL
# below, and EnvironmentFile= injects it directly into the container
# env. Do NOT add OPENAI_API_KEY_FILE pointing at this same file: the
# _FILE variant makes Open WebUI read the ENTIRE multi-line file as the
# key value (comments + every other VAR= line included), which the
# gateway then rejects. Operator-confirmed 2026-05-14 ("Invalid API
# key" / "You do not have permission" on every Open WebUI call).
EnvironmentFile=/etc/mios/hermes/api.env

# Wiring to the MiOS AI stack -- point at Hermes-Agent (Law 5).
# Hermes-Agent is a DIRECT HOST service now, not a container, so the
# old container-DNS name `mios-hermes` no longer resolves. Podman
# injects `host.containers.internal` into every container as the route
# to the host -- that's how a container reaches a host-side service.
# (The MiOS-DEV host-network drop-in overrides this to localhost:8642.)
# Default route OWUI -> Hermes-Agent goes through the MiOS delegation
# prefilter on :8641 (a thin HTTP forwarder that injects tool_choice=
# delegate_task on fan-outable user prompts). Hermes itself is on :8642.
# The prefilter passes through all non-fan-out traffic unchanged.
# Operators who want raw Hermes (no force-delegation) override this via
# /etc/containers/systemd/mios-open-webui.container.d/<name>.conf:
#   Environment=OPENAI_API_BASE_URL=http://host.containers.internal:8642/v1
# (The MiOS-DEV host-network drop-in overrides the host part to localhost.)
Environment=OPENAI_API_BASE_URL=http://host.containers.internal:8641/v1

# Disable Open WebUI's direct-Ollama integration -- all inference must
# route through Hermes-Agent (Law 5). The ollama backend URL is still
# provided for completeness but ENABLE_OLLAMA=False keeps it dormant.
Environment=ENABLE_OLLAMA=False
Environment=OLLAMA_BASE_URL=http://host.containers.internal:11434

# General config.
# WEBUI_NAME drives the brand displayed in OWUI's title bar, login
# screen, and PWA manifest. "MiOS Agent" matches the MiOS-Agent model
# label in the model picker -- both are the operator-facing name for
# the agent stack. Operator directive 2026-05-15: "fix name to
# MiOS-Agent Globally and change the MiOS AI (Open WebUI) to just
# MiOS AI/Agent". OWUI appends "(Open WebUI)" in some contexts (PWA
# title) which we can't fully suppress without forking, but the
# primary brand string is what we control here.
Environment=WEBUI_NAME="MiOS Agent"
Environment=WEBUI_SECRET_KEY=mios-stable-secret-change-me
Environment=ENABLE_SIGNUP=False
Environment=DEFAULT_USER_ROLE=admin
# Pre-select the hermes gateway as the chat default + hide raw model
# IDs from the picker (operator sees friendly "MiOS-Agent" name set
# via the model registration's `name` field, NOT the underlying
# "hermes-agent" model id).
Environment=DEFAULT_MODELS=hermes-agent

# Global feature gates -- ENABLE the rich-chat features that MiOS-Agent
# advertises in its model.meta.capabilities (web_search,
# image_generation, code_interpreter). Without these env vars the
# feature endpoints are 404 and the per-model toggles do nothing even
# when checked.  Defaults in upstream OWUI:
#   ENABLE_WEB_SEARCH         -> False (master gate; we flip True)
#   ENABLE_IMAGE_GENERATION   -> False (master gate; we flip True)
#   ENABLE_CODE_INTERPRETER   -> True  (already-on; pinned for clarity)
# The PER-MODEL default-on state of these toggles is set on the model
# row via meta.defaultFeatureIds (see mios-owui-apply-system-prompt).
# Operator directive 2026-05-15: web/image/code-interpreter all on by
# default for MiOS-Agent.
Environment=ENABLE_WEB_SEARCH=True
Environment=ENABLE_IMAGE_GENERATION=True
Environment=ENABLE_CODE_INTERPRETER=True
# API key auth: required so /usr/libexec/mios/mios-owui-install-pipe
# (and other admin scripts) can POST functions / models / tools to
# OWUI's /api/v1/* endpoints with a Bearer token. The token lives in
# webui.db's api_key table (one row per admin); the installer
# auto-generates one on first run. Operator directive 2026-05-16:
# vendor the MiOS-Agent pipe so OWUI's model dropdown shows it
# without manual paste.
Environment=ENABLE_API_KEY=True
# JWT-style ENABLE_API_KEY needs the SECRET_KEY env too -- OWUI uses
# it to sign user sessions. The installer writes one to webui.db's
# config table on first run if absent.
Environment=ENABLE_API_KEY_ENDPOINT_RESTRICTIONS=False

# Identity. UID 817 (mios-open-webui)
User=${MIOS_OPEN_WEBUI_UID:-817}
Group=${MIOS_OPEN_WEBUI_GID:-817}

Label=org.opencontainers.image.title=mios-open-webui
Label=org.opencontainers.image.url=http://localhost:3030/
Label=io.podman_desktop.openInBrowser=http://localhost:3030/

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=300s
Delegate=yes

[Install]
WantedBy=multi-user.target
