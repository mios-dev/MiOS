# /etc/containers/systemd/mios-searxng.container
# 'MiOS' privacy-respecting metasearch (SearXNG upstream).
#
# SearXNG is the search counterpart to mios-hermes/ollama: it gives the
# operator (and the LLM, via Tools) a single localhost endpoint that
# aggregates results from ~250 upstream search engines without leaking
# any IP, user-agent, or session identifier to those engines. It is
# AGPL-3.0 and 100% local -- no external account, no API key, no
# telemetry. Pairs naturally with the agent surface as a `web_search`
# tool target without breaking Architectural Law 5 (no vendor cloud
# AI URL): SearXNG is a *search proxy*, not a model.
#
# Defaults policy: enabled by default. ConditionPathIsDirectory guards
# the config dir; if /etc/mios/searxng/ doesn't exist (incomplete
# bootstrap) the unit no-ops at pre-boot rather than crash-looping.

[Unit]
Description='MiOS' SearXNG metasearch (privacy-respecting search proxy)
After=network-online.target
Wants=network-online.target
ConditionPathIsDirectory=/etc/mios/searxng

[Container]
# Image / Port / UID placeholders -- resolved at image build time by
# automation/15-render-quadlets.sh from mios.toml [image.sidecars].searxng,
# [ports].searxng, [services.searxng].uid/.gid. Multi-arch index manifest
# at the upstream tag covers amd64 / arm64 / armv7.
Image=${MIOS_SEARXNG_IMAGE:-docker.io/searxng/searxng:latest}
ContainerName=mios-searxng
# Dual-network: mios.network keeps the unit reachable for the rest of
# MiOS; ai-net.network puts SearXNG on the same bridge as mios-hermes
# so the agent's `web_search` tool can call mios-searxng:8080 by
# container name without leaving the network.
Network=${MIOS_QUADLET_NETWORK:-mios.network}
Network=ai-net.network
# searxng host:8888 -> container:8888. 8080 (the granian default) was
# avoided historically to dodge a collision with LocalAI; LocalAI was
# purged 2026-05-11 but 8888 stays the canonical SearXNG port because
# every Hermes-Agent tool wire-up + agent system prompt references it.
# Sibling Quadlets on mios.network reach it as http://mios-searxng:8888/
# without going through host loopback.
PublishPort=${MIOS_PORT_SEARXNG:-8888}:${MIOS_PORT_SEARXNG:-8888}

# Persistent state: settings.yml + uwsgi.ini live under /etc/searxng;
# the container expects them at /etc/searxng inside. We bind-mount the
# host's /etc/mios/searxng read-write so the operator (and SearXNG's
# own first-run secret_key generator) can persist edits across image
# rebuilds. /var/cache/mios/searxng holds the on-disk results cache so
# a restart doesn't repeat queries that the upstream engines have
# already answered.
Volume=/etc/mios/searxng:/etc/searxng:Z
Volume=/var/cache/mios/searxng:/var/cache/searxng:Z

# Identity. UID resolved from mios.toml [services.searxng].uid (default
# 818, pinned in usr/lib/sysusers.d/50-mios-services.conf). The upstream
# SearXNG image's `searxng` user inside the container is uid 977; we're
# overriding it so host-side bind-mounts are owned by mios-searxng and
# the container process can still read+write because the volumes are
# chowned <uid>:<gid> by usr/lib/tmpfiles.d/mios-searxng.conf at boot.
User=${MIOS_SEARXNG_UID:-818}
Group=${MIOS_SEARXNG_GID:-818}

# Public-facing URL. SearXNG uses this as the canonical base for
# generated absolute links (RSS feeds, opensearch.xml, etc.). Operators
# fronting SearXNG behind a reverse proxy override this in
# /etc/mios/searxng/settings.yml -> server.base_url.
Environment=SEARXNG_BASE_URL=http://localhost:${MIOS_PORT_SEARXNG:-8888}/
# Bind directly to the canonical MiOS port (mios.toml [ports].searxng).
# Previously this said 0.0.0.0:8080 with PublishPort=${MIOS_PORT_SEARXNG}:8080
# doing the 8888->8080 remap inside Quadlet's bridge network. That fails
# on the dev VM where Network=host drop-ins make PublishPort a no-op:
# SearXNG ends up trying to bind 0.0.0.0:8080 in the host netns and
# historically collided with mios-ai (LocalAI, since purged) on 8080.
# Operator-flagged 2026-05-11 with `RuntimeError: Address already in
# use (os error 98)` in granian's _init_shared_socket. Bind 8888
# directly so host-network mode just works; bridge-network deployments
# still work via PublishPort= forwarding to 8888.
Environment=SEARXNG_BIND_ADDRESS=0.0.0.0:${MIOS_PORT_SEARXNG:-8888}
Environment=BIND_ADDRESS=0.0.0.0:${MIOS_PORT_SEARXNG:-8888}
# SearXNG's entrypoint calls granian, which reads GRANIAN_HOST +
# GRANIAN_PORT directly (the BIND_ADDRESS / SEARXNG_BIND_ADDRESS
# above are SearXNG-app-level hints used by the upstream Helm chart
# and aren't read by the image's CMD). On the dev VM with Network=
# host, the unmodified granian defaults bind 0.0.0.0:8080; we pin
# them to 8888 explicitly so SearXNG always ends up where MiOS expects.
# Operator-flagged 2026-05-11.
Environment=GRANIAN_HOST=0.0.0.0
Environment=GRANIAN_PORT=${MIOS_PORT_SEARXNG:-8888}

# Limit log volume; SearXNG is chatty per-query.
Environment=SEARXNG_LOG_LEVEL=WARNING

# OCI image labels for Podman Desktop. Values MUST NOT contain
# whitespace -- Quadlet's Label= parser word-splits on spaces and
# emits each word as a separate --label arg, breaking the run line.
Label=org.opencontainers.image.title=mios-searxng
Label=org.opencontainers.image.url=http://localhost:8888/
Label=org.opencontainers.image.documentation=https://docs.searxng.org/
Label=io.podman_desktop.openInBrowser=http://localhost:8888/

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=300s
Delegate=yes

[Install]
WantedBy=multi-user.target default.target
