# /etc/containers/systemd/ai-net.network
# 'MiOS' AI stack network: Hermes-Workspace -> Hermes-Agent -> Ollama.
#
# Topology:
#   browser -> mios-hermes-workspace (3030) -> mios-hermes (8642) -> ollama (11434) -> GPU
#
# Sidecars (mios-hermes, mios-hermes-workspace, ollama, mios-searxng)
# join this bridge in addition to mios.network so they can reach each
# other by container DNS without going through host loopback.
#
# Subnet 10.90.0.0/24 is one octet beyond mios.network's 10.89.0.0/24 to
# stay clear of any podman default ranges, the WSL2 eth0 prefixes
# (10.88.x typical), and the rootful podman default (10.88.0.0/16).
# Quadlet generates the actual podman network as 'systemd-ai-net'.

[Network]
Subnet=10.90.0.0/24
Gateway=10.90.0.1
Label=io.mios.network=ai-stack
