# /etc/containers/systemd/ai-net.network
# 'MiOS' AI stack network (Hermes-Agent <-> Hermes-Workspace <-> Ollama).
#
# Operator directive 2026-05-11:
#   Ollama >> Hermes Agent >> Hermes Workspace app  (chat front-end)
#   LocalAI purged from the codebase; Open WebUI dropped to legacy/masked.
#
# Topology of the live AI stack:
#
#   browser -> mios-hermes-workspace (3030) -> mios-hermes (8642) -> ollama (11434) -> GPU
#
# Every MiOS AI sidecar (mios-hermes, mios-hermes-workspace, ollama,
# mios-searxng) lives on this bridge in addition to mios.network. That way:
#
#   * Hermes-Agent (the LIVE MiOS agent at root /) reaches ollama by
#     container name without leaving the bridge.
#   * mios-hermes-workspace targets mios-hermes:8642/v1 via container DNS.
#   * SearXNG is reachable from the agent's `web_search` tool surface as
#     mios-searxng:8888 without going through host loopback.
#
# Subnet 10.90.0.0/24 is one octet beyond mios.network's 10.89.0.0/24 to
# stay clear of any podman default ranges, the WSL2 eth0 prefixes
# (10.88.x typical), and the rootful podman default (10.88.0.0/16).
# Quadlet generates the actual podman network as 'systemd-ai-net'.

[Network]
Subnet=10.90.0.0/24
Gateway=10.90.0.1
Label=io.mios.network=ai-stack
