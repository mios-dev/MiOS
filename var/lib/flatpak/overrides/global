[Context]
sockets=x11;
devices=all;
filesystems=xdg-config/gtk-3.0:ro;xdg-config/gtk-4.0:ro;xdg-data/icons:ro;xdg-data/themes:ro;/dev/dri;

[Environment]
GSK_RENDERER=cairo
XCURSOR_SIZE=24
GTK_USE_PORTAL=1
LIBGL_ALWAYS_SOFTWARE=1
DISABLE_VK_LAYER_VALVE_steam_overlay_1=1
XCURSOR_THEME=Bibata-Modern-Classic
GDK_BACKEND=x11
GDK_VULKAN_DISABLE=1
XCURSOR_PATH=~/.local/share/icons:~/.icons:/usr/share/icons:/usr/share/pixmaps
ADW_DEBUG_COLOR_SCHEME=prefer-dark
