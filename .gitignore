# bootc ships base helper binaries (initramfs-setup, storage,
# fedora-bootc-destructive-cleanup) at the top level. Track ONLY the
# MiOS-owned declarative subdirs (kargs.d/, install/, bound-images.d/).
!/usr/lib/bootc/
usr/lib/bootc/*
!/usr/lib/bootc/kargs.d/
