<?xml version="1.0" encoding="UTF-8"?>
<!--
  MiOS-Build Windows 11 Secure Boot VM Template
  
  Features:
  - Vendor Secure Boot enabled
  - TPM 2.0 emulation
  - Hyper-V enlightenments for optimal Windows performance
  - Q35 chipset with PCIe root ports for GPU passthrough
  - CPU pinning placeholders for X3D optimization
  
  Usage:
  1. Replace TEMPLATE_VM_NAME with your VM name
  2. Adjust memory (default: 24GB)
  3. Adjust vCPU count and pinning based on your preset
  4. Add storage devices (disk images)
  5. Add GPU passthrough devices if needed
  
  CPU Pinning Presets for 9950X3D:
  
  Gaming Optimized (14 vCPUs):
    CPUs: 1,2,3,4,5,6,7,17,18,19,20,21,22,23
    Emulator: 0,16
    Topology: cores="7" threads="2"
    
  Balanced Gaming Pool (12 vCPUs):
    CPUs: 2,3,4,5,6,7,18,19,20,21,22,23
    Emulator: 0,1,16,17
    Topology: cores="6" threads="2"
    
  Service Pool (12 vCPUs):
    CPUs: 10,11,12,13,14,15,26,27,28,29,30,31
    Emulator: 8,9,24,25
    Topology: cores="6" threads="2"
-->
<domain type="kvm">
  <name>TEMPLATE_VM_NAME</name>
  <metadata>
    <libosinfo:libosinfo xmlns:libosinfo="http://libosinfo.org/xmlns/libvirt/domain/1.0">
      <libosinfo:os id="http://microsoft.com/win/11"/>
    </libosinfo:libosinfo>
  </metadata>
  
  <!-- Memory: 24GB (adjust as needed) -->
  <memory unit="KiB">25165824</memory>
  <currentMemory unit="KiB">25165824</currentMemory>
  
  <!-- vCPU count (adjust based on preset) -->
  <vcpu placement="static">12</vcpu>
  
  <!-- CPU Pinning - Balanced Gaming Pool Preset (default) -->
  <cputune>
    <vcpupin vcpu="0" cpuset="2"/>
    <vcpupin vcpu="1" cpuset="3"/>
    <vcpupin vcpu="2" cpuset="4"/>
    <vcpupin vcpu="3" cpuset="5"/>
    <vcpupin vcpu="4" cpuset="6"/>
    <vcpupin vcpu="5" cpuset="7"/>
    <vcpupin vcpu="6" cpuset="18"/>
    <vcpupin vcpu="7" cpuset="19"/>
    <vcpupin vcpu="8" cpuset="20"/>
    <vcpupin vcpu="9" cpuset="21"/>
    <vcpupin vcpu="10" cpuset="22"/>
    <vcpupin vcpu="11" cpuset="23"/>
    <emulatorpin cpuset="0,1,16,17"/>
  </cputune>
  
  <!-- UEFI Secure Boot Configuration -->
  <os>
    <type arch="x86_64" machine="pc-q35-10.1">hvm</type>
    <loader readonly="yes" secure="yes" type="pflash">/usr/share/edk2/x64/OVMF_CODE.secboot.4m.fd</loader>
    <nvram template="/usr/share/edk2/x64/OVMF_VARS.4m.fd">/var/lib/libvirt/qemu/nvram/TEMPLATE_VM_NAME_VARS.fd</nvram>
    <bootmenu enable="yes"/>
  </os>
  
  <!-- Hardware Features -->
  <features>
    <acpi/>
    <apic/>
    <!-- Hyper-V Enlightenments for Windows Performance -->
    <hyperv mode="custom">
      <relaxed state="on"/>
      <vapic state="on"/>
      <spinlocks state="on" retries="8191"/>
      <vpindex state="on"/>
      <runtime state="on"/>
      <synic state="on"/>
      <stimer state="on"/>
      <frequencies state="on"/>
      <tlbflush state="on"/>
      <ipi state="on"/>
      <avic state="on"/>
    </hyperv>
    <vmport state="off"/>
    <!-- SMM required for Secure Boot -->
    <smm state="on"/>
  </features>
  
  <!-- CPU Configuration -->
  <cpu mode="host-passthrough" check="none" migratable="on">
    <!-- Topology: 6 cores x 2 threads = 12 vCPUs (adjust for preset) -->
    <topology sockets="1" dies="1" clusters="1" cores="6" threads="2"/>
    <cache mode="passthrough"/>
    <!-- AMD-specific features for optimal performance -->
    <feature policy="require" name="topoext"/>
    <feature policy="require" name="invtsc"/>
  </cpu>
  
  <!-- Clock Configuration -->
  <clock offset="localtime">
    <timer name="rtc" tickpolicy="catchup"/>
    <timer name="pit" tickpolicy="delay"/>
    <timer name="hpet" present="no"/>
    <timer name="hypervclock" present="yes"/>
  </clock>
  
  <!-- Power Management -->
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <pm>
    <suspend-to-mem enabled="no"/>
    <suspend-to-disk enabled="no"/>
  </pm>
  
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>
    
    <!-- USB Controller -->
    <controller type="usb" index="0" model="qemu-xhci" ports="15">
      <address type="pci" domain="0x0000" bus="0x02" slot="0x00" function="0x0"/>
    </controller>
    
    <!-- PCIe Controllers for GPU Passthrough -->
    <controller type="pci" index="0" model="pcie-root"/>
    <controller type="pci" index="1" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="1" port="0x8"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x0" multifunction="on"/>
    </controller>
    <controller type="pci" index="2" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="2" port="0x9"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x1"/>
    </controller>
    <controller type="pci" index="3" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="3" port="0xa"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x2"/>
    </controller>
    <controller type="pci" index="4" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="4" port="0xb"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x3"/>
    </controller>
    <controller type="pci" index="5" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="5" port="0xc"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x4"/>
    </controller>
    <controller type="pci" index="6" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="6" port="0xd"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x5"/>
    </controller>
    <controller type="pci" index="7" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="7" port="0xe"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x6"/>
    </controller>
    <controller type="pci" index="8" model="pcie-root-port">
      <model name="pcie-root-port"/>
      <target chassis="8" port="0xf"/>
      <address type="pci" domain="0x0000" bus="0x00" slot="0x01" function="0x7"/>
    </controller>
    
    <!-- SATA Controller -->
    <controller type="sata" index="0">
      <address type="pci" domain="0x0000" bus="0x00" slot="0x1f" function="0x2"/>
    </controller>
    
    <!-- Virtio Serial (for SPICE agent) -->
    <controller type="virtio-serial" index="0">
      <address type="pci" domain="0x0000" bus="0x03" slot="0x00" function="0x0"/>
    </controller>
    
    <!--
    ADD YOUR STORAGE HERE
    Example (virtio disk):
    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2" discard="unmap"/>
      <source file="/var/lib/libvirt/images/TEMPLATE_VM_NAME.qcow2"/>
      <target dev="vda" bus="virtio"/>
      <address type="pci" domain="0x0000" bus="0x04" slot="0x00" function="0x0"/>
    </disk>
    -->
    
    <!-- Network (virtio) -->
    <interface type="network">
      <mac address="52:54:00:XX:XX:XX"/>
      <source network="default"/>
      <model type="virtio"/>
      <address type="pci" domain="0x0000" bus="0x01" slot="0x00" function="0x0"/>
    </interface>
    
    <!-- Serial Console -->
    <serial type="pty">
      <target type="isa-serial" port="0">
        <model name="isa-serial"/>
      </target>
    </serial>
    <console type="pty">
      <target type="serial" port="0"/>
    </console>
    
    <!-- SPICE Channel -->
    <channel type="spicevmc">
      <target type="virtio" name="com.redhat.spice.0"/>
      <address type="virtio-serial" controller="0" bus="0" port="1"/>
    </channel>
    
    <!-- Input Devices -->
    <input type="tablet" bus="usb">
      <address type="usb" bus="0" port="1"/>
    </input>
    <input type="mouse" bus="ps2"/>
    <input type="keyboard" bus="ps2"/>
    
    <!-- TPM 2.0 (required for Windows 11) -->
    <tpm model="tpm-crb">
      <backend type="emulator" version="2.0"/>
    </tpm>
    
    <!-- SPICE Graphics (for initial setup) -->
    <graphics type="spice" autoport="yes">
      <listen type="address"/>
      <image compression="off"/>
    </graphics>
    
    <!-- Audio (ICH9 HD Audio) -->
    <sound model="ich9">
      <address type="pci" domain="0x0000" bus="0x00" slot="0x1b" function="0x0"/>
    </sound>
    <audio id="1" type="none"/>
    
    <!-- Video: Set to none for GPU passthrough -->
    <video>
      <model type="none"/>
    </video>
    
    <!--
    ADD GPU PASSTHROUGH HERE
    Example (RTX 4090):
    <hostdev mode="subsystem" type="pci" managed="yes">
      <source>
        <address domain="0x0000" bus="0x01" slot="0x00" function="0x0"/>
      </source>
      <address type="pci" domain="0x0000" bus="0x05" slot="0x00" function="0x0"/>
    </hostdev>
    <hostdev mode="subsystem" type="pci" managed="yes">
      <source>
        <address domain="0x0000" bus="0x01" slot="0x00" function="0x1"/>
      </source>
      <address type="pci" domain="0x0000" bus="0x06" slot="0x00" function="0x0"/>
    </hostdev>
    -->
    
    <!-- Watchdog -->
    <watchdog model="itco" action="reset"/>
    
    <!-- Disable memory ballooning for consistent performance -->
    <memballoon model="none"/>
  </devices>
</domain>
