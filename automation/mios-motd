#!/bin/bash
# MiOS v0.2.0 -- MOTD Dashboard
# Shows management interfaces, service statuses, and clickable links.
# Displayed on TTY login and terminal open via profile.d.
[[ $- != *i* ]] && exit 0
[[ -n "$MIOS_NO_MOTD" ]] && exit 0

_ip() { ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1; }
IP=$(_ip); [[ -z "$IP" ]] && IP="1.1.1.1"
HN=$(hostname -s 2>/dev/null || echo "MiOS")
_l() { printf '\e]8;;%s\e\\%s\e]8;;\e\\' "$1" "$2"; }
C='\033[0;36m';W='\033[1;37m';G='\033[0;32m';Y='\033[0;33m';D='\033[0;90m';N='\033[0m'
_s() { systemctl is-active --quiet "$1" 2>/dev/null && printf "${G}‚óè${N}" || printf "${D}‚óã${N}"; }

echo ""
printf "${C}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${N}\n"
printf "${W}  MiOS v0.2.0${N}  ${D}${HN} -- ${IP}${N}\n"
printf "${C}‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê‚ïê${N}\n"
echo ""
printf "${W}  Management${N}\n"
printf "  $(_s cockpit.socket)  Cockpit           $(_l "https://${IP}:9090" "https://${IP}:9090")\n"
printf "  $(_s sshd)  SSH               $(_l "ssh://${IP}" "${IP}:22")\n"

# RDP -- check both GRD and xRDP
if systemctl is-active --quiet gnome-remote-desktop 2>/dev/null; then
    printf "  ${G}‚óè${N}  Remote Desktop    $(_l "rdp://${IP}:3389" "${IP}:3389") ${D}(GRD)${N}\n"
elif systemctl is-active --quiet xrdp 2>/dev/null; then
    printf "  ${G}‚óè${N}  Remote Desktop    $(_l "rdp://${IP}:3389" "${IP}:3389") ${D}(xRDP)${N}\n"
else
    printf "  ${D}‚óã${N}  Remote Desktop    ${D}inactive${N}\n"
fi

# Guacamole
if systemctl is-active --quiet mios-guacamole.service 2>/dev/null || \
   podman ps --format '{{.Names}}' 2>/dev/null | grep -q mios-guacamole; then
    printf "  ${G}‚óè${N}  Browser Desktop   $(_l "http://${IP}:8080/guacamole/" "http://${IP}:8080/guacamole/")\n"
fi

echo ""
printf "${W}  Infrastructure${N}\n"
printf "  $(_s firewalld)  Firewall          ${D}firewall-cmd --list-all${N}\n"
printf "  $(_s podman.socket)  Podman            ${D}$(podman ps -q 2>/dev/null | wc -l) containers${N}\n"
printf "  $(_s libvirtd.socket)  Libvirt           ${D}virt-manager / virsh${N}\n"

# Optional services -- only show if enabled
systemctl is-active --quiet k3s.service 2>/dev/null && \
    printf "  ${G}‚óè${N}  K3s API           $(_l "https://${IP}:6443" "https://${IP}:6443")\n"
systemctl is-active --quiet ceph-mgr@*.service 2>/dev/null && \
    printf "  ${G}‚óè${N}  Ceph Dashboard    $(_l "https://${IP}:8443" "https://${IP}:8443")\n"
systemctl is-active --quiet avahi-daemon 2>/dev/null && \
    printf "  ${G}‚óè${N}  mDNS             ${D}${HN}.local${N}\n"

# Hyper-V enhanced session
VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")
if [ "$VIRT" = "microsoft" ]; then
    systemctl is-active --quiet xrdp 2>/dev/null && \
        printf "  ${G}‚óè${N}  Hyper-V Enhanced  ${D}vsock:3389${N}\n"
fi

echo ""
printf "  ${D}mios --help | export MIOS_NO_MOTD=1 to hide${N}\n"
echo ""
