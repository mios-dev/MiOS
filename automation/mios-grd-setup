#!/bin/bash
# MiOS v0.1.1 — mios-grd-setup helper
# This script is a build-time or manual helper. 
# The primary runtime setup is handled by /usr/libexec/mios-grd-setup via systemd.
set -euo pipefail

SENTINEL="/var/lib/mios/.grd-init-done"
[ -f "$SENTINEL" ] && exit 0

GRD_DIR="/var/lib/gnome-remote-desktop"
mkdir -p "$GRD_DIR"

if [ ! -f "$GRD_DIR/rdp-tls.key" ]; then
    echo "Generating self-signed TLS material for GRD (EC prime256v1)..."
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -sha256 -days 3650 -nodes \
        -keyout "$GRD_DIR/rdp-tls.key" -out "$GRD_DIR/rdp-tls.crt" -subj "/CN=MiOS-RDP" 2>/dev/null
    chown -R gnome-remote-desktop:gnome-remote-desktop "$GRD_DIR" 2>/dev/null || true
    chmod 600 "$GRD_DIR/rdp-tls.key"
fi

grdctl --system rdp set-tls-key "$GRD_DIR/rdp-tls.key" 2>/dev/null || true
grdctl --system rdp set-tls-cert "$GRD_DIR/rdp-tls.crt" 2>/dev/null || true

# Security: DO NOT set default credentials (mios:mios) here.
# Credentials should be set via /etc/mios/grd/credentials or MIOS_PASSWORD env var.

if [[ -n "${MIOS_PASSWORD:-}" ]]; then
    grdctl --system rdp set-credentials mios "$MIOS_PASSWORD" 2>/dev/null || true
    grdctl --system rdp enable 2>/dev/null || true
    systemctl enable --now gnome-remote-desktop.service 2>/dev/null || true
fi

if command -v firewall-cmd &>/dev/null && firewall-cmd --state &>/dev/null 2>&1; then
    firewall-cmd --add-port=3389/tcp --add-port=8080/tcp 2>/dev/null || true
    firewall-cmd --permanent --add-port=3389/tcp --add-port=8080/tcp 2>/dev/null || true
fi

mkdir -p "$(dirname "$SENTINEL")"
touch "$SENTINEL"
