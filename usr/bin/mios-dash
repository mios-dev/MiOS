#!/usr/bin/env bash
# mios-dash -- show the MiOS live system dashboard. Thin shell-front
# wrapper for /usr/libexec/mios/mios-dashboard.sh that matches the
# rest of the mios-* CLI naming convention (mios-status, mios-update,
# mios-rebuild, mios-build, mios-deploy, mios-flatpaks, mios-vfio-*,
# mios-backup, mios-ollama).
#
#   mios-dash                  full dashboard (logo + system info +
#                              services + git tree)
#   mios-dash --services-only  just the endpoints + Quadlet rollup +
#                              git state (no logo / no fastfetch)
#   mios-dash --no-color       strip ANSI escape codes (CI / pipe-to-file)
#   mios-dash --help           usage
#
# The dashboard is also rendered automatically at every interactive
# shell login via /etc/profile.d/zz-mios-motd.sh (deduped per session
# with $MIOS_MOTD_SHOWN).
set -euo pipefail
exec /usr/libexec/mios/mios-dashboard.sh "$@"
