def _load_routing_list(key: str) -> list:
    """Load a [routing].<key> phrase list from the layered mios.toml (lowercased,
    longest-first). SSOT -- no hardcoded English. Fail-safe -> []."""
    try:
        import tomllib
    except ImportError:
        try:
            import tomli as tomllib  # type: ignore
        except ImportError:
            return []
    for p in (os.environ.get("MIOS_TOML", ""), "/etc/mios/mios.toml",
              "/usr/share/mios/mios.toml"):
        if not p or not pathlib.Path(p).is_file():
            continue
        try:
            with open(p, "rb") as f:
                rt = (tomllib.load(f).get("routing") or {})
            vals = sorted(
                {str(x).lower().strip() for x in (rt.get(key) or []) if str(x).strip()},
                key=len, reverse=True)
            if vals:
                return vals
        except Exception:
            continue
    return []


# Launch grammar: trigger verbs mirror the catalog's open_app/launch_app ("open /
# launch / start / run X"); the strip-lists are SSOT [routing].* -- the SAME lists
# the agent-pipe deterministic route uses. Keeps the CLI launch DETERMINISTIC
# instead of relying on the small Hermes model's tool selection (which loops on
# everything_search for "open notepad" -- operator 2026-06-07).
_CLI_LAUNCH_TRIGGERS = frozenset({"open", "launch", "start", "run"})
_CLI_COMPOUND = frozenset({"in", "and", "then", "with", "on", "to"})


def _cli_launch_followup(prompt: str) -> bool:
    """True if `prompt` is a launch FOLLOW-UP / RETRY about a PRIOR launch
    (operator 2026-06-14, BUG B/C): "epiphany didn't launch for me", "attempt to
    launch and verify", "try again". These carry no fresh "open/launch X" head,
    so `_cli_launch_target` returns None and they fell through to free-form
    Hermes -> narration. When the session has a remembered last-launched app, the
    caller re-runs the launch+verify path against it deterministically. Phrase
    lists are SSOT [routing].launch_followup_phrases / launch_retry_phrases (no
    hardcoded English here)."""
    t = (prompt or "").strip().lower()
    if not t or len(t) > 160:
        return False
    for key in ("launch_followup_phrases", "launch_retry_phrases"):
        for ph in _load_routing_list(key):
            if ph and ph in t:
                return True
    return False


def _run_verified_launch(app: str) -> int:
    """Fire the LAUNCH+VERIFY path for `app` (the launch_and_verify_app verb's
    backend: mios-os-control launch <app>, which fires the launch THEN polls the
    window verifier). This is what a launch RETRY/VERIFY follow-up should run --
    not narrate (operator 2026-06-14, BUG B: the CLI told the operator to run
    `mios-gui epiphany` and asked permission instead of acting). Falls back to a
    plain mios-launch + mios-verify-launch when mios-os-control is absent, then to
    a bare mios-launch. Returns the process exit code (0 = launched/verified)."""
    for argv in (["mios-os-control", "launch", app],):
        try:
            sys.stderr.write(f"mios: launching + verifying '{app}' (deterministic verify route)\n")
            return subprocess.run(argv).returncode
        except FileNotFoundError:
            break
    # mios-os-control absent -> plain launch then a read-only verify probe.
    try:
        sys.stderr.write(f"mios: launching '{app}' (deterministic launch route)\n")
        rc = subprocess.run(["mios-launch", app]).returncode
    except FileNotFoundError:
        return 127
    try:
        subprocess.run(["mios-verify-launch", app])
    except FileNotFoundError:
        pass
    return rc


def _cli_launch_target(prompt: str):
    """If `prompt` is an unambiguous 'open/launch/start/run <app>', return the
    cleaned app name for mios-launch; else None (fall through to chat)."""
    t = (prompt or "").strip()
    if not t or len(t) > 80 or "?" in t:
        return None
    words = t.split()
    if len(words) < 2:
        return None
    if words[0].lower().strip(".,:;!\"'") not in _CLI_LAUNCH_TRIGGERS:
        return None
    rest = " ".join(words[1:]).strip().rstrip(" .,!;:")
    low = rest.lower()
    fillers = _load_routing_list("launch_filler_phrases")
    changed = True
    while changed and rest:
        changed = False
        for f in fillers:
            if f and low.endswith(f):
                rest = rest[: len(rest) - len(f)].rstrip(" ,.")
                low = rest.lower()
                changed = True
                break
    lead = set(_load_routing_list("launch_target_lead_phrases"))
    trail = set(_load_routing_list("launch_target_trail_phrases"))
    rw = rest.split()
    while rw and rw[0].lower() in lead:
        rw.pop(0)
    while rw and rw[-1].lower() in trail:
        rw.pop()
    rest = " ".join(rw).strip()
    low = rest.lower()
    if not rest or len(rest.split()) > 3:
        return None
    if "://" in rest or any(w in _CLI_COMPOUND for w in low.split()):
        return None
    return rest


def main(argv: list[str]) -> int:
    if len(argv) < 2 or argv[1] in ("-h", "--help") or (len(argv) >= 2 and argv[1] == "help"):
        sys.stderr.write(
            "mios -- MiOS verb dispatcher + locally-hosted OpenAI agent shell.\n\n"
            "Verbs:\n"
            "  mios build                           run the MiOS OCI build pipeline (unattended on a non-TTY)\n"
            "  mios dash                            framed dashboard (services + endpoints + git tree)\n"
            "  mios config                          open the HTML configurator in your browser\n"
            "  mios code                            open code-server in your browser\n"
            "  mios ai                              open Open WebUI in your browser\n"
            "  mios ai clear                        DAY-0 clean slate: wipe chats/jobs/kanban/DBs/RAG\n"
            "  mios xbox                            Xbox VM Secure Boot / XML repair\n"
            "  mios virt                            apply optimized VM config + CPU pinning\n"
            "  mios vfio                            configure GPU/USB passthrough (Isolation)\n"
            "  mios vfio-check                      report VFIO / IOMMU binding state\n"
            "  mios vfio-toggle                     interactive VFIO device selector\n"
            "  mios tune                            system-wide CPU isolation & latency tuning\n"
            "  mios summary                         quick ASCII system overview\n"
            "  mios profile                         interactive hardware/system profiler menu\n"
            "  mios assess                          comprehensive system capability report\n"
            "  mios iommu                           pretty-print hardware IOMMU topology\n"
            "  mios iommu-groups                    list raw IOMMU groups and devices\n"
            "  mios env                             inspect layered MIOS_* environment\n"
            "  mios sync-env                        regenerate install.env from mios.toml\n"
            "  mios flatpaks                        manage system-wide Flatpaks\n"
            "  mios theme                           sync bibata/GTK/Qt themes\n"
            "  mios user                            initialize user space (dotfiles/XDG)\n"
            "  mios help                            this help\n\n"
            "Chat (anything else):\n"
            "  mios <prompt>                        chat + tool calls against Hermes-Agent\n"
            "  mios --no-tools <prompt>             disable function calling\n"
            "  mios --json <schema-name> <prompt>   structured output (schema-name = file in\n"
            "                                       /usr/lib/mios/schemas/ without .schema.json)\n"
        )
        return 0 if len(argv) >= 2 else 1

    # `mios ai clear` -> Day-0 global clean slate. Handled BEFORE the verb
    # dispatch so the `clear` subcommand isn't swallowed by the `ai` verb
    # (which opens OWUI). Case-insensitive so `mios AI clear` works too.
    if len(argv) >= 3 and argv[1].lower() == "ai" and argv[2].lower() == "clear":
        _clear = "/usr/libexec/mios/mios-ai-clear"
        if pathlib.Path(_clear).is_file():
            os.execvp(_clear, [_clear] + argv[3:])
        sys.stderr.write("mios: mios-ai-clear not found at %s\n" % _clear)
        return 1

    # Verb dispatch -- if the first arg matches a known verb AND the
    # target wrapper is reachable, exec it directly. Falls through to
    # chat if the wrapper is missing so the operator still gets useful
    # output on a partially-deployed system.
    first = argv[1]
    if first in KNOWN_VERBS and KNOWN_VERBS[first] is not None:
        cmd = KNOWN_VERBS[first]
        target = cmd[0]
        if pathlib.Path(target).is_file() or subprocess.run(
            ["sh", "-c", f"command -v {target}"], capture_output=True, text=True
        ).returncode == 0:
            os.execvp(cmd[0], cmd + argv[2:])

    # THIN CLIENT (operator 2026-06-16 "UNIFY THE MiOS AI PIPELINE"): default to NO
    # client-side tools so the agent-pipe orchestrator (:8640) owns the WHOLE pipeline
    # -- refine -> native loop (deterministic launch + read-back-verified type-chain) ->
    # SERVER-SIDE broker execution -- instead of the CLI running its own weak client-side
    # tool roundtrip (which floundered for 17min and fabricated). Opt back into the legacy
    # client-side tools with --tools.
    use_tools  = False
    schema_obj = None
    args = argv[1:]
    if args and args[0] in ("--no-tools", "--thin"):
        use_tools = False
        args = args[1:]
    elif args and args[0] == "--tools":
        use_tools = True
        args = args[1:]
    elif args and args[0] == "--json":
        if len(args) < 3:
            sys.stderr.write("mios --json requires <schema-name> <prompt>\n")
            return 2
        schema_obj = load_schema(args[1])
        if not schema_obj:
            sys.stderr.write(
                f"mios: schema '{args[1]}' not found at "
                f"{LIB}/schemas/{args[1]}.schema.json\n"
            )
            return 2
        use_tools = False
        args = args[2:]

    prompt = " ".join(args).strip()
    if not prompt:
        sys.stderr.write("mios: empty prompt\n")
        return 2

    # Per-terminal session: one stable conversation id + a rolling transcript +
    # the last-launched app, so consecutive `@`/`mios` turns in this terminal
    # share context (operator 2026-06-14, BUG C). Structured-output (--json) is a
    # one-shot contract, so it opts OUT of the rolling history but still rolls the
    # id forward. Best-effort: a load/save failure degrades to the old stateless
    # behaviour, never blocks the turn.
    session = load_session()

    # Deterministic launch pre-route. TWO shapes:
    #   (1) a bare "open/launch/start/run <app>" -- one concrete action; dispatch
    #       it to mios-launch DIRECTLY (Windows-native via the in-session executor;
    #       Linux apps fall through inside mios-launch), bypassing the Hermes model
    #       whose small-model tool loop is unreliable for launches (operator
    #       2026-06-07: "open notepad" looped on everything_search).
    #   (2) a launch FOLLOW-UP / RETRY ("X didn't launch", "attempt to launch and
    #       verify", "try again") referring to the PRIOR launch -- re-run the
    #       launch+VERIFY path against the session's last-launched app instead of
    #       narrating advice + asking permission (operator 2026-06-14, BUG B).
    # Default tool-using chat only (not --no-tools / --json). Falls through to chat
    # if the launch wrappers are missing.
    if use_tools:
        _app = _cli_launch_target(prompt)
        if _app:
            try:
                sys.stderr.write(f"mios: launching '{_app}' (deterministic launch route)\n")
                _r = subprocess.run(["mios-launch", _app])
                _ok = _r.returncode == 0
                print(f"Opened {_app}." if _ok
                      else f"Could not open {_app} (mios-launch exit {_r.returncode}).")
                session["last_app"] = _app
                save_session(session)
                return 0 if _ok else 1
            except FileNotFoundError:
                pass  # mios-launch not on PATH -> fall through to the chat path
        elif _cli_launch_followup(prompt):
            _last = session.get("last_app")
            if _last:
                _rc = _run_verified_launch(str(_last))
                _ok = _rc == 0
                print(f"Re-ran launch + verify for {_last}: "
                      + ("confirmed it opened." if _ok
                         else f"still could not confirm it opened (exit {_rc})."))
                session["last_app"] = str(_last)
                save_session(session)
                return 0 if _ok else 1
            # No remembered app in this session -> fall through to chat so the
            # agent can ask / resolve (rather than the CLI guessing a target).

    client = OpenAI(base_url=ENDPOINT, api_key=API_KEY)
    is_orchestrator = ":8640" in ENDPOINT or "/agent-pipe" in ENDPOINT
    msgs: list[dict[str, Any]] = []
    if not is_orchestrator:
        msgs.append({"role": "system", "content": resolve_system_prompt()})
    # Replay this terminal's rolling transcript so the model sees prior turns
    # (BUG C). --json is a single-shot structured contract -> no replay.
    _replay = (not schema_obj) and isinstance(session.get("history"), list)
    if _replay:
        for _m in session["history"][-(SESSION_HISTORY_TURNS * 2):]:
            if isinstance(_m, dict) and _m.get("role") in ("user", "assistant") and _m.get("content"):
                msgs.append({"role": _m["role"], "content": str(_m["content"])})
    msgs.append({"role": "user", "content": prompt})
    tools = load_tools() if use_tools else None

    # Send the session id to Hermes as the OpenAI-standard session keys
    # (metadata.chat_id -- the SAME key the agent-pipe/OWUI path uses -- plus the
    # `user` field) so a gateway that persists per-conversation state threads the
    # turns server-side too. extra_body merges into the request JSON body.
    # Forward this shell's INVOCATION ENVIRONMENT so the agent knows WHERE it is
    # being spoken to from (operator 2026-06-19 "@*/mios ... should know what
    # folder it's currently in ... aware of all env details for all chat surfaces
    # natively"). The agent-pipe reads metadata.variables (_client_env) and
    # threads cwd/surface/host + local date/time into its grounding. Best-effort:
    # any probe failure just omits that key.
    import socket as _socket, platform as _platform, datetime as _datetime
    _now = _datetime.datetime.now().astimezone()
    _client_vars = {"SURFACE": "mios-cli"}
    try: _client_vars["CWD"] = os.getcwd()
    except OSError: pass
    try: _client_vars["HOST"] = _socket.gethostname()
    except OSError: pass
    try: _client_vars["OS"] = (_platform.system() + " " + _platform.release()).strip()
    except Exception: pass
    _client_vars["CURRENT_DATE"] = _now.strftime("%Y-%m-%d")
    _client_vars["CURRENT_TIME"] = _now.strftime("%H:%M")
    _client_vars["CURRENT_WEEKDAY"] = _now.strftime("%A")
    if _now.tzname():
        _client_vars["CURRENT_TIMEZONE"] = _now.tzname()
    extra_body = {"metadata": {"chat_id": session.get("id"),
                               "session_id": session.get("id"),
                               "variables": _client_vars}}
    request_user = session.get("id")

    # Capture the assistant's visible answer so it can be appended to the rolling
    # transcript after the turn completes (mutated in place by chat_streaming).
    answer_box: list[str] = []
    try:
        chat_streaming(client, msgs, tools, schema_obj,
                       extra_body=extra_body, request_user=request_user,
                       answer_box=answer_box)
        if _replay:
            session.setdefault("history", [])
            session["history"].append({"role": "user", "content": prompt})
            _ans = ("".join(answer_box)).strip()
            if _ans:
                session["history"].append({"role": "assistant", "content": _ans[:4000]})
            save_session(session)
        else:
            save_session(session)  # roll the id's TTL forward
        return 0
    except KeyboardInterrupt:
        sys.stderr.write("\nmios: interrupted\n")
        return 130
    except Exception as e:                    # noqa: BLE001
        sys.stderr.write(f"\nmios: {type(e).__name__}: {e}\n")
        sys.stderr.write(f"  endpoint: {ENDPOINT}\n  model: {MODEL}\n")
        return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv))
