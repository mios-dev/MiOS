#!/usr/bin/env python3
# AI-hint: The primary CLI entry point for the MiOS system, providing an OpenAI-compatible agent shell that handles tool-calling, system prompt resolution, and streaming responses from the Hermes-Agent gateway.
# AI-related: /usr/lib/mios/tools/chat-completions-api/, /usr/libexec/mios/tools, /etc/mios/install.env, /etc/mios/hermes/api.env, /etc/mios/ai/system-prompt.md, /usr/share/mios/ai/system.md, /usr/libexec/mios/tools/, /usr/libexec/mios/mios-build-driver, /usr/libexec/mios/mios-dashboard.sh, /usr/libexec/mios/mios-configurator-launch
# /usr/bin/mios -- locally-hosted OpenAI-API-compatible agent shell.
#
# Drives whichever model is bound to MIOS_AI_ENDPOINT (default
# http://localhost:8642/v1 -- Hermes-Agent, the live MiOS agent at /).
# Streams tokens, runs the function-calling roundtrip against the tool
# definitions in /usr/lib/mios/tools/chat-completions-api/, and
# resolves the canonical system prompt via the layered override chain.
#
# Usage:
#   mios <prompt>
#   mios --json <schema-name> <prompt>   # structured output, no tools
#   mios --no-tools <prompt>             # disable function calling
#
# Environment (per Architectural Law 5):
#   MIOS_AI_ENDPOINT=http://localhost:8642/v1   OpenAI-compatible base URL
#   MIOS_AI_KEY=                                bearer token
#   MIOS_AI_MODEL=qwen3.5:2b                    chat model id
#   MIOS_AI_SYSTEM_PROMPT=/path/to/system.md    explicit override
#   MIOS_SHARE_DIR=/usr/share/mios              resolved-file base

from __future__ import annotations

import glob
import json
import os
import pathlib
import subprocess
import sys
from typing import Any, Iterable

try:
    from openai import OpenAI                      # openai>=1.55
except ImportError:
    sys.stderr.write(
        "mios: openai SDK missing. Install via:\n"
        "    sudo dnf install -y python3-openai      # Fedora 44+\n"
        "  OR\n"
        "    pip install --user 'openai>=1.55'\n"
    )
    sys.exit(127)

# ─── Configuration ────────────────────────────────────────────────────
ENDPOINT = os.environ.get("MIOS_AI_ENDPOINT", "http://localhost:8640/v1")
# UNIFIED ENTRYPOINT (operator 2026-06-16 "UNIFY THE MiOS AI PIPELINE"): route
# `mios <prompt>` / `@<prompt>` to the AGENT-PIPE ORCHESTRATOR (:8640), NOT Hermes
# (:8642). The pipe runs the full MiOS pipeline (refine -> route -> native-loop /
# council / client-tools-hybrid -> polish) and executes EVERY tool SERVER-SIDE via
# the broker (firewall/HITL/audit/read-back verification), so the CLI gets the same
# orchestrated, anti-fabricating behaviour as OWUI -- never a weak leaf model
# fabricating "I typed it". Hermes :8642 becomes a leaf engine the pipe calls, not a
# public entrypoint. The pipe serves the virtual model "MiOS-Agent". MIOS_AI_MODEL
# stays the raw-tag SSOT for the image build; the request model is MIOS_AI_GATEWAY_MODEL.
MODEL    = os.environ.get("MIOS_AI_GATEWAY_MODEL", "MiOS AI")
SHARE    = pathlib.Path(os.environ.get("MIOS_SHARE_DIR", "/usr/share/mios"))
LIB      = pathlib.Path("/usr/lib/mios")
LIBEXEC  = pathlib.Path("/usr/libexec/mios/tools")


def _resolve_api_key() -> str:
    # Order: MIOS_AI_KEY env > /etc/mios/install.env > /etc/mios/hermes/api.env > "sk-noop".
    # Hermes-Agent requires the shared API_SERVER_KEY for /v1/* calls;
    # an empty/wrong key returns 401 with "Invalid API key".
    v = os.environ.get("MIOS_AI_KEY")
    if v:
        return v
    import re
    for env_file in ("/etc/mios/install.env", "/etc/mios/hermes/api.env"):
        try:
            with open(env_file, encoding="utf-8") as f:
                for line in f:
                    m = re.match(r'^(?:API_SERVER_KEY|MIOS_AI_KEY|OPENAI_API_KEY)\s*=\s*"?([^"\r\n]+)"?', line)
                    if m:
                        return m.group(1).strip()
        except OSError:
            continue
    return "sk-noop"


API_KEY = _resolve_api_key()


# ─── Per-terminal session continuity ──────────────────────────────────
# Each `mios <prompt>` / `@<prompt>` invocation is a FRESH process: it builds a
# brand-new request to Hermes (:8642) with no shared id, so consecutive turns in
# the SAME terminal lose context (operator 2026-06-14, BUG C: after "open
# epiphany", "attempt to launch and verify" had no idea what to launch -- a
# stateless hermes session asked "which app?"). Fix: derive a STABLE session id
# per controlling TTY, persisted in a short-TTL rolling state file under the XDG
# state dir, so successive turns in one terminal share ONE conversation id (sent
# to Hermes as metadata.chat_id + the OpenAI `user` field) AND a small client-
# side rolling transcript we replay as prior messages -- continuity holds even
# if the gateway doesn't persist server-side. A new terminal (different TTY) or
# an idle gap past the TTL starts a fresh session.
SESSION_TTL_S = int(os.environ.get("MIOS_CLI_SESSION_TTL", "1800") or 1800)
SESSION_HISTORY_TURNS = int(os.environ.get("MIOS_CLI_SESSION_TURNS", "12") or 12)


def _state_dir() -> pathlib.Path:
    base = os.environ.get("XDG_STATE_HOME") or str(pathlib.Path.home() / ".local/state")
    d = pathlib.Path(base) / "mios" / "cli-sessions"
    try:
        d.mkdir(parents=True, exist_ok=True)
    except OSError:
        d = pathlib.Path("/tmp") / f"mios-cli-{os.getuid() if hasattr(os, 'getuid') else 'u'}"
        try:
            d.mkdir(parents=True, exist_ok=True)
        except OSError:
            pass
    return d


def _tty_token() -> str:
    """A stable token identifying THIS controlling terminal, so every turn typed
    into the same terminal shares one session. Prefer the real TTY device; fall
    back to the parent PID (the interactive shell) so a piped/non-tty `@` still
    groups by its launching shell. Last resort: a constant so the user at least
    gets one rolling session per machine."""
    for fd in (0, 1, 2):
        try:
            tty = os.ttyname(fd)
            if tty:
                return tty.replace("/", "_").strip("_")
        except (OSError, AttributeError):
            continue
    sid = os.environ.get("MIOS_CLI_SESSION_ID")
    if sid:
        return "env_" + sid
    try:
        return "ppid_" + str(os.getppid())
    except Exception:
        return "shared"


def _session_state_path() -> pathlib.Path:
    import hashlib
    tok = hashlib.sha256(_tty_token().encode("utf-8", "replace")).hexdigest()[:16]
    return _state_dir() / f"{tok}.json"


def load_session() -> dict[str, Any]:
    """Load (or roll a fresh) per-terminal session: a stable conversation id, a
    rolling client-side transcript, and the last-launched app. A gap longer than
    the TTL since the last turn rolls a NEW conversation id (fresh context)."""
    import time, uuid
    p = _session_state_path()
    now = time.time()
    st: dict[str, Any] = {}
    try:
        if p.is_file():
            st = json.loads(p.read_text(encoding="utf-8")) or {}
    except (OSError, json.JSONDecodeError, ValueError):
        st = {}
    last = float(st.get("updated", 0) or 0)
    if (not st.get("id")) or (now - last > SESSION_TTL_S):
        st = {"id": "mios-cli-" + uuid.uuid4().hex[:16], "history": [], "last_app": None}
    if not isinstance(st.get("history"), list):
        st["history"] = []
    return st


def save_session(st: dict[str, Any]) -> None:
    import time
    st["updated"] = time.time()
    # Cap the rolling transcript so the file (and the replayed context) stays small.
    hist = st.get("history")
    if isinstance(hist, list) and len(hist) > SESSION_HISTORY_TURNS * 2:
        st["history"] = hist[-(SESSION_HISTORY_TURNS * 2):]
    p = _session_state_path()
    try:
        tmp = p.with_suffix(".tmp")
        tmp.write_text(json.dumps(st), encoding="utf-8")
        os.replace(tmp, p)
        try:
            os.chmod(p, 0o600)
        except OSError:
            pass
    except OSError:
        pass


def resolve_system_prompt() -> str:
    # Layered override chain (highest wins):
    #   $MIOS_AI_SYSTEM_PROMPT -> ~/.config/mios/system-prompt.md
    #   -> /etc/mios/ai/system-prompt.md -> /usr/share/mios/ai/system.md
    candidates = [
        os.environ.get("MIOS_AI_SYSTEM_PROMPT"),
        str(pathlib.Path.home() / ".config/mios/system-prompt.md"),
        "/etc/mios/ai/system-prompt.md",
        str(SHARE / "ai/system.md"),
        # Fallback for development when the package isn't deployed
        str(pathlib.Path(__file__).parent.parent / "share/mios/ai/system.md"),
    ]
    parts = []
    for c in candidates:
        if c and pathlib.Path(c).is_file():
            try:
                txt = pathlib.Path(c).read_text(encoding="utf-8").strip()
                if txt:
                    parts.append(txt)
            except OSError:
                continue
    if not parts:
        return "You are the MiOS local agent."
    # Highest-precedence layer LAST so it has the final word in-prompt;
    # canonical prompt first sets the baseline.
    return "\n\n---\n\n".join(reversed(parts))


def load_tools() -> list[dict[str, Any]]:
    paths = sorted(glob.glob(str(LIB / "tools/chat-completions-api/*.json")))
    tools: list[dict[str, Any]] = []
    for p in paths:
        try:
            tools.append(json.loads(pathlib.Path(p).read_text(encoding="utf-8")))
        except (OSError, json.JSONDecodeError) as e:
            print(f"[mios] WARN: skipping malformed tool {p}: {e}", file=sys.stderr)
    return tools


def load_schema(name: str) -> dict[str, Any] | None:
    p = LIB / "schemas" / f"{name}.schema.json"
    if not p.is_file():
        return None
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None


def dispatch_tool(name: str, args: dict[str, Any]) -> str:
    # Tool implementations live at /usr/libexec/mios/tools/<name>. Each
    # is a self-contained executable that reads JSON args on stdin and
    # writes the result string on stdout. Missing dispatchers report
    # cleanly so the model can recover via a different tool or a direct
    # answer.
    exe = LIBEXEC / name
    if not exe.is_file() or not os.access(exe, os.X_OK):
        return json.dumps({
            "error": f"tool '{name}' not implemented at {exe}",
            "hint":  "create /usr/libexec/mios/tools/" + name + " (chmod +x)"
        })
    try:
        r = subprocess.run(
            [str(exe)],
            input=json.dumps(args),
            capture_output=True,
            text=True,
            timeout=120,
        )
    except subprocess.TimeoutExpired:
        return json.dumps({"error": f"tool '{name}' timed out after 120s"})
    if r.returncode != 0:
        return json.dumps({
            "error":  f"tool '{name}' exited {r.returncode}",
            "stderr": r.stderr.strip()[-2000:],
            "stdout": r.stdout.strip()[-2000:],
        })
    return r.stdout or json.dumps({"ok": True})


def chat_streaming(client: OpenAI, msgs: list[dict[str, Any]],
                   tools: list[dict[str, Any]] | None,
                   schema: dict[str, Any] | None,
                   extra_body: dict[str, Any] | None = None,
                   request_user: str | None = None,
                   answer_box: list[str] | None = None) -> None:
    # Tool-calling roundtrip. The model may emit zero or more
    # tool_calls; for each we append the assistant turn then a
    # role:tool result and re-call. Loop until the model finishes
    # without requesting another tool. Print content deltas as they
    # arrive so the operator sees incremental output.
    #
    # extra_body / request_user carry the per-terminal session identity to the
    # gateway (metadata.chat_id + the OpenAI `user` field) so consecutive turns
    # thread server-side too; answer_box (if given) accumulates the visible
    # assistant text so the caller can persist it to the rolling transcript.
    while True:
        kwargs: dict[str, Any] = {"model": MODEL, "messages": msgs}
        if tools:
            kwargs["tools"] = tools
            kwargs["tool_choice"] = "auto"
        if request_user:
            kwargs["user"] = request_user
        if extra_body:
            kwargs["extra_body"] = extra_body
        if schema:
            # Structured outputs (Chat Completions response_format).
            kwargs["response_format"] = {
                "type": "json_schema",
                "json_schema": {
                    "name":   schema.get("$id", "mios_structured_output").split("/")[-1].replace(".schema.json", ""),
                    "schema": schema,
                    "strict": True,
                },
            }
        # SDK 1.30+ stream context manager auto-accumulates tool-call
        # argument fragments and exposes a typed event union.
        _rsn_open = False
        with client.chat.completions.stream(**kwargs) as s:
            for ev in s:
                if ev.type == "content.delta":
                    if _rsn_open:
                        # close the dim reasoning block before the real answer
                        sys.stderr.write("\x1b[0m\n")
                        sys.stderr.flush()
                        _rsn_open = False
                    sys.stdout.write(ev.delta)
                    sys.stdout.flush()
                    if answer_box is not None:
                        answer_box.append(ev.delta)
                elif ev.type == "chunk":
                    # Stream the gateway's THINKING on the non-standard
                    # delta.reasoning_content channel (parity with OWUI's
                    # reasoning dropdown -- operator 2026-06-20 "thought streaming
                    # ... in hermes CLI"). Dimmed + to STDERR so it's visibly the
                    # thinking, never mixed into the answer or the saved transcript
                    # (a piped `mios ...` still captures only the answer). No
                    # reasoning emitted -> this branch is a clean no-op.
                    try:
                        _d = ev.chunk.choices[0].delta
                        _r = (getattr(_d, "reasoning_content", None)
                              or getattr(_d, "reasoning", None)
                              or (getattr(_d, "model_extra", None) or {}).get("reasoning_content")
                              or (getattr(_d, "model_extra", None) or {}).get("reasoning"))
                    except Exception:
                        _r = None
                    if _r:
                        if not _rsn_open:
                            sys.stderr.write("\x1b[2m\U0001f4ad ")  # dim + 💭
                            _rsn_open = True
                        sys.stderr.write(str(_r))
                        sys.stderr.flush()
            final = s.get_final_completion()
        if _rsn_open:
            sys.stderr.write("\x1b[0m\n")
            sys.stderr.flush()

        msg = final.choices[0].message
        # Append the assistant turn verbatim so the next iteration sees
        # the same conversation the model produced.
        msgs.append(msg.model_dump(exclude_none=True))

        if not getattr(msg, "tool_calls", None):
            sys.stdout.write("\n")
            return

        # Resolve every tool call requested in this turn before looping.
        for tc in msg.tool_calls:
            try:
                args = json.loads(tc.function.arguments) if tc.function.arguments else {}
            except json.JSONDecodeError:
                args = {"_raw": tc.function.arguments}
            sys.stdout.write(f"\n[tool] {tc.function.name}({json.dumps(args)})\n")
            sys.stdout.flush()
            result = dispatch_tool(tc.function.name, args)
            msgs.append({
                "role": "tool",
                "tool_call_id": tc.id,
                "content": result,
            })


KNOWN_VERBS = {
    # verb name -> command argv (list of str). Resolved via shutil.which
    # / pathlib.is_file before dispatch so missing wrappers fall through
    # to chat rather than 127ing.
    #
    # CRITICAL: this table MUST stay in sync with the `mios()` shell
    # function in /etc/profile.d/mios-verbs.sh. That function only
    # exists for INTERACTIVE shells ([ -n "$PS1" ] || return 0), so any
    # NON-interactive caller -- the Hermes/MiOS agent's terminal tool,
    # CI, the Forgejo runner, `bash -c 'mios build'` -- bypasses it and
    # lands here. If a verb is missing from this dict it falls through
    # to CHAT: e.g. `mios build` got sent to the gateway as the literal
    # prompt "build", so the agent recursively asked ITSELF to build and
    # returned ~empty output (operator-confirmed 2026-05-14). Every verb
    # the shell function routes must have an entry here too.
    "build":  ["/usr/libexec/mios/mios-build-driver"],
