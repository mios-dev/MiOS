#!/usr/bin/env bash
# /usr/bin/hermes
# Thin launcher for the DIRECT-installed Hermes-Agent. Operator
# directive 2026-05-13/14: Hermes-Agent is installed natively onto the
# MiOS root filesystem (automation/38-hermes-agent.sh -> venv at
# /usr/lib/mios/hermes-agent/.venv) and runs as the hermes-agent.service
# host systemd service. There is NO mios-hermes container -- the
# container Quadlets were removed.
#
# Usage:
#   hermes                  interactive chat REPL
#   hermes gateway status   gateway service control
#   hermes kanban ...        kanban subcommands
#   hermes <any subcommand>  passes through to the upstream CLI
#
# `mios <prompt>` and `@<prompt>` remain the one-shot chat shortcuts
# (they target the OpenAI gateway via /usr/bin/mios). `hermes` is the
# agent's own CLI.
set -euo pipefail

HERMES_BIN=/usr/lib/mios/hermes-agent/.venv/bin/hermes
if [[ ! -x "$HERMES_BIN" ]]; then
    echo "hermes: direct install not found at $HERMES_BIN" >&2
    echo "  the Hermes-Agent host install (automation/38-hermes-agent.sh) hasn't run" >&2
    echo "  -- run 'mios update' or re-run the bootstrap to install it." >&2
    exit 127
fi
exec "$HERMES_BIN" "$@"
