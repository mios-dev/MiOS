#!/usr/bin/env bash
# /usr/libexec/mios-verify -- post-install architectural-purity check.
#
# Wired in via /usr/lib/systemd/system/mios-verify.service (initrd
# context) and also runnable from the command line for ad-hoc audits.
# Exit non-zero on architectural-law violations so a `mios-verify`
# in CI / smoke pipelines fails loudly.
#
# Checks performed (each gated on the relevant filesystem being
# present, so this script works in initrd, full boot, dev VM, and
# WSL contexts):
#   1. ostree HEAD reachable and matches a known commit.
#   2. composefs root has fs-verity enabled (when running from initrd).
#   3. /usr is read-only at runtime (immutable contract).
#   4. /var has been realized by systemd-tmpfiles (no build-time
#      writes leaked through; LAW 2: NO /VAR WRITES AT BUILD).
#   5. /etc/mios layered config resolves cleanly via userenv.sh.
#   6. /usr/share/mios overlay present (vendor defaults landed).
#   7. mios.toml SSOT exists at /usr/share/mios/mios.toml.
#   8. Critical systemd units load (no-mask, no-fail-on-load).
#   9. fapolicyd is in enforcing mode (when present).
#  10. SELinux is enforcing (when present).
#  11. /usr/bin/mios CLI exists and responds to --version.
set -uo pipefail

LOG_TAG="mios-verify"
log() { logger -t "$LOG_TAG" -- "$*"; printf '[%s] %s\n' "$LOG_TAG" "$*"; }
fail() { log "FAIL  $*"; FAILS=$((FAILS+1)); }
ok()   { log "OK    $*"; PASSES=$((PASSES+1)); }
skip() { log "skip  $*"; SKIPS=$((SKIPS+1)); }

PASSES=0; FAILS=0; SKIPS=0

# Detect context. The same script runs in initrd (limited tools),
# full system boot, dev-VM, and WSL distro -- branch behavior on
# what's actually mounted.
in_initrd=0
[[ -d /sysroot/ostree/deploy ]] && in_initrd=1
on_wsl=0
[[ "$(systemd-detect-virt 2>/dev/null || echo)" == "wsl" ]] && on_wsl=1

# 1. ostree HEAD.
if command -v ostree >/dev/null 2>&1 && [[ -d /ostree ]]; then
    head=$(ostree rev-parse HEAD 2>/dev/null || echo)
    if [[ -n "$head" ]]; then ok "ostree HEAD: ${head:0:12}"; else fail "ostree HEAD unresolvable"; fi
else
    skip "ostree (non-ostree shape: dev VM / WSL / container)"
fi

# 2. composefs + fs-verity.
if (( in_initrd )); then
    if command -v fsverity >/dev/null 2>&1 && fsverity measure /sysroot/usr/lib/ostree-boot/init >/dev/null 2>&1; then
        ok "fs-verity enabled on /usr layer"
    else
        skip "fs-verity tooling not present in initrd"
    fi
else
    if grep -qE 'composefs' /proc/mounts 2>/dev/null; then
        ok "composefs mount present"
    else
        skip "composefs (non-composefs shape)"
    fi
fi

# 3. /usr read-only at runtime (LAW 1: USR-OVER-ETC immutable).
if (( ! in_initrd )); then
    if findmnt -no OPTIONS /usr 2>/dev/null | grep -qw ro; then
        ok "/usr is read-only"
    elif (( on_wsl )); then
        skip "/usr writability check (WSL distro -- not bootc-managed)"
    else
        fail "/usr is mounted read-write -- bootc immutability contract broken"
    fi
fi

# 4. /var realization (LAW 2: NO /VAR WRITES AT BUILD).
# Sample tmpfiles.d-managed dirs; if they exist with the expected
# owner the realizer ran. If /var holds files older than the
# tmpfiles entries they'd be build-time leaks.
for d in /var/lib/mios /var/cache /var/log; do
    if [[ -d "$d" ]]; then
        ok "$d exists"
    else
        fail "$d missing -- systemd-tmpfiles --create may have failed"
    fi
done

# 5. mios.toml SSOT layered resolver.
if [[ -r /usr/lib/mios/userenv.sh ]]; then
    if ( source /usr/lib/mios/userenv.sh 2>&1 >/dev/null ); then
        ok "/usr/lib/mios/userenv.sh sources cleanly"
    else
        fail "/usr/lib/mios/userenv.sh source error"
    fi
else
    fail "/usr/lib/mios/userenv.sh missing -- TOML resolver absent"
fi

# 6. /usr/share/mios overlay.
for p in /usr/share/mios /usr/share/mios/PACKAGES.md /usr/share/mios/mios.toml /usr/share/mios/ai/system.md; do
    if [[ -e "$p" ]]; then ok "$p"; else fail "$p missing"; fi
done

# 7. /etc/mios.
if [[ -d /etc/mios ]]; then ok "/etc/mios"; else fail "/etc/mios missing"; fi

# 8. Critical systemd units load (no Reload errors).
if (( ! in_initrd )) && command -v systemctl >/dev/null 2>&1; then
    for u in cockpit.socket bootc-fetch-apply-updates.timer mios-cdi-detect.service; do
        if systemctl list-unit-files --no-legend "$u" 2>/dev/null | grep -q "$u"; then
            state=$(systemctl is-enabled "$u" 2>/dev/null || echo unknown)
            case "$state" in
                enabled|enabled-runtime|alias|static) ok "$u (enabled state: $state)" ;;
                masked)                                fail "$u is MASKED" ;;
                disabled)                              skip "$u (disabled by config)" ;;
                *)                                     skip "$u (state: $state)" ;;
            esac
        fi
    done
fi

# 9. fapolicyd enforcing.
if command -v fapolicyd >/dev/null 2>&1; then
    if systemctl is-active --quiet fapolicyd 2>/dev/null; then
        ok "fapolicyd active"
    else
        skip "fapolicyd installed but inactive"
    fi
fi

# 10. SELinux enforcing.
if command -v getenforce >/dev/null 2>&1; then
    enf=$(getenforce 2>/dev/null || echo unknown)
    case "$enf" in
        Enforcing)   ok "SELinux: $enf" ;;
        Permissive)  skip "SELinux: $enf (development mode)" ;;
        Disabled)    fail "SELinux: $enf -- security policy not active" ;;
        *)           skip "SELinux state: $enf" ;;
    esac
fi

# 11. mios CLI.
if [[ -x /usr/bin/mios ]]; then
    if /usr/bin/mios --version >/dev/null 2>&1; then
        ok "/usr/bin/mios --version"
    else
        skip "/usr/bin/mios present but --version errored (may need runtime data)"
    fi
else
    fail "/usr/bin/mios missing"
fi

log ""
log "summary: $PASSES ok, $FAILS fail, $SKIPS skip"

if (( FAILS > 0 )); then
    exit 1
fi
exit 0
