#!/bin/bash
# AI-hint: Provides a Windows-host computer-use interface for MiOS-Agent via PowerShell scripts to perform screen capture, mouse/keyboard input, and window management on WSL2-hosted systems.
# AI-related: /usr/libexec/mios/mios-pc-control, /usr/share/mios/windows, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-windows, mios-oscontrol-server, mios-launch
# AI-functions: usage, _oscontrol_executor, _json_body
set -euo pipefail
# /usr/libexec/mios/mios-pc-control <subcommand> [args...]
#
# Windows-host computer-use surface for MiOS-Agent. Hermes ships a
# `computer_use` toolset but it's macOS-only (cua-driver). This
# helper provides the equivalent for MiOS-on-WSL2 by driving Win32
# SendInput / GDI screen capture / Win32 window enumeration via
# PowerShell scripts that run on the Windows side (through
# mios-windows ps which goes through the broker for the agent's
# context).
#
# Operator directive 2026-05-15: "Hermes-Agent supports PC control,
# NO?!" -- yes, but only on macOS. This shim is the MiOS-Windows
# equivalent so agents can screenshot, click, type, move windows,
# focus, list desktops on the Windows host.
#
# SUBCOMMANDS
#
#   screenshot <out-path>        Capture the primary monitor; saves
#                                PNG to <out-path> (Windows-side
#                                path or /mnt/c/... -- converted
#                                via wslpath).
#   click <x> <y> [button]       Move cursor to (x,y) + click. button
#                                = left (default) | right | middle.
#   double-click <x> <y>         Double-click at (x,y).
#   mouse-move <x> <y>           Move cursor only (no click).
#   type "<text>"                Type the literal text (no special
#                                key sequence handling).
#   key <name>                   Press a single key: Enter | Tab |
#                                Escape | Backspace | Delete | Up |
#                                Down | Left | Right | F1..F12 |
#                                <letter> | <digit>.
#   key-combo "Ctrl+C" | ...     Modifier-key combo (Ctrl/Alt/Shift
#                                /Win + key).
#   window-list                  List visible top-level windows
#                                (title, PID, hwnd, x, y, w, h).
#   window-focus <hwnd-or-pid>   Bring window to foreground.
#   window-move <hwnd> <x> <y>   Move window to (x,y).
#   window-resize <hwnd> <w> <h> Resize window to <w>x<h>.
#   help                         This message.
set -eu

PS1_DIR=/usr/share/mios/windows
PS1_HELPER="$PS1_DIR/mios-pc-control.ps1"

usage() {
    sed -n '2,/^set -eu$/p' "$0" | sed 's/^# \?//'
}

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ] || [ "$1" = "help" ]; then
    usage
    exit 0
fi

if ! command -v mios-windows >/dev/null 2>&1; then
    echo "mios-pc-control: mios-windows not on PATH (need WSL2 interop)" >&2
    exit 1
fi
if [ ! -f "$PS1_HELPER" ]; then
    echo "mios-pc-control: $PS1_HELPER not present" >&2
    exit 1
fi

sub="$1"
shift

# --json flag (task #148): emit machine-mode JSON for the
# subcommands whose PS1 backing supports it (currently
# window-list; others fall through to plain prose).
JSON_FLAG=""
case "${1:-}" in
    --json) JSON_FLAG="-Json"; shift ;;
esac

# ── OS-control executor routing (operator 2026-05-26) ───────────────────────
# When an interactive-desktop executor is configured
# ([os_control].executor_endpoint in mios.toml -- real tailnet URL in the /etc
# overlay, empty in vendor), route window enumeration + ops THERE. The executor
# (mios-oscontrol-server.ps1) runs on WinSta0\Default so EnumWindows actually
# sees the desktop; the WSL-interop PS path below is BLIND (count:0) from a
# service window station. No endpoint -> fall through to interop unchanged.
# Endpoint set but unreachable -> HONEST error (never a silent fall-back to the
# blind path -- that reintroduces the false count:0 reports we just fixed).
_oscontrol_executor() {
    # 1) Explicit operator / federation endpoint ([os_control].executor_endpoint
    #    in the layered mios.toml) wins -- a tailnet URL, or another node's desktop.
    local _ep
    _ep="$(python3 - <<'PYEOF' 2>/dev/null || true
import os
try:
    import tomllib
except Exception:
    try:
        import tomli as tomllib
    except Exception:
        raise SystemExit(0)
def _read(path):
    try:
        with open(path, "rb") as f:
            d = tomllib.load(f)
        return str(((d.get("os_control") or {}).get("executor_endpoint") or "")).strip()
    except Exception:
        return ""
for p in (os.environ.get("MIOS_TOML", ""), "/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    if not p:
        continue
    ep = _read(p)
    if ep:
        print(ep.rstrip("/"))
        break
PYEOF
)"
    if [ -n "$_ep" ]; then
        printf '%s\n' "$_ep"
        return 0
    fi
    # 2) WSL2 local auto-discovery (operator 2026-06-07): no tailnet endpoint is
    #    configured, but the Windows-host executor (mios-oscontrol-server.ps1)
    #    listens on :11437. Reach it over the WSL NAT default-route gateway (the
    #    Windows host) so OS control works WITHOUT Tailscale. The caller
    #    health-probes this before use, so a firewall-blocked gateway just falls
    #    through to the blind WSL-interop path -- no regression -- and it starts
    #    working the moment the host firewall admits the WSL subnet.
    if grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease 2>/dev/null; then
        local _gw _port
        _gw="$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}' || true)"
        _port="${MIOS_OSCONTROL_PORT:-11437}"
        if [ -n "$_gw" ]; then
            printf 'http://%s:%s\n' "$_gw" "$_port"
        fi
    fi
}

# Build a JSON object body from key value pairs, safely (python json.dumps).
# All-digit values are coerced to numbers (x/y/width/height); the executor
# stringifies text/name/combo/button anyway, so blanket coercion is safe.
_json_body() {
    python3 - "$@" <<'PYEOF'
import sys, json
a = sys.argv[1:]
d = {}
for i in range(0, len(a) - 1, 2):
    k, v = a[i], a[i + 1]
    try:
        d[k] = int(v)
    except ValueError:
        d[k] = v
print(json.dumps(d))
PYEOF
}

case "$sub" in
    launch|window-list|window-close|window-focus|window-move|window-resize|window-center|screen-layout|screenshot|click|double-click|mouse-move|type|key|key-combo|ui-find|ui-click)
        EXEC_EP="$(_oscontrol_executor)"
        # GRACEFUL FALLBACK (operator 2026-05-26): only route to the executor if
        # it's actually UP (quick /health probe). When it's configured but not
        # running yet, fall back to the WSL-interop path instead of hard-failing
        # every window op -- the executor takes over automatically once it's
        # installed + listening. (Per-op unreachable below is then a rare race.)
        if [ -n "$EXEC_EP" ] && ! curl -fsS -m 3 "$EXEC_EP/health" >/dev/null 2>&1; then
            EXEC_EP=""
        fi
        # `launch` renders VISIBLY only via the interactive-desktop executor: a
        # WSL-interop launch lands in a Session-0 window station, so the process
        # starts but no window appears on the operator's desktop (operator
        # 2026-06-07: `mios-launch notepad` returned rc=0 but opened nothing). With
        # no reachable executor, signal the caller to use its own path -- exit 2,
        # never a blind no-op that falsely claims success.
        case "$sub" in
            launch|ui-find|ui-click)
                # These need the interactive-desktop executor (WinSta0): launch must
                # surface a window; ui-find/ui-click walk the UIA tree. No blind
                # interop fallback -- signal the caller honestly instead of a no-op.
                if [ -z "$EXEC_EP" ]; then
                    echo "mios-pc-control: no OS-control executor reachable for $sub" >&2
                    exit 2
                fi ;;
        esac
        if [ -n "$EXEC_EP" ]; then
            case "$sub" in
                launch)
                    app="$*"
                    [ -z "$app" ] && { echo "mios-pc-control: launch needs <app-name>" >&2; exit 64; }
                    body="$(_json_body app "$app")"
                    if ! out="$(curl -fsS -m 30 -X POST "$EXEC_EP/launch" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /launch)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                window-list)
                    if ! body="$(curl -fsS -m 15 "$EXEC_EP/windows" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (GET /windows)" >&2
                        exit 1
                    fi
                    if [ -n "$JSON_FLAG" ]; then
                        printf '%s\n' "$body"
                    else
                        printf '%s' "$body" | python3 -c 'import sys,json
d=json.load(sys.stdin); print("hwnd pid x y w h title")
for w in (d.get("windows") or []):
    print("%s %s %s %s %s %s %s" % (w.get("hwnd",0),w.get("pid",0),w.get("x",0),w.get("y",0),w.get("w",0),w.get("h",0),w.get("title","")))'
                    fi
                    exit 0
                    ;;
                window-close|window-focus)
                    op="${sub#window-}"; hwnd="${1:-}"
                    [ -z "$hwnd" ] && { echo "mios-pc-control: $sub needs an hwnd" >&2; exit 64; }
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/window/$op" -H 'Content-Type: application/json' -d "{\"hwnd\": $hwnd}" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /window/$op)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                window-move)
                    hwnd="${1:-}"; x="${2:-0}"; y="${3:-0}"
                    [ -z "$hwnd" ] && { echo "mios-pc-control: window-move needs <hwnd> <x> <y>" >&2; exit 64; }
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/window/move" -H 'Content-Type: application/json' -d "{\"hwnd\": $hwnd, \"x\": $x, \"y\": $y}" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /window/move)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                window-resize)
                    hwnd="${1:-}"; w="${2:-0}"; h="${3:-0}"
                    [ -z "$hwnd" ] && { echo "mios-pc-control: window-resize needs <hwnd> <w> <h>" >&2; exit 64; }
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/window/resize" -H 'Content-Type: application/json' -d "{\"hwnd\": $hwnd, \"width\": $w, \"height\": $h}" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /window/resize)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                window-center)
                    hwnd="${1:-}"
                    [ -z "$hwnd" ] && { echo "mios-pc-control: window-center needs an hwnd" >&2; exit 64; }
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/window/center" -H 'Content-Type: application/json' -d "{\"hwnd\": $hwnd}" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /window/center)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                ui-find|ui-click)
                    # UIA semantic targeting: find a control BY NAME in the foreground
                    # window (ui-find -> list; ui-click -> click the first match's center).
                    name="$*"
                    [ -z "$name" ] && { echo "mios-pc-control: $sub needs <name>" >&2; exit 64; }
                    _uiop="${sub#ui-}"   # find | click
                    body="$(_json_body name "$name")"
                    if ! out="$(curl -fsS -m 25 -X POST "$EXEC_EP/ui/$_uiop" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /ui/$_uiop)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                screen-layout)
                    if ! out="$(curl -fsS -m 15 "$EXEC_EP/screen-layout" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (GET /screen-layout)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                screenshot)
                    out_path="${1:-}"
                    [ -z "$out_path" ] && { echo "mios-pc-control: screenshot needs <out-path>" >&2; exit 64; }
                    if ! resp="$(curl -fsS -m 30 "$EXEC_EP/screenshot" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (GET /screenshot)" >&2
                        exit 1
                    fi
                    printf '%s' "$resp" | python3 -c 'import sys,json,base64
d=json.load(sys.stdin); b=d.get("image_b64")
if not b: sys.exit("mios-pc-control: executor returned no image")
open(sys.argv[1],"wb").write(base64.b64decode(b))
print("[mios-pc-control] screenshot saved to %s (%sx%s)" % (sys.argv[1], d.get("width"), d.get("height")))' "$out_path"
                    exit 0
                    ;;
                mouse-move)
                    body="$(_json_body x "${1:-0}" y "${2:-0}")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/mouse-move" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/mouse-move)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                click)
                    body="$(_json_body x "${1:-0}" y "${2:-0}" button "${3:-left}")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/click" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/click)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                double-click)
                    body="$(_json_body x "${1:-0}" y "${2:-0}")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/double-click" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/double-click)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                type)
                    body="$(_json_body text "$*")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/type" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/type)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                key)
                    body="$(_json_body name "${1:-}")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/key" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/key)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
                key-combo)
                    body="$(_json_body combo "$*")"
                    if ! out="$(curl -fsS -m 15 -X POST "$EXEC_EP/input/key-combo" -H 'Content-Type: application/json' -d "$body" 2>/dev/null)"; then
                        echo "mios-pc-control: OS-control executor $EXEC_EP unreachable (POST /input/key-combo)" >&2
                        exit 1
                    fi
                    printf '%s\n' "$out"
                    exit 0
                    ;;
            esac
        fi
        ;;
esac

# Translate the helper's Linux path to a UNC path Windows can read,
# then invoke via mios-windows ps -File. wslpath -w converts.
WIN_PS1="$(wslpath -w "$PS1_HELPER" 2>/dev/null)"
if [ -z "$WIN_PS1" ]; then
    echo "mios-pc-control: wslpath failed for $PS1_HELPER" >&2
    exit 1
fi

# Forward to PowerShell helper with subcommand as -Action <name>
# and remaining args as -Args <arg1> <arg2> ...
mios-windows ps "& '$WIN_PS1' -Action '$sub' $JSON_FLAG $*"
