#!/usr/bin/env python3
# AI-hint: Provides a Windows-host computer-use interface for MiOS-Agent via PowerShell scripts to perform screen capture, mouse/keyboard input, and window management on WSL2-hosted systems.
# AI-related: /usr/libexec/mios/mios-pc-control, /usr/share/mios/windows, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-windows, mios-oscontrol-server, mios-launch
import sys
import os
import json
import urllib.request
import urllib.error
import subprocess
import base64

def usage():
    print("""usage: mios-pc-control <subcommand> [args...]

  screenshot <out-path>
  click <x> <y> [button]
  double-click <x> <y>
  mouse-move <x> <y>
  type "<text>"
  key <name>
  key-combo "Ctrl+C" | ...
  window-list
  window-focus <hwnd-or-pid>
  window-move <hwnd> <x> <y>
  window-resize <hwnd> <w> <h>
  ui-find <name>
  ui-click <name>
  ui-list
  ui-tree
  ui-set-value <name> <text>
  help""")
    sys.exit(0)

sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib", "mios"))
import mios_toml  # noqa: E402  -- the ONE shared layered-mios.toml resolver

def _read_toml_endpoint():
    """[os_control].executor_endpoint via the shared resolver. Priority
    MIOS_TOML > /etc > vendor (no per-user layer), matching the former reader."""
    layers = ["/usr/share/mios/mios.toml", "/etc/mios/mios.toml"]
    env_toml = os.environ.get("MIOS_TOML", "")
    if env_toml:
        layers.append(env_toml)
    ep = mios_toml.get("os_control", "executor_endpoint", "",
                       data=mios_toml.load_merged(layers))
    return str(ep).strip().rstrip("/") if ep else ""

def _get_executor_endpoint():
    ep = os.environ.get("MIOS_OSCONTROL_EXECUTOR", "")
    if ep:
        ep = ep.rstrip("/")
    else:
        ep = _read_toml_endpoint()

    # WSL detection and dynamic gateway routing for loopback targets
    try:
        with open("/proc/sys/kernel/osrelease", "r") as f:
            content = f.read().lower()
            is_wsl = "microsoft" in content or "wsl" in content
    except Exception:
        is_wsl = False

    if is_wsl:
        needs_gw = (not ep) or ("localhost" in ep) or ("127.0.0.1" in ep)
        if needs_gw:
            try:
                ip_route = subprocess.check_output(["ip", "route", "show", "default"], text=True)
                parts = ip_route.split()
                if "default" in parts:
                    idx = parts.index("default")
                    gw = parts[idx + 2]
                    if ep:
                        ep = ep.replace("localhost", gw).replace("127.0.0.1", gw)
                    else:
                        port = os.environ.get("MIOS_PORT_OSCONTROL", os.environ.get("MIOS_OSCONTROL_PORT", "11437"))
                        ep = f"http://{gw}:{port}"
            except Exception:
                pass
    return ep

def _http_request(url, method="GET", data=None, timeout=15):
    req_data = None
    if data is not None:
        req_data = json.dumps(data).encode("utf-8")
    req = urllib.request.Request(url, data=req_data, method=method)
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as f:
            return f.read().decode("utf-8")
    except urllib.error.HTTPError as e:
        return e.read().decode("utf-8")
    except Exception as e:
        sys.stderr.write(f"mios-pc-control: OS-control executor unreachable ({method} {url}): {e}\n")
        sys.exit(1)

def _exit_on_verdict(resp):
    """Exit reflecting the executor's READ-BACK verdict, not just transport success.
    The Windows OS-control executor returns {ok,verified,reason} (Invoke-TypeText et
    al.): a type/click/window op that did NOT land returns verified:false / ok:false
    in the BODY.

    FAIL CLOSED (operator 2026-06-19/20: "type reported SUCCESS but nothing was
    typed" -- twice). The prior version exited 0 on an unparseable/empty/non-dict/
    keyless body to "not false-fail a transport quirk" -- but THAT is the lie: when
    the verdict cannot be determined the op's success is UNKNOWN, and an unknown is
    NOT a success. A false FAILURE is recoverable (the caller retries / sees real
    state); a false SUCCESS is the fabrication the operator keeps catching. So we
    exit 0 ONLY on an EXPLICIT truthy verdict key; every undeterminable case exits 1
    with a diagnostic. (Launch is ALSO independently re-verified by the window-diff
    in server.py, so failing this closed never silently drops a real launch.)"""
    try:
        d = json.loads(resp) if resp else {}
    except Exception:
        sys.stderr.write("mios-pc-control: executor returned an unparseable body; "
                         "verdict UNKNOWN -> failing closed (exit 1)\n")
        sys.exit(1)
    if not isinstance(d, dict):
        sys.stderr.write("mios-pc-control: executor body is not a JSON object; "
                         "verdict UNKNOWN -> failing closed (exit 1)\n")
        sys.exit(1)
    for k in ("verified", "ok", "launched"):
        if k in d:
            if d.get(k):
                sys.exit(0)
            sys.stderr.write(f"mios-pc-control: executor verdict {k}=false"
                             f"{(' (' + str(d.get('reason')) + ')') if d.get('reason') else ''}\n")
            sys.exit(1)
    sys.stderr.write("mios-pc-control: executor body carries no verified/ok/launched "
                     "verdict; cannot confirm the action landed -> failing closed "
                     "(exit 1)\n")
    sys.exit(1)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        usage()
        
    sub = sys.argv[1]
    args = sys.argv[2:]
    
    json_flag = ""
    if args and args[0] == "--json":
        json_flag = "-Json"
        args = args[1:]
        
    valid_subs = {"launch", "window-list", "window-close", "window-focus", "window-move", 
                  "window-resize", "window-center", "screen-layout", "screenshot", "click", 
                  "double-click", "mouse-move", "type", "key", "key-combo", "ui-find", "ui-click", "ui-list", "ui-tree", "ui-set-value"}
                  
    exec_ep = _get_executor_endpoint()
    
    if exec_ep:
        try:
            urllib.request.urlopen(f"{exec_ep}/health", timeout=3)
        except Exception:
            exec_ep = ""
            
    if sub in ("launch", "ui-find", "ui-click", "ui-list", "ui-tree", "ui-set-value") and not exec_ep:
        sys.stderr.write(f"mios-pc-control: no OS-control executor reachable for {sub}\n")
        sys.exit(2)
        
    if exec_ep and sub in valid_subs:
        if sub == "launch":
            if not args:
                sys.stderr.write("mios-pc-control: launch needs <app-name>\n")
                sys.exit(64)
            app = " ".join(args)
            resp = _http_request(f"{exec_ep}/launch", "POST", {"app": app}, 30)
            print(resp); _exit_on_verdict(resp)   # exit reflects launched==true
            
        elif sub == "window-list":
            resp = _http_request(f"{exec_ep}/windows", "GET", None, 15)
            if json_flag:
                print(resp)
            else:
                try:
                    d = json.loads(resp)
                    print("hwnd pid x y w h title")
                    for w in d.get("windows", []):
                        print(f"{w.get('hwnd',0)} {w.get('pid',0)} {w.get('x',0)} {w.get('y',0)} {w.get('w',0)} {w.get('h',0)} {w.get('title','')}")
                except Exception:
                    print(resp)
            sys.exit(0)
            
        elif sub in ("window-close", "window-focus", "window-center"):
            if not args:
                sys.stderr.write(f"mios-pc-control: {sub} needs an hwnd\n")
                sys.exit(64)
            op = sub.replace("window-", "")
            resp = _http_request(f"{exec_ep}/window/{op}", "POST", {"hwnd": int(args[0])}, 15)
            print(resp); _exit_on_verdict(resp)
            
        elif sub == "window-move":
            if len(args) < 3:
                sys.stderr.write("mios-pc-control: window-move needs <hwnd> <x> <y>\n")
                sys.exit(64)
            resp = _http_request(f"{exec_ep}/window/move", "POST", {"hwnd": int(args[0]), "x": int(args[1]), "y": int(args[2])}, 15)
            print(resp); _exit_on_verdict(resp)
            
        elif sub == "window-resize":
            if len(args) < 3:
                sys.stderr.write("mios-pc-control: window-resize needs <hwnd> <w> <h>\n")
                sys.exit(64)
            resp = _http_request(f"{exec_ep}/window/resize", "POST", {"hwnd": int(args[0]), "width": int(args[1]), "height": int(args[2])}, 15)
            print(resp); _exit_on_verdict(resp)
            
        elif sub == "ui-list":
            print(_http_request(f"{exec_ep}/ui/list", "GET", None, 25))
            sys.exit(0)
            
        elif sub == "ui-tree":
            print(_http_request(f"{exec_ep}/ui/tree", "GET", None, 60))
            sys.exit(0)
            
        elif sub == "ui-set-value":
            if len(args) < 2:
                sys.stderr.write("mios-pc-control: ui-set-value needs <name> <text>\n")
                sys.exit(64)
            name = args[0]
            text = " ".join(args[1:])
            resp = _http_request(f"{exec_ep}/ui/set-value", "POST", {"name": name, "text": text}, 25)
            print(resp); _exit_on_verdict(resp)
            
        elif sub in ("ui-find", "ui-click"):
            if not args:
                sys.stderr.write(f"mios-pc-control: {sub} needs <name>\n")
                sys.exit(64)
            op = sub.replace("ui-", "")
            resp = _http_request(f"{exec_ep}/ui/{op}", "POST", {"name": " ".join(args)}, 25)
            print(resp); _exit_on_verdict(resp)
            
        elif sub == "screen-layout":
            print(_http_request(f"{exec_ep}/screen-layout", "GET", None, 15))
            sys.exit(0)
            
        elif sub == "screenshot":
            if not args:
                sys.stderr.write("mios-pc-control: screenshot needs <out-path>\n")
                sys.exit(64)
            out_path = args[0]
            resp = _http_request(f"{exec_ep}/screenshot", "GET", None, 30)
            try:
                d = json.loads(resp)
                b64 = d.get("image_b64")
                if not b64:
                    sys.stderr.write("mios-pc-control: executor returned no image\n")
                    sys.exit(1)
                with open(out_path, "wb") as f:
                    f.write(base64.b64decode(b64))
                print(f"[mios-pc-control] screenshot saved to {out_path} ({d.get('width')}x{d.get('height')})")
            except Exception as e:
                sys.stderr.write(f"mios-pc-control: failed to parse screenshot: {e}\n")
                sys.exit(1)
            sys.exit(0)
            
        elif sub == "mouse-move":
            x = int(args[0]) if len(args) > 0 else 0
            y = int(args[1]) if len(args) > 1 else 0
            print(_http_request(f"{exec_ep}/input/mouse-move", "POST", {"x": x, "y": y}, 15))
            sys.exit(0)
            
        elif sub == "click":
            x = int(args[0]) if len(args) > 0 else 0
            y = int(args[1]) if len(args) > 1 else 0
            button = args[2] if len(args) > 2 else "left"
            resp = _http_request(f"{exec_ep}/input/click", "POST", {"x": x, "y": y, "button": button}, 15)
            print(resp); _exit_on_verdict(resp)

        elif sub == "double-click":
            x = int(args[0]) if len(args) > 0 else 0
            y = int(args[1]) if len(args) > 1 else 0
            resp = _http_request(f"{exec_ep}/input/double-click", "POST", {"x": x, "y": y}, 15)
            print(resp); _exit_on_verdict(resp)
            
        elif sub == "type":
            hwnd = None
            text_args = []
            i = 0
            while i < len(args):
                if args[i] in ("--handle", "--hwnd", "--window-handle"):
                    if i + 1 < len(args):
                        try:
                            hwnd = int(args[i+1])
                        except ValueError:
                            pass
                        i += 2
                        continue
                text_args.append(args[i])
                i += 1
            payload = {"text": " ".join(text_args)}
            if hwnd is not None:
                payload["hwnd"] = hwnd
            resp = _http_request(f"{exec_ep}/input/type", "POST", payload, 15)
            print(resp); _exit_on_verdict(resp)   # honor the read-back verdict

        elif sub == "key":
            name = args[0] if args else ""
            resp = _http_request(f"{exec_ep}/input/key", "POST", {"name": name}, 15)
            print(resp); _exit_on_verdict(resp)

        elif sub == "key-combo":
            resp = _http_request(f"{exec_ep}/input/key-combo", "POST", {"combo": " ".join(args)}, 15)
            print(resp); _exit_on_verdict(resp)

    # Fallback to mios-windows ps
    ps1_helper = "/usr/share/mios/windows/mios-pc-control.ps1"
    try:
        win_ps1 = subprocess.check_output(["wslpath", "-w", ps1_helper], text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        sys.stderr.write(f"mios-pc-control: wslpath failed for {ps1_helper}\n")
        sys.exit(1)
        
    def ps_quote(s):
        return "'" + s.replace("'", "''") + "'"
        
    args_str = " ".join(ps_quote(a) for a in args)
    cmd_str = f"& '{win_ps1}' -Action '{sub}' {json_flag} {args_str}"
    cmd = ["mios-windows", "ps", cmd_str.strip()]
    os.execvp("mios-windows", cmd)

if __name__ == "__main__":
    main()
