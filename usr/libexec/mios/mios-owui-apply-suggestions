#!/usr/bin/env python3
"""mios-owui-apply-suggestions -- HANDS-OFF mode.

Operator directive 2026-05-17: "no hardcoded answers or anything
hardcoded for english at all--Completely generic and platform
agnostic--GLOBALLY FOR ALL FILES; AUDIT".

Previous incarnations of this script seeded a 40-entry English-only
pool of MiOS-flavored prompt cards. That violated the rule above.

The correct architecture: OWUI's built-in
`ENABLE_SUGGESTION_GENERATION=True` (set in the Quadlet) asks the
task model (TASK_MODEL_EXTERNAL=hermes-agent) to PRODUCE suggestions
per session, in the operator's language, aware of recent context.
The model picks the locale + the content from the running chat;
nothing is hardcoded here.

This script now ONLY WIPES any leftover hardcoded suggestions from
prior runs so OWUI falls back to its LLM-generated path. Re-running
is idempotent.

Operators who want a fixed set (no LLM call per session) can populate
ui.prompt_suggestions in OWUI's admin UI by hand -- that's their
choice, not vendor default.
"""
from __future__ import annotations

import datetime
import json
import os
import sqlite3
import sys
from pathlib import Path

DB_PATH = Path(os.environ.get("MIOS_OWUI_DB", "/var/lib/mios/open-webui/webui.db"))


def _log(msg: str) -> None:
    print(f"  [mios-owui-apply-suggestions] {msg}", flush=True)


def main() -> int:
    if not DB_PATH.is_file():
        _log(f"{DB_PATH} not present yet -- skipping (OWUI hasn't bootstrapped)")
        return 0
    try:
        c = sqlite3.connect(str(DB_PATH))
    except sqlite3.Error as e:
        _log(f"could not open DB: {e}")
        return 1

    row = c.execute("SELECT data FROM config WHERE id=1").fetchone()
    if row is None:
        _log("no config row yet -- nothing to clear")
        return 0

    try:
        data = json.loads(row[0])
    except json.JSONDecodeError as e:
        _log(f"existing config JSON is corrupt -- aborting: {e}")
        return 1

    ui = data.get("ui") or {}
    existing = ui.get("prompt_suggestions")
    if not existing:
        _log("no stale prompt_suggestions present -- OWUI is already on LLM-generated path")
        return 0

    # Wipe -> OWUI falls back to ENABLE_SUGGESTION_GENERATION + the
    # task model produces suggestions per session in the user's locale.
    ui["prompt_suggestions"] = []
    data["ui"] = ui
    now_iso = datetime.datetime.utcnow().isoformat()
    c.execute(
        "UPDATE config SET data=?, updated_at=? WHERE id=1",
        (json.dumps(data), now_iso),
    )
    c.commit()
    _log(f"cleared {len(existing)} hardcoded prompt_suggestion(s); "
         "OWUI will now generate them per session via TASK_MODEL_EXTERNAL")
    return 0


if __name__ == "__main__":
    sys.exit(main())
