#!/bin/bash
# AI-hint: A high-speed wrapper for the Voidtools Everything CLI that provides agents with sub-100ms access to the full Windows NTFS index for file discovery across all mounted drives.
# AI-related: /usr/libexec/mios/mios-everything, /etc/mios/install.env, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-find, mios-es-err, hermes-agent.service
# AI-functions: usage
set -euo pipefail
# /usr/libexec/mios/mios-everything <query> [-n <max>] [-ext <csv>]
#
# First-class wrapper around Voidtools Everything CLI (es.exe) for
# the entire MiOS agentic stack. Operator directive 2026-05-16:
# "WE HAVE EVERYTHING CLI STILL DOING NOTHING AS A TOOL FOR THE
# ENTIRE MIOS AGENTIC STACKS" -- previously the es.exe probe was
# siloed inside mios-find; promoting to its own helper so any
# agent (Hermes, sys-agent, opencode, micro-LLMs) can search the
# Windows NTFS index in <100 ms without going through mios-find.
#
# Returns matching paths (one per line) sorted by Everything's
# default relevance ranking. Empty stdout + exit 1 on no-match.
#
# Env-args-first path resolution (no hardcoded paths):
#   1. $EVERYTHING_CLI env (colon-separated probe list -- set by
#      hermes-agent.service.d drop-in or /etc/mios/install.env)
#   2. mios.toml [paths].everything_cli  (operator-edited)
#   3. compiled-in /mnt/m/Programs/Everything/es.exe fallback

set -eu

usage() {
    cat <<'USAGE'
usage: mios-everything <query> [-n <max>] [-ext <csv>]

  <query>      Everything query syntax. Examples (placeholders only):
                 <name>                 substring on filename
                 <name>*.exe            wildcard
                 path:<dir>             filter by path
                 size:>1mb              filter by size
                 dm:today               filter by modify-date
  -n <max>     limit results (default 10)
  -ext <csv>   filter to these extensions (e.g. -ext exe,bat,lnk)

Returns one Windows path per line. Exit 0 with match(es); exit 1
on no-match or es.exe unavailable. Sub-100 ms typical.

Underlying: Voidtools Everything CLI on the Windows side, invoked
via WSL interop. The index covers EVERY mounted NTFS drive.
USAGE
}

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
    exit 0
fi

# ─── Parse args ───────────────────────────────────────────────────
MAX=10
EXT=""
QUERY=""
JSON=0
while [ "$#" -gt 0 ]; do
    case "$1" in
        -n)     MAX="$2"; shift 2 ;;
        -ext)   EXT="$2"; shift 2 ;;
        --json) JSON=1; shift ;;
        --)     shift; QUERY="$*"; break ;;
        *)      QUERY="$1"; shift ;;
    esac
done
[ -z "$QUERY" ] && { echo "mios-everything: missing <query>" >&2; usage >&2; exit 64; }

# ─── Resolve es.exe path (env-args-first) ─────────────────────────
ES_PROBE_LIST=""
if [ -n "${EVERYTHING_CLI:-}" ]; then
    ES_PROBE_LIST="$(printf '%s\n' "$EVERYTHING_CLI" | tr ':' '\n')"
else
    ES_PROBE_LIST="$(python3 - <<'PYEOF' 2>/dev/null
import tomllib, sys
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
        paths = d.get("paths", {}).get("everything_cli")
        if paths:
            print("\n".join(paths))
            sys.exit(0)
    except (OSError, tomllib.TOMLDecodeError):
        continue
print("/mnt/m/Programs/Everything/es.exe")
PYEOF
)"
fi

ES_BIN=""
while IFS= read -r p; do
    [ -z "$p" ] && continue
    if [ -x "$p" ] || [ -f "$p" ]; then
        ES_BIN="$p"; break
    fi
done <<< "$ES_PROBE_LIST"

if [ -z "$ES_BIN" ]; then
    # es.exe (Everything CLI) not installed. A PowerShell recursive fallback was
    # tried (2026-06-09) but a non-indexed walk of C:\Windows/Program Files is too
    # slow (times out) -- the NTFS index is the whole point. everything_search
    # needs es.exe; meanwhile the agent uses fs_search / mios_find / app_search.
    echo "mios-everything: es.exe not found in probe list" >&2
    echo "  install Everything CLI es.exe + set EVERYTHING_CLI / mios.toml [paths].everything_cli" >&2
    if [ "$JSON" -eq 1 ]; then
        printf '{"ok":false,"verb":"everything_search","error":"es_cli_missing","hint":"install Everything CLI es.exe; agent can use fs_search/mios_find/app_search meanwhile","results":[]}\n'
    fi
    exit 1
fi

# ─── Build the es.exe invocation ──────────────────────────────────
# Extension filter via OR-of-wildcards (Everything's native syntax).
if [ -n "$EXT" ]; then
    EXT_FILTER=""
    IFS=',' read -ra EXT_ARR <<< "$EXT"
    for e in "${EXT_ARR[@]}"; do
        e_clean=$(echo "$e" | sed -e 's/^\.//' -e 's/[[:space:]]//g')
        [ -z "$e_clean" ] && continue
        if [ -z "$EXT_FILTER" ]; then
            EXT_FILTER="ext:$e_clean"
        else
            EXT_FILTER="$EXT_FILTER|ext:$e_clean"
        fi
    done
    [ -n "$EXT_FILTER" ] && QUERY="$QUERY $EXT_FILTER"
fi

# es.exe normally returns in <100ms native, but a COLD WSL-interop spawn can be
# slower -- 8s ceiling so a cold first call isn't killed mid-spawn. stderr is
# CAPTURED (not discarded) so a connection failure is reported, not silenced.
_ES_ERR="$(mktemp 2>/dev/null || echo /tmp/mios-es-err.$$)"
RAW=$(timeout 8 "$ES_BIN" -n "$MAX" "$QUERY" 2>"$_ES_ERR" | tr -d '\r')
_ES_STDERR="$(tr -d '\r' < "$_ES_ERR" 2>/dev/null)"; rm -f "$_ES_ERR"

if [ -z "$RAW" ]; then
    # Distinguish "Everything UNREACHABLE" (es.exe can't find the IPC window --
    # es.exe version mismatched to the running Everything, Everything not
    # running, or an elevation/session split) from a genuine 0-result match, so
    # agents + the operator get an ACTIONABLE signal instead of a silent "no
    # match". Operator 2026-05-27: FS search was silently dead -- es.exe
    # v1.1.0.30 vs Everything v1.4.x IPC mismatch returned "Error 8: IPC window
    # not found" which the old code swallowed as "no match".
    if printf '%s' "$_ES_STDERR" | grep -qiE 'IPC window not found|make sure Everything is running|Error 8'; then
        _MSG="Everything UNREACHABLE -- es.exe could not connect ($_ES_STDERR). Install an es.exe whose version matches the running Everything, point EVERYTHING_CLI or mios.toml [paths].everything_cli at it, and ensure Everything is running."
        if [ "$JSON" -eq 1 ]; then
            printf '{"ok":false,"verb":"everything_search","query":%s,"error":"everything_unreachable","detail":%s,"results":[]}\n' \
                "$(printf '%s' "$QUERY" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')" \
                "$(printf '%s' "$_MSG" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')"
        else
            echo "mios-everything: $_MSG" >&2
        fi
        exit 3
    fi
    if [ "$JSON" -eq 1 ]; then
        printf '{"ok":false,"verb":"everything_search","query":%s,"error":"no_match","results":[]}\n' \
            "$(printf '%s' "$QUERY" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')"
    else
        echo "mios-everything: no match for '$QUERY'" >&2
    fi
    exit 1
fi

if [ "$JSON" -eq 1 ]; then
    # Machine-mode JSON: array of {path, name, ext, drive} so the
    # agent can filter/sort without re-parsing prose. Operator
    # directive 2026-05-18 'shim machine-mode JSON sweep' (task #148).
    # Pass RAW via env (RAW_LINES) -- heredoc + pipe stdin conflict
    # made `printf '$RAW' | python3 - <<PYEOF` deliver the heredoc
    # text to python's stdin, dropping the RAW data.
    RAW_LINES="$RAW" python3 - "$QUERY" <<'PYEOF'
import json, os, sys, re
query = sys.argv[1]
raw = os.environ.get("RAW_LINES", "")
results = []
for line in raw.splitlines():
    line = line.strip()
    if not line:
        continue
    # Windows paths use backslash separator; posix os.path doesn't
    # split on it. Split on both / and \ for basename extraction.
    base = line.replace("\\", "/").rsplit("/", 1)[-1]
    name, ext = os.path.splitext(base)
    drive = re.match(r'^[A-Za-z]:', line)
    results.append({
        "path":  line,
        "name":  name,
        "ext":   ext.lstrip("."),
        "drive": drive.group(0) if drive else "",
    })
print(json.dumps({
    "ok":      True,
    "verb":    "everything_search",
    "query":   query,
    "count":   len(results),
    "results": results,
}))
PYEOF
    exit 0
fi

printf '%s\n' "$RAW"
