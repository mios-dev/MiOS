#!/usr/bin/env python3
# AI-hint: Provides a Model Context Protocol (MCP) stdio server that exposes the MiOS [verbs.*] catalog as tools and resources for local agents (Hermes, OpenCode) to execute system actions via the agent-pipe.
# AI-related: mios-daemon-agent, mios-mcp, mios-mcp.service, localhost:8640
"""mios-mcp-server -- Model Context Protocol stdio server.

Exposes MiOS's [verbs.*] catalog (SSOT in mios.toml) as MCP tools so
LOCAL MCP-aware agents can drive MiOS verbs natively.

LOCAL-ONLY by design. Intended consumers:
  * MiOS-Hermes        (local; primary tool catalog)
  * MiOS-OpenCode      (local; coding agent)
  * mios-daemon-agent  (local; background sub-agent)
  * Any LOCAL MCP client the operator stands up against on-host models

NOT for cloud-LLM clients. The operator's binding rule (2026-05-19)
is "no cloud dependencies": MCP clients that route through hosted LLM
providers (Claude Desktop, Cursor, GitHub Copilot, Codex Cloud) MUST
NOT be in the chain. They CAN consume this server, but the MiOS
operator does not run them.

Protocol: JSON-RPC 2.0 over stdio. Spec: 2025-06-18.
  https://modelcontextprotocol.io/specification/2025-06-18/server/tools

Implements:
  initialize          -- handshake; returns serverInfo + capabilities
  notifications/initialized  -- accepted, no response
  tools/list          -- renders [verbs.*] as MCP tool specs (calls
                         agent-pipe /v1/verbs)
  tools/call          -- dispatches via agent-pipe /v1/dispatch which
                         routes through the launcher broker
  resources/list      -- the COMPLETE read-only surface (every verb/script
                         + recipe + skill, promoted AND not) via agent-pipe
                         /v1/resources -- progressive-disclosure discovery
  resources/read      -- fetch one mios:// resource via /v1/resources/read
  ping                -- liveness
  shutdown            -- (informational; client closes stdio)

Defers to v2:
  notifications/{tools,resources}/list_changed (inotify on mios.toml + the
  skill store)
  prompts/list (no MCP prompts yet)
"""
from __future__ import annotations

import http.server
import json
import os
import sys
import time
import uuid
import urllib.request
import urllib.error
import urllib.parse

AGENT_PIPE_URL = os.environ.get(
    "MIOS_AGENT_PIPE_URL", "http://localhost:8640"
).rstrip("/")
PROTOCOL_VERSION = "2025-06-18"
SERVER_INFO = {"name": "mios-mcp-server", "version": "0.1.0"}
TIMEOUT_S = 60
# Streamable-HTTP session id. The relay is stateless (it just dispatches
# verbs), but the MCP spec lets a server assign a session at initialize, and
# strict clients (Hermes treats a missing/empty Mcp-Session-Id as a FATAL
# session fault and abandons the connection -- issue #13383) require a
# non-empty value. One id per server process is sufficient.
SESSION_ID = uuid.uuid4().hex


def _http_get(path: str) -> dict:
    req = urllib.request.Request(
        f"{AGENT_PIPE_URL}{path}",
        headers={"Accept": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=TIMEOUT_S) as r:
        return json.loads(r.read().decode("utf-8", errors="replace"))


def _http_post(path: str, body: dict) -> dict:
    req = urllib.request.Request(
        f"{AGENT_PIPE_URL}{path}",
        data=json.dumps(body).encode("utf-8"),
        headers={
            "Accept": "application/json",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=TIMEOUT_S) as r:
        return json.loads(r.read().decode("utf-8", errors="replace"))


def _ok(mid, result: dict) -> dict:
    return {"jsonrpc": "2.0", "id": mid, "result": result}


def _err(mid, code: int, message: str, data=None) -> dict:
    e: dict = {"code": code, "message": message}
    if data is not None:
        e["data"] = data
    return {"jsonrpc": "2.0", "id": mid, "error": e}


def _handle_initialize(mid, params: dict) -> dict:
    # Server announces its capabilities. listChanged=False until the
    # inotify watcher ships in v2.
    return _ok(mid, {
        "protocolVersion": PROTOCOL_VERSION,
        "capabilities": {
            "tools": {"listChanged": False},
            "resources": {"subscribe": False, "listChanged": False},
        },
        "serverInfo": SERVER_INFO,
    })


# Last-good tools/list cache. tools/list proxies agent-pipe /v1/verbs (/v1/tools);
# when agent-pipe is momentarily down (a restart), an UNCACHED relay returns 0 tools
# -> a fresh Hermes/OpenCode session registers NO MiOS tools and stays toolless for
# its ENTIRE life (MCP tools load only at session start, no mid-session reload). That
# is exactly the recurring "desktop app can't launch/type" failure (operator
# 2026-06-15). Caching the catalog (mem + disk) lets the relay ride out the blip.
# Must live under the unit's ReadWritePaths (mios-mcp.service: ProtectSystem=strict
# + ReadWritePaths=/var/lib/mios/mcp) -- /var/lib/mios/agent-env is sandbox-blocked.
_TOOLS_CACHE_FILE = os.environ.get(
    "MIOS_MCP_TOOLS_CACHE", "/var/lib/mios/mcp/tools.cache.json")
_TOOLS_CACHE_MEM = None


def _tools_cache_save(tools):
    global _TOOLS_CACHE_MEM
    _TOOLS_CACHE_MEM = tools
    try:
        _d = os.path.dirname(_TOOLS_CACHE_FILE)
        if _d and not os.path.isdir(_d):
            os.makedirs(_d, exist_ok=True)
        _tmp = _TOOLS_CACHE_FILE + ".tmp"
        with open(_tmp, "w", encoding="utf-8") as _f:
            json.dump(tools, _f)
        os.replace(_tmp, _TOOLS_CACHE_FILE)
    except Exception:
        pass


def _tools_cache_load():
    if _TOOLS_CACHE_MEM:
        return _TOOLS_CACHE_MEM
    try:
        with open(_TOOLS_CACHE_FILE, "r", encoding="utf-8") as _f:
            _d = json.load(_f)
            return _d if isinstance(_d, list) and _d else None
    except Exception:
        return None


def _handle_tools_list(mid, _params: dict) -> dict:
    # /v1/tools is the UNIFIED capability feed: every verb + every OS recipe +
    # every promoted skill. It is served in OpenAI function-tool shape
    # ({type:function, function:{name,description,parameters}}); MCP tools/list
    # REQUIRES {name, description, inputSchema}. Convert here so strict MCP
    # clients (Hermes, Claude Desktop, Cursor) parse the full surface -- without
    # this the tools arrive nameless and unusable. A row already in MCP shape
    # (top-level `name`) passes through untouched.
    try:
        data = _http_get("/v1/tools")
    except Exception as e:  # noqa: BLE001 -- URLError or any transport failure
        # agent-pipe momentarily down (e.g. a restart). Returning 0 tools would
        # leave a fresh session PERMANENTLY toolless. Serve the last-good cache so
        # the client keeps the full MiOS surface across the blip.
        cached = _tools_cache_load()
        if cached:
            sys.stderr.write(
                f"[mios-mcp] /v1/tools unreachable ({e}); served "
                f"{len(cached)} CACHED tools\n")
            return _ok(mid, {"tools": cached})
        return _err(mid, -32000, f"agent-pipe unreachable + no cache: {e}")
    mcp_tools = []
    for t in (data.get("tools") or []):
        if not isinstance(t, dict):
            continue
        if t.get("name") and t.get("inputSchema") is not None:
            mcp_tools.append(t)            # already MCP shape
            continue
        fn = t.get("function") or {}
        nm = fn.get("name")
        if not nm:
            continue
        mcp_tools.append({
            "name": nm,
            "description": fn.get("description", ""),
            "inputSchema": fn.get("parameters")
            or {"type": "object", "properties": {}},
        })
    if mcp_tools:
        _tools_cache_save(mcp_tools)   # persist last-good for blip resilience
    return _ok(mid, {"tools": mcp_tools})


def _handle_tools_call(mid, params: dict) -> dict:
    name = (params or {}).get("name", "")
    args = (params or {}).get("arguments") or {}
    if not name:
        return _err(mid, -32602, "missing tool name")
    # Route by name prefix -- the SAME mangling the unified /v1/tools feed
    # applies. mios_skill__<name> executes via the skill runner; a
    # mios_recipe__<name> wraps the opaque os_recipe verb; a bare name is a
    # plain verb. All three land on the launcher-broker path eventually, but
    # via the correct endpoint/envelope. Discover at /v1/tools, execute here.
    try:
        if name.startswith("mios_skill__"):
            real = name[len("mios_skill__"):]
            result = _http_post("/skills/run", {
                "name": real, "params": args,
            })
        elif name.startswith("mios_recipe__"):
            real = name[len("mios_recipe__"):]
            result = _http_post("/v1/dispatch", {
                "tool": "os_recipe",
                "args": {"name": real, "params": args},
            })
        else:
            result = _http_post("/v1/dispatch", {
                "tool": name, "args": args,
            })
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"dispatch failed: {e}")
    # MCP wraps tool results as content blocks. We surface the JSON
    # envelope as a single text block; modern clients (Claude Desktop,
    # Cursor) parse JSON-shaped text content automatically.
    is_error = not result.get("success", False)
    return _ok(mid, {
        "content": [{
            "type": "text",
            "text": json.dumps(result, ensure_ascii=False),
        }],
        "isError": is_error,
    })


def _handle_resources_list(mid, _params: dict) -> dict:
    # /v1/resources is the COMPLETE read-only surface: every verb (script),
    # every recipe, and EVERY skill (promoted AND not), as MCP Resources --
    # the progressive-disclosure half of the catalog. Browse here; fetch via
    # resources/read. The curated CALLABLE half is tools/list. (operator
    # 2026-06-04 "port all skills/tools/recipes/scripts to MCP")
    try:
        data = _http_get("/v1/resources")
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"resources fetch failed: {e}")
    return _ok(mid, {"resources": data.get("resources") or []})


def _handle_resources_read(mid, params: dict) -> dict:
    uri = (params or {}).get("uri", "")
    if not uri:
        return _err(mid, -32602, "missing resource uri")
    try:
        data = _http_get(
            "/v1/resources/read?uri=" + urllib.parse.quote(uri, safe=""))
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"resource read failed: {e}")
    if data.get("error"):
        # MCP resource-not-found is -32002.
        return _err(mid, -32002, str(data.get("error")))
    return _ok(mid, {"contents": data.get("contents") or []})


def _handle_ping(mid, _params: dict) -> dict:
    return _ok(mid, {})


def _write(msg: dict) -> None:
    sys.stdout.write(json.dumps(msg, ensure_ascii=False) + "\n")
    sys.stdout.flush()


def _dispatch_rpc(msg: dict):
    """Route ONE parsed JSON-RPC message to its handler. Returns the response
    dict, or None for a notification (no reply). Shared by the stdio loop AND
    the Streamable-HTTP transport so both behave identically."""
    method = msg.get("method", "")
    mid = msg.get("id")
    params = msg.get("params") or {}
    # Notifications carry no id and expect no response.
    if mid is None and method.startswith("notifications/"):
        return None
    if method == "initialize":
        return _handle_initialize(mid, params)
    if method == "tools/list":
        return _handle_tools_list(mid, params)
    if method == "tools/call":
        return _handle_tools_call(mid, params)
    if method == "resources/list":
        return _handle_resources_list(mid, params)
    if method == "resources/read":
        return _handle_resources_read(mid, params)
    if method == "ping":
        return _handle_ping(mid, params)
    if method == "shutdown":
        return _ok(mid, {})
    if mid is not None:
        return _err(mid, -32601, f"unknown method: {method}")
    return None


# ── Streamable-HTTP transport (MCP spec §transports) ─────────────────────────
# A stdio server cannot be a standalone daemon -- with no client on stdin it
# reads EOF and exits. This transport lets mios-mcp.service actually SERVE the
# verb relay as a persistent service. Bound to 127.0.0.1 ONLY: tools/call
# dispatches MiOS verbs, so unauthenticated tailnet exposure is deliberately
# withheld until an auth gate ships (operator no-live-launch rule).
# POST a JSON-RPC request -> application/json response (with an Mcp-Session-Id
# assigned at initialize); GET /mcp -> an idle keepalive SSE stream so strict
# clients that open the server->client channel during the handshake don't hang;
# GET /health for liveness. Stdlib only (offline-safe).
class _MCPHTTP(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def _json(self, obj, code: int = 200, extra_headers: dict | None = None) -> None:
        body = json.dumps(obj, ensure_ascii=False).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        for k, v in (extra_headers or {}).items():
            self.send_header(k, v)
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self) -> None:
        try:
            n = int(self.headers.get("Content-Length") or 0)
        except ValueError:
            n = 0
        raw = self.rfile.read(n) if n else b""
        try:
            msg = json.loads(raw.decode("utf-8", "replace") or "{}")
        except json.JSONDecodeError:
            self._json({"jsonrpc": "2.0", "id": None,
                        "error": {"code": -32700, "message": "parse error"}}, 400)
            return
        if isinstance(msg, list):          # JSON-RPC batch
            out = [r for r in (_dispatch_rpc(m) for m in msg
                               if isinstance(m, dict)) if r is not None]
            self._json(out)
            return
        if not isinstance(msg, dict):
            self._json({"jsonrpc": "2.0", "id": None,
                        "error": {"code": -32600, "message": "invalid request"}}, 400)
            return
        resp = _dispatch_rpc(msg)
        if resp is None:                   # notification -> 202, no body
            self.send_response(202)
            self.send_header("Content-Length", "0")
            self.end_headers()
            return
        # Assign a session id on initialize so strict clients get a non-empty
        # Mcp-Session-Id (the relay itself is stateless).
        extra = ({"Mcp-Session-Id": SESSION_ID}
                 if msg.get("method") == "initialize" else None)
        self._json(resp, extra_headers=extra)

    def do_GET(self) -> None:
        if self.path.rstrip("/") in ("/health", "/healthz"):
            self._json({"status": "ok", "server": SERVER_INFO,
                        "protocolVersion": PROTOCOL_VERSION})
            return
        # Streamable-HTTP standalone SSE stream (server->client). This tools-only
        # relay emits no server-initiated messages, but strict clients (Hermes's
        # streamable_http client) OPEN this stream during the handshake and HANG
        # then abandon if it 405s -- so hold an idle, keepalive'd event stream
        # open instead of refusing it. Per-connection thread (ThreadingHTTPServer
        # + daemon_threads), reaped when the client disconnects.
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.send_header("Mcp-Session-Id", SESSION_ID)
        self.end_headers()
        try:
            while True:
                self.wfile.write(b": keepalive\n\n")
                self.wfile.flush()
                time.sleep(15)
        except (BrokenPipeError, ConnectionResetError, OSError):
            return

    def log_message(self, *_a) -> None:    # quiet; the unit journal is the log
        return


def _run_http(port: int) -> None:
    srv = http.server.ThreadingHTTPServer(("127.0.0.1", port), _MCPHTTP)
    srv.daemon_threads = True
    sys.stderr.write(f"[mcp] Streamable-HTTP server on 127.0.0.1:{port} "
                     f"(verb relay -> {AGENT_PIPE_URL})\n")
    sys.stderr.flush()
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        pass


def main() -> int:
    # Transport select: HTTP (persistent daemon, via the service) vs stdio
    # (a client spawns us as a subprocess and talks over our stdin/stdout).
    if ("--http" in sys.argv[1:]
            or os.environ.get("MIOS_MCP_HTTP", "").strip().lower()
            in {"1", "true", "yes"}):
        port = int(os.environ.get("MIOS_PORT_MCP")
                   or os.environ.get("MIOS_MCP_PORT") or "8765")
        _run_http(port)
        return 0
    # Line-delimited JSON-RPC over stdio.
    for raw in sys.stdin:
        line = raw.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            _write({"jsonrpc": "2.0", "id": None,
                    "error": {"code": -32700, "message": "parse error"}})
            continue
        resp = _dispatch_rpc(msg)
        if resp is not None:
            _write(resp)
        if msg.get("method") == "shutdown":
            return 0
    return 0


if __name__ == "__main__":
    sys.exit(main())
