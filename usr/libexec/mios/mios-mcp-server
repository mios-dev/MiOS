#!/usr/bin/env python3
# AI-hint: Provides a Model Context Protocol (MCP) stdio server that exposes the MiOS [verbs.*] catalog as tools and resources for local agents (Hermes, OpenCode) to execute system actions via the agent-pipe.
# AI-related: mios-daemon-agent, mios-mcp, mios-mcp.service, localhost:8640
"""mios-mcp-server -- Model Context Protocol stdio server.

Exposes MiOS's [verbs.*] catalog (SSOT in mios.toml) as MCP tools so
LOCAL MCP-aware agents can drive MiOS verbs natively.

LOCAL-ONLY by design. Intended consumers:
  * MiOS-Hermes        (local; primary tool catalog)
  * MiOS-OpenCode      (local; coding agent)
  * mios-daemon-agent  (local; background sub-agent)
  * Any LOCAL MCP client the operator stands up against on-host models

NOT for cloud-LLM clients. The operator's binding rule (2026-05-19)
is "no cloud dependencies": MCP clients that route through hosted LLM
providers (Claude Desktop, Cursor, GitHub Copilot, Codex Cloud) MUST
NOT be in the chain. They CAN consume this server, but the MiOS
operator does not run them.

Protocol: JSON-RPC 2.0 over stdio. Spec: 2025-06-18.
  https://modelcontextprotocol.io/specification/2025-06-18/server/tools

Implements:
  initialize          -- handshake; returns serverInfo + capabilities
  notifications/initialized  -- accepted, no response
  tools/list          -- renders [verbs.*] as MCP tool specs (calls
                         agent-pipe /v1/verbs)
  tools/call          -- dispatches via agent-pipe /v1/dispatch which
                         routes through the launcher broker
  resources/list      -- the COMPLETE read-only surface (every verb/script
                         + recipe + skill, promoted AND not) via agent-pipe
                         /v1/resources -- progressive-disclosure discovery
  resources/read      -- fetch one mios:// resource via /v1/resources/read
  ping                -- liveness
  shutdown            -- (informational; client closes stdio)

Defers to v2:
  notifications/{tools,resources}/list_changed (inotify on mios.toml + the
  skill store)
  prompts/list (no MCP prompts yet)
"""
from __future__ import annotations

import http.server
import json
import os
import re
import sys
import threading
import time
import uuid
import urllib.request
import urllib.error
import urllib.parse

AGENT_PIPE_URL = os.environ.get(
    "MIOS_AGENT_PIPE_URL", "http://localhost:8640"
).rstrip("/")
PROTOCOL_VERSION = "2025-06-18"
SERVER_INFO = {"name": "mios-mcp-server", "version": "0.1.0"}
TIMEOUT_S = 60
# Streamable-HTTP session id. The relay is stateless (it just dispatches
# verbs), but the MCP spec lets a server assign a session at initialize, and
# strict clients (Hermes treats a missing/empty Mcp-Session-Id as a FATAL
# session fault and abandons the connection -- issue #13383) require a
# non-empty value. One id per server process is sufficient.
SESSION_ID = uuid.uuid4().hex


def _http_get(path: str, timeout: int | None = None) -> dict:
    req = urllib.request.Request(
        f"{AGENT_PIPE_URL}{path}",
        headers={"Accept": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout or TIMEOUT_S) as r:
            return json.loads(r.read().decode("utf-8", errors="replace"))
    except urllib.error.HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace")
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {"success": False, "error": f"HTTP {e.code}: {raw}"}


def _http_post(path: str, body: dict) -> dict:
    req = urllib.request.Request(
        f"{AGENT_PIPE_URL}{path}",
        data=json.dumps(body).encode("utf-8"),
        headers={
            "Accept": "application/json",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT_S) as r:
            return json.loads(r.read().decode("utf-8", errors="replace"))
    except urllib.error.HTTPError as e:
        raw = e.read().decode("utf-8", errors="replace")
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {"success": False, "error": f"HTTP {e.code}: {raw}"}


def _ok(mid, result: dict) -> dict:
    return {"jsonrpc": "2.0", "id": mid, "result": result}


def _err(mid, code: int, message: str, data=None) -> dict:
    e: dict = {"code": code, "message": message}
    if data is not None:
        e["data"] = data
    return {"jsonrpc": "2.0", "id": mid, "error": e}


def _handle_initialize(mid, params: dict) -> dict:
    # tools.listChanged=True: the background refresher pushes
    # notifications/tools/list_changed over the standalone SSE channel when the
    # catalog recovers (SSOT floor / degraded set -> full surface), so clients that
    # honor it (Hermes) re-list mid-session instead of staying degraded for life.
    # resources.listChanged stays False (no resource watcher yet).
    return _ok(mid, {
        "protocolVersion": PROTOCOL_VERSION,
        "capabilities": {
            "tools": {"listChanged": True},
            "resources": {"subscribe": False, "listChanged": False},
        },
        "serverInfo": SERVER_INFO,
    })


# Last-good tools/list cache. tools/list proxies agent-pipe /v1/verbs (/v1/tools);
# when agent-pipe is momentarily down (a restart), an UNCACHED relay returns 0 tools
# -> a fresh Hermes/OpenCode session registers NO MiOS tools and stays toolless for
# its ENTIRE life (MCP tools load only at session start, no mid-session reload). That
# is exactly the recurring "desktop app can't launch/type" failure (operator
# 2026-06-15). Caching the catalog (mem + disk) lets the relay ride out the blip.
# Must live under the unit's ReadWritePaths (mios-mcp.service: ProtectSystem=strict
# + ReadWritePaths=/var/lib/mios/mcp) -- /var/lib/mios/agent-env is sandbox-blocked.
_TOOLS_CACHE_FILE = os.environ.get(
    "MIOS_MCP_TOOLS_CACHE", "/var/lib/mios/mcp/tools.cache.json")
_TOOLS_CACHE_MEM = None
# Resilience tunables. A background thread keeps the catalog warm (mem+disk) every
# _REFRESH_INTERVAL_S, INDEPENDENT of when a client connects -- so a client that
# handshakes moments after an agent-pipe restart still receives the full last-good
# set instead of the empty/partial catalog agent-pipe serves mid-warmup. The
# per-request tools/list fetch uses a SHORT timeout so a hung/slow agent-pipe can
# never stall the client's handshake; the warm cache covers the gap.
_REFRESH_INTERVAL_S = int(os.environ.get("MIOS_MCP_REFRESH_INTERVAL", "30"))
_LIST_TIMEOUT_S = int(os.environ.get("MIOS_MCP_LIST_TIMEOUT", "8"))

# Open standalone-SSE connections (the GET /mcp channel). Each holds a private
# threading.Event; the background refresher SETS every event on catalog recovery,
# and each connection's own do_GET loop wakes, writes notifications/tools/list_changed,
# and resumes keepalive. All socket writes happen in the owning handler thread -- the
# refresher only signals -- so there are no cross-thread writes to one socket. This is
# how an ALREADY-CONNECTED client (Hermes honors tools/list_changed, auto-re-lists
# mid-session) recovers the full catalog after connecting during an outage, with no
# app restart.
_SSE_EVENTS: set = set()
_SSE_LOCK = threading.Lock()


def _signal_list_changed() -> None:
    with _SSE_LOCK:
        for ev in list(_SSE_EVENTS):
            ev.set()


def _tools_cache_save(tools):
    global _TOOLS_CACHE_MEM
    _TOOLS_CACHE_MEM = tools
    try:
        _d = os.path.dirname(_TOOLS_CACHE_FILE)
        if _d and not os.path.isdir(_d):
            os.makedirs(_d, exist_ok=True)
        _tmp = _TOOLS_CACHE_FILE + ".tmp"
        with open(_tmp, "w", encoding="utf-8") as _f:
            json.dump(tools, _f)
        os.replace(_tmp, _TOOLS_CACHE_FILE)
    except Exception:
        pass


def _tools_cache_load():
    if _TOOLS_CACHE_MEM:
        return _TOOLS_CACHE_MEM
    try:
        with open(_TOOLS_CACHE_FILE, "r", encoding="utf-8") as _f:
            _d = json.load(_f)
            return _d if isinstance(_d, list) and _d else None
    except Exception:
        return None


def _tools_cache_prime():
    """Load the last-good catalog from disk into memory at startup so the very
    first tools/list -- even before the background refresher has run, even if
    agent-pipe is still booting -- serves the full set."""
    global _TOOLS_CACHE_MEM
    if _TOOLS_CACHE_MEM:
        return
    try:
        with open(_TOOLS_CACHE_FILE, "r", encoding="utf-8") as _f:
            _d = json.load(_f)
            if isinstance(_d, list) and _d:
                _TOOLS_CACHE_MEM = _d
                sys.stderr.write(
                    f"[mios-mcp] primed {len(_d)} tools from disk cache\n")
    except Exception:
        pass


def _build_mcp_tools(data: dict) -> list:
    """Convert agent-pipe /v1/tools (OpenAI function-tool shape) to MCP tool
    shape ({name, description, inputSchema}). Rows already in MCP shape pass
    through untouched."""
    out = []
    for t in (data.get("tools") or []):
        if not isinstance(t, dict):
            continue
        if t.get("name") and t.get("inputSchema") is not None:
            out.append(t)
            continue
        fn = t.get("function") or {}
        nm = fn.get("name")
        if not nm:
            continue
        out.append({
            "name": nm,
            "description": fn.get("description", ""),
            "inputSchema": fn.get("parameters")
            or {"type": "object", "properties": {}},
        })
    return out


MIOS_TOML = os.environ.get("MIOS_TOML", "/usr/share/mios/mios.toml")


def _verb_row_ssot(vname: str, vcfg: dict) -> dict:
    """Mirror agent-pipe _verb_to_openai_tool (server.py:15461): model-facing name
    = model_name||vname; each param required (OpenAI strict); a param WITH a default
    becomes nullable ([t,'null'], enum+[None]) but stays required."""
    props, required = {}, []
    for argname, argcfg in (vcfg.get("params") or {}).items():
        if not isinstance(argcfg, dict):
            continue
        _t = argcfg.get("type", "string")
        spec = {"description": argcfg.get("desc", "")}
        if argcfg.get("enum"):
            spec["enum"] = list(argcfg["enum"])
        if "default" in argcfg:
            spec["type"] = [_t, "null"]
            if "enum" in spec:
                spec["enum"] = spec["enum"] + [None]
        else:
            spec["type"] = _t
        required.append(argname)
        props[argname] = spec
    facing = str(vcfg.get("model_name", "") or "").strip() or vname
    return {"type": "function", "function": {
        "name": facing, "description": vcfg.get("desc", ""), "strict": True,
        "parameters": {"type": "object", "properties": props,
                       "required": required, "additionalProperties": False}}}


def _recipe_row_ssot(name: str, cfg: dict) -> dict:
    """Mirror agent-pipe _recipe_to_openai_tool (server.py:5345): name mangled to
    mios_recipe__<name>; every arg a string prop + an optional `os`; none required."""
    props = {}
    for argname in (cfg.get("args") or []):
        if isinstance(argname, str) and argname:
            props[argname] = {"type": "string", "description": f"value for {argname}"}
    if "os" not in props:
        props["os"] = {"type": "string",
                       "description": "target OS selector (optional; defaults to host)"}
    return {"type": "function", "function": {
        "name": "mios_recipe__" + re.sub(r"[^A-Za-z0-9_]", "_", name),
        "description": cfg.get("description", "") or f"MiOS OS recipe {name}",
        "parameters": {"type": "object", "properties": props,
                       "required": [], "additionalProperties": True}}}


def _build_catalog_from_ssot() -> list:
    """Build the verb+recipe catalog DIRECTLY from mios.toml as MCP tool specs --
    the guaranteed non-empty FLOOR, served when BOTH the live feed AND the cache
    are unavailable (cold start + agent-pipe down) so a client is never toolless
    for its whole life. Skills are NOT built here (they live in pgvector,
    unreachable from this sandbox); the verb+recipe surface -- every launch /
    OS-control / web tool -- is the floor that matters. Mirrors agent-pipe's
    /v1/tools projections (server.py:15461 verbs, :5345 recipes, :4760 filter)."""
    try:
        try:
            import tomllib
        except ImportError:
            import tomli as tomllib  # type: ignore
        with open(MIOS_TOML, "rb") as f:
            data = tomllib.load(f)
        rows = []
        verbs = data.get("verbs") or {}
        if isinstance(verbs, dict):
            for vname, vcfg in verbs.items():
                if isinstance(vcfg, dict) and "section" in vcfg:
                    rows.append(_verb_row_ssot(vname, vcfg))
        recipes = data.get("recipes") or {}
        if isinstance(recipes, dict):
            for rname, rcfg in recipes.items():
                if isinstance(rcfg, dict):
                    rows.append(_recipe_row_ssot(rname, rcfg))
        return _build_mcp_tools({"tools": rows})
    except Exception as e:  # noqa: BLE001 -- floor build is best-effort
        sys.stderr.write(f"[mios-mcp] SSOT floor build failed: {e}\n")
        return []


def _skill_names(tools) -> set:
    return {t.get("name") for t in (tools or [])
            if str(t.get("name", "")).startswith("mios_skill__")}


def _is_poisoned(live: list, cached) -> bool:
    """True when `live` looks like a degrade-open partial that would POISON
    last-good if saved. Two cases: (a) empty or >50%-shrunk vs cache (warmup);
    (b) it LOST promoted skills without gaining any -- agent-pipe's /v1/tools is
    degrade-open (server.py:15583-15590): a pgvector outage silently drops the
    skills tail (HTTP 200, no error), a drop too small to trip the size guard, so
    a skill-less feed would otherwise be accepted + persisted as the new last-good."""
    if not cached:
        return False
    if len(live) < max(1, len(cached) // 2):
        return True
    prev_sk, live_sk = _skill_names(cached), _skill_names(live)
    if (prev_sk - live_sk) and not (live_sk - prev_sk):
        return True
    return False


def _fetch_live_tools(timeout: int | None = None) -> list:
    """Fetch + convert the live agent-pipe catalog. Raises on transport failure."""
    data = _http_get("/v1/tools", timeout=timeout)
    if isinstance(data, dict) and data.get("error"):
        raise Exception(f"agent-pipe error: {data['error']}")
    return _build_mcp_tools(data)


def _refresh_once() -> bool:
    """One background catalog refresh: fetch live, and persist as last-good
    UNLESS it would poison the cache (empty/shrunk, or a degrade-open skills-tail
    drop -- see _is_poisoned)."""
    try:
        live = _fetch_live_tools(timeout=TIMEOUT_S)
    except Exception:
        return False
    cached = _tools_cache_load()
    if live and not _is_poisoned(live, cached):
        _tools_cache_save(live)
        return True
    return False


def _refresh_loop() -> None:
    """Keep the last-good catalog warm independent of client connect timing.
    Re-tries faster while the upstream looks unhealthy so the cache re-warms
    promptly once agent-pipe recovers. When the served catalog actually CHANGES
    (e.g. recovers from the SSOT floor / a degraded set back to the full surface),
    push notifications/tools/list_changed so already-connected clients that honor
    it (Hermes) re-list mid-session instead of being stuck on the degraded set."""
    prev = tuple(sorted(t.get("name", "") for t in (_tools_cache_load() or [])))
    while True:
        ok = _refresh_once()
        if ok:
            cur = tuple(sorted(t.get("name", "") for t in (_tools_cache_load() or [])))
            if cur and cur != prev:
                _signal_list_changed()
                sys.stderr.write(
                    f"[mios-mcp] catalog changed ({len(cur)} tools); "
                    f"pushed tools/list_changed\n")
            prev = cur
        time.sleep(_REFRESH_INTERVAL_S if ok else max(5, _REFRESH_INTERVAL_S // 6))


def _handle_tools_list(mid, _params: dict) -> dict:
    # /v1/tools is the UNIFIED capability feed: every verb + every OS recipe +
    # every promoted skill. It is served in OpenAI function-tool shape
    # ({type:function, function:{name,description,parameters}}); MCP tools/list
    # REQUIRES {name, description, inputSchema}. Convert here so strict MCP
    # clients (Hermes, Claude Desktop, Cursor) parse the full surface -- without
    # this the tools arrive nameless and unusable. A row already in MCP shape
    # (top-level `name`) passes through untouched.
    cached = _tools_cache_load()
    try:
        # SHORT timeout: a hung/slow agent-pipe must never stall the client's
        # handshake -- the warm cache (kept fresh by the background refresher)
        # covers the gap.
        live = _fetch_live_tools(timeout=_LIST_TIMEOUT_S)
    except Exception as e:  # noqa: BLE001 -- URLError or any transport failure
        # agent-pipe momentarily down/slow. Returning 0 tools would leave a fresh
        # session PERMANENTLY toolless (MCP tools load once at session start, no
        # mid-session reload). Serve the last-good warm cache across the blip.
        if cached:
            sys.stderr.write(
                f"[mios-mcp] /v1/tools unreachable ({e}); served "
                f"{len(cached)} CACHED tools\n")
            return _ok(mid, {"tools": cached})
        # Cold cache AND agent-pipe down: build the verb+recipe FLOOR straight from
        # mios.toml so a client is NEVER handed zero tools (it would be toolless for
        # its whole life -- the recurring "can't launch/type" failure).
        floor = _build_catalog_from_ssot()
        if floor:
            sys.stderr.write(
                f"[mios-mcp] /v1/tools unreachable + cold cache; served "
                f"{len(floor)} SSOT-floor tools (verbs+recipes from mios.toml)\n")
            return _ok(mid, {"tools": floor})
        return _err(mid, -32000,
                    f"agent-pipe unreachable + no cache + no SSOT floor: {e}")
    # agent-pipe can answer 200 with an EMPTY/partial catalog for a few seconds after
    # a restart (verb catalog still loading). The catalog only grows in normal use, so
    # an empty or >50%-shrunk live feed => warmup, not a real removal: serve the
    # last-good cache instead. (A genuine large reduction lands via a rebuild, which
    # restarts this server and re-seeds the cache.) Closes the restart toolless window.
    if cached and _is_poisoned(live, cached):
        sys.stderr.write(
            f"[mios-mcp] /v1/tools returned a partial set ({len(live)} tools vs "
            f"{len(cached)} cached); serving CACHED set (agent-pipe warming up / "
            f"degrade-open)\n")
        return _ok(mid, {"tools": cached})
    if live:
        _tools_cache_save(live)
    return _ok(mid, {"tools": live})


def _handle_tools_call(mid, params: dict) -> dict:
    name = (params or {}).get("name", "")
    args = (params or {}).get("arguments") or {}
    if not name:
        return _err(mid, -32602, "missing tool name")
    # Route by name prefix -- the SAME mangling the unified /v1/tools feed
    # applies. mios_skill__<name> executes via the skill runner; a
    # mios_recipe__<name> wraps the opaque os_recipe verb; a bare name is a
    # plain verb. All three land on the launcher-broker path eventually, but
    # via the correct endpoint/envelope. Discover at /v1/tools, execute here.
    try:
        if name.startswith("mios_skill__"):
            real = name[len("mios_skill__"):]
            result = _http_post("/skills/run", {
                "name": real, "params": args,
            })
        elif name.startswith("mios_recipe__"):
            real = name[len("mios_recipe__"):]
            result = _http_post("/v1/dispatch", {
                "tool": "os_recipe",
                "args": {"name": real, "params": args},
            })
        else:
            result = _http_post("/v1/dispatch", {
                "tool": name, "args": args,
            })
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"dispatch failed: {e}")
    # MCP wraps tool results as content blocks. We surface the JSON
    # envelope as a single text block; modern clients (Claude Desktop,
    # Cursor) parse JSON-shaped text content automatically.
    is_error = not result.get("success", False)
    return _ok(mid, {
        "content": [{
            "type": "text",
            "text": json.dumps(result, ensure_ascii=False),
        }],
        "isError": is_error,
    })


def _handle_resources_list(mid, _params: dict) -> dict:
    # /v1/resources is the COMPLETE read-only surface: every verb (script),
    # every recipe, and EVERY skill (promoted AND not), as MCP Resources --
    # the progressive-disclosure half of the catalog. Browse here; fetch via
    # resources/read. The curated CALLABLE half is tools/list. (operator
    # 2026-06-04 "port all skills/tools/recipes/scripts to MCP")
    try:
        data = _http_get("/v1/resources")
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"resources fetch failed: {e}")
    if isinstance(data, dict) and data.get("error"):
        return _err(mid, -32000, str(data.get("error")))
    return _ok(mid, {"resources": data.get("resources") or []})


def _handle_resources_read(mid, params: dict) -> dict:
    uri = (params or {}).get("uri", "")
    if not uri:
        return _err(mid, -32602, "missing resource uri")
    try:
        data = _http_get(
            "/v1/resources/read?uri=" + urllib.parse.quote(uri, safe=""))
    except urllib.error.URLError as e:
        return _err(mid, -32000, f"agent-pipe unreachable: {e.reason}")
    except Exception as e:
        return _err(mid, -32000, f"resource read failed: {e}")
    if data.get("error"):
        # MCP resource-not-found is -32002.
        return _err(mid, -32002, str(data.get("error")))
    return _ok(mid, {"contents": data.get("contents") or []})


def _handle_ping(mid, _params: dict) -> dict:
    return _ok(mid, {})


def _write(msg: dict) -> None:
    sys.stdout.write(json.dumps(msg, ensure_ascii=False) + "\n")
    sys.stdout.flush()


def _dispatch_rpc(msg: dict):
    """Route ONE parsed JSON-RPC message to its handler. Returns the response
    dict, or None for a notification (no reply). Shared by the stdio loop AND
    the Streamable-HTTP transport so both behave identically."""
    method = msg.get("method", "")
    mid = msg.get("id")
    params = msg.get("params") or {}
    # Notifications carry no id and expect no response.
    if mid is None and method.startswith("notifications/"):
        return None
    if method == "initialize":
        return _handle_initialize(mid, params)
    if method == "tools/list":
        return _handle_tools_list(mid, params)
    if method == "tools/call":
        return _handle_tools_call(mid, params)
    if method == "resources/list":
        return _handle_resources_list(mid, params)
    if method == "resources/read":
        return _handle_resources_read(mid, params)
    if method == "ping":
        return _handle_ping(mid, params)
    if method == "shutdown":
        return _ok(mid, {})
    if mid is not None:
        return _err(mid, -32601, f"unknown method: {method}")
    return None


# ── Streamable-HTTP transport (MCP spec §transports) ─────────────────────────
# A stdio server cannot be a standalone daemon -- with no client on stdin it
# reads EOF and exits. This transport lets mios-mcp.service actually SERVE the
# verb relay as a persistent service. Bound to 127.0.0.1 ONLY: tools/call
# dispatches MiOS verbs, so unauthenticated tailnet exposure is deliberately
# withheld until an auth gate ships (operator no-live-launch rule).
# POST a JSON-RPC request -> application/json response (with an Mcp-Session-Id
# assigned at initialize); GET /mcp -> an idle keepalive SSE stream so strict
# clients that open the server->client channel during the handshake don't hang;
# GET /health for liveness. Stdlib only (offline-safe).
class _MCPHTTP(http.server.BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"

    def _json(self, obj, code: int = 200, extra_headers: dict | None = None) -> None:
        body = json.dumps(obj, ensure_ascii=False).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        for k, v in (extra_headers or {}).items():
            self.send_header(k, v)
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self) -> None:
        try:
            n = int(self.headers.get("Content-Length") or 0)
        except ValueError:
            n = 0
        raw = self.rfile.read(n) if n else b""
        try:
            msg = json.loads(raw.decode("utf-8", "replace") or "{}")
        except json.JSONDecodeError:
            self._json({"jsonrpc": "2.0", "id": None,
                        "error": {"code": -32700, "message": "parse error"}}, 400)
            return
        if isinstance(msg, list):          # JSON-RPC batch
            out = [r for r in (_dispatch_rpc(m) for m in msg
                               if isinstance(m, dict)) if r is not None]
            self._json(out)
            return
        if not isinstance(msg, dict):
            self._json({"jsonrpc": "2.0", "id": None,
                        "error": {"code": -32600, "message": "invalid request"}}, 400)
            return
        resp = _dispatch_rpc(msg)
        if resp is None:                   # notification -> 202, no body
            self.send_response(202)
            self.send_header("Content-Length", "0")
            self.end_headers()
            return
        # Assign a session id on initialize so strict clients get a non-empty
        # Mcp-Session-Id (the relay itself is stateless).
        extra = ({"Mcp-Session-Id": SESSION_ID}
                 if msg.get("method") == "initialize" else None)
        self._json(resp, extra_headers=extra)

    def do_GET(self) -> None:
        if self.path.rstrip("/") in ("/health", "/healthz"):
            self._json({"status": "ok", "server": SERVER_INFO,
                        "protocolVersion": PROTOCOL_VERSION})
            return
        # Streamable-HTTP standalone SSE stream (server->client). This tools-only
        # relay emits no server-initiated messages, but strict clients (Hermes's
        # streamable_http client) OPEN this stream during the handshake and HANG
        # then abandon if it 405s -- so hold an idle, keepalive'd event stream
        # open instead of refusing it. Per-connection thread (ThreadingHTTPServer
        # + daemon_threads), reaped when the client disconnects.
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.send_header("Mcp-Session-Id", SESSION_ID)
        self.end_headers()
        # Register so the refresher can wake this connection to push
        # notifications/tools/list_changed; otherwise emit a keepalive every 15s.
        ev = threading.Event()
        with _SSE_LOCK:
            _SSE_EVENTS.add(ev)
        try:
            self.wfile.write(b": keepalive\n\n")
            self.wfile.flush()
            while True:
                fired = ev.wait(timeout=15)
                if fired:
                    ev.clear()
                    payload = json.dumps(
                        {"jsonrpc": "2.0",
                         "method": "notifications/tools/list_changed"})
                    self.wfile.write(
                        f"event: message\ndata: {payload}\n\n".encode("utf-8"))
                else:
                    self.wfile.write(b": keepalive\n\n")
                self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError, OSError):
            return
        finally:
            with _SSE_LOCK:
                _SSE_EVENTS.discard(ev)

    def log_message(self, *_a) -> None:    # quiet; the unit journal is the log
        return


def _ensure_warm() -> None:
    """Guarantee a servable catalog before the first client connects: disk
    last-good first, else the mios.toml SSOT verb+recipe floor. So even a
    cold-started server whose agent-pipe is still booting answers the first
    tools/list with the full surface -- never zero tools, never toolless-for-life."""
    global _TOOLS_CACHE_MEM
    _tools_cache_prime()
    if not _TOOLS_CACHE_MEM:
        floor = _build_catalog_from_ssot()
        if floor:
            _TOOLS_CACHE_MEM = floor
            sys.stderr.write(
                f"[mios-mcp] seeded {len(floor)} tools from mios.toml SSOT floor "
                f"(cold cache)\n")


def _run_http(port: int) -> None:
    srv = http.server.ThreadingHTTPServer(("127.0.0.1", port), _MCPHTTP)
    srv.daemon_threads = True
    sys.stderr.write(f"[mcp] Streamable-HTTP server on 127.0.0.1:{port} "
                     f"(verb relay -> {AGENT_PIPE_URL})\n")
    sys.stderr.flush()
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        pass


def main() -> int:
    # Transport select: HTTP (persistent daemon, via the service) vs stdio
    # (a client spawns us as a subprocess and talks over our stdin/stdout).
    if ("--http" in sys.argv[1:]
            or os.environ.get("MIOS_MCP_HTTP", "").strip().lower()
            in {"1", "true", "yes"}):
        port = int(os.environ.get("MIOS_PORT_MCP")
                   or os.environ.get("MIOS_MCP_PORT") or "8765")
        # Warm the catalog (disk last-good, else mios.toml SSOT floor) BEFORE
        # serving, then keep it warm in the background -- so tools/list is never
        # empty/partial regardless of how soon a client connects after a restart.
        _ensure_warm()
        threading.Thread(target=_refresh_loop, name="mcp-tools-refresh",
                         daemon=True).start()
        _run_http(port)
        return 0
    # Line-delimited JSON-RPC over stdio.
    if hasattr(sys.stdout, "reconfigure"):
        sys.stdout.reconfigure(encoding="utf-8")
    if hasattr(sys.stdin, "reconfigure"):
        sys.stdin.reconfigure(encoding="utf-8")
    for raw in sys.stdin:
        line = raw.strip()
        if not line:
            continue
        try:
            msg = json.loads(line)
        except json.JSONDecodeError:
            _write({"jsonrpc": "2.0", "id": None,
                    "error": {"code": -32700, "message": "parse error"}})
            continue
        resp = _dispatch_rpc(msg)
        if resp is not None:
            _write(resp)
        if msg.get("method") == "shutdown":
            return 0
    return 0


if __name__ == "__main__":
    sys.exit(main())
