#!/usr/bin/env python3
# AI-hint: Active-memory write interface for agents to store/update/delete durable facts in the Postgres+pgvector agent_memory table, scoped global/agent:<name>/conversation:<id>. WS-A3: every write is PARAMETERIZED via `mios-db --pg-json` (values bound out-of-band through mios-pg-query's extended protocol -- never f-string-spliced into SQL); the retired legacy transport is removed.
# AI-related: /usr/libexec/mios/mios-db, mios-db, /usr/libexec/mios/mios-pg-query, localhost:11450
# AI-functions: _pg_json, _embed_vec, main
"""mios-remember -- agent-authored durable memory (Letta/MemGPT core tier).

P4.2 (Letta/MemGPT active virtual memory): MiOS already has the PASSIVE tiers
-- per-conversation scratchpad (working), the knowledge table (auto-stored Q+A,
recall), and episodic SKILL.md + viking:// (archival). What was missing is the
ACTIVE / SELF-EDITING tier: the agent (or operator) deliberately WRITING a
durable fact it wants to keep -- Letta's core_memory_append. This shim is that
write half.

DESIGN respects the MiOS "NO context injection" rule ([[CLAUDE.md]]): memory is
TOOL-DRIVEN both ways -- the agent WRITES with this verb and READS with `recall`
(or viking_ls memory). Nothing is auto-prepended to prompts; the model learns
its memory by CALLING tools, not via a pre_llm_call inject.

Stored in Postgres+pgvector `agent_memory`, scope-tagged:
  global         -- durable facts true across all conversations
  agent:<name>   -- specific to one agent
  conversation:<id> -- scoped to one chat thread

WS-A3 cutover: the legacy DB (:8000) is RETIRED. The datastore is Postgres+pgvector,
and EVERY statement is parameterized -- values are bound out-of-band via
`mios-db --pg-json` (-> mios-pg-query extended protocol), never spliced into the
SQL string. The pg column is `mem_key` (this tool's `key`).

USAGE
  mios-remember add "<fact>" [--scope global] [--key <k>] [--source <s>]
  mios-remember list [--scope global] [--limit 30]
  mios-remember forget --key <k>          # delete by key
  mios-remember update --key <k> "<new>"  # core_memory_replace

Output JSON: {ok, ...}.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.request

TABLE = os.environ.get("MIOS_AGENT_MEMORY_TABLE", "agent_memory")
_MIOS_DB = "/usr/libexec/mios/mios-db"


def _pg_json(envelope: dict):
    """Run a parameterized statement / atomic batch via `mios-db --pg-json`,
    which binds the values OUT-OF-BAND through mios-pg-query's extended protocol
    (no value is ever spliced into the SQL text -> SQL-injection-safe). Returns
    (ok, stdout). Degrade-open: any error -> (False, '') so a DB hiccup never
    breaks a turn."""
    try:
        import subprocess
        r = subprocess.run([_MIOS_DB, "--pg-json"],
                           input=json.dumps(envelope),
                           capture_output=True, text=True, timeout=20)
        return r.returncode == 0, (r.stdout or "").strip()
    except Exception:  # noqa: BLE001
        return False, ""


# P1 AIOS Memory Manager: embed agent-memory facts ON WRITE so they're
# semantically RECALLABLE (the self-edit tier was write-only -> inert: nothing
# embedded the rows, so the HNSW recall never surfaced them). Embed via the live
# dGPU /v1 lane; degrade-open -- the row still writes without emb on any miss.
_EMBED_ENDPOINT = os.environ.get("MIOS_RAG_EMBED_ENDPOINT",
                                 f"http://localhost:{os.environ.get('MIOS_PORT_LLM_LIGHT', '8450')}").rstrip("/")
_EMBED_MODEL = os.environ.get("MIOS_RAG_EMBED_MODEL", "nomic-embed-text")
# WS-A2 embedding-version hygiene: stamp the embedding identity alongside every
# stored vector so a model/dim change is detectable + re-embeddable (matches the
# agent-pipe EMB_VERSION). Bump MIOS_EMB_VERSION when the model/dims change.
_EMB_VERSION = os.environ.get("MIOS_EMB_VERSION", "nomic-768-v1")


def _embed_vec(text: str) -> str:
    """Embed -> pgvector literal '[..]', or '' on any miss (degrade-open). The
    literal is BOUND as a text param with a ::vector cast, not spliced as SQL."""
    try:
        base = (_EMBED_ENDPOINT if _EMBED_ENDPOINT.endswith("/v1")
                else _EMBED_ENDPOINT + "/v1")
        req = urllib.request.Request(
            f"{base}/embeddings",
            data=json.dumps({"model": _EMBED_MODEL,
                             "input": (text or "")[:4000]}).encode(),
            headers={"Content-Type": "application/json"})
        r = json.loads(urllib.request.urlopen(req, timeout=20).read())
        d = r.get("data") or []
        emb = (d[0].get("embedding") if d else r.get("embedding")) or []
        return "[" + ",".join(f"{float(x):.6f}" for x in emb) + "]" if emb else ""
    except Exception:  # noqa: BLE001
        return ""


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-remember")
    sub = p.add_subparsers(dest="cmd", required=True)
    pa = sub.add_parser("add")
    pa.add_argument("fact")
    pa.add_argument("--scope", default="global")
    pa.add_argument("--key", default="")
    pa.add_argument("--source", default="agent")
    pl = sub.add_parser("list")
    pl.add_argument("--scope", default="")
    pl.add_argument("--limit", type=int, default=30)
    pf = sub.add_parser("forget")
    pf.add_argument("--key", required=True)
    pu = sub.add_parser("update")
    pu.add_argument("--key", required=True)
    pu.add_argument("fact")
    args = p.parse_args()

    try:
        if args.cmd == "add":
            fact = args.fact.strip()
            # Strip leading conversational filler so the STORED fact is clean
            # ("Please remember this fact: I prefer X" -> "I prefer X"); the refine
            # extraction sometimes keeps the "this fact:" prefix (Claude 2026-06-15).
            _lf = fact.lower()
            for _pre in ("please remember this fact:", "remember this fact:",
                         "please remember that ", "remember that ",
                         "please remember:", "remember:", "this fact:",
                         "note that ", "fyi:"):
                if _lf.startswith(_pre):
                    fact = fact[len(_pre):].strip()
                    break
            if not fact:
                print(json.dumps({"ok": False, "error": "empty fact"}))
                return 2
            key = args.key.strip() or f"m{abs(hash(fact)) % (10**10)}"
            # Upsert by (key, scope): DELETE then INSERT in ONE atomic batch
            # (BEGIN/COMMIT). All values are BOUND params ($1..$n) -- TABLE is a
            # trusted config identifier, never request data.
            _emb = _embed_vec(fact)
            cols = ["fact", "scope", "mem_key", "source"]
            phs = ["$1", "$2", "$3", "$4"]
            ins_params = [fact, args.scope, key, args.source]
            if _emb:
                # WS-A2: stamp the embedding identity (model + version) too.
                cols += ["emb", "emb_model", "emb_version"]
                phs += ["$5::vector", "$6", "$7"]
                ins_params += [_emb, _EMBED_MODEL, _EMB_VERSION]
            ok, _ = _pg_json({"statements": [
                {"sql": f"DELETE FROM {TABLE} WHERE mem_key = $1 AND scope = $2",
                 "params": [key, args.scope]},
                {"sql": (f"INSERT INTO {TABLE} (" + ", ".join(cols)
                         + ") VALUES (" + ", ".join(phs) + ")"),
                 "params": ins_params},
            ]})
            print(json.dumps({"ok": ok, "op": "add", "key": key,
                              "scope": args.scope, "stored": ok}))
            return 0 if ok else 1
        if args.cmd == "list":
            params = []
            where = ""
            if args.scope:
                where = "WHERE scope = $1 "
                params = [args.scope]
            # LIMIT stays inline (int-coerced -> not injectable); scope is bound.
            inner = (f"SELECT mem_key AS key, scope, fact, source FROM {TABLE} "
                     f"{where}ORDER BY ts DESC LIMIT {int(args.limit)}")
            ok, out = _pg_json({
                "sql": (f"SELECT coalesce(json_agg(row_to_json(t)),'[]') "
                        f"FROM ({inner}) t;"),
                "params": params})
            try:
                mem = json.loads(out) if out else []
            except Exception:  # noqa: BLE001
                mem = []
            print(json.dumps({"ok": True, "count": len(mem), "memories": mem}))
            return 0
        if args.cmd == "forget":
            ok, _ = _pg_json({"sql": f"DELETE FROM {TABLE} WHERE mem_key = $1;",
                              "params": [args.key]})
            print(json.dumps({"ok": ok, "op": "forget", "key": args.key}))
            return 0 if ok else 1
        if args.cmd == "update":
            # A bare UPDATE returns rc 0 even when it matches ZERO rows, so the
            # old code reported ok/updated:1 for a key that doesn't exist. Confirm
            # the key exists first (same proven json_agg SELECT path as `list`) and
            # report the real match status so a no-op update is never a phantom
            # success.
            _ck_ok, _ck_out = _pg_json({
                "sql": (f"SELECT coalesce(json_agg(1),'[]') FROM {TABLE} "
                        f"WHERE mem_key = $1;"),
                "params": [args.key]})
            try:
                _matched = len(json.loads(_ck_out)) if _ck_out else 0
            except Exception:  # noqa: BLE001
                _matched = 0
            if not _matched:
                print(json.dumps({"ok": False, "op": "update", "key": args.key,
                                  "updated": 0, "matched": False,
                                  "error": "no_such_key"}))
                return 1
            _emb = _embed_vec(args.fact)
            if _emb:
                sql = (f"UPDATE {TABLE} SET fact = $1, emb = $2::vector, "
                       f"ts = now() WHERE mem_key = $3;")
                params = [args.fact, _emb, args.key]
            else:
                sql = (f"UPDATE {TABLE} SET fact = $1, ts = now() "
                       f"WHERE mem_key = $2;")
                params = [args.fact, args.key]
            ok, _ = _pg_json({"sql": sql, "params": params})
            print(json.dumps({"ok": ok, "op": "update", "key": args.key,
                              "updated": _matched if ok else 0, "matched": True}))
            return 0 if ok else 1
    except Exception as e:  # noqa: BLE001
        print(json.dumps({"ok": False, "error": f"{type(e).__name__}: {e}"}))
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
