#!/bin/bash
# AI-hint: Captures and formats the system's hardware, service status, and configuration facts into brief, full, or machine-readable formats to provide the Hermes agent with deterministic environmental context.
# AI-related: /usr/libexec/mios/mios-env-probe, /usr/share/mios/mios.toml, /usr/libexec/mios/mios-apps, /usr/share/mios/ai/system.md, /usr/share/mios/ai/INDEX.md, /usr/share/mios/hermes/skills/, mios-apps, mios-hermes-init-hook, mios-delegation-prefilter, mios-open-webui
# AI-functions: _toml_get, _svc_active, _count
set -euo pipefail
# /usr/libexec/mios/mios-env-probe [--brief|--full|--markdown|--json]
#
# Snapshot the agent's CURRENT environment as deterministic facts.
# Designed to be injected into a Hermes session's first turn via the
# pre_llm_call hook (see mios-hermes-init-hook), AND callable
# explicitly when an agent realises mid-conversation that it doesn't
# know what's around it.
#
# Operator directive 2026-05-15: "make sure the AI stack has an
# understanding of its environment when initialized -- MiOS AI's
# should have an understanding of the MiOS codebase/stack -- the
# Agents dispatched Globally Should be informed of the environment
# via an agent init/probe pass on first query".
#
# Modes:
#   --brief      ~10-line summary (used as init context; cheap to inject)
#   --full       all sections; longer
#   --markdown   markdown formatting (default for --full)
#   --json       machine-readable
set -eu

# Guard set -u: a value with shell-metachars must not abort under set -u.
if [ -r /etc/mios/install.env ]; then
    _mios_had_u=0; case "$-" in *u*) _mios_had_u=1;; esac
    set +u; set -a; . /etc/mios/install.env 2>/dev/null || true; set +a
    [ "$_mios_had_u" = 1 ] && set -u
fi
_PORT_HERMES="${MIOS_PORT_HERMES:-8642}"
_PORT_PREFILTER="${MIOS_PORT_PREFILTER:-8641}"
_PORT_LLM_LIGHT="${MIOS_PORT_LLM_LIGHT:-8450}"

MODE="${1:-brief}"
case "$MODE" in
    --brief|brief|-b) MODE=brief ;;
    --full|full|-f)   MODE=full ;;
    --markdown|markdown|-m) MODE=markdown ;;
    --json|json|-j)   MODE=json ;;
    -h|--help)
        cat <<'USAGE'
usage: mios-env-probe [--brief|--full|--markdown|--json]

Snapshot the current environment as deterministic facts (identity,
hardware, services up, models loaded, app counts, stack endpoints).

  --brief      ~10-line summary; default; safe to inject every turn
  --full       all sections; longer
  --markdown   markdown formatting
  --json       machine-readable
USAGE
        exit 0
        ;;
esac

# ─── facts gathering ─────────────────────────────────────────────────
_toml_get() {
    # _toml_get <section> <key> -- read mios.toml [section].key (vendor)
    awk -v sec="[$1]" -v key="$2" '
        $0==sec { in_sec=1; next }
        /^\[/ { in_sec=0 }
        in_sec && $0 ~ "^[[:space:]]*"key"[[:space:]]*=" {
            sub(/^[^=]+=[[:space:]]*"?/, "")
            sub(/"?[[:space:]]*$/, "")
            print
            exit
        }
    ' /usr/share/mios/mios.toml 2>/dev/null
}

OPERATOR_NAME="$(_toml_get identity username)"
OPERATOR_FULL="$(_toml_get identity fullname)"
HOSTNAME_TOML="$(_toml_get identity hostname)"
HOSTNAME_LIVE="$(hostname 2>/dev/null || echo unknown)"

# WSL detection
IS_WSL=false
WSL_DISTRO=""
if [ -r /proc/version ]; then
    case "$(cat /proc/version)" in
        *Microsoft*|*microsoft*|*WSL*)
            IS_WSL=true
            WSL_DISTRO="$(cat /etc/wsl.conf 2>/dev/null | awk -F= '/^hostname/{print $2; exit}' | tr -d ' ' )"
            [ -z "$WSL_DISTRO" ] && WSL_DISTRO="$(grep -oP '(?<=Microsoft|WSL).*' /proc/version | head -1)"
            ;;
    esac
fi

# Hardware
CPU_MODEL="$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | sed 's/^.*: //' | head -c 60)"
CPU_CORES="$(nproc 2>/dev/null || echo ?)"
RAM_GB="$(awk '/MemTotal/ {printf "%.1f", $2/1024/1024}' /proc/meminfo 2>/dev/null || echo ?)"
GPU_LINE="$(lspci 2>/dev/null | grep -iE 'vga|3d|display' | head -1 | sed 's/.*: //' | head -c 70)"
[ -z "$GPU_LINE" ] && GPU_LINE="(no GPU detected via lspci; on WSL2 GPU goes through /dev/dxg)"

# OS
OS_PRETTY="$(grep -m1 PRETTY_NAME= /etc/os-release 2>/dev/null | sed 's/^.*=//; s/"//g')"

# Services
_svc_active() {
    if systemctl is-active --quiet "$1"; then echo up; else echo down; fi
}
SVC_HERMES=$(_svc_active mios-gateway-agent.service)
SVC_PREFILTER=$(_svc_active mios-delegation-prefilter.service)
SVC_OWUI=$(_svc_active mios-open-webui.service)
SVC_LLM_LIGHT=$(_svc_active mios-llm-light.service)
SVC_PGVECTOR=$(_svc_active mios-pgvector.service)
SVC_SEARXNG=$(_svc_active mios-searxng.service)
SVC_BROWSER=$(_svc_active mios-hermes-browser.service)
SVC_CROND=$(_svc_active crond.service)
SVC_ATD=$(_svc_active atd.service)

# Models loaded in Ollama
OLLAMA_MODELS="$((curl -sS --max-time 2 http://127.0.0.1:${MIOS_PORT_LLM_LIGHT:-8450}/api/tags 2>/dev/null || true) \
    | python3 -c 'import sys, json
try:
  d = json.load(sys.stdin)
  print(",".join(m["name"] for m in d.get("models", [])[:8]))
except Exception:
  print("?")' 2>/dev/null)"
[ -z "$OLLAMA_MODELS" ] && OLLAMA_MODELS="(unreachable)"

# App counts via mios-apps (cheap; just --names | wc -l per category)
_count() {
    /usr/libexec/mios/mios-apps --names --category "$1" 2>/dev/null | wc -l
}
N_FLATPAK=$(_count linux-flatpak)
N_HOST_GUI=$(_count linux-rpm-gui)
N_WIN_GUI=$(_count windows-gui)
N_WIN_APP=$(_count windows-app)
N_SHIM=$(_count mios-shim)
N_CLI=$(_count agent-cli)
N_URL=$(_count service-url)

# ─── render ─────────────────────────────────────────────────────────
case "$MODE" in
brief)
    # Windows-host facts ONLY when on WSL2 (best-effort; never blocks).
    # Single-quoted PS expression so bash leaves the $vars alone; the
    # PowerShell child receives literal $os / $cpu / $mem.
    WIN_LINE=""
    if [ "$IS_WSL" = true ] && command -v mios-windows >/dev/null 2>&1; then
        WIN_LINE="$(timeout 4 mios-windows ps 'try { $o=Get-CimInstance Win32_OperatingSystem; $c=Get-CimInstance Win32_Processor | Select-Object -First 1; $m=[math]::Round($o.TotalVisibleMemorySize/1024/1024,1); "$($o.Caption) on $($o.CSName), $($c.Name), $($c.NumberOfLogicalProcessors) cores, $m GB RAM" } catch { "?" }' 2>/dev/null | tr -d '\r' | head -1)"
        [ -z "$WIN_LINE" ] && WIN_LINE="(probe failed; mios-windows ps unreachable)"
    fi
    cat <<EOF
**MiOS environment** ($(date -Iseconds))
- Linux host: $OS_PRETTY on $HOSTNAME_LIVE ($(if [ "$IS_WSL" = true ]; then echo "WSL2 distro"; else echo "bare/VM"; fi))
- Linux HW: $CPU_CORES cores / ${RAM_GB} GB RAM / GPU: $GPU_LINE${WIN_LINE:+
- Windows host (via WSL interop): $WIN_LINE}
- Operator (mios.toml [identity]): $OPERATOR_FULL ($OPERATOR_NAME) on $HOSTNAME_TOML
- Stack services: hermes=$SVC_HERMES prefilter=$SVC_PREFILTER owui=$SVC_OWUI llm_light=$SVC_LLM_LIGHT pgvector=$SVC_PGVECTOR searxng=$SVC_SEARXNG browser=$SVC_BROWSER crond=$SVC_CROND atd=$SVC_ATD
- Models loaded (llm-light): $OLLAMA_MODELS
- Launchable: $N_FLATPAK flatpaks, $N_HOST_GUI host GUIs, $N_WIN_GUI windows shortcuts, $N_WIN_APP **all-windows apps** (Get-StartApps), $N_SHIM MiOS shims, $N_CLI CLIs, $N_URL service URLs
- Discovery + launch: \`mios-apps\` (inventory) and \`mios-launch <name>\` (universal launcher)
EOF
    ;;
full|markdown)
    # Full Windows-host probe (computer info + GPU) when on WSL2.
    # Single-quoted PS expression so bash leaves $vars alone.
    WIN_BLOCK=""
    if [ "$IS_WSL" = true ] && command -v mios-windows >/dev/null 2>&1; then
        WIN_BLOCK="$(timeout 6 mios-windows ps 'try { $o=Get-CimInstance Win32_OperatingSystem; $c=Get-CimInstance Win32_Processor | Select-Object -First 1; $m=[math]::Round($o.TotalVisibleMemorySize/1024/1024,2); $g=(Get-CimInstance Win32_VideoController | Select-Object -First 1 -ExpandProperty Name); "- Hostname (Windows): $($o.CSName)`n- OS: $($o.Caption) $($o.Version)`n- CPU: $($c.Name) ($($c.NumberOfLogicalProcessors) logical cores)`n- RAM: $m GB`n- GPU: $g" } catch { "(Windows probe error: $_)" }' 2>/dev/null | tr -d '\r')"
        [ -z "$WIN_BLOCK" ] && WIN_BLOCK="(Windows-host probe failed; mios-windows ps unreachable)"
    fi
    cat <<EOF
# MiOS environment probe ($(date -Iseconds))

## Identity
- Operator (mios.toml [identity]): **$OPERATOR_FULL** (\`$OPERATOR_NAME\`)
- Hostname (toml / live): \`$HOSTNAME_TOML\` / \`$HOSTNAME_LIVE\`

## Linux host (the MiOS distro)
- OS: $OS_PRETTY
- WSL2: $IS_WSL${WSL_DISTRO:+ (distro: $WSL_DISTRO)}
- CPU: $CPU_MODEL ($CPU_CORES cores)
- RAM: ${RAM_GB} GB
- GPU: $GPU_LINE
$(if [ -n "$WIN_BLOCK" ]; then printf '\n## Windows host (the machine WSL lives inside)\n%s\n' "$WIN_BLOCK"; fi)

## MiOS stack services
| service                              | state |
|--------------------------------------|-------|
| mios-gateway-agent.service           | $SVC_HERMES |
| mios-delegation-prefilter.service    | $SVC_PREFILTER |
| mios-open-webui.service              | $SVC_OWUI |
| mios-llm-light.service               | $SVC_LLM_LIGHT |
| mios-pgvector.service                | $SVC_PGVECTOR |
| mios-searxng.service                 | $SVC_SEARXNG |
| mios-hermes-browser.service          | $SVC_BROWSER |
| crond.service                        | $SVC_CROND |
| atd.service                          | $SVC_ATD |

## AI inference
- Models loaded (llm-light): \`$OLLAMA_MODELS\`
- Hermes gateway: http://localhost:${_PORT_HERMES}/v1
- Prefilter (force delegate_task on fan-out): http://localhost:${_PORT_PREFILTER}/v1
- Backend llm-light: http://localhost:${_PORT_LLM_LIGHT}

## Launchable inventory
- $N_FLATPAK flatpaks
- $N_HOST_GUI host RPM GUIs
- $N_WIN_GUI Windows shortcut shorts (notepad, explorer, calc, ...)
- $N_WIN_APP **all-Windows apps** (every Start-menu entry; Win32 + UWP/MSIX) via \`Get-StartApps\`
- $N_SHIM MiOS shims (under /usr/libexec/mios/ and /usr/local/bin/)
- $N_CLI agent-CLI tools
- $N_URL known internal-service URLs

Full inventory: \`mios-apps\`. Launch by name: \`mios-launch <name>\`.

## Pointers (for any deeper question)
- /usr/share/mios/ai/system.md         -- canonical agent system prompt
- /usr/share/mios/ai/INDEX.md          -- system interface reference
- /usr/share/mios/mios.toml            -- vendor SSOT for configuration
- /usr/share/doc/mios/reference/PACKAGES.md          -- RPM package documentation
- /usr/share/mios/hermes/skills/       -- shipped skills (windows-control, parallel-fanout, mios-environment, self-improvement)
- /CLAUDE.md, /AGENTS.md               -- repo-root architectural laws
EOF
    ;;
json)
    # Pass every value through the ENVIRONMENT (not source interpolation) so a
    # quote/special char in a field -- or a bash boolean like $IS_WSL=true,
    # which is NOT valid Python -- can't break the JSON. The heredoc is
    # single-quoted so bash leaves the python untouched; python reads os.environ.
    export EP_TS="$(date -Iseconds)" \
        EP_OP_USER="$OPERATOR_NAME" EP_OP_FULL="$OPERATOR_FULL" \
        EP_HOST_TOML="$HOSTNAME_TOML" EP_HOST_LIVE="$HOSTNAME_LIVE" \
        EP_OS="$OS_PRETTY" EP_IS_WSL="$IS_WSL" EP_WSL_DISTRO="$WSL_DISTRO" \
        EP_CPU="$CPU_MODEL" EP_CPU_CORES="$CPU_CORES" EP_RAM="$RAM_GB" \
        EP_GPU="$GPU_LINE" \
        EP_SVC_HERMES="$SVC_HERMES" EP_SVC_PREFILTER="$SVC_PREFILTER" \
        EP_SVC_OWUI="$SVC_OWUI" EP_SVC_LLM_LIGHT="$SVC_LLM_LIGHT" \
        EP_SVC_PGVECTOR="$SVC_PGVECTOR" \
        EP_SVC_SEARXNG="$SVC_SEARXNG" EP_SVC_BROWSER="$SVC_BROWSER" \
        EP_SVC_CROND="$SVC_CROND" EP_SVC_ATD="$SVC_ATD" \
        EP_OLLAMA_MODELS="$OLLAMA_MODELS" \
        EP_N_FLATPAK="$N_FLATPAK" EP_N_HOST_GUI="$N_HOST_GUI" \
        EP_N_WIN_GUI="$N_WIN_GUI" EP_N_WIN_APP="$N_WIN_APP" \
        EP_N_SHIM="$N_SHIM" EP_N_CLI="$N_CLI" EP_N_URL="$N_URL"
    python3 - <<'PYEOF'
import json, os
def _i(k):
    try:
        return int(os.environ.get(k, "") or 0)
    except ValueError:
        return 0
print(json.dumps({
    "ts": os.environ.get("EP_TS", ""),
    "identity": {
        "operator_username": os.environ.get("EP_OP_USER", ""),
        "operator_fullname": os.environ.get("EP_OP_FULL", ""),
        "hostname_toml": os.environ.get("EP_HOST_TOML", ""),
        "hostname_live": os.environ.get("EP_HOST_LIVE", ""),
    },
    "host": {
        "os": os.environ.get("EP_OS", ""),
        "is_wsl": os.environ.get("EP_IS_WSL", "") == "true",
        "wsl_distro": os.environ.get("EP_WSL_DISTRO", ""),
        "cpu": os.environ.get("EP_CPU", ""),
        "cpu_cores": os.environ.get("EP_CPU_CORES", ""),
        "ram_gb": os.environ.get("EP_RAM", ""),
        "gpu": os.environ.get("EP_GPU", ""),
    },
    "services": {
        "hermes_agent":         os.environ.get("EP_SVC_HERMES", ""),
        "delegation_prefilter": os.environ.get("EP_SVC_PREFILTER", ""),
        "open_webui":           os.environ.get("EP_SVC_OWUI", ""),
        "llm_light":            os.environ.get("EP_SVC_LLM_LIGHT", ""),
        "pgvector":             os.environ.get("EP_SVC_PGVECTOR", ""),
        "searxng":              os.environ.get("EP_SVC_SEARXNG", ""),
        "hermes_browser":       os.environ.get("EP_SVC_BROWSER", ""),
        "crond":                os.environ.get("EP_SVC_CROND", ""),
        "atd":                  os.environ.get("EP_SVC_ATD", ""),
    },
    "ollama_models": os.environ.get("EP_OLLAMA_MODELS", ""),
    "launchable_counts": {
        "linux_flatpak": _i("EP_N_FLATPAK"),
        "linux_rpm_gui": _i("EP_N_HOST_GUI"),
        "windows_gui":   _i("EP_N_WIN_GUI"),
        "windows_app":   _i("EP_N_WIN_APP"),
        "mios_shim":     _i("EP_N_SHIM"),
        "agent_cli":     _i("EP_N_CLI"),
        "service_url":   _i("EP_N_URL"),
    },
}, indent=2))
PYEOF
    ;;
esac
