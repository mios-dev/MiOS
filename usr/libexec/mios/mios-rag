#!/usr/bin/env python3
# AI-hint: Python tool for RAG retrieval that embeds MiOS documentation into Postgres+pgvector (table mios_rag) via nomic-embed-text to provide context to agents during the agent-pipe enrich stage. WS-A3: the ingest INSERT is PARAMETERIZED via mios-pg-query --exec-json (source/content/emb bound out-of-band, never f-string-spliced); the retired legacy transport is removed.
# AI-related: /usr/share/mios/docs, /usr/libexec/mios/mios-pg-query, mios-pg-query, localhost:8450
# AI-functions: _embed, _pg, _pg_param, _vec, _chunks, cmd_ingest, cmd_query, main
"""mios-rag -- agent-pipe RAG over MiOS knowledge, on infra MiOS already runs:
nomic-embed-text for embeddings + Postgres+pgvector for the vector store. Keeps
RAG in-loop for every agent/sub-agent turn WITHOUT OWUI's blocking pre-pipe
knowledge_search (operator 2026-05-20: "move RAG into the agent-pipe enrich
stage").

Subcommands:
  ingest [--dir D ...]   Chunk + embed the MiOS docs (and any extra dirs) into
                         the pgvector table `mios_rag`. Idempotent: clears +
                         rebuilds. Run on docs change.
  query  <text> [--k N]  Embed the text, vector-search the store, print the
                         top-N {source, text, score} as JSON.

WS-A3 cutover: the legacy DB (:8000) is RETIRED. The vector store is Postgres+
pgvector reached via the pure-python mios-pg-query wire client, and the ingest
INSERT binds source/content/emb as OUT-OF-BAND params (mios-pg-query --exec-json
extended protocol) -- no filesystem-sourced value is ever spliced into SQL.

Config (SSOT-overridable via env):
  MIOS_RAG_EMBED_ENDPOINT  default http://localhost:8450 (mios-llm-light /v1)
  MIOS_RAG_EMBED_MODEL     default nomic-embed-text
  MIOS_RAG_DOCS_DIR        default /usr/share/mios/docs
  MIOS_RAG_CHUNK_CHARS     default 700
"""
from __future__ import annotations

import argparse
import glob
import json
import os
import sys
import urllib.request

EMBED_ENDPOINT = os.environ.get("MIOS_RAG_EMBED_ENDPOINT",
                                f"http://localhost:{os.environ.get('MIOS_PORT_LLM_LIGHT', '8450')}").rstrip("/")  # mios-llm-light /v1
EMBED_MODEL = os.environ.get("MIOS_RAG_EMBED_MODEL", "nomic-embed-text")
DOCS_DIR = os.environ.get("MIOS_RAG_DOCS_DIR", "/usr/share/mios/docs")
CHUNK_CHARS = int(os.environ.get("MIOS_RAG_CHUNK_CHARS", "700"))
TABLE = "mios_rag"
_PGQ = "/usr/libexec/mios/mios-pg-query"


def _embed(text: str) -> "list[float]":
    import time
    # OpenAI /v1/embeddings (mios-llm-light serves nomic-embed-text; MiOS is /v1-only)
    base = EMBED_ENDPOINT if EMBED_ENDPOINT.endswith("/v1") else EMBED_ENDPOINT + "/v1"
    endpoints = [
        (base, EMBED_MODEL),
    ]
    for attempt in range(3):
        for ep, model in endpoints:
            try:
                payload = {"model": model, "input": text[:4000]}
                req = urllib.request.Request(
                    f"{ep}/embeddings",
                    data=json.dumps(payload).encode(),
                    headers={"Content-Type": "application/json"},
                )
                r = json.loads(urllib.request.urlopen(req, timeout=15).read())
                data = r.get("data") or []
                if data:
                    return data[0].get("embedding") or []
                if r.get("embedding"):
                    return r.get("embedding")
            except Exception:
                continue
        time.sleep(1)
    return []


def _pg(sql: str) -> list:
    """Run one CONSTANT SQL statement (DDL/TRUNCATE) on pgvector via mios-pg-query
    (pure-python pg wire client). For statements with VALUES, use _pg_param so
    nothing is spliced. Rows -> lists of string columns (psql -At)."""
    import subprocess
    p = subprocess.run([_PGQ, sql],
                       capture_output=True, text=True, timeout=90)
    if p.returncode != 0:
        raise RuntimeError(f"pg error: {(p.stderr or '')[:200]}")
    return [ln.split("\t") for ln in p.stdout.splitlines() if ln]


def _pg_param(sql: str, params: list) -> list:
    """Run a PARAMETERIZED statement via mios-pg-query --exec-json: values are
    bound out-of-band ($1..$n) through the extended protocol -- SQL-injection-safe
    (the WS-A3 way). Rows -> lists of string columns."""
    import subprocess
    p = subprocess.run([_PGQ, "--exec-json"],
                       input=json.dumps({"sql": sql, "params": params}),
                       capture_output=True, text=True, timeout=90)
    if p.returncode != 0:
        raise RuntimeError(f"pg error: {(p.stderr or '')[:200]}")
    return [ln.split("\t") for ln in p.stdout.splitlines() if ln]


def _vec(emb: list) -> str:
    """pgvector literal: [f1,f2,...]. Bound as a text param with a ::vector cast,
    never spliced as SQL."""
    return "[" + ",".join(f"{float(x):.6f}" for x in emb) + "]"


def _chunks(text: str, src: str):
    # Paragraph-aware chunking with overlap capped at CHUNK_CHARS.
    OVERLAP_CHARS = 150
    buf = ""
    for para in text.split("\n\n"):
        para = para.strip()
        if not para:
            continue
        if len(buf) + len(para) + 2 > CHUNK_CHARS and buf:
            yield buf.strip(), src
            overlap = buf[-OVERLAP_CHARS:] if len(buf) > OVERLAP_CHARS else buf
            if " " in overlap:
                overlap = overlap.split(" ", 1)[-1]
            buf = overlap + "\n\n"
        buf += para + "\n\n"
    if buf.strip():
        yield buf.strip(), src


def cmd_ingest(dirs: "list[str]") -> int:
    paths: "list[str]" = []
    for d in [DOCS_DIR] + (dirs or []):
        paths += glob.glob(os.path.join(d, "**", "*.md"), recursive=True)
        paths += glob.glob(os.path.join(d, "**", "*.txt"), recursive=True)
    paths = sorted(set(paths))
    if not paths:
        print("mios-rag: no source files found", file=sys.stderr)
        return 1
    # pgvector store. Brute-force cosine is fine for the docs-sized corpus; an
    # HNSW index is added best-effort.
    _pg("CREATE TABLE IF NOT EXISTS mios_rag ("
        "id bigserial PRIMARY KEY, source text, content text, emb vector(768));")
    try:
        _pg("CREATE INDEX IF NOT EXISTS mios_rag_emb_idx ON mios_rag "
            "USING hnsw (emb vector_cosine_ops);")
    except Exception:
        pass   # index optional -- brute-force cosine still works
    _pg("TRUNCATE mios_rag;")
    n = 0
    for p in paths:
        try:
            text = open(p, "r", errors="replace").read()
        except OSError:
            continue
        src = os.path.relpath(p, "/")
        for chunk, _ in _chunks(text, src):
            try:
                emb = _embed(chunk)
                if not emb:
                    continue
                # PARAMETERIZED: source (filesystem path) + content (file text)
                # are BOUND, never spliced -> no quote/backslash/encoding edge
                # case can break or inject the SQL.
                _pg_param(
                    "INSERT INTO mios_rag (source, content, emb) "
                    "VALUES ($1, $2, $3::vector)",
                    [src, chunk, _vec(emb)])
                n += 1
            except Exception:
                # transient embed 500 (mios-llm-light loading) or a bad chunk --
                # skip it and keep going so one failure can't abort the run.
                continue
    print(json.dumps({"ok": True, "files": len(paths), "chunks": n}))
    return 0


def cmd_query(text: str, k: int) -> int:
    emb = _embed(text)
    if not emb:
        print(json.dumps({"ok": False, "error": "embed_failed", "hits": []}))
        return 1
    qv = _vec(emb)
    # pgvector cosine: distance is emb <=> qv ; similarity = 1 - distance. The
    # vector is BOUND as $1 (reused); LIMIT stays inline (int-coerced -> safe).
    # Flatten newlines/tabs in content so mios-pg-query's tab-separated,
    # one-row-per-line output stays parseable.
    q = ("SELECT source, translate(content, E'\\n\\t\\r', '   '), "
         "round((1 - (emb <=> $1::vector))::numeric, 4) "
         "FROM mios_rag ORDER BY emb <=> $1::vector LIMIT " + str(int(k)) + ";")
    try:
        rows = _pg_param(q, [qv])
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e), "hits": []}))
        return 1
    hits = []
    for r in rows:
        if len(r) >= 3:
            try:
                sc = float(r[2])
            except (ValueError, TypeError):
                sc = 0.0
            hits.append({"source": r[0], "text": r[1], "score": sc})
    print(json.dumps({"ok": True, "hits": hits}))
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="mios-rag")
    sub = ap.add_subparsers(dest="cmd", required=True)
    pi = sub.add_parser("ingest")
    pi.add_argument("--dir", action="append", default=[])
    pq = sub.add_parser("query")
    pq.add_argument("text")
    pq.add_argument("--k", type=int, default=4)
    a = ap.parse_args()
    if a.cmd == "ingest":
        return cmd_ingest(a.dir)
    return cmd_query(a.text, a.k)


if __name__ == "__main__":
    sys.exit(main())
