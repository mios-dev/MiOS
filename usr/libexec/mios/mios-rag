#!/usr/bin/env python3
# AI-hint: Python tool for RAG-based knowledge retrieval that embeds MiOS documentation into SurrealDB using nomic-embed-text to provide context-aware data to agents during the enrichment stage of the agent-pipe.
# AI-related: /usr/share/mios/docs, /usr/libexec/mios/mios-pg-query, mios-pg-query, localhost:11434, localhost:8000, localhost:11450
"""mios-rag -- agent-pipe RAG over MiOS knowledge, on infra MiOS already
runs: nomic-embed-text (ollama) for embeddings + SurrealDB for the vector
store. Keeps RAG in-loop for every agent/sub-agent turn WITHOUT OWUI's
blocking pre-pipe knowledge_search (operator 2026-05-20: "move RAG into
the agent-pipe enrich stage ... SurrealDB vector + nomic-embed-text").

Subcommands:
  ingest [--dir D ...]   Chunk + embed the MiOS docs (and any extra dirs)
                         into SurrealDB table `mios_rag`. Idempotent:
                         clears + rebuilds. Run on docs change.
  query  <text> [--k N]  Embed the text, vector-search the store, print
                         the top-N {source, text, score} as JSON.

Config (SSOT-overridable via env):
  MIOS_RAG_EMBED_ENDPOINT  default http://localhost:11434
  MIOS_RAG_EMBED_MODEL     default nomic-embed-text
  MIOS_DB_URL              default http://localhost:8000  (SurrealDB)
  MIOS_DB_USER/PASS/NS     default root/root/mios ; DB fixed to `agent`
  MIOS_RAG_DOCS_DIR        default /usr/share/mios/docs
  MIOS_RAG_CHUNK_CHARS     default 700
"""
from __future__ import annotations

import argparse
import base64
import glob
import json
import os
import sys
import urllib.error
import urllib.request

EMBED_ENDPOINT = os.environ.get("MIOS_RAG_EMBED_ENDPOINT",
                                "http://localhost:11450").rstrip("/")  # llama-swap /v1 (ollama :11434 retired)
EMBED_MODEL = os.environ.get("MIOS_RAG_EMBED_MODEL", "nomic-embed-text")
DB_URL = os.environ.get("MIOS_DB_URL", "http://localhost:8000").rstrip("/")
DB_USER = os.environ.get("MIOS_DB_USER", "root")
DB_PASS = os.environ.get("MIOS_DB_PASS", "root")
DB_NS = os.environ.get("MIOS_DB_NS", "mios")
DB_DB = "agent"
DOCS_DIR = os.environ.get("MIOS_RAG_DOCS_DIR", "/usr/share/mios/docs")
CHUNK_CHARS = int(os.environ.get("MIOS_RAG_CHUNK_CHARS", "700"))
TABLE = "mios_rag"


def _embed(text: str) -> list[float]:
    # OpenAI /v1/embeddings (llama-swap serves nomic-embed-text; the ollama
    # /api/embeddings lane :11434 was retired). Falls back to the ollama shape.
    base = EMBED_ENDPOINT if EMBED_ENDPOINT.endswith("/v1") else EMBED_ENDPOINT + "/v1"
    req = urllib.request.Request(
        f"{base}/embeddings",
        data=json.dumps({"model": EMBED_MODEL, "input": text[:4000]}).encode(),
        headers={"Content-Type": "application/json"},
    )
    r = json.loads(urllib.request.urlopen(req, timeout=30).read())
    data = r.get("data") or []
    if data:
        return data[0].get("embedding") or []
    return r.get("embedding") or []   # ollama-shape fallback


def _pg(sql: str) -> list:
    """Run one SQL statement on pgvector via mios-pg-query (pure-python pg wire
    client -- no psql/psycopg/podman). Rows -> lists of string columns (psql -At)."""
    import subprocess
    p = subprocess.run(["/usr/libexec/mios/mios-pg-query", sql],
                       capture_output=True, text=True, timeout=90)
    if p.returncode != 0:
        raise RuntimeError(f"pg error: {(p.stderr or '')[:200]}")
    return [ln.split("\t") for ln in p.stdout.splitlines() if ln]


def _vec(emb: list) -> str:
    """pgvector literal: [f1,f2,...]."""
    return "[" + ",".join(f"{float(x):.6f}" for x in emb) + "]"


def _sql(query: str) -> list:
    auth = base64.b64encode(f"{DB_USER}:{DB_PASS}".encode()).decode()
    # Prepend USE NS/DB in-query: urllib title-cases custom headers
    # (NS -> Ns) so SurrealDB never sees the namespace headers and returns
    # NamespaceEmpty. The USE statement is immune to header mangling.
    full = f"USE NS {DB_NS} DB {DB_DB}; {query}"
    req = urllib.request.Request(
        f"{DB_URL}/sql", data=full.encode("utf-8"),
        headers={"Authorization": f"Basic {auth}",
                 "Accept": "application/json", "Content-Type": "text/plain"},
        method="POST",
    )
    try:
        return json.loads(urllib.request.urlopen(req, timeout=30).read())
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", "replace")[:200]
        sys.stderr.write(f"  surql {e.code}: {body}  (q={query[:80]})\n")
        return []


def _chunks(text: str, src: str):
    # Paragraph-aware chunking capped at CHUNK_CHARS.
    buf = ""
    for para in text.split("\n\n"):
        para = para.strip()
        if not para:
            continue
        if len(buf) + len(para) + 2 > CHUNK_CHARS and buf:
            yield buf.strip(), src
            buf = ""
        buf += para + "\n\n"
    if buf.strip():
        yield buf.strip(), src


def cmd_ingest(dirs: list[str]) -> int:
    paths: list[str] = []
    for d in [DOCS_DIR] + (dirs or []):
        paths += glob.glob(os.path.join(d, "**", "*.md"), recursive=True)
        paths += glob.glob(os.path.join(d, "**", "*.txt"), recursive=True)
    paths = sorted(set(paths))
    if not paths:
        print("mios-rag: no source files found", file=sys.stderr)
        return 1
    # pgvector store (pg unification; the SurrealDB agent DB is retired and 500s
    # on write). Brute-force cosine is fine for the docs-sized corpus; an HNSW
    # index is added best-effort.
    _pg("CREATE TABLE IF NOT EXISTS mios_rag ("
        "id bigserial PRIMARY KEY, source text, content text, emb vector(768));")
    try:
        _pg("CREATE INDEX IF NOT EXISTS mios_rag_emb_idx ON mios_rag "
            "USING hnsw (emb vector_cosine_ops);")
    except Exception:
        pass   # index optional -- brute-force cosine still works
    _pg("TRUNCATE mios_rag;")
    n = 0
    for p in paths:
        try:
            text = open(p, "r", errors="replace").read()
        except OSError:
            continue
        src = os.path.relpath(p, "/")
        for chunk, _ in _chunks(text, src):
            try:
                emb = _embed(chunk)
                if not emb:
                    continue
                c = chunk.replace("'", "''")
                s = src.replace("'", "''")
                _pg(f"INSERT INTO mios_rag (source, content, emb) "
                    f"VALUES ('{s}', '{c}', '{_vec(emb)}'::vector);")
                n += 1
            except Exception:
                # transient embed 500 (llama-swap loading) or a bad chunk --
                # skip it and keep going so one failure can't abort the run.
                continue
    print(json.dumps({"ok": True, "files": len(paths), "chunks": n}))
    return 0


def cmd_query(text: str, k: int) -> int:
    emb = _embed(text)
    if not emb:
        print(json.dumps({"ok": False, "error": "embed_failed", "hits": []}))
        return 1
    qv = _vec(emb)
    # pgvector cosine: distance is emb <=> qv ; similarity = 1 - distance.
    # Flatten newlines/tabs in content so mios-pg-query's tab-separated,
    # one-row-per-line output stays parseable.
    q = (f"SELECT source, translate(content, E'\\n\\t\\r', '   '), "
         f"round((1 - (emb <=> '{qv}'::vector))::numeric, 4) "
         f"FROM mios_rag ORDER BY emb <=> '{qv}'::vector LIMIT {int(k)};")
    try:
        rows = _pg(q)
    except Exception as e:
        print(json.dumps({"ok": False, "error": str(e), "hits": []}))
        return 1
    hits = []
    for r in rows:
        if len(r) >= 3:
            try:
                sc = float(r[2])
            except (ValueError, TypeError):
                sc = 0.0
            hits.append({"source": r[0], "text": r[1], "score": sc})
    print(json.dumps({"ok": True, "hits": hits}))
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="mios-rag")
    sub = ap.add_subparsers(dest="cmd", required=True)
    pi = sub.add_parser("ingest")
    pi.add_argument("--dir", action="append", default=[])
    pq = sub.add_parser("query")
    pq.add_argument("text")
    pq.add_argument("--k", type=int, default=4)
    a = ap.parse_args()
    if a.cmd == "ingest":
        return cmd_ingest(a.dir)
    return cmd_query(a.text, a.k)


if __name__ == "__main__":
    sys.exit(main())
