#!/usr/bin/env python3
# AI-hint: CLI tool for managing the PostgreSQL/pgvector-backed Personal Knowledge Graph (PKG) to resolve ambiguous user phrases into concrete app targets via the kg_lookup() helper in the agent-pipe.
# AI-related: /usr/libexec/mios/mios-db, mios-db, mios-apps, args.target
"""mios-kg -- Personal Knowledge Graph CLI for the MiOS agent stack.

Phase C.1 of the AgentOS roadmap. Manages the operator-preference
data in PostgreSQL/pgvector (person / app_install / alias +
resolves_to natural-key edge). The agent-pipe's kg_lookup() helper
queries the same tables (JOIN on app_id) to resolve ambiguous noun
phrases to concrete launch targets. Mappings are PER-OPERATOR data
-- this CLI is the interface, never the source. NO hardcoded English
aliases in this codebase. (SurrealDB, BSL 1.1, is retired.)

Subcommands:
  bootstrap                Create the person row (from $USER /
                           $MIOS_USER) + ingest mios-apps inventory
                           into app_install rows. Idempotent.
  alias add <phrase> <target>
                           Add an alias. <target> can be:
                             app:<short_name>   (resolves to app_install)
                             "<short_name>"     (bare = app:<short_name>)
  alias rm <phrase>        Remove an alias.
  alias list               List all aliases + their resolves_to.
  lookup <phrase>          Print the lookup result for <phrase>.
  apps                     Print known app_install rows.
  who                      Print the person row.

Fully local: routes all reads + writes through the shared
/usr/libexec/mios/mios-db --pg CLI (pure-python pg wire client, no
pip deps). resolves_to / app_install / alias / person tables are
defined in /usr/share/mios/postgres/schema-init.sql.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import socket as _socket
import subprocess
import sys

# PKG store: PostgreSQL + pgvector via the shared mios-db --pg CLI. SurrealDB
# (BSL 1.1) is retired -- ALL reads + writes go to pg. Natural-key model
# (resolves_to(phrase, app_id)) -- no record-id round-trips. MIOS_DB_BACKEND
# is kept for SSOT compatibility but the only live store is pg, so the tool
# behaves identically under surreal|dual|postgres (always pg).
DB_BACKEND = os.environ.get("MIOS_DB_BACKEND", "postgres").strip().lower()
_PG_ENABLED = True
_PG_PRIMARY = True
_MIOS_DB = "/usr/libexec/mios/mios-db"


def _pgesc(s) -> str:
    return str(s).replace("'", "''")


def _pgq(s) -> str:
    return "'" + _pgesc(s) + "'"


def _pg_exec(sql: str) -> None:
    if not _PG_ENABLED:
        return
    try:
        import subprocess
        subprocess.run([_MIOS_DB, "--pg", sql],
                       capture_output=True, text=True, timeout=15)
    except Exception:  # noqa: BLE001
        pass


def _pg_rows(sql_inner: str) -> list:
    """Read rows from pgvector as list[dict] via json_agg + mios-db --pg."""
    try:
        import subprocess
        out = subprocess.run(
            [_MIOS_DB, "--json", "--pg",
             f"SELECT coalesce(json_agg(row_to_json(t)),'[]') "
             f"FROM ({sql_inner}) t;"],
            capture_output=True, text=True, timeout=15).stdout.strip()
        return json.loads(out) if out else []
    except Exception:  # noqa: BLE001
        return []

# Phase C.1 SSOT knobs from mios.toml [pkg].* (via userenv.sh slot
# map). Defaults match the mios.toml seed so a Day-0 deploy with
# no overrides still ingests sensibly.
PER_SOURCE_CAP = int(os.environ.get(
    "MIOS_PKG_BOOTSTRAP_PER_SOURCE_CAP", "200"))


# ─── bootstrap ─────────────────────────────────────────────────────
def cmd_bootstrap(args: argparse.Namespace) -> int:
    """Create / update the singleton person row + ingest mios-apps
    catalog into app_install rows. Idempotent -- re-running on an
    already-bootstrapped host is a no-op for unchanged rows."""
    username = (os.environ.get("MIOS_USER")
                or os.environ.get("USER")
                or os.environ.get("LOGNAME")
                or "operator")
    hostname = os.environ.get("MIOS_HOSTNAME") or _socket.gethostname()
    # Upsert the person via DELETE + INSERT (cheaper than UPDATE for the
    # singleton case + survives schema changes). pg `person` table, natural
    # key = username.
    _pg_exec(
        f"DELETE FROM person WHERE username = {_pgq(username)}; "
        f"INSERT INTO person (username, hostname, created_at) VALUES "
        f"({_pgq(username)}, {_pgq(hostname)}, now());")
    pr = _pg_rows(
        f"SELECT id FROM person WHERE username = {_pgq(username)} LIMIT 1")
    if not pr:
        sys.stderr.write("bootstrap: failed to create person row\n")
        return 1
    person_id = pr[0].get("id")
    print(f"person: {person_id} (username={username}, hostname={hostname})")

    # Ingest the inventory. Default source is `mios-apps --json`
    # (NDJSON of {category, name, description, launch} objects).
    # Operator can pass --source <path> or `-` for stdin so this
    # CLI is a template -- any tool that emits the same NDJSON shape
    # can re-bootstrap the graph (operator directive 2026-05-18:
    # "tools/skills are global templates that can be self improved
    # upon").
    src = getattr(args, "source", None) or ""
    text = ""
    if src == "-":
        text = sys.stdin.read()
    elif src:
        try:
            text = open(src, "r", encoding="utf-8").read()
        except OSError as e:
            sys.stderr.write(f"bootstrap: cannot read {src}: {e}\n")
            return 2
    else:
        try:
            raw = subprocess.run(
                ["mios-apps", "--json"], capture_output=True, timeout=60,
            )
            text = raw.stdout.decode("utf-8", errors="replace")
        except (OSError, subprocess.TimeoutExpired) as e:
            sys.stderr.write(f"bootstrap: mios-apps --json failed: {e}\n")
            return 2

    # Parse NDJSON. Aggregate by category so we keep the
    # per-source cap.
    catalog: dict = {}
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        cat = obj.get("category") or "unknown"
        catalog.setdefault(cat, []).append(obj)
    inserted = 0
    for source, entries in catalog.items():
        if not isinstance(entries, list):
            continue
        for entry in entries[:PER_SOURCE_CAP]:  # SSOT cap (mios.toml [pkg])
            if not isinstance(entry, dict):
                continue
            short_name = (entry.get("name") or entry.get("short_name") or "").strip()
            if not short_name:
                continue
            # Extract app_id from "Display (com.foo.Bar)" suffix in description.
            description = entry.get("description") or ""
            app_id = entry.get("app_id") or entry.get("id") or ""
            if not app_id:
                # Pull the parenthesised id from the description tail.
                m = re.search(r"\(([^()]+)\)\s*$", description)
                if m:
                    app_id = m.group(1)
            label = description or short_name
            launch_hint = entry.get("launch") or entry.get("launch_cmd") or ""
            # Idempotent insert into pg app_install (natural key:
            # short_name + source). _pgq single-quote-escapes every string
            # field so embedded apostrophes ("'MiOS' CDI spec ...") stay safe.
            _pg_exec(
                f"DELETE FROM app_install WHERE short_name = {_pgq(short_name)} "
                f"AND source = {_pgq(source)}; "
                f"INSERT INTO app_install (short_name, app_id, source, label, "
                f"launch_hint) VALUES ({_pgq(short_name)}, {_pgq(app_id)}, "
                f"{_pgq(source)}, {_pgq(label or '')}, {_pgq(launch_hint or '')});")
            inserted += 1

    print(f"bootstrap: ingested {inserted} app_install rows")
    return 0


# ─── alias ─────────────────────────────────────────────────────────
def cmd_alias_add(args: argparse.Namespace) -> int:
    phrase = args.phrase.strip().lower()
    target = args.target.strip()
    if not phrase or not target:
        sys.stderr.write("alias add: <phrase> and <target> required\n")
        return 64
    # Resolve target: app:<short_name> or bare short_name.
    if target.startswith("app:"):
        target = target[4:]
    # pg path (natural-key): phrase -> app_id via app_install.short_name.
    # Resolve the target's app_id first so we can fail loudly when the
    # operator names an app that isn't in the inventory (preserves the old
    # surreal UX: stderr + exit 1, suggesting `mios-kg apps`).
    pgr = _pg_rows(f"SELECT app_id FROM app_install "
                   f"WHERE short_name = {_pgq(target)} LIMIT 1")
    if not pgr or not pgr[0].get("app_id"):
        sys.stderr.write(
            f"alias add: no app_install with short_name = {target!r}. "
            f"Try `mios-kg apps` to see the list.\n"
        )
        return 1
    app_id = pgr[0]["app_id"]
    # Upsert the alias + its resolves_to edge (delete-then-insert).
    _pg_exec(
        f"DELETE FROM alias WHERE phrase = {_pgq(phrase)}; "
        f"INSERT INTO alias (phrase) VALUES ({_pgq(phrase)}); "
        f"DELETE FROM resolves_to WHERE phrase = {_pgq(phrase)}; "
        f"INSERT INTO resolves_to (phrase, app_id) VALUES "
        f"({_pgq(phrase)}, {_pgq(app_id)});")
    print(f"alias: {phrase!r} -> app:{target} ({app_id})")
    return 0


def cmd_alias_rm(args: argparse.Namespace) -> int:
    phrase = args.phrase.strip().lower().replace("'", "''")
    _pg_exec(f"DELETE FROM resolves_to WHERE phrase = '{phrase}'; "
             f"DELETE FROM alias WHERE phrase = '{phrase}';")
    print(f"alias: removed {phrase!r}")
    return 0


def cmd_alias_list(args: argparse.Namespace) -> int:
    # pg JOIN replaces the surreal `->resolves_to->app_install` graph walk.
    # LEFT JOIN so aliases with no edge still list (as "(unresolved)").
    # Aggregate resolved targets per phrase into a JSON array of short_names.
    rows = _pg_rows(
        "SELECT al.phrase AS phrase, "
        "coalesce(json_agg(ai.short_name) "
        "FILTER (WHERE ai.short_name IS NOT NULL), '[]') AS targets "
        "FROM alias al "
        "LEFT JOIN resolves_to r ON r.phrase = al.phrase "
        "LEFT JOIN app_install ai ON ai.app_id = r.app_id "
        "GROUP BY al.phrase ORDER BY al.phrase")
    if not rows:
        print("(no aliases configured)")
        return 0
    for row in rows:
        phrase = row.get("phrase", "?")
        targets = row.get("targets") or []
        tlist = ", ".join(str(t) for t in targets) if targets else "(unresolved)"
        print(f"  {phrase!r} -> {tlist}")
    return 0


# ─── lookup ────────────────────────────────────────────────────────
def cmd_lookup(args: argparse.Namespace) -> int:
    phrase = args.phrase.strip().lower().replace("'", "''")
    # Exact first; fall back to contains. SurrealDB doesn't accept
    # boolean expressions in ORDER BY, so we run the queries in
    # priority order and pick the first non-empty. pg JOINs replace the
    # surreal `->resolves_to->app_install` graph walk (same shape the
    # agent-pipe kg_lookup uses); each row aggregates its resolved apps into
    # the `app` JSON array.
    _app_obj = ("json_build_object('id', ai.id, 'short_name', ai.short_name, "
                "'app_id', ai.app_id, 'source', ai.source, 'label', ai.label, "
                "'launch_hint', ai.launch_hint)")
    # Stage 1a: alias EXACT match.
    rows = _pg_rows(
        f"SELECT al.phrase AS phrase, json_agg({_app_obj}) AS app "
        f"FROM alias al "
        f"JOIN resolves_to r ON r.phrase = al.phrase "
        f"JOIN app_install ai ON ai.app_id = r.app_id "
        f"WHERE al.phrase = '{phrase}' "
        f"GROUP BY al.phrase LIMIT 1")
    if not rows:
        # Stage 1b: alias CONTAINS match (fuzzy fallback).
        rows = _pg_rows(
            f"SELECT al.phrase AS phrase, json_agg({_app_obj}) AS app "
            f"FROM alias al "
            f"JOIN resolves_to r ON r.phrase = al.phrase "
            f"JOIN app_install ai ON ai.app_id = r.app_id "
            f"WHERE al.phrase ILIKE '%{phrase}%' "
            f"   OR '{phrase}' ILIKE '%' || al.phrase || '%' "
            f"GROUP BY al.phrase LIMIT 3")
    if not rows:
        # Stage 2: direct app_install lookup by short_name substring.
        rows = _pg_rows(
            f"SELECT id, short_name, app_id, source, label, launch_hint "
            f"FROM app_install "
            f"WHERE short_name ILIKE '%{phrase}%' "
            f"   OR '{phrase}' ILIKE '%' || short_name || '%' "
            f"LIMIT 5")
        if not rows:
            print(f"(no match for {args.phrase!r})")
            return 1
        print(f"── direct app_install match for {args.phrase!r}")
        for row in rows:
            print(f"  {row.get('short_name')}  [{row.get('source')}] "
                  f"{row.get('app_id') or ''} -- {row.get('label') or ''}")
        return 0
    print(f"── alias match for {args.phrase!r}")
    for row in rows:
        apps = row.get("app") or []
        for app in apps:
            print(f"  {row.get('phrase')!r} -> {app.get('short_name')}  "
                  f"[{app.get('source')}] {app.get('app_id') or ''} "
                  f"-- {app.get('label') or ''}")
    return 0


# ─── apps ──────────────────────────────────────────────────────────
def cmd_apps(args: argparse.Namespace) -> int:
    filt = (args.filter or "").strip().lower().replace("'", "''")
    pgwhere = (f"WHERE short_name ILIKE '%{filt}%' " if filt else "")
    rows = _pg_rows(f"SELECT short_name, source, label FROM app_install "
                    f"{pgwhere}ORDER BY short_name LIMIT 50")
    if not rows:
        print("(no apps)")
        return 0
    for row in rows:
        print(f"  {row.get('short_name'):30}  [{row.get('source'):14}]  "
              f"{row.get('label') or ''}")
    return 0


# ─── who ───────────────────────────────────────────────────────────
def cmd_who(args: argparse.Namespace) -> int:
    rows = _pg_rows("SELECT id, username, hostname, created_at::text "
                    "AS created_at FROM person")
    if not rows:
        print("(no person row -- run `mios-kg bootstrap`)")
        return 1
    for row in rows:
        print(f"  {row.get('id')}  {row.get('username')}@{row.get('hostname')}  "
              f"(since {(row.get('created_at') or '?')[:19]})")
    return 0


# ─── main ──────────────────────────────────────────────────────────
def main() -> int:
    p = argparse.ArgumentParser(prog="mios-kg")
    sub = p.add_subparsers(dest="cmd", required=True)
    p_bs = sub.add_parser("bootstrap",
                          help="Create person + ingest inventory")
    p_bs.add_argument(
        "--source", default="",
        help="Path to NDJSON inventory (default: run mios-apps --json). "
             "Pass `-` to read from stdin. Lets operators pipe in custom "
             "inventories without code edits.",
    )
    sub.add_parser("who",       help="Print person row").set_defaults(func=cmd_who)
    p_apps = sub.add_parser("apps", help="List app_install rows")
    p_apps.add_argument("--filter", default="", help="substring filter")
    p_apps.set_defaults(func=cmd_apps)
    p_lookup = sub.add_parser("lookup", help="Resolve a phrase via the graph")
    p_lookup.add_argument("phrase", help="The phrase to resolve")
    p_lookup.set_defaults(func=cmd_lookup)
    p_alias = sub.add_parser("alias", help="Manage operator aliases")
    asub = p_alias.add_subparsers(dest="alias_cmd", required=True)
    p_add = asub.add_parser("add", help="Add an alias")
    p_add.add_argument("phrase", help="e.g. 'my browser'")
    p_add.add_argument("target", help="e.g. app:chromedev")
    p_add.set_defaults(func=cmd_alias_add)
    p_rm = asub.add_parser("rm", help="Remove an alias")
    p_rm.add_argument("phrase")
    p_rm.set_defaults(func=cmd_alias_rm)
    asub.add_parser("list", help="List all aliases").set_defaults(func=cmd_alias_list)
    args = p.parse_args()
    if args.cmd == "bootstrap":
        return cmd_bootstrap(args)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
