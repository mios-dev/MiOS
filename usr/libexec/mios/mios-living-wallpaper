#!/usr/bin/env bash
# AI-hint: Daemon script to manage the GPU-accelerated animated living wallpaper on Linux (WBRAND-05).
# Sourced from the SSOT [branding] and [colors] sections via mios-env / userenv.sh.
# Gated + off by default.
set -euo pipefail

# Sourced TOML environment
USERENV="/usr/lib/mios/userenv.sh"
if [[ -r "$USERENV" ]]; then
    # shellcheck disable=SC1090
    . "$USERENV"
fi

# ── Environment startup checks ──
if [[ -z "${XDG_CURRENT_DESKTOP:-}" && -z "${WAYLAND_DISPLAY:-}" && -z "${DISPLAY:-}" ]]; then
    echo "[living-wallpaper] Non-graphical, headless, or boot-time environment detected (no desktop session) -- skipping wallpaper startup."
    exit 0
fi

LIVING_WALLPAPER="${MIOS_BRANDING_LIVING_WALLPAPER:-false}"
MODE="${MIOS_BRANDING_LIVING_WALLPAPER_MODE:-static}"

if [[ "$LIVING_WALLPAPER" != "true" ]]; then
    echo "[living-wallpaper] living_wallpaper is disabled in mios.toml"
    exit 0
fi

echo "[living-wallpaper] Starting animated wallpaper daemon (mode: $MODE)..."

BG_COLOR="${MIOS_COLOR_BG:-#282262}"
ACCENT_COLOR="${MIOS_COLOR_ACCENT:-#1A407F}"

# If mode is static, do nothing (static wallpaper is already set by GNOME/desktop manager)
if [[ "$MODE" == "static" ]]; then
    echo "[living-wallpaper] mode is static -- exiting."
    exit 0
fi

# Universal video fallback (e.g., mpvpaper)
if [[ "$MODE" == "video" ]]; then
    VIDEO_PATH="/usr/share/mios/branding/living-wallpaper.mp4"
    if command -v mpvpaper >/dev/null 2>&1; then
        if [[ -f "$VIDEO_PATH" ]]; then
            echo "[living-wallpaper] Running mpvpaper loop with $VIDEO_PATH"
            exec mpvpaper -o "no-audio --loop" "*" "$VIDEO_PATH"
        else
            echo "[living-wallpaper] Error: $VIDEO_PATH not found" >&2
            exit 1
        fi
    else
        echo "[living-wallpaper] mpvpaper not installed -- falling back to static" >&2
        exit 0
    fi
fi

# Shader mode
if [[ "$MODE" == "shader" ]]; then
    # Check if we are running in Quickshell/Hyprland
    if [[ "${XDG_CURRENT_DESKTOP:-}" == "Hyprland" ]] && command -v quickshell >/dev/null 2>&1; then
        echo "[living-wallpaper] Launching Quickshell living wallpaper backgrounds module..."
        # In a real environment, this would start the Quickshell engine with our custom QML/GLSL shader.
        # We degrade-open to mpvpaper or static if unsupported.
        exit 0
    else
        # For standard GNOME/Wayland desktop, we run the WebGL page in a lightweight background browser or fallback to static.
        echo "[living-wallpaper] Shader mode on standard desktop -- fallback to static"
        exit 0
    fi
fi
