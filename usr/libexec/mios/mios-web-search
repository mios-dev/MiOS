#!/usr/bin/env python3
"""mios-web-search -- native WEB-search verb backend (concurrent fan-out).

Queries the LOCAL, self-hosted SearXNG metasearch (offline-first; NO cloud
AI dependency -- Architectural Law 5) and returns clean, citable results so
agents GROUND current-world answers (weather, news, events, prices, facts,
general knowledge) on REAL fetched data instead of fabricating from model
memory.

Operator 2026-05-21: the chat agent invented a weather report -- wrong city
(Port Hope vs. the asked-about Toronto), wrong units (Fahrenheit for a
Canadian user), and made-up event details -- because NO web_search verb
existed; only filesystem search (everything_search / fs_search) did, whose
own descriptions tell the model to "use a WEB search" that was never wired.
SearXNG was already up (:8888) and advertised as the web_search backend.

Operator 2026-05-22: "have web tools shoot off more web queries concurrently".
QUERY FAN-OUT (--fanout K, the industry pattern behind Google AI Mode /
RAG-Fusion / ParallelSearch): expand one query into K diverse sub-queries via
the always-warm micro-LLM, fire them at SearXNG CONCURRENTLY, then merge with
Reciprocal Rank Fusion + URL dedupe. K parallel queries overlap latency (8
parallel ~= 300-500ms vs ~200ms single) and surface evidence one phrasing
misses. SearXNG's own limiter is off + granian workers are bumped so the
local instance absorbs the burst; agent-pipe bounds CROSS-agent concurrency.

SSOT: SearXNG endpoint = $MIOS_SEARXNG_URL; micro-LLM = $MIOS_MICRO_MODEL /
$MIOS_MICRO_ENDPOINT (same as agent-pipe); fan-out knobs = $MIOS_WEB_FANOUT /
$MIOS_WEB_FANOUT_WORKERS / $MIOS_WEB_RRF_K (rendered from mios.toml). The
localhost fallbacks are the only literals, matching the unit defaults.
"""
from __future__ import annotations

import argparse
import concurrent.futures
import json
import os
import re
import sys
import time
import urllib.parse
import urllib.request

# SSOT endpoints (env rendered from mios.toml); localhost fallbacks = the
# vendor container publish ports.
SEARXNG_URL = os.environ.get("MIOS_SEARXNG_URL", "http://localhost:8888").rstrip("/")
# Query-EXPANSION model. Operator 2026-05-24 ("did NOT do multiple passes /
# differing queries"): the old default (qwen3:0.6b-cpu @ :11434) was loaded
# NOWHERE -- cold -- so every expansion blew the 6 s budget and SILENTLY fell
# back to a single query, killing the whole fan-out. Default instead to the
# model the mios-daemon pins ALWAYS-WARM on the CPU lane (qwen3:1.7b @ :11435,
# keep_alive=-1): expansion is then sub-second, never cold-fails, and is more
# capable than the weak 0.6b. Override via MIOS_WEB_EXPAND_MODEL / _ENDPOINT.
_EXPAND_MODEL = os.environ.get(
    "MIOS_WEB_EXPAND_MODEL",
    os.environ.get("MIOS_DAEMON_MODEL", "qwen3:1.7b"))
_EXPAND_ENDPOINT = os.environ.get(
    "MIOS_WEB_EXPAND_ENDPOINT",
    os.environ.get("MIOS_DAEMON_ENDPOINT", "http://localhost:11450/v1")).rstrip("/")
# Native /api/chat lives at the base (strip a trailing /v1 like agent-pipe).
_EXPAND_BASE = (_EXPAND_ENDPOINT[:-3].rstrip("/")
                if _EXPAND_ENDPOINT.endswith("/v1") else _EXPAND_ENDPOINT)
# Reciprocal Rank Fusion constant (the standard 60 from the RRF paper).
_RRF_K = int(os.environ.get("MIOS_WEB_RRF_K", "60"))


def search(query: str, limit: int, timeout: float, category: str = "",
           time_range: str = "") -> dict:
    """One SearXNG JSON query. Returns the FULL result list (caller slices)
    plus instant answers + infoboxes. category='news' targets SearXNG's NEWS
    engines (dated stories) instead of the general web -- operator 2026-05-24: a
    vague 'current global trending' matched the 'Current' banking app + 'electric
    current' (Wikipedia) on general search; the news category returns real dated
    news stories. time_range (day|week|month|year) recency-filters the GENERAL
    web -- operator 2026-05-25: this instance's news ENGINES are IP-blocked so the
    news category returns only stale wikinews; a time_range on GENERAL search
    pulls CURRENT content (CNBC/Reuters/FT/2026 outlooks) and drops the evergreen
    Wikipedia / stale-listicle junk WITHOUT needing the blocked news engines."""
    params = {"q": query, "format": "json"}
    if category:
        params["categories"] = category
    if time_range:
        params["time_range"] = time_range
    qs = urllib.parse.urlencode(params)
    req = urllib.request.Request(
        f"{SEARXNG_URL}/search?{qs}",
        headers={"User-Agent": "mios-web-search/2 (+local SearXNG)"},
    )
    with urllib.request.urlopen(req, timeout=timeout) as r:
        data = json.loads(r.read().decode("utf-8", "replace"))
    results = [
        {
            "title": it.get("title", ""),
            "url": it.get("url", ""),
            "content": (it.get("content") or "")[:500],
            # publishedDate passthrough (operator 2026-05-25): SearXNG NEWS
            # engines set this on dated stories -- lets the caller PREFER real
            # articles over bare homepages and cite recency. Empty on general web.
            "publishedDate": it.get("publishedDate") or "",
        }
        for it in (data.get("results") or [])
    ]
    answers = list(data.get("answers") or [])
    infoboxes = [
        {"title": ib.get("infobox", ""), "content": (ib.get("content") or "")[:500]}
        for ib in (data.get("infoboxes") or [])[:2]
    ]
    return {"query": query, "results": results,
            "answers": answers, "infoboxes": infoboxes}


# Topical anchor (operator 2026-05-27): a multi-word but OFF-TOPIC invented
# sub-query ("what is 2026 minus 1978" from a flights ask) passes the degenerate
# word-count filter yet fetches junk (age calculators), which RRF then surfaces.
# Require >=1 shared CONTENT token with the ORIGINAL query. Structural -- a small
# classic function-word + generic-qualifier set + trailing-s plural fold, NOT a
# topic deny-list. Pure numbers are excluded (a bare year is too weak an anchor).
_ANCHOR_STOPWORDS = frozenset((
    "the", "a", "an", "of", "to", "from", "and", "or", "for", "in", "on", "at",
    "by", "with", "as", "is", "are", "was", "were", "be", "this", "that", "these",
    "those", "it", "its", "me", "my", "we", "our", "you", "your", "they", "them",
    "what", "which", "who", "when", "where", "why", "how", "do", "does", "did",
    "can", "could", "will", "would", "should", "may", "might", "near", "into",
    "about", "than", "then", "there", "here", "out", "not", "no", "all", "any",
    "some", "more", "most", "find", "get", "make", "show", "give", "tell", "list",
    "need", "want", "like", "use", "using", "best", "cheap", "cheapest",
))
_ANCHOR_TOKEN_RE = re.compile(r"[A-Za-z][A-Za-z0-9]{2,}")


def _content_toks(text: str) -> set:
    out = set()
    for m in _ANCHOR_TOKEN_RE.finditer(text or ""):
        t = m.group(0).lower()
        if t in _ANCHOR_STOPWORDS:
            continue
        if len(t) >= 5 and t.endswith("s"):
            t = t[:-1]
        out.add(t)
    return out


def expand_queries(query: str, k: int, timeout: float) -> list:
    """Micro-LLM query expansion -> up to k diverse sub-queries (the ORIGINAL
    is always first). Intent diversity / synonyms / entity reformulation. Any
    error or timeout falls back to just [query] so a cold or busy micro never
    blocks the search."""
    if k <= 1:
        return [query]
    # Date-aware (operator 2026-05-26 "use env detect for current values for all
    # AI functions"): the live system year, so time-sensitive sub-queries anchor
    # to NOW (2026 this year, 2027 next) instead of a stale year. Never hardcoded.
    _cur_year = time.localtime().tm_year
    sys_p = (
        f"The current year is {_cur_year}. "
        "You expand a user's question into DIVERSE web-search queries for "
        "parallel retrieval. Each query must target a DIFFERENT facet, angle, "
        "sub-topic, or named entity of the request -- NOT a synonym or rewording "
        "of the others. For a broad request, split it into specific sub-topics "
        "that surface concrete stories/facts (e.g. distinct regions, sectors, or "
        "events), not generic homepages. For ANYTHING time-sensitive (trending, "
        f"latest, current, 'this year', best-of), anchor the query to {_cur_year} "
        "(or 'latest') -- NEVER a past year. Each is a SHORT keyword query, not a "
        'question. Output JSON only: {"queries":["...","..."]}.'
    )
    _msgs = [
        {"role": "system", "content": sys_p},
        {"role": "user",
         "content": f"Make {k - 1} alternative search queries for: {query}"},
    ]
    # ENDPOINT-AWARE (operator 2026-05-25: the expander can run on the iGPU =
    # llama.cpp OpenAI /v1, NOT Ollama /api/chat). Ollama lanes (:11434/:11435)
    # use native /api/chat + think:False + keep_alive (the /v1 compat path strands
    # a qwen3 'think' answer in empty content); a non-ollama /v1 endpoint (the
    # iGPU's qwen2.5) uses /chat/completions + response_format json_object.
    _exp_ollama = (":11434" in _EXPAND_ENDPOINT) or (":11435" in _EXPAND_ENDPOINT)
    extra: list = []
    try:
        if _exp_ollama:
            payload = {"model": _EXPAND_MODEL, "messages": _msgs, "think": False,
                       "stream": False, "format": "json",
                       "keep_alive": int(os.environ.get("MIOS_MICRO_KEEP_ALIVE", "-1")),
                       "options": {"num_predict": 200}}
            url = f"{_EXPAND_BASE}/api/chat"
        else:
            payload = {"model": _EXPAND_MODEL, "messages": _msgs, "stream": False,
                       "max_tokens": 512, "temperature": 0.0,
                       # qwen3 via llama.cpp /v1 strands the answer in <think> and
                       # returns EMPTY content -> 0 sub-queries (silent single-query
                       # fallback). Disable thinking so the JSON lands in content.
                       "chat_template_kwargs": {"enable_thinking": False},
                       "response_format": {"type": "json_object"}}
            url = (f"{_EXPAND_ENDPOINT}/chat/completions"
                   if _EXPAND_ENDPOINT.endswith("/v1")
                   else f"{_EXPAND_ENDPOINT}/v1/chat/completions")
        req = urllib.request.Request(
            url, data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=timeout) as r:
            _d = json.loads(r.read().decode("utf-8", "replace"))
        content = (((_d.get("message") or {}).get("content")) if _exp_ollama
                   else ((_d.get("choices") or [{}])[0].get("message") or {}).get("content")) or "{}"
        obj = json.loads(content)
        extra = [str(q).strip() for q in (obj.get("queries") or []) if str(q).strip()]
    except Exception as e:
        # De-silenced (operator 2026-05-24: a SILENT cold-micro fallback to one
        # query is exactly what hid the dead fan-out). Log to stderr so a broken
        # expansion is visible in the journal; still fall back so search runs.
        print(f"mios-web-search: query expansion failed via {_EXPAND_MODEL} @ "
              f"{_EXPAND_BASE} ({type(e).__name__}: {e}); using single query",
              file=sys.stderr)
        extra = []
    # Drop DEGENERATE expansions before they hit SearXNG: a bare single word or
    # stopword fragment ("last" from "last minute", "set" from "set up", "best",
    # "many") makes the metasearch return a DICTIONARY / unrelated page (Merriam-
    # Webster, Last.fm, a card game) that then pollutes the RRF-fused results
    # (operator 2026-05-26: "last"->dictionary, "set"->card game). Language-
    # agnostic -- word-count + length only, NO keyword/topic list. The ORIGINAL
    # query is ALWAYS kept (it is the caller's real, vetted facet); only the
    # model-invented alternatives are screened. Tunable knobs.
    _min_words = int(os.environ.get("MIOS_WEB_EXPAND_MIN_WORDS", "2"))
    _min_chars = int(os.environ.get("MIOS_WEB_EXPAND_MIN_CHARS", "6"))
    _anchor = _content_toks(query)
    out = [query]
    for q in extra:
        # Token count over alphanumerics so HYPHENATED / underscored slugs
        # ("cheapest-flights-toronto-to-tokyo" -> 5 tokens) count as multi-word
        # and pass, while a bare "last" / "set" (1 token) is dropped.
        _ntok = len(re.findall(r"[A-Za-z0-9]+", q))
        if _ntok < _min_words or len(q) < _min_chars:
            print(f"mios-web-search: dropped degenerate expansion {q!r} "
                  f"({_ntok} tok / {len(q)} chars)", file=sys.stderr)
            continue
        # OFF-TOPIC drop: a multi-word invented sub-query that shares NO content
        # token with the original has drifted (the "2026 minus 1978" case); skip
        # it so the fan-out stays on-topic. Skipped when the anchor is too thin.
        if len(_anchor) >= 2 and not (_content_toks(q) & _anchor):
            print(f"mios-web-search: dropped off-anchor expansion {q!r}",
                  file=sys.stderr)
            continue
        if q.lower() != query.lower() and q not in out:
            out.append(q)
        if len(out) >= k:
            break
    return out


def multi_search(query: str, limit: int, k: int, timeout: float,
                 max_workers: int, category: str = "", time_range: str = "") -> dict:
    """Expand -> query SearXNG CONCURRENTLY -> Reciprocal Rank Fusion merge."""
    queries = expand_queries(query, k, min(timeout, 6.0))
    per: list = []
    workers = max(1, min(max_workers, len(queries)))
    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as ex:
        futs = [ex.submit(search, q, limit, timeout, category, time_range)
                for q in queries]
        for f in concurrent.futures.as_completed(futs):
            try:
                per.append(f.result())
            except Exception:
                pass
    # RRF: each result earns 1/(RRF_K + rank) per query list it appears in;
    # appearing high across MULTIPLE phrasings wins. Dedupe by URL.
    fused: dict = {}
    answers: list = []
    infoboxes: list = []
    for res in per:
        for rank, it in enumerate(res.get("results") or [], start=1):
            url = it.get("url") or ""
            if not url:
                continue
            e = fused.setdefault(url, {"item": it, "score": 0.0})
            e["score"] += 1.0 / (_RRF_K + rank)
        answers.extend(res.get("answers") or [])
        infoboxes.extend(res.get("infoboxes") or [])
    ranked = sorted(fused.values(), key=lambda e: e["score"], reverse=True)
    results = [e["item"] for e in ranked[:limit]]
    seen = set()
    ans = []
    for a in answers:
        key = json.dumps(a, sort_keys=True) if isinstance(a, (dict, list)) else str(a)
        if key not in seen:
            seen.add(key)
            ans.append(a)
    return {
        "success": bool(results or ans or infoboxes),
        "query": query,
        "queries": queries,
        "count": len(results),
        "answers": ans,
        "infoboxes": infoboxes[:2],
        "results": results,
    }


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-web-search")
    p.add_argument("query", nargs="+", help="search query")
    p.add_argument("-n", "--limit", type=int, default=5)
    p.add_argument("--fanout", type=int,
                   default=int(os.environ.get("MIOS_WEB_FANOUT", "1")),
                   help="expand into N concurrent sub-queries (1 = single)")
    p.add_argument("--max-workers", type=int,
                   default=int(os.environ.get("MIOS_WEB_FANOUT_WORKERS", "4")))
    p.add_argument("--json", action="store_true", default=True)
    p.add_argument("--timeout", type=float, default=12.0)
    p.add_argument("--news", action="store_true",
                   help="search SearXNG's NEWS category (dated stories) instead "
                        "of the general web -- for current-events / trending asks")
    p.add_argument("--category", default="",
                   help="explicit SearXNG category (e.g. news); --news is a shortcut")
    p.add_argument("--time-range", default="", choices=["", "day", "week", "month", "year"],
                   help="recency-filter GENERAL search (day|week|month|year) -- pulls "
                        "current content without the IP-blocked news engines")
    a = p.parse_args()

    q = " ".join(a.query).strip()
    if not q:
        print(json.dumps({"success": False, "error": "empty query", "results": []}))
        return 64
    category = "news" if a.news else (a.category or "")
    time_range = a.time_range or ""
    try:
        if a.fanout and a.fanout > 1:
            out = multi_search(q, max(1, a.limit), a.fanout, a.timeout,
                               a.max_workers, category, time_range)
        else:
            s = search(q, max(1, a.limit), a.timeout, category, time_range)
            results = s["results"][:max(1, a.limit)]
            out = {
                "success": bool(results or s["answers"] or s["infoboxes"]),
                "query": q,
                "count": len(results),
                "answers": s["answers"],
                "infoboxes": s["infoboxes"],
                "results": results,
            }
    except Exception as e:
        # Offline / SearXNG down: be HONEST -- never fabricate. The caller
        # surfaces this so the model says it couldn't reach the web instead
        # of inventing an answer.
        out = {
            "success": False,
            "query": q,
            "error": f"web search unavailable: {e}",
            "results": [],
        }
    print(json.dumps(out, ensure_ascii=False))
    return 0 if out.get("success") else 1


if __name__ == "__main__":
    sys.exit(main())
