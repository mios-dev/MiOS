#!/bin/bash
# AI-hint: Resolves and launches a URL in the MiOS-defined default browser or a specified override by resolving mios.toml entries and dispatching via mios-gui to the operator's WSLg desktop session.
# AI-related: /usr/libexec/mios/mios-open-url, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-gui, mios-find, mios-window-active, mios-as-operator, mios-wsl-flatpak-heal
# AI-functions: _resolve_browser_chain, _parse_summary, _derive_verify_pattern
set -euo pipefail
# /usr/libexec/mios/mios-open-url <url> [<browser-override>]
#
# Open a URL in the MiOS-defined default browser. Operator directive
# 2026-05-16: "WRONG BROWSER!!!! NOT THE GLOBALLY DEFINED LINUX
# DEFAULTS FROM THE USER SPECIFIED mios.toml/html" -- this used to
# hardcode chromedev as the default, which routed URLs through the
# operator's Windows-side default browser via WSL interop instead
# of the MiOS-defined Linux default.
#
# Resolution order for the default browser (high precedence first):
#   1. <browser-override>  if passed as $2 (operator-tunable per-call)
#   2. mios.toml [[desktop.apps]] entry with role="browser" + default=true
#   3. mios.toml [mios-find.aliases].web
#
# Operator directive 2026-05-16: "Should be understood from the
# source that defines all global settings(mios.toml/html)" -- NO
# compiled fallback to a specific app name. If mios.toml defines
# no default browser, this script ERRORS so the operator knows to
# pick one via mios.html. Silent-default-to-some-name is a bug.
#
# The URL is passed through to mios-gui <resolved-default> "$URL"
# which dispatches via flatpak-launch into the operator's WSLg
# session. Window appears on the operator's desktop, NOT in the
# headless Hermes-Agent CDP browser.

set -eu

if [ "$#" -lt 1 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat <<'USAGE'
usage: mios-open-url <url> [<browser-override>]

  <url>               http:// https:// file:// chrome:// about: ...
  <browser-override>  optional: any [[desktop.apps]] entry id OR alias.
                      Without this, the MiOS-defined default browser
                      from mios.toml is used.

Opens the URL in the MiOS-defined default browser. The actual app
is resolved at run time from mios.toml -- operators rename their
default by editing one entry in mios.html / mios.toml.

Forms (every token in <ANGLES> is operator-substituted):
  mios-open-url <url>                   open in MiOS default browser
  mios-open-url <url> <browser-id>      open in a specific browser
USAGE
    [ "$#" -lt 1 ] && exit 64 || exit 0
fi

# ── Native launch args (from the open_url verb schema) + back-compat positional
# <url> [<browser-override>]. mode/private/reuse drive tab-vs-window: the URL is
# opened as a TAB in the ALREADY-RUNNING browser by default (reuse the instance),
# never a new window. NO-HARDCODE: the per-browser flags come from mios.toml. ──
URL=""
OVERRIDE=""
MODE="tab"
PRIVATE=0
REUSE=1
PROFILE=""
while [ "$#" -gt 0 ]; do
    case "$1" in
        --mode)    MODE="${2:-tab}"; shift $(( $# >= 2 ? 2 : 1 )) ;;
        --browser) OVERRIDE="${2:-}"; shift $(( $# >= 2 ? 2 : 1 )) ;;
        --private) case "$(printf '%s' "${2:-true}" | tr '[:upper:]' '[:lower:]')" in false|0|no|off) PRIVATE=0 ;; *) PRIVATE=1 ;; esac; shift $(( $# >= 2 ? 2 : 1 )) ;;
        --reuse)   case "$(printf '%s' "${2:-true}" | tr '[:upper:]' '[:lower:]')" in false|0|no|off) REUSE=0 ;; *) REUSE=1 ;; esac; shift $(( $# >= 2 ? 2 : 1 )) ;;
        --profile) PROFILE="${2:-}"; shift $(( $# >= 2 ? 2 : 1 )) ;;
        --)        shift ;;
        *)         if [ -z "$URL" ]; then URL="$1"; elif [ -z "$OVERRIDE" ]; then OVERRIDE="$1"; fi; shift ;;
    esac
done
[ -n "$URL" ] || { echo "mios-open-url: missing <url>" >&2; exit 64; }
# Effective disposition: private overrides; reuse=false forces a fresh instance.
EFF_MODE="$MODE"
if [ "$PRIVATE" = 1 ]; then EFF_MODE="private"; fi
if [ "$REUSE" = 0 ] && [ "$EFF_MODE" = "tab" ]; then EFF_MODE="new-window"; fi
# A literal "default" / "operator default" / "system" / "none" is NOT a browser
# id -- it means "use the mios.toml-defined Linux default chain". Treating it as
# an app id made mios-gui try to launch a bogus flatpak
# "org.fedoraproject.Platform.CL.default" -> bwrap execvp /bin/sh failure
# (operator 2026-05-27). Normalise these sentinels to empty so the resolved
# Linux-native browser chain is used (Linux apps are always the first default).
case "$(printf '%s' "$OVERRIDE" | tr '[:upper:]' '[:lower:]' | tr -d ' ')" in
    default|operatordefault|systemdefault|system|none) OVERRIDE="" ;;
esac

# Quick sanity: warn (not error) if it doesn't look like a URL.
case "$URL" in
    http://*|https://*|file://*|about:*|chrome://*) : ;;
    *)
        echo "[mios-open-url] WARN: '$URL' doesn't look like a URL; passing as-is" >&2
        ;;
esac

# ─── Resolve the browser FALLBACK CHAIN from mios.toml ──────────────
# SSOT: mios.toml [[desktop.apps]] entries with role="browser". The
# default=true entry leads; the rest follow in declaration order.
# Caller iterates the chain on launch failure -- when Epiphany hits
# the WSLg portal env-fd error (operator-flagged trace 2026-05-18),
# the next browser (ChromeDev, then Windows-side host) gets a shot.
_resolve_browser_chain() {
    if command -v mios-app-type >/dev/null 2>&1; then
        _lead="$(mios-app-type "browser" 2>/dev/null || true)"
        [ -n "$_lead" ] && echo "$_lead"
    fi
    python3 - "$(cd "$(dirname "$0")" && pwd)/../../lib/mios" <<'PYEOF' 2>/dev/null
import sys
sys.path.insert(0, sys.argv[1]); import mios_toml  # the ONE shared layered resolver
chain = []
seen = set()
# MiOS is Linux-native first. Browser chain reads [[desktop.apps]]
# role=browser in declaration order (defaults first). Windows-side
# fallback (cmd.exe /c start) is the LAST resort -- appended only
# at the tail by mios-open-url's runtime loop, NOT prepended.
# Operator binding: "always prefer Linux native apps first."
d = mios_toml.load_merged()
apps = mios_toml.section(d, "desktop").get("apps", [])
if isinstance(apps, list):
    # Pass 1: defaults first (preserve declaration order)
    for entry in apps:
        if not isinstance(entry, dict) or entry.get("role") != "browser":
            continue
        aid = entry.get("id")
        if aid and aid not in seen and entry.get("default"):
            chain.append(aid)
            seen.add(aid)
    # Pass 2: non-defaults
    for entry in apps:
        if not isinstance(entry, dict) or entry.get("role") != "browser":
            continue
        aid = entry.get("id")
        if aid and aid not in seen:
            chain.append(aid)
            seen.add(aid)
# mios-find.aliases.web as tail fallback (legacy operator config)
aliases = mios_toml.section(d, "mios-find").get("aliases", {})
web = aliases.get("web") if isinstance(aliases, dict) else None
if isinstance(web, str) and web and web not in seen:
    chain.append(web)
    seen.add(web)
print("\n".join(chain))
PYEOF
}

# Resolve the native tab/window flag(s) for a browser target + mode from the SSOT
# [browser.*] map. Empty when unknown (degrade-open: the running instance opens a
# tab by default when the binary is invoked with the URL). NO-HARDCODE.
_browser_flag() {
    python3 - "$(cd "$(dirname "$0")" && pwd)/../../lib/mios" "$1" "$2" <<'PYEOF' 2>/dev/null || true
import sys
sys.path.insert(0, sys.argv[1]); import mios_toml  # the ONE shared layered resolver
target = (sys.argv[2] or "").lower()
mode = sys.argv[3] or "tab"
br = mios_toml.section(mios_toml.load_merged(), "browser")
fam_map = br.get("family", {}) or {}
flags = br.get("flags", {}) or {}
fam = ""
for name, subs in fam_map.items():
    if isinstance(subs, list) and any(isinstance(s, str) and s.lower() in target for s in subs):
        fam = name
        break
if fam and isinstance(flags.get(fam), dict):
    print((flags[fam].get(mode) or "").strip())
PYEOF
}

if [ -n "$OVERRIDE" ]; then
    CHAIN="$OVERRIDE"
else
    CHAIN="$(_resolve_browser_chain)"
    if [ -z "$CHAIN" ]; then
        cat >&2 <<ERR
mios-open-url: no browser defined in mios.toml.

Set one by editing mios.html (or directly):
  /usr/share/mios/mios.toml      (vendor; immutable on bootc hosts)
  /etc/mios/mios.toml            (host override)
  ~/.config/mios/mios.toml       (per-user override)

Add at least one:
  [[desktop.apps]]
  id      = "<your-browser-app-id>"
  role    = "browser"
  default = true     # leads the chain
  # Additional role="browser" entries form the fallback chain
  # in declaration order.

After editing, re-run mios-open-url.
ERR
        exit 78    # EX_CONFIG -- configuration error
    fi
fi

set +e   # the verification path catches its own rcs; set -e here
         # would propagate python json-parse failures as exit-1.

_parse_summary() {
    printf '%s' "$1" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    print(d.get('summary', ''))
except Exception:
    print('')
" 2>/dev/null || true
}

_derive_verify_pattern() {
    local target="$1"
    local _pattern_last="$(printf '%s' "$target" | awk -F. "{print tolower(\$NF)}")"
    local _pattern_desktop_name=""
    for _df in "/var/lib/flatpak/exports/share/applications/$target.desktop" \
               "/var/lib/flatpak/app/$target/current/active/files/share/applications/$target.desktop" \
               "/usr/share/applications/$target.desktop"; do
        if [ -r "$_df" ]; then
            _pattern_desktop_name=$(awk -F= '/^Name=/{print tolower($2); exit}' "$_df" 2>/dev/null)
            [ -n "$_pattern_desktop_name" ] && break
        fi
    done
    if [ -n "$_pattern_desktop_name" ] && [ "$_pattern_desktop_name" != "$_pattern_last" ]; then
        printf '%s,%s' "$_pattern_last" "$_pattern_desktop_name"
    else
        printf '%s' "$_pattern_last"
    fi
}

# Iterate the fallback chain. First browser that lands a presented
# window wins. Each attempt: launch -> wait -> verify presented.
# Heal-on-failure once after the FIRST flatpak failure (covers the
# stale portal env-fd / dbus credentials case); subsequent chain
# entries get their own launch attempt without re-healing.
_HEAL_ATTEMPTED=0
_LAST_VERIFY=""
_LAST_SUMMARY=""
_LAST_TARGET=""
_LAST_RC=0
while IFS= read -r TARGET; do
    [ -z "$TARGET" ] && continue
    echo "[mios-open-url] trying browser: $TARGET" >&2
    _verify_pattern="$(_derive_verify_pattern "$TARGET")"
    # Native disposition flag (tab reuses the running instance; SSOT [browser.*]).
    _FLAG="$(_browser_flag "$TARGET" "$EFF_MODE")"

    _already_running=0
    _seg="$(printf '%s' "$TARGET" | sed 's/.*\.//')"
    if [ "$EFF_MODE" = "tab" ]; then
        if pgrep -fi "$TARGET" >/dev/null 2>&1 \
           || { [ -n "$_seg" ] && pgrep -fi "$_seg" >/dev/null 2>&1; }; then
            _already_running=1
        elif command -v mios-windows >/dev/null 2>&1; then
            _win_proc="$(basename "$TARGET" | sed 's/\.exe$//I')"
            if mios-windows ps "Get-Process -Name $_win_proc -ErrorAction SilentlyContinue" >/dev/null 2>&1; then
                _already_running=1
            fi
        fi
    fi

    # ─── Already running CDP browser shortcut ───
    if [ "$_already_running" = "1" ] && { echo "$TARGET" | grep -qiE 'chrome|chromium'; }; then
        # Try local CDP port first if responding
        _cdp_port="${CDP_PORT:-9222}"
        if curl -fsS -m 2 "http://127.0.0.1:${_cdp_port}/json/version" >/dev/null 2>&1; then
            echo "[mios-open-url] browser $TARGET is already running with CDP -> opening tab via CDP" >&2
            if /usr/lib/mios/agents/.venv/bin/python3 - "$_cdp_port" "$URL" <<'PYEOF' 2>/dev/null; then
import sys
import json
import urllib.request
import urllib.parse
import asyncio

async def cdp_create_tab(port, url):
    try:
        req = urllib.request.Request(f"http://127.0.0.1:{port}/json/new?{urllib.parse.quote(url)}", method="PUT")
        with urllib.request.urlopen(req, timeout=5) as r:
            return True
    except Exception:
        pass
    try:
        import websockets
        with urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version", timeout=5) as r:
            version_data = json.loads(r.read().decode())
        ws_url = version_data.get("webSocketDebuggerUrl")
        if not ws_url:
            return False
        async with websockets.connect(ws_url, open_timeout=5) as ws:
            mid = 1
            await ws.send(json.dumps({
                "id": mid,
                "method": "Target.createTarget",
                "params": {"url": url}
            }))
            raw = await asyncio.wait_for(ws.recv(), timeout=5)
            resp = json.loads(raw)
            if resp.get("id") == mid and "result" in resp:
                return True
    except Exception:
        pass
    return False

if __name__ == "__main__":
    port = int(sys.argv[1])
    url = sys.argv[2]
    success = asyncio.run(cdp_create_tab(port, url))
    sys.exit(0 if success else 1)
PYEOF
                printf '%s\n' "{\"success\": true, \"target\": \"$TARGET\", \"url\": \"$URL\", \"summary\": \"tab-opened-cdp\", \"engine\": \"cdp\", \"launch_rc\": 0}"
                exit 0
            fi
        fi
    fi

        if [ "$TARGET" = "cmd.exe" ] || [ "$TARGET" = "explorer.exe" ]; then
            WIN_URL=$(wslpath -w "$URL" 2>/dev/null || echo "$URL")
            # cmd.exe start delegates to the Windows default browser's protocol
            # handler, which reuses the running instance -> opens a TAB already.
            echo "[mios-open-url] trying Windows handler: $TARGET '$WIN_URL'" >&2
            cmd.exe /c start "" "$WIN_URL"
            _launch_rc=$?
            _used_windows_fallback=1
        else
            # shellcheck disable=SC2086  # $_FLAG deliberately word-splits into flag tokens
            mios-gui "$TARGET" $_FLAG "$URL"
            _launch_rc=$?
            _used_windows_fallback=0
            if [ "$_launch_rc" -ne 0 ] && command -v mios-windows >/dev/null 2>&1; then
                echo "[mios-open-url] mios-gui $TARGET failed; trying Windows fallback via mios-windows" >&2
                # shellcheck disable=SC2086
                if mios-windows launch "$TARGET" $_FLAG "$URL" >/dev/null 2>&1; then
                    _launch_rc=0
                    _used_windows_fallback=1
                fi
            fi
        fi

    # Poll the window verifier up to ~15s with progressive delays.
    # WSLg flatpak cold-launches register a Win32 window via the
    # weston RDP rail AFTER bwrap unpack + GTK4 init + Wayland surface
    # bind + RDP frame -- empirically 5-12s on first launch (faster on
    # warm). A single immediate check (the prior implementation)
    # caught only fast launches; slow ones reported "no-window" while
    # the window actually rendered seconds later. Operator-flagged
    # 2026-05-19: "in the end it DID actually open it in ChromeDev"
    # despite mios-open-url declaring EXHAUSTED chain.
    _summary=""
    _verify=""
    if [ "$_already_running" = "0" ]; then
        for _delay in 1 2 3 4 5; do
            _verify=$(mios-window-active --present "$_verify_pattern" 2>/dev/null)
            _summary=$(_parse_summary "$_verify")
            if [ "$_summary" = "presented" ]; then
                break
            fi
            sleep "$_delay"
        done
        _LAST_VERIFY="$_verify"
        _LAST_SUMMARY="$_summary"
    fi
    _LAST_TARGET="$TARGET"
    _LAST_RC="$_launch_rc"

    if [ "$_summary" = "presented" ]; then
        echo "$_verify"
        echo "[mios-open-url] OK target=$TARGET pattern=$_verify_pattern" >&2
        exit 0
    fi

    echo "[mios-open-url] $TARGET summary=${_summary:-<empty>} launch_rc=$_launch_rc" >&2

    # PID-PROBE verification (operator 2026-05-30: "just probe PIDs for verifying
    # success"). WSLg windows are NOT enumerable here (no wmctrl/xdotool), so the
    # mios-window-active check above false-fails even when the browser opened. So
    # confirm the flatpak's PROCESS is RUNNING instead -- a live instance means the
    # app launched on the WSLg desktop. Linux is the DEFAULT; fall through to the
    # next browser / Windows last-resort only when NOTHING is running.
    _proc_ok=0
    if [ "$TARGET" = "cmd.exe" ] || [ "$TARGET" = "explorer.exe" ] || [ "${_used_windows_fallback:-0}" = "1" ]; then
        _proc_ok=1
    else
        # PID probe against the GLOBAL process table. The flatpak runs as the
        # operator (uid != agent uid), so neither `flatpak ps` (per-user) nor
        # `mios-as-operator flatpak ps` (a fire-and-forget LAUNCHER that returns
        # NO stdout -- it dispatches detached) can see it. But /proc is global,
        # so pgrep finds the operator's process from any agent context. Match
        # the full app-id (present in the bwrap'd flatpak app path) then the
        # trailing segment / binary name as a looser fallback. Backoff loop
        # because GTK4 apps take a moment to fork the real process in.
        for _pp in 1 2 3 4; do
            if pgrep -fi "$TARGET" >/dev/null 2>&1 \
               || { [ -n "$_seg" ] && pgrep -fi "$_seg" >/dev/null 2>&1; }; then
                _proc_ok=1; break
            fi
            sleep "$_pp"
        done
    fi

    # If the browser was already running, and we opened a tab, we don't expect a new window to open.
    # So if the process is still alive and mios-gui succeeded (rc=0) or returned unconfirmed (rc=3),
    # we treat it as success immediately.
    if [ "$_already_running" = "1" ] && { [ "$_launch_rc" = "0" ] || [ "$_launch_rc" = "3" ]; } && [ "$_proc_ok" = "1" ]; then
        if [ "${_used_windows_fallback:-0}" = "1" ]; then
            printf '%s\n' "{\"success\": true, \"target\": \"$TARGET\", \"url\": \"$URL\", \"summary\": \"tab-opened-existing\", \"engine\": \"windows-host\", \"verified_by\": \"already-running\", \"launch_rc\": $_launch_rc}"
            echo "[mios-open-url] $TARGET was already running on Windows -> tab opened in existing instance" >&2
        else
            printf '%s\n' "{\"success\": true, \"target\": \"$TARGET\", \"url\": \"$URL\", \"summary\": \"tab-opened-existing\", \"engine\": \"linux-flatpak\", \"verified_by\": \"already-running\", \"launch_rc\": $_launch_rc}"
            echo "[mios-open-url] $TARGET was already running -> tab opened in existing instance" >&2
        fi
        exit 0
    fi

    if [ "$_launch_rc" = "0" ] && [ "$_proc_ok" = "1" ]; then
        if [ "${_used_windows_fallback:-0}" = "1" ]; then
            printf '%s\n' "{\"success\": true, \"target\": \"$TARGET\", \"url\": \"$URL\", \"summary\": \"running\", \"engine\": \"windows-host\", \"verified_by\": \"windows-launch\", \"launch_rc\": 0}"
            echo "[mios-open-url] $TARGET launched on Windows host via mios-windows" >&2
        else
            printf '%s\n' "{\"success\": true, \"target\": \"$TARGET\", \"url\": \"$URL\", \"summary\": \"running\", \"engine\": \"linux-flatpak\", \"verified_by\": \"pid-probe\", \"launch_rc\": 0}"
            echo "[mios-open-url] $TARGET launched -> process verified running via PID probe (engine=linux-flatpak, Linux default); window surfacing is confirmed separately by the agent-pipe window-diff" >&2
        fi
        exit 0
    fi

    # First-failure heal: when launch_rc != 0 (sandbox bootstrap
    # broke), restart the user-side portal stack ONCE before
    # continuing the chain. Subsequent attempts on different
    # browsers don't re-heal (one heal per turn).
    if [ "$_HEAL_ATTEMPTED" = "0" ] \
       && [ "$_launch_rc" -ne 0 ] \
       && command -v mios-wsl-flatpak-heal >/dev/null 2>&1; then
        echo "[mios-open-url] launch_rc=$_launch_rc; running wsl-flatpak-heal" >&2
        if [ -n "${SUDO_USER:-}" ] && [ "$(id -un)" != "$SUDO_USER" ]; then
            su - "$SUDO_USER" -c "mios-wsl-flatpak-heal" >/dev/null 2>&1 || true
        else
            mios-wsl-flatpak-heal >/dev/null 2>&1 || true
        fi
        _HEAL_ATTEMPTED=1
        # Re-try the SAME browser one more time after heal before
        # moving down the chain (give the heal a chance on the
        # operator's preferred default).
        # shellcheck disable=SC2086
        mios-gui "$TARGET" $_FLAG "$URL" >/dev/null 2>&1
        _verify=$(mios-window-active --present "$_verify_pattern" 2>/dev/null)
        _summary=$(_parse_summary "$_verify")
        if [ "$_summary" = "presented" ]; then
            echo "$_verify"
            echo "[mios-open-url] OK after heal target=$TARGET" >&2
            exit 0
        fi
        _LAST_VERIFY="$_verify"
        _LAST_SUMMARY="$_summary"
    fi
done <<EOF
$CHAIN
EOF

# Chain exhausted with no winner.
echo "$_LAST_VERIFY"
echo "[mios-open-url] EXHAUSTED chain; last=$_LAST_TARGET summary=${_LAST_SUMMARY:-<empty>} launch_rc=$_LAST_RC" >&2
exit 2
