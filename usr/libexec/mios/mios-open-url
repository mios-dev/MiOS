#!/bin/bash
# /usr/libexec/mios/mios-open-url <url> [<browser-override>]
#
# Open a URL in the MiOS-defined default browser. Operator directive
# 2026-05-16: "WRONG BROWSER!!!! NOT THE GLOBALLY DEFINED LINUX
# DEFAULTS FROM THE USER SPECIFIED mios.toml/html" -- this used to
# hardcode chromedev as the default, which routed URLs through the
# operator's Windows-side default browser via WSL interop instead
# of the MiOS-defined Linux default.
#
# Resolution order for the default browser (high precedence first):
#   1. <browser-override>  if passed as $2 (operator-tunable per-call)
#   2. mios.toml [[desktop.apps]] entry with role="browser" + default=true
#   3. mios.toml [mios-find.aliases].web
#
# Operator directive 2026-05-16: "Should be understood from the
# source that defines all global settings(mios.toml/html)" -- NO
# compiled fallback to a specific app name. If mios.toml defines
# no default browser, this script ERRORS so the operator knows to
# pick one via mios.html. Silent-default-to-some-name is a bug.
#
# The URL is passed through to mios-gui <resolved-default> "$URL"
# which dispatches via flatpak-launch into the operator's WSLg
# session. Window appears on the operator's desktop, NOT in the
# headless Hermes-Agent CDP browser.

set -eu

if [ "$#" -lt 1 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat <<'USAGE'
usage: mios-open-url <url> [<browser-override>]

  <url>               http:// https:// file:// chrome:// about: ...
  <browser-override>  optional: any [[desktop.apps]] entry id OR alias.
                      Without this, the MiOS-defined default browser
                      from mios.toml is used.

Opens the URL in the MiOS-defined default browser. The actual app
is resolved at run time from mios.toml -- operators rename their
default by editing one entry in mios.html / mios.toml.

Forms (every token in <ANGLES> is operator-substituted):
  mios-open-url <url>                   open in MiOS default browser
  mios-open-url <url> <browser-id>      open in a specific browser
USAGE
    [ "$#" -lt 1 ] && exit 64 || exit 0
fi

URL="$1"
OVERRIDE="${2:-}"

# Quick sanity: warn (not error) if it doesn't look like a URL.
case "$URL" in
    http://*|https://*|file://*|about:*|chrome://*) : ;;
    *)
        echo "[mios-open-url] WARN: '$URL' doesn't look like a URL; passing as-is" >&2
        ;;
esac

# ─── Resolve the default browser from mios.toml ─────────────────────
# Operator directive: the SoT is mios.toml. Read it.
_resolve_default_browser() {
    python3 - <<'PYEOF' 2>/dev/null
import tomllib
for path in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(path, "rb") as f:
            d = tomllib.load(f)
    except (OSError, tomllib.TOMLDecodeError):
        continue
    # Source 1: [[desktop.apps]] entry with role="browser" + default=true
    apps = d.get("desktop", {}).get("apps", [])
    if isinstance(apps, list):
        for entry in apps:
            if isinstance(entry, dict) and entry.get("role") == "browser" and entry.get("default"):
                aid = entry.get("id")
                if aid:
                    print(aid)
                    raise SystemExit(0)
    # Source 2: [mios-find.aliases].web
    aliases = d.get("mios-find", {}).get("aliases", {})
    web = aliases.get("web") if isinstance(aliases, dict) else None
    if isinstance(web, str) and web:
        print(web)
        raise SystemExit(0)
# No source defines a default browser; print nothing -> caller errors.
PYEOF
}

if [ -n "$OVERRIDE" ]; then
    TARGET="$OVERRIDE"
else
    TARGET="$(_resolve_default_browser)"
    if [ -z "$TARGET" ]; then
        cat >&2 <<ERR
mios-open-url: no default browser defined in mios.toml.

Set one by editing mios.html (or directly):
  /usr/share/mios/mios.toml      (vendor; immutable on bootc hosts)
  /etc/mios/mios.toml            (host override)
  ~/.config/mios/mios.toml       (per-user override)

Either of:
  [[desktop.apps]]
  id      = "<your-browser-app-id>"
  role    = "browser"
  default = true

OR:
  [mios-find.aliases]
  web = "<your-browser-app-id>"

After editing, re-run mios-open-url.
ERR
        exit 78    # EX_CONFIG -- configuration error
    fi
fi

# Dispatch via mios-gui (which handles flatpak / RPM / shim
# resolution + operator-session escape). Capture the launch result
# instead of exec'ing so we can VERIFY the window appeared.
#
# Operator directive 2026-05-16: "MiOS-Hermes should reason
# natively until it's confirmed it's provided the solutions/end
# result". Process-alive (mios-gui's pgrep check) is insufficient
# -- the agent has repeatedly claimed "Browser opened to URL" when
# nothing visible appeared. Tooling-side verification + auto-retry
# makes the success/failure signal land in the AGENT'S TOOL OUTPUT,
# not in its self-reported text.
set +e   # the verification path catches its own rcs; set -e here
         # would propagate python json-parse failures as exit-1 and
         # mask the real "summary=X" failure signal.

mios-gui "$TARGET" "$URL"
_launch_rc=$?

# Derive MULTIPLE verifier patterns from the app id + its .desktop
# Name= field. WSLg-hosted Linux app windows show the .desktop Name=
# in MainWindowTitle (Epiphany's Name= is "Web", not "Epiphany"), so
# a single-word pattern misses the window every time. Pass a CSV of
# patterns; mios-window-active tries each.
# Operator-flagged 2026-05-16: mios-window-active returned no-window
# for Epiphany even when window was visibly open; root cause = title
# match miss because pattern was "epiphany" but title was "Welcome to Web".
_pattern_last="$(printf '%s' "$TARGET" | awk -F. "{print tolower(\$NF)}")"
_pattern_desktop_name=""
for _df in "/var/lib/flatpak/exports/share/applications/$TARGET.desktop" \
           "/var/lib/flatpak/app/$TARGET/current/active/files/share/applications/$TARGET.desktop" \
           "/usr/share/applications/$TARGET.desktop"; do
    if [ -r "$_df" ]; then
        _pattern_desktop_name=$(awk -F= '/^Name=/{print tolower($2); exit}' "$_df" 2>/dev/null)
        [ -n "$_pattern_desktop_name" ] && break
    fi
done
# CSV pattern list (mios-window-active iterates them, first match wins).
if [ -n "$_pattern_desktop_name" ] && [ "$_pattern_desktop_name" != "$_pattern_last" ]; then
    _verify_pattern="$_pattern_last,$_pattern_desktop_name"
else
    _verify_pattern="$_pattern_last"
fi

_parse_summary() {
    printf '%s' "$1" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    print(d.get('summary', ''))
except Exception:
    print('')
" 2>/dev/null || true
}

# First-pass verification: --present mode also restores/foregrounds
# a minimized window before re-measuring, so summary is either
# "presented" or a genuine non-recoverable state.
_verify1=$(mios-window-active --present "$_verify_pattern" 2>/dev/null)
_summary1=$(_parse_summary "$_verify1")

if [ "$_summary1" = "presented" ]; then
    echo "$_verify1"
    exit 0
fi

# Not presented after launch+present. ONE auto-retry: launch again
# (some flatpaks race-condition on first call after long idle).
echo "[mios-open-url] first attempt summary=${_summary1:-<empty>}; retrying once..." >&2
sleep 1
mios-gui "$TARGET" "$URL" >/dev/null 2>&1 || true
sleep 2
_verify2=$(mios-window-active --present "$_verify_pattern" 2>/dev/null)
_summary2=$(_parse_summary "$_verify2")

echo "$_verify2"
echo "[mios-open-url] FINAL summary=${_summary2:-<empty>} launch_rc=$_launch_rc target=$TARGET pattern=$_verify_pattern" >&2

if [ "$_summary2" = "presented" ]; then
    exit 0
fi

# Still not presented -> exit non-zero so the agent's terminal tool
# sees a failure signal it can't paraphrase as success. Operator
# directive ("reason natively until confirmed") -- the agent now
# has to act on the actual failure mode (summary tells it which:
# not-running / no-window / hidden / off-screen).
exit 2
