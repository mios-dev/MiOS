#!/usr/bin/env python3
# AI-hint: Provides a shared, persistent snapshot of hardware, services, and app inventory in pgvector, allowing agents to query current system state via the `sys_env` table instead of performing live probes.
# AI-related: /usr/libexec/mios/mios-sys-env, mios-daemon, mios-os-control, mios-env-probe, mios-apps, mios-shim, localhost:8000
"""/usr/libexec/mios/mios-sys-env <refresh|get|help> [--json]

Live system/environment probe persisted to pgvector so EVERY agent reads a
fast, always-current snapshot from the shared DB -- the same cache pattern
mios-daemon uses for directory_entry.

Operator 2026-05-23: "mios-os-control should fetch live system apps from a
tool/skill for probing systems/environment live and storing+updating a
mios-sys-env database; ALL agents share global read+write access (via verbs)".

What it stores (single row `sys_env:current`, in sys_env table):
  env   -- the full `mios-env-probe --json` envelope (identity, host HW, stack
           services up/down, loaded ollama models, launchable-app counts).
  apps  -- live launchable inventory, names per category (mios-apps --names
           --category <cat>), capped -- "the live system apps".
  indexed_at / host / source -- provenance.

Subcommands:
  refresh [--json]   WRITE: probe live + upsert sys_env:current. Any agent can
                     call this to UPDATE the shared env DB (sys_env_refresh verb).
  get [--json] [--full]
                     READ: return sys_env:current. COMPACT by default (env +
                     per-category app counts + a small sample) so it stays
                     parseable under the broker's ~6 KB stdout cap; --full emits
                     the complete inventory (CLI/dashboard). If the row is
                     missing, falls back to a live (non-persisted) probe so the
                     read is always useful (sys_env verb).
  help

SSOT: DB endpoint + creds from MIOS_DB_* env (identical to mios-daemon); the
app categories come from mios-apps. No hardcoded literals.
"""
from __future__ import annotations

import datetime
import json
import os
import subprocess
import sys

# ── pgvector store (FOSS-pure replacement for the retired SurrealDB agent DB).
# The singleton lives in the shared `sys_env` table (schema-init.sql): one row
# id='current', the whole envelope under the `data` jsonb column. Reached via
# the pure-python mios-pg-query client -- the same pattern mios-rag uses. ─────
PG_QUERY = os.environ.get("MIOS_PG_QUERY_BIN",
                          "/usr/libexec/mios/mios-pg-query")
TABLE = os.environ.get("MIOS_SYS_ENV_TABLE", "sys_env")
# Fixed singleton key (was the SurrealDB record id `sys_env:current`).
RECORD = "current"
# Per-category cap so a huge host can't bloat the stored row.
APPS_CAP = int(os.environ.get("MIOS_SYS_ENV_APPS_CAP", "300"))
# Per-category sample size for the COMPACT `get` envelope (the agent-facing
# read). The dispatch broker truncates a verb's stdout at ~6 KB, which would
# corrupt a larger JSON mid-string; the full inventory lives in the DB row +
# `get --full`, while agents read counts + a small sample (and use app_search /
# mios_apps to resolve a specific app). Keeps the read parseable + lean.
APPS_SAMPLE = int(os.environ.get("MIOS_SYS_ENV_SAMPLE", "15"))
# Categories mirror mios-env-probe's launchable inventory (kept in sync with
# mios-apps' own category set; passed straight through, no semantic hardcode).
APP_CATEGORIES = (os.environ.get("MIOS_SYS_ENV_APP_CATEGORIES", "")
                  or "linux-flatpak,linux-rpm-gui,windows-gui,windows-app,"
                     "mios-shim,agent-cli,service-url").split(",")


def _pg(sql: str, timeout: float = 30.0) -> list | None:
    """Run one SQL statement on pgvector via mios-pg-query (pure-python pg wire
    client -- no psql/psycopg/podman). Returns rows as lists of string columns
    (psql -At: tab-separated, newline rows), or None on error."""
    try:
        p = subprocess.run([PG_QUERY, sql], capture_output=True, text=True,
                           timeout=timeout)
        if p.returncode != 0:
            sys.stderr.write(
                f"mios-sys-env: db error: {(p.stderr or '').strip()[:200]}\n")
            return None
        return [ln.split("\t") for ln in p.stdout.splitlines() if ln]
    except Exception as e:
        sys.stderr.write(f"mios-sys-env: db error: {e}\n")
        return None


def _run_json(cmd: list[str], timeout: float = 20.0):
    try:
        out = subprocess.run(cmd, capture_output=True, text=True,
                             timeout=timeout).stdout
        return json.loads(out) if out.strip() else None
    except Exception:
        return None


def _run_lines(cmd: list[str], timeout: float = 20.0) -> list[str]:
    try:
        out = subprocess.run(cmd, capture_output=True, text=True,
                             timeout=timeout).stdout
        return [ln.strip() for ln in out.splitlines() if ln.strip()]
    except Exception:
        return []


def _probe() -> dict:
    """Gather the live environment: the env-probe envelope + the launchable
    app inventory (names per category, capped)."""
    env = _run_json(["mios-env-probe", "--json"]) or {}
    apps: dict[str, list[str]] = {}
    for cat in APP_CATEGORIES:
        cat = cat.strip()
        if not cat:
            continue
        names = _run_lines(["mios-apps", "--names", "--category", cat])
        if names:
            apps[cat] = names[:APPS_CAP]
    return {"env": env, "apps": apps}


def _now() -> str:
    return datetime.datetime.now(datetime.timezone.utc).isoformat()


def cmd_refresh(json_out: bool) -> int:
    payload = _probe()
    host = (((payload.get("env") or {}).get("identity") or {})
            .get("hostname_live") or "")
    now = _now()
    row = {
        "env": payload["env"], "apps": payload["apps"],
        "host": host, "source": "mios-sys-env", "indexed_at": now,
    }
    # Single ATOMIC upsert of the fixed singleton key. ON CONFLICT (vs
    # DELETE+INSERT) is race-safe when the refresh timer and an agent's
    # sys_env_refresh fire concurrently -- last-write-wins, O(1), one row, no
    # history bloat. The envelope is json.dumps'd into a jsonb literal; quotes
    # are doubled ('' ) so app names/paths can't break out (no injection).
    data = json.dumps(row, default=str).replace("'", "''")
    rid = RECORD.replace("'", "''")
    res = _pg(
        f"INSERT INTO {TABLE} (id, data, ts) "
        f"VALUES ('{rid}', '{data}'::jsonb, now()) "
        f"ON CONFLICT (id) DO UPDATE "
        f"SET data = EXCLUDED.data, ts = EXCLUDED.ts;")
    ok = res is not None
    n_apps = sum(len(v) for v in payload["apps"].values())
    env_keys = list((payload.get("env") or {}).keys())
    envelope = {
        "ok": bool(ok),
        "verb": "sys_env_refresh",
        "record": RECORD,
        "indexed_at": now,
        "host": host,
        "app_count": n_apps,
        "app_categories": {k: len(v) for k, v in payload["apps"].items()},
        "env_sections": env_keys,
    }
    if not ok:
        envelope["error"] = "pgvector upsert failed (see stderr)"
    print(json.dumps(envelope, indent=None if json_out else 2))
    return 0 if ok else 1


def _read_current() -> dict | None:
    # The whole envelope is stored under the `data` jsonb column of the
    # singleton row; unwrap it back to a top-level dict (env/apps/host/...)
    # so _compact / cmd_get see the same shape the database row had.
    rid = RECORD.replace("'", "''")
    rows = _pg(f"SELECT data FROM {TABLE} WHERE id = '{rid}';")
    if not rows:
        return None
    raw = rows[0][0] if rows[0] else ""
    if not raw:
        return None
    try:
        obj = json.loads(raw)
    except (ValueError, TypeError):
        return None
    return obj if isinstance(obj, dict) else None


def _compact(payload: dict, full: bool) -> dict:
    """Trim the per-category apps lists to COUNTS + a small sample so the
    agent-facing envelope stays parseable under the dispatch ~6 KB stdout cap.
    `full` keeps everything (CLI / dashboard use, where the cap doesn't apply)."""
    apps = payload.get("apps")
    if full or not isinstance(apps, dict):
        return payload
    out = dict(payload)
    out["app_counts"] = {k: len(v) for k, v in apps.items()}
    out["apps"] = {k: v[:APPS_SAMPLE] for k, v in apps.items()}
    out["apps_note"] = (
        f"sampled {APPS_SAMPLE}/category (full totals in app_counts); call "
        f"app_search or mios_apps to resolve a specific app, or "
        f"`mios-sys-env get --full` for the complete inventory")
    return out


def cmd_get(json_out: bool, full: bool) -> int:
    row = _read_current()
    if row:
        out = {"ok": True, "verb": "sys_env", "source": "db",
               **_compact(row, full)}
        print(json.dumps(out, indent=None if json_out else 2, default=str))
        return 0
    # Row missing (e.g. first boot, before the timer/refresh ran): live
    # fallback so a READ is never empty. NOT persisted -- get stays read-only;
    # sys_env_refresh / the timer own the write.
    live = _probe()
    out = {"ok": True, "verb": "sys_env", "source": "live-fallback",
           "indexed_at": _now(),
           "note": "sys_env:current not yet persisted; call sys_env_refresh",
           **_compact(live, full)}
    print(json.dumps(out, indent=None if json_out else 2, default=str))
    return 0


def main() -> int:
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(__doc__)
        return 0
    sub = argv[0]
    flags = argv[1:]
    json_out = "--json" in flags
    full = "--full" in flags
    if sub == "refresh":
        return cmd_refresh(json_out)
    if sub == "get":
        return cmd_get(json_out, full)
    sys.stderr.write(f"mios-sys-env: unknown subcommand {sub!r} "
                     f"(try: refresh, get, help)\n")
    return 2


if __name__ == "__main__":
    sys.exit(main())
