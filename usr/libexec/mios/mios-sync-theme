#!/usr/bin/env bash
# AI-hint: Regenerates the /etc/mios/theme/ bridge (theme.json + mios-theme.css)
# from mios.toml [colors] + [theme] + [theme.font] -- the SAME three-layer
# vendor/host/user overlay tools/lib/userenv.sh already resolves for shell
# consumers. This is the CSS/QML-facing sibling of the existing
# /etc/mios/install.env bridge: one command, one regenerated artifact, so a
# palette edit in mios.toml reaches the Portal, the Configurator, the
# Quickshell panel, and (via automation/56-bake-surfer.sh /
# automation/54-bake-hyprland.sh at build time) the browser shell and
# compositor borders, without hand-editing hex codes in five different files.
# AI-related: usr/share/mios/mios.toml, usr/share/mios/quickshell/Theme.qml,
# usr/share/mios/branding/mios-app-shell.css, tools/lib/userenv.sh,
# usr/lib/tmpfiles.d/mios-theme.conf, usr/lib/systemd/system/mios-sync-theme.service
#
# Usage: mios-sync-theme            # regenerate from the resolved TOML layers
#        mios-sync-theme --check    # print what would be written, don't write
#
# Same layering as userenv.sh: /usr/share/mios/mios.toml (vendor, lowest)
# < /etc/mios/mios.toml (host) < ~/.config/mios/mios.toml (user, highest).
set -euo pipefail

MIOS_VENDOR_TOML="${MIOS_VENDOR_TOML:-/usr/share/mios/mios.toml}"
MIOS_HOST_TOML="${MIOS_HOST_TOML:-/etc/mios/mios.toml}"
MIOS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/mios"
MIOS_USER_TOML="${MIOS_USER_TOML:-${MIOS_CONFIG_DIR}/mios.toml}"

OUT_DIR="${MIOS_THEME_OUT_DIR:-/etc/mios/theme}"
CHECK_ONLY=0
[[ "${1:-}" == "--check" ]] && CHECK_ONLY=1

command -v python3 >/dev/null 2>&1 || {
    echo "[mios-sync-theme] python3 not found -- cannot resolve mios.toml, aborting" >&2
    exit 1
}

MIOS_LAYERS="${MIOS_VENDOR_TOML} ${MIOS_HOST_TOML} ${MIOS_USER_TOML}" \
MIOS_THEME_OUT_DIR="${OUT_DIR}" \
MIOS_THEME_CHECK="${CHECK_ONLY}" \
python3 - <<'PY'
import json
import os
import sys

try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        sys.stderr.write("[mios-sync-theme] no TOML reader available (need py3.11+ tomllib or tomli) -- aborting\n")
        sys.exit(1)

layers = os.environ["MIOS_LAYERS"].split()
out_dir = os.environ["MIOS_THEME_OUT_DIR"]
check_only = os.environ.get("MIOS_THEME_CHECK") == "1"


def deep_merge(dst, src):
    for k, v in src.items():
        if isinstance(v, dict) and isinstance(dst.get(k), dict):
            deep_merge(dst[k], v)
        else:
            dst[k] = v


merged = {}
for path in layers:
    if not path or not os.path.isfile(path):
        continue
    try:
        with open(path, "rb") as f:
            deep_merge(merged, tomllib.load(f))
    except Exception as e:
        sys.stderr.write(f"[mios-sync-theme] failed to parse {path}: {e}\n")

colors = merged.get("colors", {})
theme = merged.get("theme", {})
font = theme.get("font", {})

# Vendor defaults (mirrors mios.toml [colors] verbatim) so this script still
# produces a usable bridge even if every TOML layer is unreadable -- the
# SAME degrade-open posture Theme.qml's fallback properties use.
DEFAULTS = {
    "bg": "#282262", "fg": "#E7DFD3", "accent": "#1A407F", "cursor": "#F35C15",
    "success": "#3E7765", "warning": "#F35C15", "error": "#DC271B",
    "info": "#1A407F", "muted": "#948E8E", "subtle": "#B7C9D7",
    "earth": "#734F39", "silver": "#E0E0E0",
}

resolved = {k: colors.get(k, v) for k, v in DEFAULTS.items()}
resolved["font_family"] = font.get("family", "GeistMono Nerd Font Mono")
resolved["font_size"] = font.get("size", 12)
# [theme] acrylic/opacity/scrollbar_state are the operator's standing
# "frameless / borderless / 50% acrylic" directive (mios.toml [theme],
# originally a Windows Terminal setting) -- carried here so the web/QML
# surfaces can honor the SAME frosted-glass intent instead of inventing a
# separate opacity value.
resolved["acrylic"] = bool(theme.get("acrylic", True))
resolved["opacity_pct"] = int(theme.get("opacity", 50))
resolved["radius_px"] = 10  # matches usr/share/mios/hyprland/hyprland.conf decoration.rounding

os.makedirs(out_dir, exist_ok=True)

theme_json_path = os.path.join(out_dir, "theme.json")
css_path = os.path.join(out_dir, "mios-theme.css")

theme_json = json.dumps(resolved, indent=2, sort_keys=True) + "\n"

css_lines = [
    "/* GENERATED by usr/libexec/mios/mios-sync-theme -- do not hand-edit.",
    " * Source of truth: mios.toml [colors] / [theme] / [theme.font].",
    " * Re-run mios-sync-theme after editing mios.toml to refresh this file. */",
    ":root {",
    f'  --mios-bg: {resolved["bg"]};',
    f'  --mios-fg: {resolved["fg"]};',
    f'  --mios-accent: {resolved["accent"]};',
    f'  --mios-cursor: {resolved["cursor"]};',
    f'  --mios-success: {resolved["success"]};',
    f'  --mios-warning: {resolved["warning"]};',
    f'  --mios-error: {resolved["error"]};',
    f'  --mios-info: {resolved["info"]};',
    f'  --mios-muted: {resolved["muted"]};',
    f'  --mios-subtle: {resolved["subtle"]};',
    f'  --mios-earth: {resolved["earth"]};',
    f'  --mios-silver: {resolved["silver"]};',
    f'  --mios-font-family: \'{resolved["font_family"]}\', \'Geist Mono\', ui-monospace, monospace;',
    f'  --mios-font-size: {resolved["font_size"]}px;',
    f'  --mios-radius: {resolved["radius_px"]}px;',
    f'  --mios-opacity: {resolved["opacity_pct"] / 100};',
    "  --mios-border-thin: 1px solid var(--mios-subtle);",
    "}",
    "",
]
css_text = "\n".join(css_lines)

if check_only:
    print(f"-- would write {theme_json_path} --")
    print(theme_json)
    print(f"-- would write {css_path} --")
    print(css_text)
    sys.exit(0)

with open(theme_json_path, "w") as f:
    f.write(theme_json)
with open(css_path, "w") as f:
    f.write(css_text)

print(f"[mios-sync-theme] wrote {theme_json_path} + {css_path}")
PY
