#!/bin/bash
# /usr/libexec/mios/mios-owui-install-pipe
#
# Install the MiOS-Agent OWUI Pipe Function into the running OWUI.
# Auto-generates an admin API key (stashed in webui.db's api_key
# table) if none exists, then POSTs the pipe to the functions API.
# Idempotent: re-running updates the function content if changed.
#
# Operator directive 2026-05-16: "OWUI's MiOS-Agent is the 'model'
# that users speak to" / "OWUI should emit all global agents
# printing/answers/etc". This script makes the vendored pipe at
# /usr/share/mios/owui/pipes/mios_agent_pipe.py available in OWUIs
# model dropdown without the operator having to paste it manually.

set -eu

PIPE_SRC=/usr/share/mios/owui/pipes/mios_agent_pipe.py
PIPE_ID="mios_agent"
# User-facing display name shown in OWUI's model dropdown + chat
# header. Operator preference 2026-05-18: shorter, more consumer-
# y ("MiOS AI" not "MiOS-Agent"). The PIPE_ID below stays
# "mios_agent" for backwards compatibility (the id is the stable
# row key in webui.db's function table; renaming it would orphan
# existing chats that reference the old model id).
PIPE_NAME="MiOS AI"
FILTER_SRC=/usr/share/mios/owui/pipes/mios_antimeta_filter.py
FILTER_ID="mios_antimeta"
FILTER_NAME="MiOS Anti-Meta Filter"
# Sidecar filter id, retained ONLY so the disable block below can
# target the row in webui.db when a previous install enabled it.
# agent-pipe is the canonical orchestrator now; it surfaces its own
# SSE status events and the sidecar's hermes-tail polling + post-
# call response-replacement was actively destructive on chat turns.
SIDECAR_ID="mios_sidecar"
OWUI_URL="${MIOS_OWUI_URL:-http://localhost:3030}"
OWUI_DB="${MIOS_OWUI_DB:-/var/lib/mios/open-webui/webui.db}"

[ -f "$PIPE_SRC" ] || { echo "mios-owui-install-pipe: $PIPE_SRC missing" >&2; exit 2; }
[ -f "$OWUI_DB" ] || { echo "mios-owui-install-pipe: $OWUI_DB missing" >&2; exit 3; }

# ─── Find / generate an admin API key ────────────────────────────────
TOKEN=$(python3 - "$OWUI_DB" <<'PYEOF'
import sqlite3, sys, secrets, time
path = sys.argv[1]
c = sqlite3.connect(path)
cur = c.cursor()
# Find an admin user
row = cur.execute("SELECT id FROM user WHERE role='admin' LIMIT 1").fetchone()
if not row:
    print("", end="")
    sys.exit(0)
user_id = row[0]
# Check for existing API key
existing = cur.execute(
    "SELECT key FROM api_key WHERE user_id=? ORDER BY created_at DESC LIMIT 1",
    (user_id,)
).fetchone()
if existing and existing[0]:
    print(existing[0], end="")
    sys.exit(0)
# Generate new API key + insert (OWUI's format: sk-<32 hex chars>)
new_key = "sk-" + secrets.token_hex(24)
now_ms = int(time.time() * 1000)
api_id = secrets.token_hex(16)
cur.execute(
    "INSERT INTO api_key (id, user_id, key, data, expires_at, last_used_at, "
    "created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
    (api_id, user_id, new_key, "{}", None, None, now_ms, now_ms),
)
c.commit()
print(new_key, end="")
PYEOF
)

if [ -z "$TOKEN" ]; then
    echo "mios-owui-install-pipe: could not find or create admin API key" >&2
    echo "  (does webui.db have an admin user?)" >&2
    exit 4
fi

echo "[mios-owui-install-pipe] using admin api_key: ${TOKEN:0:12}..."

# ─── Build the pipe payload ───────────────────────────────────────────
PAYLOAD=$(python3 - "$PIPE_ID" "$PIPE_NAME" "$PIPE_SRC" <<'PYEOF'
import json, sys
pid, pname, src = sys.argv[1], sys.argv[2], sys.argv[3]
with open(src) as f:
    content = f.read()
print(json.dumps({
    "id": pid,
    "name": pname,
    "content": content,
    "meta": {
        "description": "local-first Agent for MiOS systems",
        "manifest": {},
    },
    "type": "pipe",
    "is_active": True,
    "is_global": True,
}))
PYEOF
)

# ─── POST to OWUI's functions API ────────────────────────────────────
RESP=$(curl -s -X POST "$OWUI_URL/api/v1/functions/create" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD" \
    -o /tmp/mios-owui-install-pipe.resp \
    -w "%{http_code}")

case "$RESP" in
    200|201)
        echo "[mios-owui-install-pipe] ✓ created pipe $PIPE_ID"
        ;;
    400|409)
        # Already exists; try update
        echo "[mios-owui-install-pipe] (exists; updating)"
        RESP2=$(curl -s -X POST "$OWUI_URL/api/v1/functions/id/$PIPE_ID/update" \
            -H "Authorization: Bearer $TOKEN" \
            -H "Content-Type: application/json" \
            -d "$PAYLOAD" \
            -o /tmp/mios-owui-install-pipe.resp \
            -w "%{http_code}")
        case "$RESP2" in
            200|201)
                echo "[mios-owui-install-pipe] ✓ updated pipe $PIPE_ID"
                ;;
            *)
                echo "[mios-owui-install-pipe] ✗ update returned $RESP2" >&2
                cat /tmp/mios-owui-install-pipe.resp >&2
                exit 5
                ;;
        esac
        ;;
    *)
        echo "[mios-owui-install-pipe] ✗ create returned $RESP" >&2
        cat /tmp/mios-owui-install-pipe.resp >&2
        exit 6
        ;;
esac


# ─── Bind a Model entry that uses the pipe ────────────────────────────
# OWUI distinguishes "Functions" (which include Pipes) from "Models".
# A Pipe registered in Functions is callable but doesn't auto-appear
# as a chat model unless a Model entry binds to it via base_model_id.
# This block creates that Model entry so "MiOS-Agent" shows up in the
# chat dropdown + actually routes through our pipe.
MODEL_ID="mios-agent"
MODEL_NAME="MiOS AI"
BASE_MODEL="mios_agent.mios-agent"  # <function_id>.<pipe_id> from pipes()

MODEL_PAYLOAD=$(python3 - "$MODEL_ID" "$MODEL_NAME" "$BASE_MODEL" <<'PYEOF'
import json, sys
mid, mname, base = sys.argv[1], sys.argv[2], sys.argv[3]

# Operator directive 2026-05-17: "could use a system prompt for
# MiOS-Agent in OWUI and configure the settings too as well".
#
# This is the OWUI-side system prompt operators see + can edit
# under Settings -> Models -> MiOS-Agent -> Advanced. It's
# prepended by OWUI before the pipe receives the messages, so:
#   - the CPU refine step sees it (helps refine route phrasing)
#   - hermes sees it (reinforces SOUL.md from the user-prompt side)
#   - OWUI's task generators (title, tags, follow-ups) see it
#
# Kept short -- the full operating manual lives in SOUL.md inside
# hermes. This is the "what is this agent" intro. NO env values
# baked in (operator: "no context injection for environment
# detection") -- only canonical verb names.
SYSTEM_PROMPT = (
    "You are MiOS-Agent, a local-first agent running on the operator's "
    "MiOS host. You speak the user's language and mirror their tone. "
    "For any visible-to-operator action (launch app, open URL, install "
    "software, take screenshot, control window) you ALWAYS go through "
    "the canonical MiOS verb -- never bare PowerShell, never browser "
    "automation for visible browsing, never vendor download pages. "
    "Canonical verbs: mios-find (launch resolver), mios-open-url "
    "(visible browser), mios-installer (cross-platform install), "
    "mios-windows (Windows dispatch), mios-window (focus/close/move), "
    "mios-screenshot, mios-steamcmd, mios-system-status (single source "
    "of truth for hardware/services/models), mios-hermes-browser ensure "
    "(bring CDP up before any browser_* tool call). Use web_search not "
    "web_extract (the extract backend is search-only in this MiOS). "
    "Native tools (memory_save, kanban_*, discord_send_message, "
    "delegate_task, etc.) are tool_calls -- never call them as bash "
    "lines through terminal. You can fork and improve your own tools "
    "(mios-tool-clone) and skills (mios-skill-clone) when a recurring "
    "task hits the same friction twice. Report tool stdout verbatim; "
    "guessing confidently is a defect."
)

print(json.dumps({
    "id": mid,
    "base_model_id": base,
    "name": mname,
    "meta": {
        "profile_image_url": "/static/favicon.png",
        "description": "local-first Agent for MiOS systems",
        "capabilities": {"vision": False, "citations": True},
        # Native MiOS tool surface -- the model SEES these in its
        # tool_calls list (no `terminal: mios-<verb>` indirection).
        # Registered separately by mios-owui-install-tools + the
        # OpenUI installer; this just binds them to the model. Each
        # entry must match a tool row id in OWUI's `tool` table.
        "toolIds": ["mios_verbs", "openui"],
        # NO hardcoded suggestion_prompts: mios-daemon.suggestions_loop
        # populates the blank-chat panel dynamically every 20 min from
        # recent state + chat language (operator directive 2026-05-17:
        # "no hardcoded answers or anything hardcoded for english").
    },
    "params": {
        # The system prompt OWUI prepends to every chat. Edit in
        # the OWUI admin UI (Settings -> Models -> MiOS-Agent) or
        # re-run this installer.
        "system": SYSTEM_PROMPT,
        # Sampling defaults tuned for the refine -> hermes -> polish
        # chain. Low temperature: agent should be predictable about
        # which canonical verb to call, not "creative". top_p left
        # at OWUI default. Hermes internally overrides these on its
        # delegate spawns -- this is just the outer chat-completion
        # default.
        "temperature": 0.2,
        "top_p": 0.9,
        # Stop tokens: hermes occasionally emits these as text inside
        # delegate-spawn tool args; cut them so they don't leak into
        # the polished answer.
        "stop": ["<|im_end|>", "<|endoftext|>"],
        # OWUI streams tokens incrementally; no need to override.
    },
    "is_active": True,
}))
PYEOF
)

echo "[mios-owui-install-pipe] POST /api/v1/models/create"
RESP3=$(curl -s -X POST "$OWUI_URL/api/v1/models/create" \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    -d "$MODEL_PAYLOAD" \
    -o /tmp/mios-owui-install-pipe.resp \
    -w "%{http_code}")

case "$RESP3" in
    200|201)
        echo "[mios-owui-install-pipe] ✓ created Model entry $MODEL_ID"
        ;;
    400|401|409)
        # OWUI returns 401 (not 409) for "model id already registered"
        # -- detail body "Uh-oh! This model id is already registered."
        # Treat all three as "exists -- need to update".
        echo "[mios-owui-install-pipe] (Model exists; updating)"
        RESP4=$(curl -s -X POST "$OWUI_URL/api/v1/models/model/update?id=$MODEL_ID" \
            -H "Authorization: Bearer $TOKEN" \
            -H "Content-Type: application/json" \
            -d "$MODEL_PAYLOAD" \
            -o /tmp/mios-owui-install-pipe.resp \
            -w "%{http_code}")
        case "$RESP4" in
            200|201) echo "[mios-owui-install-pipe] ✓ updated Model entry $MODEL_ID" ;;
            *)       echo "[mios-owui-install-pipe] ✗ Model update returned $RESP4" >&2
                     cat /tmp/mios-owui-install-pipe.resp >&2 ;;
        esac
        ;;
    *)
        echo "[mios-owui-install-pipe] ✗ Model create returned $RESP3" >&2
        cat /tmp/mios-owui-install-pipe.resp >&2
        ;;
esac

# ─── Register the anti-meta Filter Function (post-hoc scrubber) ───────
# Operator directive 2026-05-16: research-driven approach -- replace
# rigid "DO NOT say X" SOUL.md text-blocks with an OWUI Filter that
# strips meta-speak from the stream. The filter reads the same shared
# refusal-patterns.txt the nudger + prefilter use; one source of truth.
if [ -f "$FILTER_SRC" ]; then
    FILTER_PAYLOAD=$(python3 - "$FILTER_ID" "$FILTER_NAME" "$FILTER_SRC" <<'PYEOF'
import json, sys
fid, fname, src = sys.argv[1], sys.argv[2], sys.argv[3]
with open(src) as f:
    content = f.read()
print(json.dumps({
    "id": fid,
    "name": fname,
    "content": content,
    "meta": {
        "description": "Post-hoc scrubber for meta-speak + refusal phrases + Qwen XML markup.",
        "manifest": {},
    },
    "type": "filter",
    "is_active": True,
    "is_global": True,
}))
PYEOF
)
    RESPF=$(curl -s -X POST "$OWUI_URL/api/v1/functions/create" \
        -H "Authorization: Bearer $TOKEN" \
        -H "Content-Type: application/json" \
        -d "$FILTER_PAYLOAD" \
        -o /tmp/mios-owui-install-pipe.resp \
        -w "%{http_code}")
    case "$RESPF" in
        200|201) echo "[mios-owui-install-pipe] ✓ created Filter $FILTER_ID" ;;
        400|409)
            RESPF2=$(curl -s -X POST "$OWUI_URL/api/v1/functions/id/$FILTER_ID/update" \
                -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
                -d "$FILTER_PAYLOAD" \
                -o /tmp/mios-owui-install-pipe.resp -w "%{http_code}")
            case "$RESPF2" in
                200|201) echo "[mios-owui-install-pipe] ✓ updated Filter $FILTER_ID" ;;
                *)       echo "[mios-owui-install-pipe] ✗ Filter update $RESPF2" >&2 ;;
            esac
            ;;
        *) echo "[mios-owui-install-pipe] ✗ Filter create $RESPF" >&2 ;;
    esac
fi


# ─── MiOS Agents Sidecar Filter -- RETIRED ────────────────────────
# agent-pipe is the canonical orchestrator now and emits its own
# SSE status events (📡 prompt / 🧭 route / 📋 plan / 💬 chat / ...).
# The sidecar tailed /var/lib/mios/hermes-tail/latest.json and would
# surface stale Hermes events as if current on every chat -- and its
# post-call response sometimes REPLACED the legitimate polished
# reply ("launch steam" succeeded internally but the operator saw
# "I cannot launch Steam" because the sidecar's post-emit overwrote
# the agent-pipe reply). Forcing it disabled here is the safety net;
# the install path no longer creates+enables it.
#
# A previous run may have installed + enabled the sidecar; force-
# disable both flags in webui.db so a re-run leaves the row in the
# correct disabled state.
if [ -f "$OWUI_DB" ]; then
    python3 - "$OWUI_DB" "$SIDECAR_ID" <<'PYEOF'
import sqlite3, sys
db, fid = sys.argv[1], sys.argv[2]
c = sqlite3.connect(db)
n = c.execute(
    "UPDATE function SET is_active=0, is_global=0 WHERE id=?", (fid,)
).rowcount
c.commit()
if n:
    print(f"[mios-owui-install-pipe] ✓ retired (disabled) Filter {fid} "
          f"(rows={n})")
c.close()
PYEOF
fi

# ─── Memory feature ON by default for every user ─────────────────
# OWUI's memory feature is per-user via settings.ui.memory = true.
# Operator confirmed they want it ON by default for the MiOS-Agent
# experience (without it, the agent forgets context between turns
# at the OWUI layer). Walk every user row, ensure memory: true.
# Idempotent: already-true users are left alone.
if [ -f "$OWUI_DB" ]; then
    python3 - "$OWUI_DB" <<'PYEOF'
import json, sqlite3, sys
db = sys.argv[1]
c = sqlite3.connect(db)
flipped = 0
total = 0
for uid, settings in c.execute("SELECT id, settings FROM user"):
    total += 1
    try:
        s = json.loads(settings) if settings else {}
    except (json.JSONDecodeError, ValueError):
        s = {}
    if not isinstance(s, dict):
        s = {}
    ui = s.get("ui") or {}
    if not isinstance(ui, dict):
        ui = {}
    if ui.get("memory") is True:
        continue
    ui["memory"] = True
    s["ui"] = ui
    c.execute("UPDATE user SET settings = ? WHERE id = ?",
              (json.dumps(s), uid))
    flipped += 1
c.commit()
c.close()
print(f"[mios-owui-install-pipe] ✓ memory enabled for "
      f"{flipped}/{total} user(s)")
PYEOF
fi

echo
echo "[mios-owui-install-pipe] done. Refresh OWUI; \"$MODEL_NAME\" should appear in the model dropdown."
