#!/bin/bash
# /usr/libexec/mios/mios-db [<surrealql>] [-f <file.surql>] [--ns <ns>] [--db <db>] [--json]
#                            [--owui '<sql>']
#                            [--embed '<text>'] [--embed-model <m>]
#
# Unified MiOS shared-state CLI -- one tool that fronts every
# local backend agents need to query.
#
# Operator directives 2026-05-18 stacked:
#   * "make sure this is all Ollama (and other OpenSource Alternatives /
#      Local Endpoints / Self-Hosted Endpoints) and Open WebUI Native
#      DB(s) for knowledge/memory/context/scratch/skills/functions/
#      tools/etc-etc"
#   * "unify all AI Surfaces!!"
#
# The three backends + which data lives where:
#
#   --owui <sql>      Read/write Open WebUI's webui.db (SQLite).
#                     SOURCE OF TRUTH for: chat / message / memory /
#                     knowledge / file / tool / function / model /
#                     user / group / channel.
#
#   --embed <text>    Ollama /v1/embeddings via the canonical
#                     MiOS embedding model (nomic-embed-text).
#                     Returns the float[] vector. SOURCE OF TRUTH
#                     for: embeddings. Switch model via --embed-model.
#
#   (no flag)         SurrealDB at MIOS_DB_URL. SOURCE OF TRUTH for:
#                     agent / session / tool_call / event /
#                     kanban_shadow / scratch / agent_metric.
#                     Cross-cutting state OWUI doesn't natively have.
#
# Env (with defaults). All envs source from the layered mios.toml chain
# via tools/lib/userenv.sh -- vendor (/usr/share/mios/mios.toml) <
# host (/etc/mios/mios.toml) < user (~/.config/mios/mios.toml). A shell
# `export` always wins (`:=` form). To change the defaults globally,
# edit [surrealdb] / [ports].ollama / paths in mios.toml -- DO NOT
# hardcode values here. See the SSOT directive in
# automation/15-render-quadlets.sh.
#
#   MIOS_DB_URL          http://localhost:${MIOS_PORT_SURREALDB:-8000}
#   MIOS_DB_USER         root             [surrealdb].user
#   MIOS_DB_PASS         root             [surrealdb].pass
#   MIOS_DB_NS           mios             [surrealdb].namespace
#   MIOS_DB_DB           mios             [surrealdb].database
#   MIOS_OWUI_DB         /var/lib/mios/open-webui/webui.db
#   MIOS_OLLAMA_URL      http://localhost:${MIOS_PORT_OLLAMA:-11434}
#   MIOS_EMBED_MODEL     nomic-embed-text [surrealdb].embed_model
#
# Exits 0 on success, 1 on backend unreachable, 2 on missing binary.

set -uo pipefail

# Source the SSOT-layered env first so MIOS_* envs reflect the operator's
# mios.toml overrides without callers having to source userenv.sh themselves.
# Canonical deployed paths mirror /etc/profile.d/mios-env.sh; silent no-op
# if the helper isn't present (e.g. a fresh host pre-image-rebuild). The
# script still works with raw env-var exports either way.
for _ue in /usr/lib/mios/userenv.sh /usr/share/mios/tools/lib/userenv.sh; do
    if [ -r "$_ue" ]; then
        # shellcheck disable=SC1090
        . "$_ue"
        break
    fi
done

DB_URL="${MIOS_DB_URL:-http://localhost:${MIOS_PORT_SURREALDB:-8000}}"
DB_USER="${MIOS_DB_USER:-root}"
DB_PASS="${MIOS_DB_PASS:-root}"
DB_NS="${MIOS_DB_NS:-mios}"
DB_DB="${MIOS_DB_DB:-mios}"
OWUI_DB="${MIOS_OWUI_DB:-/var/lib/mios/open-webui/webui.db}"
OLLAMA_URL="${MIOS_OLLAMA_URL:-http://localhost:${MIOS_PORT_OLLAMA:-11434}}"
EMBED_MODEL="${MIOS_EMBED_MODEL:-nomic-embed-text}"

JSON=0
FILE=""
QUERY=""
MODE="surreal"
OWUI_SQL=""
EMBED_TEXT=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        --ns)          DB_NS="$2"; shift 2 ;;
        --db)          DB_DB="$2"; shift 2 ;;
        --json)        JSON=1; shift ;;
        -f)            FILE="$2"; shift 2 ;;
        --owui)        MODE="owui"; OWUI_SQL="$2"; shift 2 ;;
        --embed)       MODE="embed"; EMBED_TEXT="$2"; shift 2 ;;
        --embed-model) EMBED_MODEL="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,46p' "$0" | sed 's/^# \?//'
            exit 0 ;;
        --)            shift; QUERY="$*"; break ;;
        *)             QUERY="$1"; shift
                       [ "$#" -gt 0 ] && QUERY="$QUERY $*"
                       break ;;
    esac
done

# ── MODE: --owui  (OWUI webui.db via sqlite3 over the bind-mount) ──
if [ "$MODE" = "owui" ]; then
    if [ ! -r "$OWUI_DB" ]; then
        echo "mios-db: OWUI webui.db not readable at $OWUI_DB" >&2
        exit 1
    fi
    if command -v sqlite3 >/dev/null 2>&1; then
        if [ "$JSON" = "1" ]; then
            exec sqlite3 -json "$OWUI_DB" "$OWUI_SQL"
        else
            exec sqlite3 -header -column "$OWUI_DB" "$OWUI_SQL"
        fi
    fi
    # Container-exec fallback: OWUI image ships python3 + sqlite.
    # Pass SQL via stdin (sys.argv[1] = SQL); use a CURSOR for
    # .description (Connection.execute returns a cursor but the
    # description attr lives on the cursor, not the connection).
    if command -v podman >/dev/null 2>&1 \
       && podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^mios-open-webui$'; then
        exec podman exec -i mios-open-webui python3 -c '
import sqlite3, json, sys
sql = sys.stdin.read()
c = sqlite3.connect("/app/backend/data/webui.db")
cur = c.execute(sql)
cols = [d[0] for d in cur.description] if cur.description else []
rows = cur.fetchall()
out = [dict(zip(cols, r)) for r in rows]
print(json.dumps(out, default=str, indent=2))
' <<<"$OWUI_SQL"
    fi
    echo "mios-db: no sqlite3 + no mios-open-webui container" >&2
    exit 2
fi

# ── MODE: --embed  (Ollama /v1/embeddings via OpenAI-compat) ──
if [ "$MODE" = "embed" ]; then
    if ! command -v curl >/dev/null 2>&1; then
        echo "mios-db: curl required for --embed" >&2
        exit 2
    fi
    # OpenAI-compat shape -- Ollama implements identical schema.
    PAYLOAD=$(python3 -c "
import json, sys
print(json.dumps({'model': '$EMBED_MODEL', 'input': sys.argv[1]}))
" "$EMBED_TEXT")
    exec curl -sS --max-time 15 \
        -X POST "$OLLAMA_URL/v1/embeddings" \
        -H "Content-Type: application/json" \
        --data "$PAYLOAD"
fi

# ── MODE: surreal  (cross-cutting state) ──

# SurrealDB 3.0 CLI args (renamed from 2.x): --conn → --endpoint,
# --user/--pass kept as aliases. WebSocket endpoint preferred over
# http:// for the `sql` REPL (3.0 default is ws://localhost:8000).
WS_URL="${DB_URL/http:/ws:}"
WS_URL="${WS_URL/https:/wss:}"

# 1. Prefer the local surreal CLI if installed (faster, REPL-friendly).
# NB: stdin must be the QUERY without an intervening pipeline -- a
# `printf | exec surreal` puts `exec` on the right side of a pipe,
# which only replaces the SUBSHELL, not the script; the script then
# falls through to step 2/3 and prints duplicate output. Use a
# here-string so `exec` actually replaces the calling process.
if command -v surreal >/dev/null 2>&1; then
    args=(sql --endpoint "$WS_URL" --username "$DB_USER" --password "$DB_PASS"
          --namespace "$DB_NS" --database "$DB_DB")
    [ "$JSON" = "1" ] && args+=(--pretty)
    if [ -n "$FILE" ]; then
        exec surreal "${args[@]}" < "$FILE"
    elif [ -n "$QUERY" ]; then
        exec surreal "${args[@]}" <<<"$QUERY"
    else
        exec surreal "${args[@]}"
    fi
fi

# 2. Container-exec fallback: surreal binary inside the container.
# The official surrealdb/surrealdb image is distroless -- no /bin/sh,
# no PATH lookup; the binary lives at /surreal. Use the full path.
# Same here-string discipline as step 1: no pipelines around `exec`.
if command -v podman >/dev/null 2>&1 \
   && podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^mios-surrealdb$'; then
    args=(exec -i mios-surrealdb /surreal sql
          --endpoint "$WS_URL" --username "$DB_USER" --password "$DB_PASS"
          --namespace "$DB_NS" --database "$DB_DB")
    [ "$JSON" = "1" ] && args+=(--pretty)
    if [ -n "$FILE" ]; then
        exec podman "${args[@]}" < "$FILE"
    elif [ -n "$QUERY" ]; then
        exec podman "${args[@]}" <<<"$QUERY"
    fi
    # No QUERY + no FILE -> fall through to curl (which prints usage).
fi

# 3. Pure HTTP fallback: SurrealDB REST API via curl.
# 3.0 dropped the NS:/DB: HTTP header form; the canonical 3.0+
# pattern is to prepend `USE NS <ns> DB <db>;` to the query body.
if [ -n "$QUERY" ] && command -v curl >/dev/null 2>&1; then
    body=$(printf 'USE NS %s DB %s; %s' "$DB_NS" "$DB_DB" "$QUERY")
    exec curl -sS -X POST "$DB_URL/sql" \
        -u "$DB_USER:$DB_PASS" \
        -H "Accept: application/json" \
        --data-binary "$body"
fi
# Also support -f file form via curl.
if [ -n "$FILE" ] && command -v curl >/dev/null 2>&1 && [ -r "$FILE" ]; then
    body=$(printf 'USE NS %s DB %s;\n' "$DB_NS" "$DB_DB"; cat "$FILE")
    exec curl -sS -X POST "$DB_URL/sql" \
        -u "$DB_USER:$DB_PASS" \
        -H "Accept: application/json" \
        --data-binary "$body"
fi

echo "mios-db: no SurrealDB backend reachable + no --owui/--embed flag set" >&2
echo "  options:" >&2
echo "    mios-db '<surrealql>'                 -- cross-cutting state" >&2
echo "    mios-db --owui '<sql>'                -- OWUI webui.db" >&2
echo "    mios-db --embed '<text>'              -- Ollama embeddings" >&2
echo "  check: systemctl start mios-surrealdb.service" >&2
exit 2
