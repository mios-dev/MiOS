#!/usr/bin/env bash
# MiOS -- wsl-firstboot: WSL2 first-boot user and runtime initialization.
# Runs once (guarded by ConditionPathExists=!/var/lib/mios/.wsl-firstboot-done).
# Safe to re-run: all operations are idempotent.
set -euo pipefail
# shellcheck source=/usr/lib/mios/paths.sh
source /usr/lib/mios/paths.sh

MARKER="${MIOS_VAR_DIR}/.wsl-firstboot-done"

# logger may fail if journald isn't up yet -- never fatal
_log() { logger -t mios-wsl-firstboot "$*" 2>/dev/null || true; echo "[wsl-firstboot] $*" >&2; }

_log "Starting WSL2 first-boot initialization"

# ── Load identity from install.env (written at bootstrap time) ──
MIOS_USER="${MIOS_USER:-mios}"
MIOS_USER_HASH="${MIOS_USER_PASSWORD_HASH:-}"
MIOS_HOSTNAME="${MIOS_HOSTNAME:-mios}"

if [[ -f ${MIOS_ETC_DIR}/install.env ]]; then
    # shellcheck disable=SC1091
    source ${MIOS_ETC_DIR}/install.env 2>/dev/null || true
    MIOS_USER="${MIOS_USER:-mios}"
    MIOS_USER_HASH="${MIOS_USER_PASSWORD_HASH:-$MIOS_USER_HASH}"
    MIOS_HOSTNAME="${MIOS_HOSTNAME:-mios}"
fi

# ── Hostname ──
if [[ -n "$MIOS_HOSTNAME" ]]; then
    # Write /etc/hostname directly -- hostnamectl requires logind which may not
    # be running yet in WSL2 (logind is conditioned out in WSL2).
    echo "$MIOS_HOSTNAME" > /etc/hostname
    hostname "$MIOS_HOSTNAME" 2>/dev/null || true
    _log "Hostname set to $MIOS_HOSTNAME"
fi

# ── User creation ──
if ! id "$MIOS_USER" &>/dev/null; then
    _log "Creating user $MIOS_USER"
    # Apply sysusers to get declarative user definitions
    systemd-sysusers 2>/dev/null || true

    if ! id "$MIOS_USER" &>/dev/null; then
        # Fallback imperative creation if sysusers didn't create the user
        useradd -m -s /bin/bash -G wheel "$MIOS_USER" 2>/dev/null || true
    fi
fi

# ── Home directory ──
if id "$MIOS_USER" &>/dev/null; then
    _home=$(getent passwd "$MIOS_USER" | cut -d: -f6)
    if [[ -n "$_home" && ! -d "$_home" ]]; then
        mkdir -p "$_home"
        cp -a /etc/skel/. "$_home/" 2>/dev/null || true
    fi
    if [[ -n "$_home" && -d "$_home" ]]; then
        _uid=$(id -u "$MIOS_USER"); _gid=$(id -g "$MIOS_USER")
        chown -R "${_uid}:${_gid}" "$_home" 2>/dev/null || true
    fi
    # Unlock account
    passwd -u "$MIOS_USER" 2>/dev/null || true
fi

# ── Password hash (default: 'mios' if none supplied) ──
if [[ -z "$MIOS_USER_HASH" ]] && id "$MIOS_USER" &>/dev/null; then
    _log "No password hash supplied -- generating default hash for password 'mios'"
    MIOS_USER_HASH=$(openssl passwd -6 'mios' 2>/dev/null) || true
fi

if [[ -n "$MIOS_USER_HASH" ]] && id "$MIOS_USER" &>/dev/null; then
    if [[ "$MIOS_USER_HASH" =~ ^\$6\$ ]]; then
        _log "Setting password hash for $MIOS_USER"
        echo "${MIOS_USER}:${MIOS_USER_HASH}" | chpasswd -e 2>/dev/null || true
    else
        _log "WARN: MIOS_USER_PASSWORD_HASH is not a valid sha512crypt hash (must start with \$6\$)"
    fi
else
    _log "WARN: Could not set password for $MIOS_USER -- manual reset required"
fi

# ── Tmpfiles for /var/lib/mios ──
if [[ -f /usr/lib/tmpfiles.d/mios.conf ]]; then
    systemd-tmpfiles --create /usr/lib/tmpfiles.d/mios.conf 2>/dev/null || true
fi

# ── subuid / subgid for rootless containers ──
# `wsl -d MiOS -- <gui-app>` runs apps under the user's namespace
# without spawning a login shell. If /etc/subuid lacks an entry for
# the mios user, podman/buildah's rootless mode aborts with:
#     "no subuid ranges found for user 'mios' in /etc/subuid"
# Idempotent: appends only if missing. The 100000:65536 range matches
# Fedora's standard rootless-user allocation and doesn't collide with
# MiOS's 800-829 service-user reservation.
if id "$MIOS_USER" &>/dev/null; then
    if ! grep -qE "^${MIOS_USER}:" /etc/subuid 2>/dev/null; then
        _log "Adding /etc/subuid entry for ${MIOS_USER} (rootless containers)"
        echo "${MIOS_USER}:100000:65536" >> /etc/subuid
    fi
    if ! grep -qE "^${MIOS_USER}:" /etc/subgid 2>/dev/null; then
        _log "Adding /etc/subgid entry for ${MIOS_USER} (rootless containers)"
        echo "${MIOS_USER}:100000:65536" >> /etc/subgid
    fi
fi

# ── Enable systemd user-session lingering for the mios user ──
# Without lingering, `wsl -d MiOS -- <gui-app>` finds no user-systemd
# and no user D-Bus session bus, surfacing as:
#     "Cannot autolaunch D-Bus without X11 $DISPLAY"
#     "Failed to connect to user scope bus via local transport"
#     "cgroupv2 manager is set to systemd but no systemd user session"
# enable-linger starts the user manager at boot and keeps it running
# even when no interactive login is active -- correct semantics for
# WSL where `wsl -d MiOS -- <cmd>` enters the distro without login.
if id "$MIOS_USER" &>/dev/null; then
    if ! loginctl show-user "$MIOS_USER" 2>/dev/null | grep -q '^Linger=yes$'; then
        _log "Enabling user-systemd lingering for ${MIOS_USER}"
        loginctl enable-linger "$MIOS_USER" 2>/dev/null || \
            _log "WARN: loginctl enable-linger ${MIOS_USER} failed (may need re-run after login)"
    fi
fi

# ── Mark done ──
mkdir -p "$(dirname "$MARKER")"
touch "$MARKER"
_log "WSL2 first-boot initialization complete"
