def svg_from_template(template, palette):
    return template.format(**{k: v for k, v in palette.items()})

def make_icon(name, category, body, _p, _s):
    full_svg = f'''<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48" height="48">
  {svg_from_template(body, PALETTE)}
</svg>
'''
    cat_dir = os.path.join(OUT_BASE, category, "scalable")
    os.makedirs(cat_dir, exist_ok=True)
    path = os.path.join(cat_dir, f"{name}.svg")
    with open(path, "w") as f:
        f.write(full_svg)
    return path

def main():
    os.makedirs(OUT_BASE, exist_ok=True)

    # Write index.theme
    with open(os.path.join(OUT_BASE, "index.theme"), "w") as f:
        f.write(INDEX)

    # Write all icon SVGs
    written = []
    for (name, cat, body, pc, sc) in ICONS:
        p = make_icon(name, cat, body, pc, sc)
        written.append(p)
        print(f"  [MiOS-icons] {p}")

    # Symlink aliases
    aliases = {
        "apps/scalable/mios-installer.svg": "mios-installer",
        "apps/scalable/utilities-terminal.svg": "mios-monitor",
        "apps/scalable/drive-harddisk.svg": "crystaldiskinfo",
    }
    for rel_link, target_name in aliases.items():
        link_path = os.path.join(OUT_BASE, rel_link)
        target = f"{target_name}.svg"
        if not os.path.exists(link_path):
            try:
                os.symlink(target, link_path)
            except OSError:
                pass

    print(f"[MiOS-icons] Generated {len(written)} SVG icons in {OUT_BASE}")
    print("[MiOS-icons] Run 'gtk-update-icon-cache -f -t /usr/share/icons/MiOS' after install")

if __name__ == "__main__":
    main()
