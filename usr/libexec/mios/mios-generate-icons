#!/usr/bin/env python3
# AI-hint: Generates the MiOS XDG icon theme index.theme and SVG icon stubs
# for all MiOS-branded surfaces. Run as part of mios-sync-theme or standalone.
# Output: /usr/share/icons/MiOS/{apps,status,devices}/scalable/*.svg + index.theme
# AI-related: usr/libexec/mios/mios-sync-theme, usr/share/mios/mios.toml [colors]
#
# Palette: read live from /etc/mios/theme/theme.json (written by mios-sync-theme
# from mios.toml [colors]).  Falls back to reading mios.toml directly if
# theme.json does not yet exist (first-boot / pre-sync degrade-open path).
# NO palette values are hardcoded here; this script is a consumer of the SSOT,
# not a second copy of it.

import os
import sys
import json
import re

# ── SSOT palette reader ────────────────────────────────────────────────────────
# Priority: theme.json > mios.toml > abort with diagnostic

THEME_JSON = os.environ.get("MIOS_THEME_JSON", "/etc/mios/theme/theme.json")
MIOS_TOML   = os.environ.get("MIOS_TOML",      "/usr/share/mios/mios.toml")

_TOML_COLOR_KEYS = ["bg","fg","accent","cursor","success","warning","error","muted","subtle"]


def _load_theme_json(path):
    """Load palette from /etc/mios/theme/theme.json (written by mios-sync-theme)."""
    try:
        with open(path) as f:
            t = json.load(f)
        return {k: t[k] for k in _TOML_COLOR_KEYS if k in t}
    except Exception:
        return {}


def _load_mios_toml(path):
    """Fallback: extract [colors] keys from mios.toml via simple regex (no third-party lib)."""
    palette = {}
    try:
        in_colors = False
        with open(path) as f:
            for line in f:
                stripped = line.strip()
                if stripped == "[colors]":
                    in_colors = True
                    continue
                if in_colors and stripped.startswith("["):
                    break  # left the [colors] section
                if in_colors:
                    m = re.match(r'^(\w+)\s*=\s*"(#[0-9A-Fa-f]{6})"', stripped)
                    if m and m.group(1) in _TOML_COLOR_KEYS:
                        palette[m.group(1)] = m.group(2)
    except Exception as e:
        print(f"[mios-generate-icons] WARNING: could not read {path}: {e}", file=sys.stderr)
    return palette


def load_palette():
    """Return palette dict, always sourced from SSOT (theme.json or mios.toml)."""
    p = _load_theme_json(THEME_JSON)
    if len(p) >= len(_TOML_COLOR_KEYS):
        pass  # full palette from theme.json
    else:
        # Supplement / replace with mios.toml
        p2 = _load_mios_toml(MIOS_TOML)
        p.update(p2)  # toml wins for any missing keys
    if not p:
        sys.exit(f"[mios-generate-icons] ERROR: could not read palette from {THEME_JSON} or {MIOS_TOML}")
    missing = [k for k in _TOML_COLOR_KEYS if k not in p]
    if missing:
        print(f"[mios-generate-icons] WARNING: palette missing keys: {missing} -- icons may render incorrectly", file=sys.stderr)

    # Computed shade tokens -- SSOT-derived, not hardcoded
    # Darken a hex color by multiplying each channel by `factor`
    def _darken(hex_color, factor=0.45):
        h = hex_color.lstrip('#')
        r, g, b = int(h[0:2],16), int(h[2:4],16), int(h[4:6],16)
        return '#{:02X}{:02X}{:02X}'.format(int(r*factor), int(g*factor), int(b*factor))

    def _lighten(hex_color, factor=1.4):
        h = hex_color.lstrip('#')
        r, g, b = int(h[0:2],16), int(h[2:4],16), int(h[4:6],16)
        return '#{:02X}{:02X}{:02X}'.format(min(255,int(r*factor)), min(255,int(g*factor)), min(255,int(b*factor)))

    p['bg_dark']      = _darken(p.get('bg',     '#000000'), 0.5)
    p['error_dark']   = _darken(p.get('error',  '#000000'), 0.5)
    p['accent_dark']  = _darken(p.get('accent', '#000000'), 0.5)
    p['success_dark'] = _darken(p.get('success','#000000'), 0.5)
    p['cursor_dark']  = _darken(p.get('cursor', '#000000'), 0.5)
    p['subtle_light'] = _lighten(p.get('subtle','#ffffff'), 1.2)
    p['white']        = '#FFFFFF'
    return p


PALETTE = load_palette()


