                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "Everything query string. Supports substring (\"crew motorfest\"), wildcards (\"BeamNG*.exe\"), path filters (\"path:steamapps\"), size (\"size:>1gb\"), modify-date (\"dm:today\"). Quote multi-word substrings.",
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Max results (default 10).",
                        "default": 10,
                    },
                    "ext": {
                        "type": "string",
                        "description": "Optional comma-separated extension filter, e.g. \"exe,lnk,url\". Empty = no filter.",
                        "default": "",
                    },
                },
                "required": ["query"],
            },
        },
        {
            "name": "web_search",
            "description": "Search the WEB via the local, self-hosted SearXNG metasearch. USE THIS for ANYTHING from the internet or the current world: weather, news, current events, event dates/times/locations, prices, products, people, places, scores, facts, general knowledge -- any question whose answer is NOT a file on this machine. Returns real fetched results (title/url/content + instant answers) so you cite the source. NEVER invent a live fact (weather, an event schedule, a price) when this tool can fetch it, and NEVER fall back to remembered facts for a current/world question -- that is the stale-data / fabrication defect. This is NOT file search: everything_search / fs_search find files on disk and return nothing for a knowledge or current-events query.",
            "parameters": {
                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "Natural-language search query. Examples: \"toronto weather today\", \"anime north 2026 dates and location\", \"current price RTX 5090\".",
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Max results to return (default 5).",
                        "default": 5,
                    },
                },
                "required": ["query"],
            },
        },
        {
            "name": "fs_search",
            "description": "Search the LINUX filesystem inside the MiOS-DEV / host environment -- the agentic peer to everything_search (which is Windows-only). Use for /usr /etc /var/lib /opt /home /root /var/log /usr/share/mios files. Backend: plocate -> locate -> find. Returns absolute Linux paths.",
            "parameters": {
                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "Substring (case-insensitive) on basename or full path. Examples: \"mios.toml\", \"hermes\", \"systemd/system\".",
                    },
                    "limit": {
                        "type": "integer",
                        "description": "Max results (default 20).",
                        "default": 20,
                    },
                    "ext": {
                        "type": "string",
