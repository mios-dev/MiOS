                        "default": "",
                    }
                },
                "required": [],
            },
        },
        {
            "name": "container_restart",
            "description": "podman restart <name>. WRITE verb. Use when the operator asks to restart a MiOS-DEV container (mios-open-webui, mios-llm-light, mios-pgvector, mios-forge, etc.).",
            "parameters": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Container name (exact). Examples: mios-open-webui, mios-llm-light, mios-pgvector, mios-forge, mios-searxng.",
                    }
                },
                "required": ["name"],
            },
        },
        # ── PHASE-3 typed window/launch surface ────────────────────
        # Operator directive 2026-05-18 (native OpenAI strict
        # function-calling with enum positions; replaces SOUL.md
        # prose + env-var preludes). The `position` enum is the
        # SAME shape as the PositionLiteral in mios_verbs.py source
        # -- the model's tool_call surface becomes the rule book.
        {
            "name": "open_app",
            "description": "Open a desktop app on the operator's screen, optionally placing the window. Use this instead of launch_app when ALSO controlling position. Works for Windows apps (Steam/Epic/Xbox/protocol-handlers/.exe) and Linux GUI apps via WSLg.",
            "parameters": {
                "type": "object",
                "properties": {
