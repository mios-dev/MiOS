                        "default": 0,
                        "description": "0-indexed monitor (0=primary).",
                    },
                },
                "required": ["name"],
            },
        },
        {
            "name": "focus_window",
            "description": "Bring an existing window to the foreground by title pattern. Case-insensitive substring match; first match wins.",
            "parameters": {
                "type": "object",
                "properties": {
                    "title": {"type": "string", "description": "Title pattern."},
                },
                "required": ["title"],
            },
        },
        {
            "name": "move_window",
            "description": "Move an existing window to a canonical position. Substring + case-insensitive title match.",
            "parameters": {
                "type": "object",
                "properties": {
                    "title": {"type": "string", "description": "Title pattern."},
                    "position": {
                        "type": "string",
                        "enum": ["default", "as-is", "center",
                                 "left", "right", "top", "bottom",
                                 "top-left", "top-right",
                                 "bottom-left", "bottom-right",
                                 "maximize"],
                        "description": "Canonical position. 'as-is' is a noop.",
                    },
                    "monitor": {
                        "type": "integer",
                        "default": 0,
                        "description": "0-indexed monitor (0=primary).",
                    },
                },
                "required": ["title", "position"],
            },
        },
        {
            "name": "close_window",
            "description": "Close a window by title pattern. Graceful (WM_CLOSE) lets the app save state; force (TerminateProcess) drops unsaved work. NEVER on MiOS infrastructure (hermes-agent / mios-open-webui / ollama / mios-daemon / mios-launcher) -- use `mios-restart <svc>` instead.",
            "parameters": {
                "type": "object",
                "properties": {
                    "title": {"type": "string", "description": "Title pattern."},
                    "mode": {
                        "type": "string",
                        "enum": ["graceful", "force"],
                        "default": "graceful",
                        "description": "graceful = WM_CLOSE; force = TerminateProcess.",
                    },
                },
                "required": ["title"],
            },
        },
        {
            "name": "list_windows",
            "description": "Enumerate visible top-level windows. Use to disambiguate when a title pattern matches multiple, or to verify a window is presented.",
            "parameters": {"type": "object", "properties": {}, "required": []},
        },
        {
            "name": "screen_layout",
            "description": "Report monitor layout (count + dims + primary index). Use to reason about which monitor is which when positioning windows.",
            "parameters": {"type": "object", "properties": {}, "required": []},
        },
        {
            "name": "open_url",
            "description": "Open a URL in the operator's MiOS-defined default browser (visible). NEVER use browser_navigate for operator-visible browsing -- that's headless CDP.",
            "parameters": {
                "type": "object",
                "properties": {
                    "url": {"type": "string", "description": "Absolute URL (http/https/file/etc)."},
                    "browser": {
                        "type": "string",
                        "description": "Override the default browser (e.g. 'chromedev'). Empty = mios.toml default.",
                    },
                },
                "required": ["url"],
            },
        },
    ]

    meta = {
        "description": "MiOS shell verbs exposed as native tool_calls.",
        "manifest": {
            "title": "MiOS Verbs",
            "author": "MiOS",
            "version": "1.0.0",
        },
    }

    # Change detection. Cover BOTH the module content AND the generated
    # specs (the model-visible tool surface). A spec-only change -- e.g.
    # adding a new function spec without editing the module body -- MUST
    # still trigger an UPDATE, else the new tool stays invisible to the
    # chat model (2026-05-21: web_search method shipped in content but the
    # content hash matched, so the new spec was silently skipped).
    new_specs_json = json.dumps(specs)
    new_hash = hashlib.sha256(
        (content + new_specs_json).encode("utf-8")
    ).hexdigest()
    row = c.execute(
        "SELECT id, content, specs FROM tool WHERE id=?", (TOOL_ID,)
    ).fetchone()

    if row is not None:
        existing_hash = hashlib.sha256(
            ((row[1] or "") + (row[2] or "")).encode("utf-8")
        ).hexdigest()
        if existing_hash == new_hash:
            _log(f"{TOOL_ID} already current ({len(content)} chars) -- no change")
            return 0
        c.execute(
            "UPDATE tool SET content=?, specs=?, meta=?, updated_at=? WHERE id=?",
            (content, new_specs_json, json.dumps(meta),
             int(datetime.datetime.utcnow().timestamp()), TOOL_ID),
        )
        c.commit()
        _log(f"updated {TOOL_ID} ({len(content)} chars)")
        return 0

    user_id = _admin_user_id(c)
    if not user_id:
        _log("no admin user found yet -- run mios-owui-bootstrap-admin first")
        return 0

    now = int(datetime.datetime.utcnow().timestamp())
    c.execute(
        "INSERT INTO tool (id, user_id, name, content, specs, meta, created_at, updated_at) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        (TOOL_ID, user_id, TOOL_NAME, content,
         json.dumps(specs), json.dumps(meta), now, now),
    )
    c.commit()
    _log(f"created {TOOL_ID} ({len(content)} chars, attributed to admin {user_id[:8]}...)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
