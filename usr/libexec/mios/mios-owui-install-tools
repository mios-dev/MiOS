                        "default": "",
                    },
                    "path": {
                        "type": "string",
                        "description": "Optional subtree to restrict the search (e.g. \"/usr/share/mios\").",
                        "default": "",
                    },
                    "type": {
                        "type": "string",
                        "enum": ["", "f", "d"],
                        "description": "\"f\" files only, \"d\" directories only, empty = both.",
                        "default": "",
                    },
                },
                "required": ["query"],
            },
        },
        {
            "name": "launch_app",
            "description": "Launch a MiOS-registered Windows/Linux app by short name. Resolves through the canonical chain (Steam/Epic/Xbox/GOG/Battle.net via protocol handler, Windows Start Menu .url shortcuts via Everything, MiOS shim, Linux GUI, plain CLI). EXECUTE the launcher's returned target verbatim -- NEVER substitute your own choice (e.g. don't call Steam install when launch_app returned a uplay:// URI).",
            "parameters": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
