                "required": ["name"],
            },
        },
        {
            "name": "mios_find",
            "description": "Resolve an app's launch info WITHOUT launching it (read-only). Returns the canonical command the launcher would execute. Use this when you want to know whether something is installed / how it would be invoked, before deciding whether to call launch_app.",
            "parameters": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "App short name (same matching rules as launch_app).",
                    }
                },
                "required": ["name"],
            },
        },
        {
            "name": "mios_apps",
            "description": "Inventory every installed app across all sources (Steam/Epic/Xbox/MS Store/flatpak/RPM/Windows shortcuts/MiOS shims/CLIs). Cached 5 minutes. Use to disambiguate when the operator's name is vague; check this BEFORE assuming an app is on a specific platform.",
            "parameters": {
                "type": "object",
