#!/usr/bin/env python3
"""mios-owui-apply-system-prompt -- seed the MiOS-Agent model registration in
Open WebUI with the MiOS-managed system prompt.

OWUI stores per-model overrides in its sqlite db at
/var/lib/mios/open-webui/webui.db, table `model`, column `params` (JSON).
The `params.system` field is what OWUI prepends to the user's first
message in every chat that selects this model -- it rides on top of
Hermes's SOUL.md (the agent's own persona) as belt-and-suspenders
reinforcement. See /usr/share/mios/open-webui/system-prompts/mios-agent.md
for the rationale.

Idempotent. Re-seed conditions (mirror SOUL.md re-seed logic):
  * model row absent: skip with a clear log line
  * params.system absent OR contains "MiOS-managed" marker AND content
    differs from source: write source content
  * params.system has been edited away from the marker: leave alone
    (operator has taken ownership)

Designed to be safe to run from a Quadlet ExecStartPost, a oneshot
service, or the operator's shell. Returns 0 on success/no-op.
"""
import json
import os
import sqlite3
import sys
from pathlib import Path

DB = Path(os.environ.get("MIOS_OWUI_DB", "/var/lib/mios/open-webui/webui.db"))
SRC_CANDIDATES = [
    Path(os.environ.get("MIOS_OWUI_PROMPT_SRC", "")),
    Path("/usr/share/mios/open-webui/system-prompts/mios-agent.md"),
    Path(f"{os.environ.get('MIOS_REPO', '')}/usr/share/mios/open-webui/system-prompts/mios-agent.md"),
]
MODEL_ID = os.environ.get("MIOS_OWUI_MODEL_ID", "hermes-agent")
MARKER = "MiOS-managed"


def _log(msg):
    print(f"[mios-owui-apply-system-prompt] {msg}", file=sys.stderr)


def _resolve_source():
    for p in SRC_CANDIDATES:
        if p and p.is_file():
            return p
    return None


# Friendly name shown in OWUI's model picker (operator directive
# 2026-05-15: rename "hermes-agent" -> "MiOS-Agent" globally).
DISPLAY_NAME = os.environ.get("MIOS_OWUI_DISPLAY_NAME", "MiOS-Agent")
DESCRIPTION = "MiOS Agent -- the local agent stack (Hermes-Agent gateway over Ollama)."


def main():
    src = _resolve_source()
    if src is None:
        _log("FATAL: no system-prompt source found in any candidate path")
        return 2
    if not DB.exists():
        _log(f"OWUI db {DB} not present yet -- skipping (re-run after OWUI first start)")
        return 0
    src_text = src.read_text(encoding="utf-8")

    import time
    conn = sqlite3.connect(str(DB))
    try:
        row = conn.execute(
            "SELECT id, name, params, meta FROM model WHERE id = ? LIMIT 1", (MODEL_ID,)
        ).fetchone()
        now = int(time.time())

        if row is None:
            # OWUI auto-discovers models from the upstream API and inserts
            # rows on first chat -- but if we run before that's happened,
            # create the row ourselves so the operator's picker shows the
            # MiOS branding from first launch instead of "hermes-agent".
            params = {"system": src_text}
            meta = {
                "profile_image_url": "/static/favicon.png",
                "description": DESCRIPTION,
                "capabilities": {
                    "file_context": True, "vision": True, "file_upload": True,
                    "web_search": True, "image_generation": True,
                    "code_interpreter": True, "terminal": True, "citations": True,
                    "status_updates": True, "usage": True, "builtin_tools": True
                },
                "suggestion_prompts": None, "tags": []
            }
            # Match the OWUI 0.9.x model schema EXACTLY:
            #   id, user_id, base_model_id, name, meta, params,
            #   created_at, updated_at, is_active
            # (no access_control column in this version)
            conn.execute(
                "INSERT INTO model (id, user_id, base_model_id, name, "
                "meta, params, created_at, updated_at, is_active) "
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
                (MODEL_ID, "", None, DISPLAY_NAME,
                 json.dumps(meta), json.dumps(params), now, now, 1)
            )
            conn.commit()
            _log(f"created MiOS-Agent model row (id={MODEL_ID!r}, name={DISPLAY_NAME!r}) "
                 f"with system prompt + capabilities + favicon")
            return 0

        _id, name, params_json, meta_json = row
        params = json.loads(params_json) if params_json else {}
        meta = json.loads(meta_json) if meta_json else {}
        existing_system = params.get("system", "")

        # Detect operator-customised state: if the operator edited the
        # system prompt OR renamed the model away from MiOS-managed
        # defaults, leave everything alone (per MiOS-managed marker
        # convention).
        if existing_system and MARKER not in existing_system:
            _log(
                f"model {_id!r}: operator-customised system prompt detected (no '{MARKER}' "
                "marker) -- leaving the entire row alone"
            )
            return 0

        # We OWN this row -- ensure name + meta + params all reflect the
        # MiOS defaults. Idempotent: rebuild the dicts from current state +
        # apply the MiOS-managed values.
        changes = []
        if name != DISPLAY_NAME:
            changes.append(f"name {name!r} -> {DISPLAY_NAME!r}")
        if existing_system != src_text:
            changes.append(f"system prompt ({len(src_text)} chars; "
                          f"{'replaced MiOS-managed' if existing_system else 'was empty'})")
        meta_desc = meta.get("description") if isinstance(meta, dict) else None
        if meta_desc != DESCRIPTION:
            changes.append("meta.description")

        if not changes:
            _log(f"model {_id!r}: name + system + description all current -- no-op")
            return 0

        params["system"] = src_text
        if isinstance(meta, dict):
            meta["description"] = DESCRIPTION
            meta.setdefault("profile_image_url", "/static/favicon.png")
        else:
            meta = {"profile_image_url": "/static/favicon.png", "description": DESCRIPTION}

        conn.execute(
            "UPDATE model SET name = ?, params = ?, meta = ?, updated_at = ? WHERE id = ?",
            (DISPLAY_NAME, json.dumps(params), json.dumps(meta), now, _id)
        )
        conn.commit()
        _log(f"model {_id!r}: applied {', '.join(changes)}")
        return 0
    finally:
        conn.close()


if __name__ == "__main__":
    sys.exit(main())
