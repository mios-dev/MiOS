#!/bin/bash
# AI-hint: Build-time helper that bakes the logically-bound Quadlet images (ARCH LAW 3) into the immutable /usr/lib/containers/storage additional store in CHUNKS -- one OCI layer per chunk -- so no single RUN layer commit exceeds buildah's large-layer ceiling (the >15-image "committing container ... exit code 125" failure). Called once per chunk from the Containerfile.
# AI-related: Containerfile, /usr/lib/bootc/bound-images.d, automation/08-system-files-overlay.sh, mios-additionalimagestores-perms
# AI-functions: (none -- linear bake)
# /usr/libexec/mios/mios-bake-bound-images <chunk-index> <chunk-total>
#
# WHY chunked (operator-confirmed 2026-06-19, build exit 125): the bound-images
# bake used to pull ALL bound images in ONE RUN -> ONE multi-GB OCI layer. buildah
# fails to commit a layer that large/file-dense ("Error: committing container ...
# exit code 125"; same class as the 2026-05-15 chmod -R >15-image failure). Pulling
# the images across N RUN steps (this script, once per chunk) yields N smaller
# layers, each well under the commit ceiling. The image content is identical; only
# the layer boundaries change.
#
# Round-robins the rendered bound images by index (idx % total == chunk) so the
# chunks are balanced. fail-loud per chunk (test failed -eq 0) keeps ARCH LAW 3's
# "any bound image that fails to bake fails the build LOUD". The LAST chunk also
# world-reads the per-driver toplevel store dirs (deep recursion happens at boot
# via mios-additionalimagestores-perms.service; NOT chmod -R here -- that recursion
# is what produced the >15-image commit failure in the first place).
#
# MIOS_BAKE_DRY_RUN=1 -> list what each chunk WOULD pull (no network/pull); used to
# verify the partition logic without baking.
set -eux

CHUNK="${1:-0}"
TOTAL="${2:-1}"
[ "$TOTAL" -ge 1 ] || TOTAL=1

install -d -m 0755 /usr/lib/containers/storage

baked=0
failed=0
skipped=0
idx=-1
for q in /usr/lib/bootc/bound-images.d/*.container; do
    [ -e "$q" ] || continue
    img="$(sed -n 's/^Image=//p' "$q" | head -1 | tr -d ' \r')"
    img="$(printf '%s' "$img" | sed -E 's/\$\{[A-Za-z_][A-Za-z0-9_]*:-([^}]*)\}/\1/g')"
    [ -n "$img" ] || continue
    case "$img" in *'$'*) echo "SKIP unrendered Image=$img ($q)"; continue ;; esac

    # Round-robin partition: count every rendered candidate, process only this
    # chunk's slice. (localhost/ + short-name handling stays inside the chunk so
    # each image is considered by EXACTLY one chunk.)
    idx=$((idx + 1))
    [ "$((idx % TOTAL))" -eq "$CHUNK" ] || continue

    first="${img%%/*}"
    case "$first" in
        *.*|*:*) ;;
        localhost)
            # localhost/<name> = an un-pushed locally-built image (no registry at
            # `localhost`); produced by a different MiOS build phase (e.g.
            # automation/45-coderun-sandbox-build.sh). Skip the registry pull.
            echo "SKIP localhost/ bound image $img (built by a different phase)"
            skipped=$((skipped + 1)); continue ;;
        *)
            echo "ERROR: bound image '$img' has a short name (no registry in '$first'). Fix the source (typically /usr/share/mios/mios.toml [image.sidecars]) to include a registry prefix. Quadlet: $q"
            failed=$((failed + 1)); continue ;;
    esac

    echo "bound-image[chunk $CHUNK/$TOTAL]: baking $img"
    if [ -n "${MIOS_BAKE_DRY_RUN:-}" ]; then
        echo "  [dry-run] would pull $img"
        baked=$((baked + 1)); continue
    fi
    _pulled=0
    for _try in 1 2 3; do
        if podman --root /usr/lib/containers/storage pull "$img"; then _pulled=1; break; fi
        echo "  pull attempt $_try/3 failed for $img -- retrying in 3s"; sleep 3
    done
    if [ "$_pulled" = 1 ]; then
        baked=$((baked + 1))
    else
        echo "ERROR: failed to bake bound image $img after 3 attempts"
        failed=$((failed + 1))
    fi
done

echo "bound-images[chunk $CHUNK/$TOTAL]: baked=$baked skipped=$skipped failed=$failed"
test "$failed" -eq 0

# LAST chunk: make the per-driver TOPLEVEL store dirs world-readable so
# unprivileged podman/flatpak callers can read the additional store. ONLY the
# toplevel dirs (NOT chmod -R -- that deep recursion produced the buildah
# large-layer commit failure); the deep chmod happens at boot via
# mios-additionalimagestores-perms.service.
if [ "$CHUNK" -eq "$((TOTAL - 1))" ] && [ -z "${MIOS_BAKE_DRY_RUN:-}" ]; then
    echo "bound-images: chmod 0755 the per-driver toplevel dirs"
    for d in /usr/lib/containers/storage \
             /usr/lib/containers/storage/overlay \
             /usr/lib/containers/storage/overlay-images \
             /usr/lib/containers/storage/overlay-containers \
             /usr/lib/containers/storage/overlay-layers \
             /usr/lib/containers/storage/libpod; do
        [ -d "$d" ] && chmod 0755 "$d"
    done
fi
