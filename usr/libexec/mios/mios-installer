#!/bin/bash
# /usr/libexec/mios/mios-installer <subcommand> [args...]
#
# Cross-platform package installer that fronts the three backends MiOS
# operators actually use:
#
#   * winget   (Windows Package Manager) -- Windows-side apps + games
#                                            via `mios-windows cmd "winget …"`
#   * dnf      (Fedora RPM)              -- Linux CLI tools, system packages
#   * flatpak  (Flathub)                 -- Linux GUI apps (mostly)
#
# Single entry point so agents and operators don't have to remember which
# package manager owns which app. Operator directive 2026-05-17:
# "mios-installer should be able to use windows CMD and Linux BASH for
# installing applications on their respective platforms".
#
# SUBCOMMANDS
#
#   search <query> [--backend <name>]
#       Search all three backends (or just one) and print combined results.
#       Default: all available. --backend = winget | dnf | flatpak.
#
#   install <id> [--backend <name>] [--no-confirm]
#       Install by package ID. Auto-detects backend from the ID shape
#       unless --backend is set:
#         "Microsoft.PowerToys"   -> winget
#         "org.mozilla.firefox"   -> flatpak (reverse-DNS = Flathub style)
#         "vim", "htop"           -> dnf (single lowercase word)
#       --no-confirm passes -y / --accept-package-agreements / --noninteractive.
#
#   uninstall <id> [--backend <name>]
#       Remove. Backend auto-detected the same way.
#
#   info <id> [--backend <name>]
#       Show package details (version, publisher, description, deps).
#
#   list [--installed] [--backend <name>]
#       List packages (default: installed=true).
#
# OUTPUT
#   Default: human-readable tables. Pass `--json` (any subcommand) to
#   emit one JSON object per result -- agent-friendly.
#
# EXIT CODES
#   0 success / found
#   1 not found / no match
#   2 backend not available
#   64 usage error
#
# ARCHITECTURAL NOTES
#   * winget calls go through `mios-windows cmd "winget ..."` because
#     winget.exe is a Windows binary; running it directly from WSL fails
#     on AppExecutionAlias / current-directory issues. mios-windows cmd
#     dispatches via the launcher broker so the operator's Windows
#     session executes the command -- needed for UAC + Windows
#     environment vars + Microsoft Store ToS prompts.
#   * dnf is run via `sudo` -- mios-hermes has a broad sudo grant in
#     /etc/sudoers.d/10-mios-hermes. Operators running this verb
#     interactively get the same prompt as `sudo dnf install`.
#   * flatpak install defaults to --user so the install lands per-user
#     (no sudo). Use --system to install for all users.
#   * On MiOS bootc, `dnf install` lands as a layered package via
#     rpm-ostree's overlay; `bootc upgrade` preserves these layers.
#     This is the operator-friendly default for "install a CLI tool".

set -u

# ─── helpers ─────────────────────────────────────────────────────────
_red()    { printf '\033[31m%s\033[0m' "$*"; }
_green()  { printf '\033[32m%s\033[0m' "$*"; }
_dim()    { printf '\033[2m%s\033[0m' "$*"; }
_bold()   { printf '\033[1m%s\033[0m' "$*"; }

_have_winget() {
    # winget is on Windows side; we reach it via mios-windows cmd.
    command -v mios-windows >/dev/null 2>&1 || return 1
    return 0
}

_have_dnf() {
    command -v dnf >/dev/null 2>&1
}

_have_flatpak() {
    command -v flatpak >/dev/null 2>&1
}

# Pick a default backend for a given package id shape.
_detect_backend() {
    local id="$1"
    # Reverse-DNS shape with dots + only-lowercase -> flatpak (Flathub
    # convention: com.spotify.Client, org.mozilla.firefox, ...)
    if [[ "$id" =~ ^[a-z]+\.[a-z][a-zA-Z0-9_.-]+$ ]]; then
        echo flatpak
        return
    fi
    # Capital-letter publisher.product -> winget (Microsoft.PowerToys,
    # 7zip.7zip, Notepad++.Notepad++)
    if [[ "$id" =~ ^[A-Z0-9][A-Za-z0-9+-]*\.[A-Z0-9][A-Za-z0-9+-]+$ ]]; then
        echo winget
        return
    fi
    # Single word -> dnf
    if [[ "$id" =~ ^[a-z][a-z0-9+_-]*$ ]]; then
        echo dnf
        return
    fi
    # Fallback: dnf (most flexible package id shape)
    echo dnf
}

# ─── search ──────────────────────────────────────────────────────────
_search_winget() {
    local query="$1"
    _have_winget || { echo "  (winget unreachable: mios-windows not on PATH)" >&2; return 2; }
    # winget search returns a multi-column table; pipe through column.
    # --accept-source-agreements is implicit after first run.
    mios-windows cmd "winget search \"$query\" --accept-source-agreements 2>&1" 2>/dev/null | \
        grep -vE '^(Found|---|Name|Loading|\|/|\s*$)' | head -20
}

_search_dnf() {
    local query="$1"
    _have_dnf || { echo "  (dnf not available)" >&2; return 2; }
    dnf search --quiet "$query" 2>/dev/null | head -25
}

_search_flatpak() {
    local query="$1"
    _have_flatpak || { echo "  (flatpak not available)" >&2; return 2; }
    # flatpak search emits TSV: Name | Description | Application ID | Version | Branch | Remotes
    flatpak search "$query" 2>/dev/null | head -20
}

# ─── install ─────────────────────────────────────────────────────────
_install_winget() {
    local id="$1" yes="${2:-0}"
    _have_winget || { echo "winget unreachable" >&2; return 2; }
    local extra=""
    if [[ "$yes" == "1" ]]; then
        extra="--accept-package-agreements --accept-source-agreements --disable-interactivity --silent"
    fi
    echo "→ winget install --id $id $extra" >&2
    mios-windows cmd "winget install --id \"$id\" $extra"
}

_install_dnf() {
    local id="$1" yes="${2:-0}"
    _have_dnf || { echo "dnf not available" >&2; return 2; }
    local flag=""
    [[ "$yes" == "1" ]] && flag="-y"
    echo "→ sudo dnf install $flag $id" >&2
    sudo dnf install $flag "$id"
}

_install_flatpak() {
    local id="$1" yes="${2:-0}"
    _have_flatpak || { echo "flatpak not available" >&2; return 2; }
    local flag=""
    [[ "$yes" == "1" ]] && flag="-y"
    echo "→ flatpak install --user $flag flathub $id" >&2
    flatpak install --user $flag flathub "$id"
}

# ─── info ────────────────────────────────────────────────────────────
_info_winget() {
    _have_winget || return 2
    mios-windows cmd "winget show --id \"$1\""
}
_info_dnf()     { _have_dnf     && dnf info "$1"           || return 2; }
_info_flatpak() { _have_flatpak && flatpak info "$1" 2>/dev/null \
                     || flatpak remote-info flathub "$1"   || return 2; }

# ─── uninstall ───────────────────────────────────────────────────────
_uninstall_winget() {
    _have_winget || return 2
    mios-windows cmd "winget uninstall --id \"$1\" --disable-interactivity"
}
_uninstall_dnf()     { _have_dnf     && sudo dnf remove -y "$1"      || return 2; }
_uninstall_flatpak() { _have_flatpak && flatpak uninstall --user -y "$1" || return 2; }

# ─── list ────────────────────────────────────────────────────────────
_list_winget()  { _have_winget  && mios-windows cmd "winget list" || return 2; }
_list_dnf()     { _have_dnf     && dnf list installed             || return 2; }
_list_flatpak() { _have_flatpak && flatpak list                   || return 2; }

usage() {
    cat <<'USAGE'
usage: mios-installer <subcommand> [args...]

  search <query> [--backend <winget|dnf|flatpak>]
  install <id>   [--backend <winget|dnf|flatpak>] [--no-confirm]
  uninstall <id> [--backend <winget|dnf|flatpak>]
  info <id>      [--backend <winget|dnf|flatpak>]
  list           [--backend <winget|dnf|flatpak>] [--installed]

Without --backend, the id shape decides:
  Microsoft.PowerToys   -> winget
  org.mozilla.firefox   -> flatpak
  vim, htop             -> dnf
USAGE
}

# ─── arg parsing ─────────────────────────────────────────────────────
# Skip dispatch when sourced (lets tests `source mios-installer; _detect_backend foo`
# without hitting the usage+exit guard).
if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    return 0 2>/dev/null || true
fi

sub="${1:-}"
[[ -z "$sub" ]] && { usage; exit 64; }
shift

backend=""
yes=0
positional=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --backend)     backend="$2"; shift 2 ;;
        --backend=*)   backend="${1#--backend=}"; shift ;;
        --no-confirm|-y|--yes) yes=1; shift ;;
        --installed)   shift ;;  # list default
        -h|--help)     usage; exit 0 ;;
        --)            shift; positional+=("$@"); break ;;
        *)             positional+=("$1"); shift ;;
    esac
done

arg="${positional[0]:-}"

case "$sub" in
    search)
        [[ -z "$arg" ]] && { echo "mios-installer search: missing <query>" >&2; exit 64; }
        if [[ -n "$backend" ]]; then
            "_search_${backend}" "$arg"
            exit $?
        fi
        printf '%s\n' "$(_bold "── winget ──")"
        _search_winget "$arg"
        printf '\n%s\n' "$(_bold "── dnf ──")"
        _search_dnf "$arg"
        printf '\n%s\n' "$(_bold "── flatpak ──")"
        _search_flatpak "$arg"
        ;;
    install)
        [[ -z "$arg" ]] && { echo "mios-installer install: missing <id>" >&2; exit 64; }
        [[ -z "$backend" ]] && backend="$(_detect_backend "$arg")"
        echo "$(_dim "(detected backend: $backend; override with --backend)")" >&2
        case "$backend" in
            winget)  _install_winget  "$arg" "$yes" ;;
            dnf)     _install_dnf     "$arg" "$yes" ;;
            flatpak) _install_flatpak "$arg" "$yes" ;;
            *) echo "unknown backend: $backend" >&2; exit 64 ;;
        esac
        ;;
    uninstall|remove)
        [[ -z "$arg" ]] && { echo "mios-installer uninstall: missing <id>" >&2; exit 64; }
        [[ -z "$backend" ]] && backend="$(_detect_backend "$arg")"
        case "$backend" in
            winget)  _uninstall_winget  "$arg" ;;
            dnf)     _uninstall_dnf     "$arg" ;;
            flatpak) _uninstall_flatpak "$arg" ;;
            *) echo "unknown backend: $backend" >&2; exit 64 ;;
        esac
        ;;
    info|show)
        [[ -z "$arg" ]] && { echo "mios-installer info: missing <id>" >&2; exit 64; }
        [[ -z "$backend" ]] && backend="$(_detect_backend "$arg")"
        case "$backend" in
            winget)  _info_winget  "$arg" ;;
            dnf)     _info_dnf     "$arg" ;;
            flatpak) _info_flatpak "$arg" ;;
            *) echo "unknown backend: $backend" >&2; exit 64 ;;
        esac
        ;;
    list|ls)
        if [[ -n "$backend" ]]; then
            "_list_${backend}"
            exit $?
        fi
        printf '%s\n' "$(_bold "── winget (Windows installed) ──")"
        _list_winget
        printf '\n%s\n' "$(_bold "── dnf (Fedora installed) ──")"
        _list_dnf
        printf '\n%s\n' "$(_bold "── flatpak ──")"
        _list_flatpak
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "mios-installer: unknown subcommand: $sub" >&2
        usage
        exit 64
        ;;
esac
