#!/bin/bash
# AI-hint: Purges volatile runtime data (sessions, tool_calls, knowledge, logs) from SurrealDB while preserving core system configurations and identity keys to reset the AI's operational state to a clean "day-0" baseline.
# AI-related: /usr/libexec/mios/mios-day0-reset, mios-agent-pipe, mios-hermes-tail, mios-daemon, mios-mcp, mios-pgvector, mios-daemon-state, mios-ai, mios-agent-pipe.service, hermes-agent.service
# AI-functions: SR
# mios-day0-reset
#
# Clear MiOS runtime + AI state back to a day-0 starting point.
# Operator-invoked: drops chat history, every tool_call/event/knowledge
# row, scratchpads, sessions, OWUI chats, SearXNG/crawl caches. KEEPS
# /etc, /usr, agent definitions, person/skill/app_install inventories,
# the ed25519 passport keypairs, MCP + A2A registries (operator config).
#
# Why a script: a chat-turn through Claude can't perform mass deletes
# (the auto-mode classifier blocks named-target destructive ops without
# explicit per-target authorization). This script bundles the canonical
# target set so a human operator can re-run it as needed without
# re-debating scope each time.
#
# Idempotent enough to re-run; not a "factory reset" -- the host stays
# fully provisioned. For a deeper reset (passport keys, agents, skills),
# extend the SR_DROP / KEEP lists below.
#
# Usage: sudo /usr/libexec/mios/mios-day0-reset
set -uo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "must be root (use sudo)" >&2
  exit 1
fi

SR() {
  curl -s -u root:root \
    -H 'surreal-ns: mios' -H 'surreal-db: mios' \
    -H 'Accept: application/json' \
    -X POST http://localhost:8000/sql --data "$1"
}

# Tables CLEARED at reset (runtime + AI state).
SR_DROP=(
  session tool_call knowledge scratch skill_invocation log_digest
  emitted agent_metric kanban_shadow directory_entry
)
# Tables PRESERVED (definitional + operator-curated):
#   agent agent_keypair alias app_install includes owns person resolves_to skill

echo "==> stopping live agents for clean DB writes"
systemctl stop mios-agent-pipe.service hermes-agent.service \
  mios-hermes-tail.service mios-daemon.service hermes-dashboard.service \
  mios-mcp.service 2>/dev/null

echo "==> clearing SurrealDB runtime tables"
for T in "${SR_DROP[@]}"; do
  printf "   %-20s -> " "$T"
  SR "DELETE $T;" | python3 -c \
    'import sys,json; print(json.load(sys.stdin)[0].get("status","?"))' 2>/dev/null
done

# `event` is high-volume; SurrealDB's memtable runs out mid-DELETE on
# >100k rows. Drop+redefine the table (schema reinstated below).
echo "   event                -> drop+redefine (high-volume bypass)"
SR "REMOVE TABLE event;
DEFINE TABLE event TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;
DEFINE FIELD kind ON event TYPE string PERMISSIONS FULL;
DEFINE FIELD passport ON event TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD payload  ON event TYPE none | object FLEXIBLE PERMISSIONS FULL;
DEFINE FIELD severity ON event TYPE string DEFAULT 'info' PERMISSIONS FULL;
DEFINE FIELD source   ON event TYPE string PERMISSIONS FULL;
DEFINE FIELD summary  ON event TYPE string PERMISSIONS FULL;
DEFINE FIELD ts       ON event TYPE datetime PERMISSIONS FULL;
DEFINE INDEX event_kind   ON event FIELDS kind;
DEFINE INDEX event_source ON event FIELDS source;
DEFINE INDEX event_ts     ON event FIELDS ts;" > /dev/null

# ── pgvector is the PRIMARY agent store since the SurrealDB->pgvector migration
# (the SurrealDB DELETEs above are now legacy/no-op for a pg-primary host but kept
# so a Surreal-primary host still resets). Clear the SAME runtime/AI tables in pg.
# KEEP the definitional/operator-curated tables (alias, app_install, resolves_to,
# run_template, skill) AND mios_rag (the docs-index RAG = baked SYSTEM knowledge,
# regenerated from /usr/share/doc -- leave it so "full AI systems knowledge" stays
# baked). TRUNCATE keeps schema + indexes; one statement so FK order never bites.
PG_DROP="knowledge session tool_call scratch skill_invocation log_digest event directory_entry agent_memory kanban pending_action sys_env"
echo "==> clearing pgvector runtime/AI tables (db=mios)"
if podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^mios-pgvector$'; then
  _pglist=$(echo "$PG_DROP" | tr ' ' '\n' | while read -r T; do
    [[ -n "$T" ]] && podman exec mios-pgvector psql -U mios -d mios -tAc \
      "SELECT to_regclass('public.$T');" 2>/dev/null | grep -qx "$T" && printf '%s,' "$T"
  done)
  _pglist=${_pglist%,}
  if [[ -n $_pglist ]]; then
    podman exec mios-pgvector psql -U mios -d mios -c \
      "TRUNCATE TABLE $_pglist RESTART IDENTITY;" 2>&1 | sed 's/^/   /'
    printf "   truncated: %s\n" "$_pglist"
  else
    echo "   (no matching pg tables found)"
  fi
else
  echo "   (mios-pgvector container not running -- skipped)"
fi

echo "==> clearing filesystem runtime dirs"
DIRS=(
  /var/home/mios/.hermes/sessions
  /var/home/mios/.hermes/logs
  /var/home/mios/.hermes/cache
  /var/lib/mios/hermes/sessions
  /var/lib/mios/hermes/logs
  /var/lib/mios/hermes/cache
  /var/lib/mios/agent-pipe
  /var/lib/mios/daemon/scratch
  /var/lib/mios/daemon/cache
  /var/lib/mios/ai/scratch
  /var/lib/mios/ai/memory
  /var/lib/mios/ai/audit
  /var/lib/mios/mcp
  /var/log/mios/ai/audit
  /var/log/mios/mcp
  /var/log/mios/daemon
  /var/cache/mios
)
for D in "${DIRS[@]}"; do
  [[ -d $D ]] && find "$D" -mindepth 1 -delete 2>/dev/null && \
    printf "   cleared %s\n" "$D"
done

# Day-0 reset also resets dir OWNERSHIP that drifted (the agent-plane
# user consolidation left some dirs owned by the legacy `mios` user).
# Without this, mcp-init.sh + mios-daemon-state fail with EPERM after
# clearing because tmpfiles 'd' does not re-chown EXISTING dirs (only
# creates missing). Make every service-owned dir mios-ai:mios-ai 0750.
echo "==> reasserting mios-ai ownership on service dirs"
for D in /var/lib/mios/mcp /var/lib/mios/daemon \
         /var/lib/mios/agent-pipe /var/lib/mios/ai \
         /var/log/mios/mcp /var/log/mios/daemon /var/log/mios/ai; do
  install -d -o mios-ai -g mios-ai -m 0750 "$D" 2>/dev/null
done

echo "==> /tmp scratch"
find /tmp -maxdepth 2 -name 'mios-*'       -delete 2>/dev/null || true
find /tmp -maxdepth 2 -name 'agent-pipe-*' -delete 2>/dev/null || true
find /tmp -maxdepth 2 -name 'a2a_*'        -delete 2>/dev/null || true

echo "==> retrieval caches"
[[ -d /var/lib/mios/searxng ]] && \
  find /var/lib/mios/searxng -name '*.cache*' -delete 2>/dev/null
for D in /var/lib/mios/crawl4ai/cache /var/home/mios/.crawl4ai; do
  [[ -d $D ]] && find "$D" -mindepth 1 -delete 2>/dev/null
done
if podman ps --format '{{.Names}}' 2>/dev/null | grep -q '^firecrawl-redis'; then
  podman exec firecrawl-redis redis-cli FLUSHALL 2>/dev/null || true
fi

echo "==> OWUI chat history"
OWUI_DB=/var/lib/mios/open-webui/webui.db
if [[ -f $OWUI_DB ]]; then
  python3 -c "
import sqlite3
c=sqlite3.connect('$OWUI_DB'); cur=c.cursor()
cur.execute('SELECT name FROM sqlite_master WHERE type=\"table\";')
tables={r[0] for r in cur.fetchall()}
targets=[t for t in ('chat','message','chat_message','chat_file','chatidtag',
                     'shared_chat','message_reaction','memory','feedback',
                     'prompt_history','automation_run') if t in tables]
for t in targets:
    cur.execute(f'SELECT count(*) FROM {t};'); pre=cur.fetchone()[0]
    cur.execute(f'DELETE FROM {t};')
    if pre: print(f'   owui.{t}: {pre} -> 0')
c.commit(); c.execute('VACUUM;'); c.close()"
fi

echo "==> restarting agents on fresh state"
systemctl reset-failed mios-mcp.service mios-daemon.service 2>/dev/null
systemctl start mios-mcp.service mios-daemon.service \
  hermes-agent.service hermes-dashboard.service \
  mios-agent-pipe.service mios-hermes-tail.service 2>/dev/null
sleep 8
echo
echo "==> POST-RESET service status"
systemctl is-active mios-mcp.service mios-daemon.service \
  hermes-agent.service hermes-dashboard.service \
  mios-agent-pipe.service mios-hermes-tail.service 2>&1 \
  | paste <(echo -e "mios-mcp\nmios-daemon\nhermes-agent\nhermes-dashboard\nagent-pipe\nhermes-tail") -

echo
echo "Day-0 reset complete."
