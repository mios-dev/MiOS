#!/usr/bin/env python3
# AI-hint: Thin client for the resident qwen3:1.7b model on the mios-llm-light /v1 lane, providing low-latency (<500ms) classification for mios-log-watcher, mios-cron-director, and other system agents.
# AI-related: /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-log-watcher, mios-cron-director, mios-log-watcher.service, mios-cron-director.service, localhost:8450
"""mios-micro-llm -- thin client + persistent-loaded helper for the
always-on tiny model.

Used by:
  * mios-log-watcher.service -- classifies journal events
  * mios-cron-director.service -- gates scheduled tasks on system state
  * any agent / shim that wants <500 ms classification

The "micro" model is configured via mios.toml [ai].micro_model
(default qwen3:1.7b -- the 4-model-set micro/CPU base, ~1.4 GB
resident; was qwen3:0.6b before the 2026-06-01 consolidation).
Kept warm on the mios-llm-light /v1 lane (llama-swap owns residency/TTL).

USAGE
    mios-micro-llm classify <prompt>            -> single-line answer
    mios-micro-llm classify --json <prompt>     -> JSON wrapper
    mios-micro-llm warm                         -> issue a 1-token gen to load
    mios-micro-llm status                       -> is it loaded? latency probe

CONFIG (per layered mios.toml [ai] priority):
    [ai]
    micro_model    = "qwen3:1.7b"
    micro_endpoint = "http://localhost:8450/v1"
    micro_keep_alive_seconds = -1   # -1 = never unload
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import time
import urllib.request
import urllib.error
from pathlib import Path

DEFAULT_MODEL = "qwen3:1.7b"  # 4-model-set micro base (was qwen3:0.6b, dropped 2026-06-01); SSOT is mios.toml [ai].micro_model
DEFAULT_ENDPOINT = "http://localhost:8450/v1"
DEFAULT_KEEP_ALIVE = "-1"  # never unload
DEFAULT_TIMEOUT_S = 30


sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib", "mios"))
import mios_toml  # noqa: E402  -- the ONE shared layered-mios.toml resolver


def _toml_layered(section: str, key: str):
    """Read [section].key from the layered mios.toml (per-user > host > vendor)
    via the shared real-TOML resolver. Replaces the former stdlib regex
    line-scanner, which disagreed with tomllib on quoting/precedence."""
    return mios_toml.get(section, key, None)


def _resolve() -> tuple[str, str, str]:
    # micro_* lives in [ai.host_thresholds] per the vendored mios.toml.
    # Probe [ai] first (operator restructure), fall back to
    # [ai.host_thresholds] (vendor default).
    model = (
        os.environ.get("MIOS_MICRO_MODEL")
        or _toml_layered("ai", "micro_model")
        or _toml_layered("ai.host_thresholds", "micro_model")
        or DEFAULT_MODEL
    )
    endpoint = (
        os.environ.get("MIOS_MICRO_ENDPOINT")
        or _toml_layered("ai", "micro_endpoint")
        or _toml_layered("ai.host_thresholds", "micro_endpoint")
        or DEFAULT_ENDPOINT
    ).rstrip("/")
    keep_alive = (
        os.environ.get("MIOS_MICRO_KEEP_ALIVE")
        or _toml_layered("ai", "micro_keep_alive_seconds")
        or _toml_layered("ai.host_thresholds", "micro_keep_alive_seconds")
        or DEFAULT_KEEP_ALIVE
    )
    return model, endpoint, keep_alive


def _post_chat(endpoint: str, model: str, system: str, user: str,
               *, max_tokens: int = 200, keep_alive: str = "-1") -> str:
    payload = {
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "max_tokens": max_tokens,
        "temperature": 0.1,
        "stream": False,
        # keep_alive residency hint (llama-swap honours its own TTL; a lane that
        # doesn't recognise it ignores the extra field).
        "keep_alive": keep_alive,
    }
    req = urllib.request.Request(
        f"{endpoint}/chat/completions",
        data=json.dumps(payload).encode(),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    
    for attempt in range(3):
        try:
            with urllib.request.urlopen(req, timeout=DEFAULT_TIMEOUT_S) as r:
                body = json.loads(r.read())
            return ((body.get("choices") or [{}])[0].get("message") or {}).get("content", "")
        except Exception as e:
            if attempt == 2:
                raise
            time.sleep(0.5 * (attempt + 1))


CLASSIFY_SYSTEM = (
    "You are a fast micro-classifier for MiOS. Reply with a SINGLE LINE -- no "
    "preamble, no explanation, no markdown. Match the user's request "
    "format precisely. Always spell the operating system name as MiOS (never MIO or Mio)."
)


def cmd_classify(args, *, model, endpoint, keep_alive) -> int:
    started = time.monotonic()
    try:
        out = _post_chat(endpoint, model, CLASSIFY_SYSTEM, args.prompt,
                         max_tokens=args.max_tokens, keep_alive=keep_alive)
    except urllib.error.URLError as e:
        print(json.dumps({"error": str(e)}), file=sys.stderr)
        return 1
    elapsed = time.monotonic() - started
    out = out.strip()
    if args.json:
        print(json.dumps({
            "answer": out,
            "model": model,
            "elapsed_ms": int(elapsed * 1000),
        }))
    else:
        print(out)
    return 0


def cmd_warm(args, *, model, endpoint, keep_alive) -> int:
    started = time.monotonic()
    try:
        _post_chat(endpoint, model, "", "warm", max_tokens=1, keep_alive=keep_alive)
    except urllib.error.URLError as e:
        print(f"warm failed: {e}", file=sys.stderr)
        return 1
    elapsed = time.monotonic() - started
    print(f"[mios-micro-llm] warmed {model} in {int(elapsed*1000)} ms (keep_alive={keep_alive})")
    return 0


def cmd_status(args, *, model, endpoint, keep_alive) -> int:
    # /v1-only: there is no residency-listing endpoint on the OpenAI surface, so
    # gauge readiness with a 1-token latency probe -- a fast reply means the model
    # is warm on the lane; a failure means it is unreachable/cold.
    started = time.monotonic()
    try:
        _post_chat(endpoint, model, "", "ok", max_tokens=1, keep_alive=keep_alive)
        latency_ms = int((time.monotonic() - started) * 1000)
        is_loaded = True
    except urllib.error.URLError as e:
        print(json.dumps({"loaded": False, "error": str(e), "model": model}))
        return 1
    print(json.dumps({
        "model": model,
        "endpoint": endpoint,
        "keep_alive": keep_alive,
        "loaded": is_loaded,
        "latency_ms": latency_ms,
    }, indent=2))
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(description="MiOS micro-LLM thin client")
    sub = ap.add_subparsers(dest="cmd", required=True)

    c = sub.add_parser("classify", help="One-shot classify; prints single-line answer")
    c.add_argument("prompt", help="The classification prompt")
    c.add_argument("--json", action="store_true", help="Wrap output in JSON")
    c.add_argument("--max-tokens", type=int, default=200)

    sub.add_parser("warm", help="Issue a 1-token gen to keep the model loaded")
    sub.add_parser("status", help="Report whether the micro model is loaded")

    args = ap.parse_args()
    model, endpoint, keep_alive = _resolve()
    fn = {"classify": cmd_classify, "warm": cmd_warm, "status": cmd_status}[args.cmd]
    return fn(args, model=model, endpoint=endpoint, keep_alive=keep_alive)


if __name__ == "__main__":
    sys.exit(main())
