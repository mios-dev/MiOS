#!/bin/bash
# AI-hint: Resolves an abstract application type (e.g. browser, editor) into a concrete app name using the [[desktop.app_types]] SSOT in mios.toml.
set -euo pipefail

if [ "$#" -lt 1 ]; then
    echo "usage: mios-app-type <type>" >&2
    exit 64
fi

TYPE="$1"

python3 - "$TYPE" <<'PYEOF' 2>/dev/null
import sys
try:
    import tomllib
except ImportError:
    import tomli as tomllib

target_type = sys.argv[1].lower().strip()

def resolve():
    best_match = target_type
    # Read files in increasing order of priority.
    # /usr/share/mios/mios.toml is lowest (vendor)
    # /etc/mios/mios.toml is middle (host)
    # ~/.config/mios/mios.toml is highest (user)
    import os
    user_config = os.path.expanduser("~/.config/mios/mios.toml")
    
    for path in ("/usr/share/mios/mios.toml", "/etc/mios/mios.toml", user_config):
        try:
            with open(path, "rb") as f:
                d = tomllib.load(f)
            app_types = d.get("desktop", {}).get("app_types", [])
            for t in app_types:
                if t.get("type", "").lower() == target_type:
                    os_priority = t.get("os_priority", "linux-first")
                    linux_def = t.get("linux_default")
                    windows_def = t.get("windows_default")
                    
                    if os_priority == "windows":
                        best_match = windows_def or target_type
                    elif os_priority == "linux":
                        best_match = linux_def or target_type
                    else:
                        best_match = linux_def or windows_def or target_type
        except Exception:
            continue
    return best_match

res = resolve()
if res:
    print(res)
PYEOF
