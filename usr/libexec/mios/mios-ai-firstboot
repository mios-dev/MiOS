#!/usr/bin/env bash
# 'MiOS' AI first-boot provisioning.
#
# Completes the build-time AI setup on deployments where it wasn't baked into
# the image (overlay-provisioned MiOS-DEV, WSL imports, any non-bootc-built
# host). Two pieces, both idempotent + best-effort:
#   1. the shared agent venv (hermes-agent + agent-pipe), via the canonical
#      builder automation/38-hermes-agent.sh (checked out at / by the overlay);
#   2. the llama.cpp GGUFs for the llama-swap lane, extracted from ollama's
#      model blobs (the tags come from /usr/share/mios/llamacpp/llama-swap.yaml).
# Then it (re)starts the AI services so they pick up the new prerequisites.
#
# The sentinel /var/lib/mios/.ai-firstboot-done is written ONLY when BOTH the
# venv and the GGUFs are in place, so a network-less boot retries next time
# (mios-ai-firstboot.service carries ConditionPathExists=!<sentinel>).
#
# NO `set -e` -- every step is guarded; a partial provision must not wedge boot.
set +eu
log(){ logger -t mios-ai-firstboot "$*" 2>/dev/null; echo "[mios-ai-firstboot] $*"; }

VENV=/usr/lib/mios/agents/.venv
MODELS=/usr/share/mios/llamacpp/models

# ── 1. shared agent venv (hermes pins Python <3.14) ──────────────────────────
if [ ! -x "${VENV}/bin/hermes" ]; then
    if ! command -v python3.13 >/dev/null 2>&1; then
        log "installing python3.13 (hermes-agent requires >=3.11,<3.14)"
        dnf install -y python3.13 python3.13-devel >/dev/null 2>&1 || log "WARN: python3.13 install failed"
    fi
    # The canonical venv builder lives in automation/ (build-time). The overlay
    # checks out usr/etc/var to / but NOT automation/, so find it across the
    # locations it can actually be: a runtime copy, the / git working tree
    # (materialize on demand), or the mounted Windows mios.git clone on the dev VM.
    HSCRIPT=""
    # Require lib/common.sh ALONGSIDE the script: 38-hermes-agent.sh sources it
    # and exits 0 (no venv) if absent -- exactly what a script-only /automation
    # checkout yields. Prefer the full /mnt/m mios.git clone (has lib/).
    for p in /mnt/m/automation/38-hermes-agent.sh /mnt/c/MiOS/automation/38-hermes-agent.sh /usr/libexec/mios/38-hermes-agent.sh /automation/38-hermes-agent.sh; do
        [ -f "$p" ] && [ -f "$(dirname "$p")/lib/common.sh" ] && HSCRIPT="$p" && break
    done
    if [ -z "$HSCRIPT" ] && [ -d /.git ]; then
        git -C / checkout -- automation 2>/dev/null
        [ -f /automation/38-hermes-agent.sh ] && [ -f /automation/lib/common.sh ] && HSCRIPT=/automation/38-hermes-agent.sh
    fi
    if [ -n "$HSCRIPT" ]; then
        log "building shared agent venv via $HSCRIPT"
        bash "$HSCRIPT" 2>&1 | tail -12
    else
        log "WARN: 38-hermes-agent.sh not found (/, git, /mnt/m) -- agent venv NOT built"
    fi
    if [ -x "${VENV}/bin/hermes" ]; then log "agent venv ready: ${VENV}"; else log "WARN: agent venv still missing"; fi
fi

# ── 2. llama.cpp GGUFs (llama.cpp-NATIVE -- HF download; ollama retired, G5/G8) ─
# GGUFs are normally BAKED at build by automation/38-llamacpp-prep.sh (the
# offline-correct path). This firstboot block is the ONLINE retry for hosts that
# didn't bake them: it fetches the SAME MIOS_LLAMACPP_BAKE_MODELS spec
# (dest.gguf=hf_repo:file, FOSS pre-quantized) directly from Hugging Face -- NO
# ollama dependency (G5 retired it; the old blob-extraction path is dead). When
# air-gapped + unbaked the lane stays inert (operator sets [llamacpp].bake_models
# + rebuilds, or seeds ${MODELS} manually) -- it never blocks boot.
if [ ! -f "${MODELS}/.ready" ]; then
    install -d -m 0755 "${MODELS}" /var/lib/mios/llamacpp/slots 2>/dev/null
    SPEC="${MIOS_LLAMACPP_BAKE_MODELS:-}"
    if [ -z "$SPEC" ]; then
        log "GGUFs not baked + [llamacpp].bake_models empty -- llama-swap lane stays inert (set bake_models + rebuild, or seed ${MODELS} manually)"
    else
        fetched=0; total=0
        IFS=',' read -ra _ents <<< "$SPEC"
        for entry in "${_ents[@]}"; do
            entry="$(printf '%s' "$entry" | tr -d '[:space:]')"; [ -z "$entry" ] && continue
            total=$((total + 1))
            dest="${entry%%=*}"; rest="${entry#*=}"; repo="${rest%%:*}"; file="${rest#*:}"
            if [ -z "$dest" ] || [ -z "$repo" ] || [ -z "$file" ] || [ "$dest" = "$entry" ]; then
                log "malformed GGUF entry '${entry}' (want dest.gguf=repo:file) -- skipping"; continue
            fi
            if [ -s "${MODELS}/${dest}" ]; then fetched=$((fetched + 1)); continue; fi
            if python3 - "$repo" "$file" "${MODELS}/${dest}" <<'PY'
import shutil, sys
try:
    from huggingface_hub import hf_hub_download
except Exception:
    sys.exit(3)   # lib absent / air-gapped -> stay inert, retry next boot
repo, fname, dest = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    shutil.copyfile(hf_hub_download(repo_id=repo, filename=fname), dest)
except Exception as e:
    sys.stderr.write(f"{type(e).__name__}: {e}\n"); sys.exit(1)
PY
            then fetched=$((fetched + 1)); log "GGUF ${dest} fetched from HF"
            else log "GGUF ${dest} fetch failed (no egress / upstream) -- will retry next boot"; fi
        done
        if [ "$total" -gt 0 ] && [ "$fetched" -ge "$total" ]; then
            touch "${MODELS}/.ready"; log "GGUFs provisioned (${fetched}/${total}) -- llama-swap lane eligible"
        else
            log "WARN: GGUFs incomplete (${fetched}/${total}) -- llama-swap lane idle until next retry"
        fi
    fi
fi

# ── 3. (re)start the AI services now their prerequisites exist ────────────────
systemctl daemon-reload 2>/dev/null
for s in hermes-agent mios-agent-pipe mios-llama-swap; do
    systemctl reset-failed "${s}" 2>/dev/null
    systemctl restart "${s}" 2>/dev/null || true
done

# ── sentinel: only when fully provisioned, so failures retry next boot ────────
install -d -m 0755 /var/lib/mios 2>/dev/null
if [ -x "${VENV}/bin/hermes" ] && [ -f "${MODELS}/.ready" ]; then
    touch /var/lib/mios/.ai-firstboot-done
    log "complete -- agent venv + GGUFs provisioned"
else
    log "incomplete (venv=$( [ -x "${VENV}/bin/hermes" ] && echo ok || echo missing ) ggufs=$( [ -f "${MODELS}/.ready" ] && echo ok || echo missing )) -- retrying next boot"
fi
exit 0
