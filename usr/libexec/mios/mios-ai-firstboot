#!/usr/bin/env bash
# AI-hint: Provisioning script that installs the hermes-agent Python venv and extracts llama.cpp GGUF models to enable AI services, creating a sentinel file to gate network-less boot retries.
# AI-related: /usr/share/mios/llamacpp/mios-llm-light.yaml, /usr/lib/mios/agents/.venv, /usr/share/mios/llamacpp/models, /usr/libexec/mios/38-hermes-agent.sh, /etc/mios/containers/coderun-sandbox, mios-coderun-sandbox, mios-coderun-session, mios-ai, mios-agent-pipe, mios-llm-light
# AI-functions: log
# 'MiOS' AI first-boot provisioning.
#
# Completes the build-time AI setup on deployments where it wasn't baked into
# the image (overlay-provisioned MiOS-DEV, WSL imports, any non-bootc-built
# host). Two pieces, both idempotent + best-effort:
#   1. the shared agent venv (hermes-agent + agent-pipe), via the canonical
#      builder automation/38-hermes-agent.sh (checked out at / by the overlay);
#   2. the llama.cpp GGUFs for the mios-llm-light lane, extracted from ollama's
#      model blobs (the tags come from /usr/share/mios/llamacpp/mios-llm-light.yaml).
# Then it (re)starts the AI services so they pick up the new prerequisites.
#
# The sentinel /var/lib/mios/.ai-firstboot-done is written ONLY when BOTH the
# venv and the GGUFs are in place, so a network-less boot retries next time
# (mios-ai-firstboot.service carries ConditionPathExists=!<sentinel>).
#
# NO `set -e` -- every step is guarded; a partial provision must not wedge boot.
set +eu
log(){ logger -t mios-ai-firstboot "$*" 2>/dev/null; echo "[mios-ai-firstboot] $*"; }

VENV=/usr/lib/mios/agents/.venv
MODELS=/usr/share/mios/llamacpp/models

# ── 1. shared agent venv (hermes pins Python <3.14) ──────────────────────────
if [ ! -x "${VENV}/bin/hermes" ]; then
    if ! command -v python3.13 >/dev/null 2>&1; then
        log "installing python3.13 (hermes-agent requires >=3.11,<3.14)"
        dnf install -y python3.13 python3.13-devel >/dev/null 2>&1 || log "WARN: python3.13 install failed"
    fi
    # The canonical venv builder lives in automation/ (build-time). The overlay
    # checks out usr/etc/var to / but NOT automation/, so find it across the
    # locations it can actually be: a runtime copy, the / git working tree
    # (materialize on demand), or the mounted Windows mios.git clone on the dev VM.
    HSCRIPT=""
    # Require lib/common.sh ALONGSIDE the script: 38-hermes-agent.sh sources it
    # and exits 0 (no venv) if absent -- exactly what a script-only /automation
    # checkout yields. Prefer the full /mnt/m mios.git clone (has lib/).
    for p in /mnt/m/automation/38-hermes-agent.sh /mnt/c/MiOS/automation/38-hermes-agent.sh /usr/libexec/mios/38-hermes-agent.sh /automation/38-hermes-agent.sh; do
        [ -f "$p" ] && [ -f "$(dirname "$p")/lib/common.sh" ] && HSCRIPT="$p" && break
    done
    if [ -z "$HSCRIPT" ] && [ -d /.git ]; then
        git -C / checkout -- automation 2>/dev/null
        [ -f /automation/38-hermes-agent.sh ] && [ -f /automation/lib/common.sh ] && HSCRIPT=/automation/38-hermes-agent.sh
    fi
    if [ -n "$HSCRIPT" ]; then
        log "building shared agent venv via $HSCRIPT"
        bash "$HSCRIPT" 2>&1 | tail -12
    else
        log "WARN: 38-hermes-agent.sh not found (/, git, /mnt/m) -- agent venv NOT built"
    fi
    if [ -x "${VENV}/bin/hermes" ]; then log "agent venv ready: ${VENV}"; else log "WARN: agent venv still missing"; fi
fi

# ── 2. llama.cpp GGUFs (llama.cpp-NATIVE -- HF download; ollama retired, G5/G8) ─
# GGUFs are normally BAKED at build by automation/38-llamacpp-prep.sh (the
# offline-correct path). This firstboot block is the ONLINE retry for hosts that
# didn't bake them: it fetches the SAME MIOS_LLAMACPP_BAKE_MODELS spec
# (dest.gguf=hf_repo:file, FOSS pre-quantized) directly from Hugging Face via a
# plain curl of the resolve URL -- NO ollama dependency (G5 retired it) and NO
# huggingface_hub/pip dependency (G8: the runtime pip install failed on
# air-gapped/locked hosts). When air-gapped + unbaked the lane stays inert
# (operator sets [llamacpp].bake_models + rebuilds, or seeds ${MODELS} manually)
# -- it never blocks boot.
if [ ! -f "${MODELS}/.ready" ]; then
    install -d -m 0755 "${MODELS}" /var/lib/mios/llamacpp/slots 2>/dev/null
    SPEC="${MIOS_LLAMACPP_BAKE_MODELS:-}"
    if [ -z "$SPEC" ]; then
        log "GGUFs not baked + [llamacpp].bake_models empty -- mios-llm-light lane stays inert (set bake_models + rebuild, or seed ${MODELS} manually)"
    else
        fetched=0; total=0
        IFS=',' read -ra _ents <<< "$SPEC"
        for entry in "${_ents[@]}"; do
            entry="$(printf '%s' "$entry" | tr -d '[:space:]')"; [ -z "$entry" ] && continue
            total=$((total + 1))
            dest="${entry%%=*}"; rest="${entry#*=}"; repo="${rest%%:*}"; file="${rest#*:}"
            if [ -z "$dest" ] || [ -z "$repo" ] || [ -z "$file" ] || [ "$dest" = "$entry" ]; then
                log "malformed GGUF entry '${entry}' (want dest.gguf=repo:file) -- skipping"; continue
            fi
            if [ -s "${MODELS}/${dest}" ]; then fetched=$((fetched + 1)); continue; fi
            # Direct HF resolve URL -- NO huggingface_hub / pip dependency
            # (G8: the runtime pip install was the firstboot failure on
            # air-gapped/locked hosts). curl --fail (no 200 -> non-zero),
            # -L (follow the CDN redirect), -C - (resume a partial .part).
            # Download to a .part then atomic-rename so a truncated file
            # never trips the .ready gate.
            _url="https://huggingface.co/${repo}/resolve/main/${file}"
            if curl -fL -C - --retry 3 --max-time 1800 \
                    -o "${MODELS}/${dest}.part" "$_url" 2>/dev/null \
               && [ -s "${MODELS}/${dest}.part" ]; then
                mv -f "${MODELS}/${dest}.part" "${MODELS}/${dest}"
                fetched=$((fetched + 1)); log "GGUF ${dest} fetched from HF (${_url})"
            else
                rm -f "${MODELS}/${dest}.part" 2>/dev/null
                log "GGUF ${dest} fetch failed (no egress / upstream) -- will retry next boot"
            fi
        done
        if [ "$total" -gt 0 ] && [ "$fetched" -ge "$total" ]; then
            touch "${MODELS}/.ready"; log "GGUFs provisioned (${fetched}/${total}) -- mios-llm-light lane eligible"
        else
            log "WARN: GGUFs incomplete (${fetched}/${total}) -- mios-llm-light lane idle until next retry"
        fi
    fi
fi

# ── 2c. code-run sandbox: the dry-run sandbox Quadlet (mios-coderun-sandbox@)
# is a USER unit -- it uses %t (XDG_RUNTIME_DIR) + is started via
# `systemctl --user` by mios-coderun-session. For the mios-ai SERVICE account
# (agent-pipe) to start it headless, mios-ai needs LINGER so a persistent user
# systemd manager + the podman user generator run without an interactive login.
# Without this, run_sandboxed_code fails (systemctl --user: no bus / unit not
# found) and the agent reports a sandbox permission error (operator 2026-06-12).
if command -v loginctl >/dev/null 2>&1 && id mios-ai >/dev/null 2>&1; then
    # (a) subuid/subgid: the sandbox Quadlet uses UserNS=keep-id, which needs a
    # rootless sub-id range for mios-ai. Build-time canonical is
    # automation/31-user.sh; this is the runtime retry for overlay/WSL hosts where
    # mios-ai was added without a range. Allocate the next free block after
    # user/mios (524288:65536) -> 589824:65536, idempotently.
    if ! grep -qE '^mios-ai:' /etc/subuid 2>/dev/null; then
        echo 'mios-ai:589824:65536' >> /etc/subuid
        echo 'mios-ai:589824:65536' >> /etc/subgid
        sudo -u mios-ai podman system migrate 2>/dev/null || true
        log "added mios-ai subuid/subgid 589824:65536 (rootless keep-id for sandbox)"
    fi
    # (b) linger: persistent user manager so `systemctl --user` (used by
    # mios-coderun-session) works headless for the mios-ai service account.
    if [ "$(loginctl show-user mios-ai -p Linger --value 2>/dev/null)" != "yes" ]; then
        if loginctl enable-linger mios-ai 2>/dev/null; then
            log "enabled linger for mios-ai (code-run sandbox user manager)"
        else
            log "WARN: enable-linger mios-ai failed -- code-run sandbox stays disabled"
        fi
    fi
fi

# ── 2d. code-run sandbox IMAGE: the user-scope Quadlet starts
# localhost/mios-coderun-sandbox:latest, which must exist in mios-ai's ROOTLESS
# store (rootless has its own image store, separate from rootful). Build it from
# the shipped context if missing -- a network build (alpine + toolkit),
# best-effort, retries next boot on failure. Needs the linger+subids above.
if id mios-ai >/dev/null 2>&1 && command -v podman >/dev/null 2>&1; then
    _aiuid="$(id -u mios-ai 2>/dev/null)"
    if ! sudo -u mios-ai env XDG_RUNTIME_DIR="/run/user/${_aiuid}" podman image exists localhost/mios-coderun-sandbox:latest 2>/dev/null; then
        _ctx=/etc/mios/containers/coderun-sandbox
        if [ -f "${_ctx}/Dockerfile" ]; then
            log "building code-run sandbox image (rootless mios-ai) -- network build"
            if sudo -u mios-ai env XDG_RUNTIME_DIR="/run/user/${_aiuid}" \
                    podman build -t localhost/mios-coderun-sandbox:latest "${_ctx}" >/dev/null 2>&1; then
                log "code-run sandbox image built"
            else
                log "WARN: sandbox image build failed (no egress?) -- run_sandboxed_code disabled until retry"
            fi
        fi
    fi
fi

# ── 3. (re)start the AI services now their prerequisites exist ────────────────
# --no-block on hermes-agent + mios-agent-pipe: firstboot must NOT wait on them
# settling. They have their own readiness deps and can deadlock against the
# firstboot ordering -- the ~23min early-boot hang (2026-06-14). mios-llm-light
# is the inference lane (no firstboot ordering dependency) so a plain restart is
# fine there.
systemctl daemon-reload 2>/dev/null
for s in hermes-agent mios-agent-pipe; do
    systemctl reset-failed "${s}" 2>/dev/null
    systemctl restart --no-block "${s}" 2>/dev/null || true
done
systemctl reset-failed mios-llm-light 2>/dev/null
systemctl restart mios-llm-light 2>/dev/null || true

# ── sentinel: only when fully provisioned, so failures retry next boot ────────
install -d -m 0755 /var/lib/mios 2>/dev/null
if [ -x "${VENV}/bin/hermes" ] && [ -f "${MODELS}/.ready" ]; then
    touch /var/lib/mios/.ai-firstboot-done
    log "complete -- agent venv + GGUFs provisioned"
else
    log "incomplete (venv=$( [ -x "${VENV}/bin/hermes" ] && echo ok || echo missing ) ggufs=$( [ -f "${MODELS}/.ready" ] && echo ok || echo missing )) -- retrying next boot"
fi
exit 0
