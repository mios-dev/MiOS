#!/bin/bash
# AI-hint: Orchestrates the lifecycle of agent-specific coderun sandboxes by managing systemd user units, btrfs snapshots, and git stashes for project isolation and state recovery based on a unique session ID.
# AI-related: /usr/libexec/mios/mios-coderun-session, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-coderun-sandbox
# AI-functions: usage, _resolve_projects_root, _resolve_snapshots_root, _require_session, _is_btrfs, _snap_btrfs, _snap_git_stash, do_start, do_stop, do_snap, do_revert, do_status
set -euo pipefail
# /usr/libexec/mios/mios-coderun-session {start|stop|snap|revert|status} <session-id>
#
# Per-session orchestrator for the MiOS agent sandbox per the FS+OS
# Control guide §15. Wraps:
#
#   * systemctl --user start/stop mios-coderun-sandbox@<id>.service
#   * btrfs subvolume snapshot (when project root is on btrfs)
#   * git stash --keep-index fallback (when not)
#   * revert from snapshot or git stash
#
# Sessions are identified by an opaque <session-id> (sha256 prefix,
# uuid, or whatever the agent uses for its session). The same id
# threads through the Quadlet template (%i in mios-coderun-sandbox@.container),
# the project subdir (/var/home/mios/coderuns/<id>/), and the
# snapshot path.
#
# Operator directive 2026-05-16: "no hardcoded anything anywhere".
# The project-root path resolves from env -> mios.toml [paths] ->
# compiled fallback, matching the rest of the MiOS helper fleet.

set -eu

usage() {
    cat <<'USAGE'
usage: mios-coderun-session <action> <session-id>

  start    <id>   systemctl --user start mios-coderun-sandbox@<id>; snapshot project root
  stop     <id>   systemctl --user stop mios-coderun-sandbox@<id>; GC snapshot
  snap     <id>   take a snapshot WITHOUT touching the sandbox unit
  revert   <id>   restore project root from the latest snapshot
  status   <id>   show systemctl status + recent snapshot list
  list            show every active session id

The <session-id> is opaque -- the agent picks it (uuid, hash, etc.).
The same id is used as the Quadlet instance name AND as the project
subdirectory name under <projects_root>/<id>/.
USAGE
}

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
    exit 0
fi

ACTION="$1"
SESSION="${2:-}"

# Resolve the projects root (env -> mios.toml [paths] -> default).
_resolve_projects_root() {
    if [ -n "${MIOS_CODERUN_WORKSPACE_ROOT:-}" ]; then
        printf '%s' "$MIOS_CODERUN_WORKSPACE_ROOT"
        return
    fi
    local val
    val=$(python3 - <<'PYEOF' 2>/dev/null
import tomllib
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
        v = d.get("paths", {}).get("coderun_workspace_root")
        if v:
            print(v)
            raise SystemExit(0)
    except (OSError, tomllib.TOMLDecodeError):
        continue
PYEOF
)
    if [ -n "$val" ]; then
        printf '%s' "$val"
    else
        printf '%s' "/var/home/mios/coderuns"
    fi
}

_resolve_snapshots_root() {
    if [ -n "${MIOS_CODERUN_SNAPSHOTS_ROOT:-}" ]; then
        printf '%s' "$MIOS_CODERUN_SNAPSHOTS_ROOT"
        return
    fi
    local val
    val=$(python3 - <<'PYEOF' 2>/dev/null
import tomllib
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
        v = d.get("paths", {}).get("coderun_snapshots_root")
        if v:
            print(v)
            raise SystemExit(0)
    except (OSError, tomllib.TOMLDecodeError):
        continue
PYEOF
)
    if [ -n "$val" ]; then
        printf '%s' "$val"
    else
        printf '%s' "/var/home/mios/.coderun-snapshots"
    fi
}

PROJECTS_ROOT="$(_resolve_projects_root)"
SNAPSHOTS_ROOT="$(_resolve_snapshots_root)"

_require_session() {
    [ -z "$SESSION" ] && { echo "mios-coderun-session: missing <session-id>" >&2; usage >&2; exit 64; }
    return 0
}

# Detect whether the project root is on btrfs (enables snapshot path).
_is_btrfs() {
    local path="$1"
    [ -d "$path" ] || return 1
    # btrfs is Linux-only; early-exit on other platforms
    [ "$(uname -s)" = "Linux" ] || return 1
    local fstype
    fstype=$(stat -f -c %T "$path" 2>/dev/null || df -T "$path" 2>/dev/null | awk 'NR==2 {print $2}')
    [ "$fstype" = "btrfs" ]
}

_snap_btrfs() {
    local project="$1" snap="$2"
    mkdir -p "$(dirname "$snap")"
    btrfs subvolume snapshot -r "$project" "$snap" >/dev/null
    echo "  ✓ btrfs snapshot: $snap"
}

_snap_git_stash() {
    local project="$1" tag="$2"
    if ! command -v git >/dev/null 2>&1; then
        echo "  ✗ no git available -- cannot snapshot non-btrfs project" >&2
        return 1
    fi
    if [ ! -d "$project/.git" ]; then
        ( cd "$project" && git init -q && git add -A && git commit -q --allow-empty -m "mios-coderun-session: initial snapshot" )
    fi
    ( cd "$project" && git stash push --include-untracked -m "mios-coderun-session:$tag" >/dev/null 2>&1 \
        && git stash apply --quiet >/dev/null 2>&1 || true )
    echo "  ✓ git stash snapshot tagged: mios-coderun-session:$tag"
}

do_start() {
    _require_session
    local project="$PROJECTS_ROOT/$SESSION"
    local snap="$SNAPSHOTS_ROOT/$SESSION/start-$(date +%s)"
    mkdir -p "$project" "$SNAPSHOTS_ROOT/$SESSION"
    echo "[mios-coderun-session] starting sandbox for session '$SESSION'"
    echo "  project root: $project"
    if _is_btrfs "$project"; then
        _snap_btrfs "$project" "$snap"
    else
        _snap_git_stash "$project" "start-$(date +%s)"
    fi

    # Start the per-session host-side broker
    local runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    local socket_file="$runtime_dir/mios-coderun-${SESSION}.sock"
    local pid_file="$runtime_dir/mios-coderun-${SESSION}.pid"
    
    echo "  starting broker for session '$SESSION'"
    python3 /usr/libexec/mios/mios-coderun-broker --session "$SESSION" &
    
    # Wait for the broker to create the socket
    local timeout=50
    while [ ! -S "$socket_file" ] && [ "$timeout" -gt 0 ]; do
        sleep 0.1
        timeout=$((timeout - 1))
    done
    if [ ! -S "$socket_file" ]; then
        echo "  ✗ failed to start broker or socket not created" >&2
        exit 1
    fi
    echo "  ✓ broker started, socket available: $socket_file"

    systemctl --user start "mios-coderun-sandbox@${SESSION}.service"
    echo "  ✓ sandbox unit started: mios-coderun-sandbox@${SESSION}.service"
}

do_stop() {
    _require_session
    echo "[mios-coderun-session] stopping sandbox for session '$SESSION'"
    systemctl --user stop "mios-coderun-sandbox@${SESSION}.service" || true
    echo "  ✓ sandbox unit stopped"

    # Stop the per-session host-side broker
    local runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
    local socket_file="$runtime_dir/mios-coderun-${SESSION}.sock"
    local pid_file="$runtime_dir/mios-coderun-${SESSION}.pid"
    
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        kill "$pid" 2>/dev/null || true
        rm -f "$pid_file"
    fi
    rm -f "$socket_file"
    echo "  ✓ broker stopped and socket removed"

    # Snapshot GC -- bound retention per the guide's pitfall list.
    local sdir="$SNAPSHOTS_ROOT/$SESSION"
    if [ -d "$sdir" ]; then
        local keep=10
        local count
        count=$(ls -1 "$sdir" 2>/dev/null | wc -l)
        if [ "$count" -gt "$keep" ]; then
            ls -1tr "$sdir" | head -n "-$keep" | while IFS= read -r old; do
                local victim="$sdir/$old"
                if _is_btrfs "$victim"; then
                    btrfs subvolume delete "$victim" >/dev/null 2>&1 || true
                else
                    rm -rf "$victim"
                fi
                echo "  ✓ GC: removed old snapshot $victim"
            done
        fi
    fi
}

do_snap() {
    _require_session
    local project="$PROJECTS_ROOT/$SESSION"
    local snap="$SNAPSHOTS_ROOT/$SESSION/manual-$(date +%s)"
    mkdir -p "$SNAPSHOTS_ROOT/$SESSION"
    if _is_btrfs "$project"; then
        _snap_btrfs "$project" "$snap"
    else
        _snap_git_stash "$project" "manual-$(date +%s)"
    fi
}

do_revert() {
    _require_session
    local project="$PROJECTS_ROOT/$SESSION"
    local sdir="$SNAPSHOTS_ROOT/$SESSION"
    local latest
    latest=$(ls -1t "$sdir" 2>/dev/null | head -1)
    [ -z "$latest" ] && { echo "mios-coderun-session: no snapshot for session '$SESSION'" >&2; exit 1; }
    echo "[mios-coderun-session] reverting '$SESSION' from $sdir/$latest"
    if _is_btrfs "$project"; then
        btrfs subvolume delete "$project" >/dev/null
        btrfs subvolume snapshot "$sdir/$latest" "$project" >/dev/null
        echo "  ✓ project root restored from btrfs snapshot"
    else
        if [ -d "$project/.git" ]; then
            ( cd "$project" && git stash apply "stash@{0}" 2>/dev/null || \
              git reset --hard HEAD )
            echo "  ✓ project root reset via git stash apply"
        else
            echo "  ✗ no btrfs + no git -- cannot revert" >&2
            exit 1
        fi
    fi
}

do_status() {
    _require_session
    systemctl --user status "mios-coderun-sandbox@${SESSION}.service" --no-pager || true
    echo
    echo "── recent snapshots ──"
    ls -1t "$SNAPSHOTS_ROOT/$SESSION" 2>/dev/null | head -10 || echo "  (none)"
}

do_list() {
    echo "── active mios-coderun-sandbox sessions ──"
    systemctl --user list-units 'mios-coderun-sandbox@*.service' --no-pager --no-legend 2>/dev/null \
        | awk '{print "  " $1 " " $4}'
    echo
    echo "── projects roots with snapshots ──"
    ls -1 "$SNAPSHOTS_ROOT" 2>/dev/null | sed 's/^/  /'
}

case "$ACTION" in
    start)  do_start  ;;
    stop)   do_stop   ;;
    snap)   do_snap   ;;
    revert) do_revert ;;
    status) do_status ;;
    list)   do_list   ;;
    *)      usage >&2; exit 64 ;;
esac
