#!/bin/bash
# AI-hint: Mutates /etc/mios/mios.toml to switch the default application for a given type.
set -euo pipefail

if [ "$#" -lt 2 ]; then
    echo "usage: mios-app-default <type> <app_name>" >&2
    exit 64
fi

TYPE="$1"
APP="$2"

python3 - "$TYPE" "$APP" <<'PYEOF' 2>/dev/null
import sys, os, re

target_type = sys.argv[1].lower().strip()
new_app = sys.argv[2].strip()
etc_path = "/etc/mios/mios.toml"

if not os.path.exists(etc_path):
    with open(etc_path, "w", encoding="utf-8") as f:
        f.write("\n")

with open(etc_path, "r", encoding="utf-8") as f:
    content = f.read()

# Very basic TOML array-of-tables injection
block = f"""
[[desktop.app_types]]
type = "{target_type}"
linux_default = "{new_app}"
windows_default = "{new_app}"
"""

# Append to file
with open(etc_path, "a", encoding="utf-8") as f:
    f.write("\n" + block + "\n")

print(f"Updated default for '{target_type}' to '{new_app}'")
PYEOF
