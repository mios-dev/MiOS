#!/bin/sh
# /usr/libexec/mios/mios-flatpak-overrides-apply
#
# Apply the MiOS-managed global flatpak override (theming + portal +
# theme filesystem mounts) so every installed flatpak respects the
# operator's color-scheme + theme + cursor choices via xdg-portal-desktop.
#
# Idempotent: safe to run on every boot. Drops nothing operator-set
# (uses --reset to clear OUR override only and re-apply our keys).
#
# Why a script vs a tracked /var/lib/flatpak/overrides/global file:
#   * `flatpak override` is the supported API; writing the file directly
#     bypasses validation and is brittle across flatpak versions.
#   * Operators expect to be able to add their own overrides via
#     `flatpak override --system <appid> --env=...` -- those land in
#     <appid> files, not in `global`, so we only own `global`.
#   * The override survives flatpak upgrades AND OS upgrades cleanly.
#
# Called by mios-hermes-firstboot at first boot, and re-runnable by the
# operator (or agent) whenever they want to reset to MiOS defaults.

set -eu

if ! command -v flatpak >/dev/null 2>&1; then
    echo "mios-flatpak-overrides-apply: flatpak not installed -- skipping" >&2
    exit 0
fi

# Read appearance keys from layered mios.toml [appearance] (operator's
# /etc/mios overrides /usr/share/mios). This SSOT is the same one
# mios-flatpak-init reads; sourcing here ensures the firstboot --reset
# doesn't drop theme env that operators expect to be applied globally.
# Operator directive 2026-05-16: "should be the GLOBAL overrides so
# that newly installed apps/flatpaks take hold of the configurations
# as well".
_toml_get() {
    local key="$1" default="$2" val=""
    for f in /etc/mios/mios.toml /usr/share/mios/mios.toml; do
        [ -r "$f" ] || continue
        val=$(python3 - "$f" "$key" 2>/dev/null <<'PYEOF'
import sys, tomllib
path, dotted = sys.argv[1], sys.argv[2]
with open(path, "rb") as fh: data = tomllib.load(fh)
node = data
for k in dotted.split("."):
    if isinstance(node, dict) and k in node:
        node = node[k]
    else:
        sys.exit(0)
print(node)
PYEOF
)
        [ -n "$val" ] && { echo "$val"; return; }
    done
    echo "$default"
}
_gtk_theme=$(_toml_get appearance.gtk_theme "adw-gtk3-dark")
_adw_color=$(_toml_get appearance.adw_color_scheme "prefer-dark")
_curs_theme=$(_toml_get appearance.cursor_theme "Bibata-Modern-Classic")
_curs_size=$(_toml_get appearance.cursor_size "24")
_xcurs_path=$(_toml_get appearance.xcursor_path '~/.icons:~/.local/share/icons:/usr/share/icons:/usr/share/pixmaps')

# --reset clears the global override file completely; then we re-create
# the MiOS-managed keys. This is safer than --unset of individual keys
# (which can fail silently if the key doesn't exist).
flatpak override --system --reset 2>/dev/null || true

# Mount the theme/icon dirs the runtime extensions need. /usr/share/* is
# REJECTED by flatpak (-> F: warnings); use xdg-data + xdg-config only.
flatpak override --system \
    --env=GTK_USE_PORTAL=1 \
    --env=GTK_THEME="$_gtk_theme" \
    --env=ADW_DEBUG_COLOR_SCHEME="$_adw_color" \
    --env=XCURSOR_THEME="$_curs_theme" \
    --env=XCURSOR_SIZE="$_curs_size" \
    --env=XCURSOR_PATH="$_xcurs_path" \
    --filesystem=xdg-config/gtk-3.0:ro \
    --filesystem=xdg-config/gtk-4.0:ro \
    --filesystem=xdg-data/themes:ro \
    --filesystem=xdg-data/icons:ro

# Defensive: negate any prior add of /usr/share/{themes,icons,fonts} so
# flatpak stops printing "Path /usr is reserved" warnings on every
# app launch.
flatpak override --system --nofilesystem=/usr/share/themes 2>/dev/null || true
flatpak override --system --nofilesystem=/usr/share/icons  2>/dev/null || true
flatpak override --system --nofilesystem=/usr/share/fonts  2>/dev/null || true

echo "mios-flatpak-overrides-apply: global flatpak override seeded"
echo "  theme: GTK_THEME=$_gtk_theme  color=$_adw_color  cursor=$_curs_theme/$_curs_size"
echo "  mounts: xdg-config/gtk-{3,4}.0 + xdg-data/{themes,icons}"
echo "  GTK_USE_PORTAL=1 (libadwaita color-scheme via xdg-portal)"

# ─── Per-app overrides from mios.toml [flatpak.app_overrides] ────────
# Operator directive 2026-05-16: "EVERYTHING IS DICTATED AND
# UNDERSTOOD FROM THE mios.toml/html file(s)". Per-app env overrides
# (Epiphany GPU compositing, Chrome CDP port, etc.) live in mios.toml
# as nested tables under [flatpak.app_overrides."<app-id>"]. Iterate
# the table and emit one /var/lib/flatpak/overrides/<id> file per
# entry. Idempotent: each rewrite is full, no merge.
python3 - <<'PYEOF'
import os, tomllib

# Layered read: later file wins per key. /etc/mios overrides /usr/share/mios.
merged = {}
for path in ("/usr/share/mios/mios.toml", "/etc/mios/mios.toml"):
    try:
        with open(path, "rb") as f:
            data = tomllib.load(f)
    except (OSError, tomllib.TOMLDecodeError):
        continue
    overrides = data.get("flatpak", {}).get("app_overrides", {})
    if isinstance(overrides, dict):
        for app_id, env_map in overrides.items():
            if isinstance(env_map, dict):
                cur = merged.setdefault(app_id, {})
                cur.update(env_map)

if not merged:
    print("mios-flatpak-overrides-apply: no [flatpak.app_overrides.*] entries -- skipping per-app emit")
    raise SystemExit(0)

OVERRIDE_DIR = "/var/lib/flatpak/overrides"
os.makedirs(OVERRIDE_DIR, exist_ok=True)
for app_id, env_map in merged.items():
    out_path = os.path.join(OVERRIDE_DIR, app_id)
    lines = ["[Context]", "", "[Environment]"]
    for k, v in env_map.items():
        # TOML bools/ints render as Python; flatpak override files
        # are plain text so str() everything.
        if isinstance(v, bool):
            v = 1 if v else 0
        lines.append(f"{k}={v}")
    lines.append("")  # trailing newline
    with open(out_path, "w") as f:
        f.write("\n".join(lines))
    print(f"mios-flatpak-overrides-apply:   {app_id} -> {len(env_map)} env keys")
PYEOF
