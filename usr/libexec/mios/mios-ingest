#!/usr/bin/env python3
# AI-hint: Python script for offline ingestion of local files (md, txt, rst, org) into the Postgres+pgvector knowledge table via parameterized mios-pg-query (extended-protocol bound params), utilizing mios-summarize to generate tiered L0/L1 metadata for the viking:// vault.
# AI-related: mios-summarize, mios-pg-query
"""mios-ingest -- OFFLINE local-source ingestion into the viking:// vault.

P5.1 (OpenHuman ingestion, offline core): OpenHuman polls external SaaS
(Gmail/Slack/GitHub/...) -- that needs cloud creds + contradicts MiOS's
offline-first principle, so the EXTERNAL pollers are deliberately NOT built.
This is the OFFLINE half that IS aligned: ingest LOCAL sources (a directory of
notes/docs/markdown the operator already has on disk) into the second-brain
vault, tiered (L0/L1 via mios-summarize) so viking:// can navigate them and the
knowledge recall can surface them. Same "compact + structure + make navigable"
value, pulling from local files instead of cloud APIs.

Each ingested doc becomes a `knowledge` row (q = derived title/L0, answer =
the L1 overview + a pointer to the source path; the raw stays on disk as L2).
Idempotent per (source_path): re-ingesting updates rather than duplicates.

USAGE
  mios-ingest --path /var/home/mios/notes            # a directory (recursive)
  mios-ingest --file /var/home/mios/notes/plan.md    # one file
  mios-ingest --path DIR --ext md,txt --max 50 --dry-run

Output JSON: {ok, ingested, skipped, sources:[...]}.
Offline: only mios-summarize (local CPU lane) + local pgvector. No network.

Storage: Postgres+pgvector via mios-pg-query. File-derived values (source path,
title/L0, L1 overview, embedding vector) are bound OUT-OF-BAND through the
parameterized extended protocol (mios-pg-query --exec-json $1..$n), never spliced
into SQL text; only trusted config identifiers (table/column names) stay inline.
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import urllib.request

TABLE = os.environ.get("MIOS_KNOWLEDGE_TABLE", "knowledge")
SUMMARIZE = os.environ.get("MIOS_SUMMARIZE_BIN", "mios-summarize")
DEFAULT_EXTS = os.environ.get("MIOS_INGEST_EXTS", "md,txt,rst,org")
PG_QUERY = os.environ.get("MIOS_PG_QUERY_BIN", "/usr/libexec/mios/mios-pg-query")

# Embed-on-write (WS-0 durability + exposure): embed the L0+L1 text at ingest so
# the row is semantically RECALLABLE via the knowledge_emb_hnsw cosine index --
# the same path agent-pipe's _store_knowledge_task uses for chat Q+A. MUST match
# agent-pipe's model + endpoint EXACTLY (MIOS_VERB_EMBED_MODEL / _URL) so the
# 768-dim nomic-embed-text vectors are comparable under <=> cosine; a mismatch
# would make ingested rows un-rankable against chat-embedded queries.
EMBED_MODEL = os.environ.get("MIOS_VERB_EMBED_MODEL", "nomic-embed-text")
EMBED_URL = os.environ.get(
    "MIOS_VERB_EMBED_URL", f"http://localhost:{os.environ.get('MIOS_PORT_LLM_LIGHT', '8450')}/v1/embeddings")
# Cap the embed input (~1200 chars). nomic handles longer, but L0+L1 is already
# a compact tiered summary; capping keeps the light-lane call fast + bounded.
EMBED_MAX_CHARS = int(os.environ.get("MIOS_INGEST_EMBED_MAX_CHARS", "1200"))


def _pg(sql: str) -> list:
    """Run one SQL statement on pgvector via mios-pg-query (pure-python pg wire
    client -- no psql/psycopg/podman). Rows -> lists of string columns (psql -At).
    Raises RuntimeError on a backend error so the caller's try/except can record
    the per-source failure (matches the old _sql contract). For statements that
    carry external (file-derived) values use _pg_param() instead -- it binds them
    out-of-band so nothing is ever spliced into SQL text."""
    p = subprocess.run([PG_QUERY, sql], capture_output=True, text=True,
                       timeout=90)
    if p.returncode != 0:
        raise RuntimeError(f"pg error: {(p.stderr or '')[:200]}")
    return [ln.split("\t") for ln in p.stdout.splitlines() if ln]


def _pg_param(statements: list) -> None:
    """Run one or more parameterized statements atomically on pgvector via
    `mios-pg-query --exec-json`, which reads a JSON envelope on STDIN and binds
    each param OUT-OF-BAND through the pg v3 extended protocol -- no string
    splicing, no escaping. `statements` is a list of {"sql": "... $1 ...",
    "params": [...]}; a multi-element list runs as an atomic BEGIN/COMMIT batch
    (used for the delete-then-insert upsert). Strings/vectors/text bind as params;
    INTEGER values (LIMIT, interval counts) must stay inline in the SQL. A vector
    is bound as a TEXT param with a ::vector cast in the SQL. Raises RuntimeError
    on a backend error so the caller's try/except records the per-source failure
    (matches _pg's contract)."""
    envelope = ({"sql": statements[0]["sql"], "params": statements[0]["params"]}
                if len(statements) == 1 else {"statements": statements})
    p = subprocess.run([PG_QUERY, "--exec-json"], input=json.dumps(envelope),
                       capture_output=True, text=True, timeout=90)
    if p.returncode != 0:
        raise RuntimeError(f"pg error: {(p.stderr or '')[:200]}")


def _summarize(text: str) -> dict:
    try:
        p = subprocess.run([SUMMARIZE, "--text", text, "--tiers", "l0,l1",
                            "--json"], capture_output=True, text=True,
                           timeout=130)
        return json.loads(p.stdout or "{}")
    except Exception:  # noqa: BLE001
        return {}


def _embed(text: str):
    """Single-vector embed via the light-lane OpenAI /v1/embeddings
    (mios-llm-light :11450, nomic-embed-text, 768-dim) -- the SAME model+endpoint
    agent-pipe uses so cosine recall is comparable. MiOS is /v1-only: the OpenAI
    shape ({input} -> {data:[{embedding}]}). Returns a list[float] or None on ANY
    failure (network down, light lane swapping, bad shape) -- the caller then stores
    the row with emb NULL (still persisted + auditable, just not recallable). NEVER
    raises: embedding is best-effort and must not fail an ingest. Stdlib-only
    (urllib) to keep this offline tool dependency-free."""
    text = (text or "").strip()
    if not text:
        return None
    text = text[:EMBED_MAX_CHARS]
    payload = {"model": EMBED_MODEL, "input": text}
    try:
        req = urllib.request.Request(
            EMBED_URL,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=60) as resp:
            if resp.status != 200:
                return None
            data = json.loads(resp.read().decode("utf-8") or "{}")
    except Exception as e:  # noqa: BLE001 -- embed is best-effort
        print(f"[mios-ingest] embed call failed (emb NULL): {str(e)[:160]}",
              file=sys.stderr)
        return None
    # OpenAI /v1 shape: {data:[{embedding:[...]}]}.
    v = None
    d = data.get("data")
    if isinstance(d, list) and d:
        v = d[0].get("embedding")
    if isinstance(v, list) and v:
        try:
            return [float(x) for x in v]
        except (TypeError, ValueError):
            return None
    return None


def _vec_literal(vec) -> str:
    """Format a float sequence as a pgvector text literal '[0.1,0.2,...]' (matches
    agent-pipe mios_pg.vector_literal). Cast with ::vector in the INSERT. The
    output contains only digits / '.' / '-' / 'e' / ',' / brackets, so it is safe
    to interpolate into the SQL string (no quote-escaping needed)."""
    return "[" + ",".join(repr(float(x)) for x in (vec or [])) + "]"


def _collect(path: str, file: str, exts: set, mx: int) -> list:
    out = []
    if file:
        if os.path.isfile(file):
            out.append(file)
        return out
    for root, _dirs, files in os.walk(path):
        for fn in files:
            if exts and fn.rsplit(".", 1)[-1].lower() not in exts:
                continue
            out.append(os.path.join(root, fn))
            if len(out) >= mx:
                return out
    return out


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-ingest")
    p.add_argument("--path", default="")
    p.add_argument("--file", default="")
    p.add_argument("--ext", default=DEFAULT_EXTS)
    p.add_argument("--max", type=int, default=100)
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()

    if not args.path and not args.file:
        print(json.dumps({"ok": False, "error": "need --path or --file"}))
        return 2
    exts = {e.strip().lower() for e in args.ext.split(",") if e.strip()}
    srcs = _collect(args.path, args.file, exts, args.max)
    if not srcs:
        print(json.dumps({"ok": True, "ingested": 0, "skipped": 0,
                          "note": "no matching files", "sources": []}))
        return 0

    # The pg `knowledge` table is created by the schema-init step
    # (usr/share/mios/postgres/schema-init.sql); no per-tool DDL needed.

    ingested, skipped, report = 0, 0, []
    for sp in srcs:
        try:
            with open(sp, encoding="utf-8", errors="replace") as f:
                raw = f.read().strip()
        except OSError:
            skipped += 1
            continue
        if not raw:
            skipped += 1
            continue
        if args.dry_run:
            report.append({"source": sp, "chars": len(raw), "action": "would-ingest"})
            ingested += 1
            continue
        s = _summarize(raw[:12000])
        l0 = (s.get("l0") or os.path.basename(sp)).strip()
        l1 = (s.get("l1") or raw[:2000]).strip()
        answer = f"[ingested from {sp}]\n\n{l1}"
        # Embed-on-write: the tiered L0+L1 summary is what recall should match
        # against, so embed that (NOT the raw L2 on disk). Best-effort -- a miss
        # leaves emb NULL (row still stored + auditable, just not cosine-
        # recallable). Capped inside _embed (EMBED_MAX_CHARS).
        emb = _embed(f"{l0}\n{l1}")
        embedded = emb is not None
        # idempotent upsert keyed on the source path. pg `knowledge` has no
        # `src`/`source` columns, so the path lives in the `sources` jsonb
        # array (preserving the old sources=[sp]) and we match it with the
        # jsonb containment operator @>. session_id='ingest' marks provenance
        # (was source='ingest'). ts defaults to now() at the column level.
        src_json = json.dumps([sp])
        try:
            # Atomic delete-then-insert upsert keyed on the source path. ALL
            # file-derived values bind out-of-band ($1..$n); only the trusted
            # table/column identifiers stay inline. The literal 'ingest'
            # session_id is a fixed constant (not request data) so it stays
            # inline. Add `emb` to the column list ONLY when the embed succeeded,
            # binding the vector literal as a TEXT param cast with ::vector
            # (matches mios_pg.build_insert). On a miss we omit the column so it
            # defaults to NULL -- never fail the ingest.
            del_stmt = {
                "sql": f"DELETE FROM {TABLE} WHERE sources @> $1::jsonb "
                       f"AND session_id = 'ingest';",
                "params": [src_json],
            }
            if embedded:
                ins_stmt = {
                    "sql": f"INSERT INTO {TABLE} (q, answer, sources, "
                           f"session_id, emb) VALUES ($1, $2, $3::jsonb, "
                           f"'ingest', $4::vector);",
                    "params": [l0[:300], answer[:6000], src_json,
                               _vec_literal(emb)],
                }
            else:
                ins_stmt = {
                    "sql": f"INSERT INTO {TABLE} (q, answer, sources, "
                           f"session_id) VALUES ($1, $2, $3::jsonb, "
                           f"'ingest');",
                    "params": [l0[:300], answer[:6000], src_json],
                }
            _pg_param([del_stmt, ins_stmt])
            ingested += 1
            report.append({"source": sp, "l0": l0[:120], "embedded": embedded})
        except Exception as e:  # noqa: BLE001
            skipped += 1
            report.append({"source": sp, "error": str(e)[:120]})

    print(json.dumps({"ok": True, "ingested": ingested, "skipped": skipped,
                      "dry_run": args.dry_run, "sources": report[:50]}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
