#!/bin/bash
# AI-hint: Ensures the flatpak-portal and xdg-desktop-portal services are active and responsive on the user bus to prevent sandbox credential failures in WSL2 environments.
# AI-related: /usr/libexec/mios/mios-wsl-flatpak-heal, mios-wsl-flatpak-heal.timer, dbus-broker.service, xdg-desktop-portal.service, xdg-document-portal.service, flatpak-portal.service
set -euo pipefail
# /usr/libexec/mios/mios-wsl-flatpak-heal
#
# Pre-emptively ensure the user-side flatpak portal stack is alive
# so the next flatpak launch doesn't die at sandbox-credential
# bootstrap. WSL2g sessions consistently let flatpak-portal idle
# out (~10-18min observed) without dbus auto-activation re-firing
# it; the result is `Connection: failed to receive credentials`
# from any flatpak the operator/agent invokes.
#
# Operator-flagged 2026-05-18: every flatpak (epiphany, nautilus,
# gnome-software, ...) failed identically because flatpak-portal
# was inactive even though every OTHER portal service (dbus-broker,
# xdg-desktop-portal*, xdg-document-portal) was active.
#
# This script is the heal helper. It:
#   1. Checks the user-bus + portal services we know flatpak needs.
#   2. Starts any that are inactive.
#   3. Pings flatpak-portal via dbus to confirm responsiveness.
#
# Run by:
#   * mios-wsl-flatpak-heal.timer (user-side, every 5 min)
#   * any operator/agent before a flatpak launch they need to land
#
# Idempotent: starting an already-active service is a no-op.

set -u

# Services we manage. xdg-document-portal + flatpak-portal are
# what bubblewrap sandboxes actually need; the others are present
# for completeness but rarely the failure point.
SERVICES=(
    "dbus-broker.service"
    "xdg-desktop-portal.service"
    "xdg-document-portal.service"
    "flatpak-portal.service"
)

started=0
already_active=0
failed=0

for svc in "${SERVICES[@]}"; do
    if systemctl --user is-active --quiet "$svc"; then
        already_active=$((already_active + 1))
    else
        if systemctl --user start "$svc" 2>/dev/null; then
            started=$((started + 1))
        else
            failed=$((failed + 1))
        fi
    fi
done

# Verify flatpak-portal responds to a dbus ping. The portal accepts
# Introspect on its well-known path which is the cheapest probe
# that proves the activation chain works end-to-end.
portal_ok=0
if command -v gdbus >/dev/null 2>&1; then
    if gdbus introspect --session \
            --dest org.freedesktop.portal.Flatpak \
            --object-path /org/freedesktop/portal/Flatpak \
            >/dev/null 2>&1; then
        portal_ok=1
    fi
fi

# Emit JSON envelope so agents can consume the result + decide.
# Non-zero exit when the portal still doesn't respond after all
# heals -- caller surfaces "flatpak portal not reachable" rather
# than attempting a doomed launch.
python3 - "$started" "$already_active" "$failed" "$portal_ok" <<'PYEOF'
import json, sys
started, already_active, failed, portal_ok = (int(x) for x in sys.argv[1:5])
ok = portal_ok == 1 and failed == 0
print(json.dumps({
    "ok": ok,
    "verb": "wsl_flatpak_heal",
    "services_started":      started,
    "services_already_up":   already_active,
    "services_failed":       failed,
    "portal_dbus_responds":  bool(portal_ok),
}))
PYEOF

if [[ "$portal_ok" -eq 1 ]] && [[ "$failed" -eq 0 ]]; then
    exit 0
fi
exit 1
