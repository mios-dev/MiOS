# ── Synchronous FIRE + VERIFY (operator 2026-05-25, 4A #2) ────────────
#
# "iGPU SHOULD FIRE MIOS OS CONTROL COMMANDS FOR AGENTS, that way the
#  main agent/sub-agents just have to check for successful launch."
#
# The always-on daemon (the iGPU daemon-tier brain) FIRES the launch AND
# runs the Definition-of-Done success-check as ONE operation; the agent
# delegates the whole thing (the `launch_verified` verb -> mios-os-control
# -> POST /os_control here) and just reads `launched`. The fire goes
# THROUGH THE LAUNCHER BROKER -- never a direct subprocess: the broker
# runs as the operator's user systemd service, so only IT inherits the
# WSLg env (WAYLAND_DISPLAY / WSL_INTEROP) that actually surfaces a window
# on the operator's desktop. The broker is threaded, so this reentrant
# call (the daemon firing while the launch_verified verb is itself
# in-flight on the broker) does NOT deadlock.
LAUNCHER_SOCK = os.environ.get(
    "MIOS_LAUNCHER_SOCK", "/run/mios-launcher/launcher.sock")
# How long fire+verify polls for the window to surface (flatpak / WSLg
# cold-launches can take a while to first paint).
OS_CONTROL_SETTLE_S = float(os.environ.get("MIOS_OS_CONTROL_SETTLE_S", "1.5"))
OS_CONTROL_ATTEMPTS = int(os.environ.get("MIOS_OS_CONTROL_ATTEMPTS", "6"))
OS_CONTROL_INTERVAL_S = float(os.environ.get("MIOS_OS_CONTROL_INTERVAL_S", "2.5"))


def _broker_dispatch(cmd: str, timeout: float = 60.0) -> dict:
    """Fire a shell command through the launcher broker using the SAME
    CAPTURE_JSON unix-socket protocol the agent-pipe uses. Returns
    {success, output, stderr, exit_code} or an error stub. NEVER raises."""
    import socket as _socket
    if not os.path.exists(LAUNCHER_SOCK):
        return {"success": False, "output": "", "exit_code": -1,
                "stderr": f"broker socket missing at {LAUNCHER_SOCK}"}
    try:
        s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
        s.settimeout(float(os.environ.get("MIOS_BROKER_TIMEOUT_S", str(timeout))))
        s.connect(LAUNCHER_SOCK)
        s.sendall(("CAPTURE_JSON: " + cmd + "\n").encode())
        chunks: list[bytes] = []
        try:
            while True:
                buf = s.recv(65536)
                if not buf:
                    break
                chunks.append(buf)
        except _socket.timeout:
            pass
        finally:
            s.close()
        raw = b"".join(chunks).decode("utf-8", "replace").strip()
        j = json.loads(raw) if raw else {}
        if not j:
            return {"success": False, "output": "", "exit_code": -1,
                    "stderr": raw or "broker: empty response"}
        ec = int(j.get("exit_code", -1))
        return {"success": ec == 0,
                "output": (j.get("stdout") or "")[:4000],
                "stderr": (j.get("stderr") or "")[:1000],
                "exit_code": ec}
    except OSError as e:
        return {"success": False, "output": "", "exit_code": -1,
                "stderr": f"broker: {e}"}


def _oscontrol_node_url(node: str) -> str:
    """4B: resolve an OS-control NODE name -> its executor base URL from the
    layered mios.toml [os_control.nodes.<node>].endpoint (vendor +/etc; /etc
    wins -- that's where the operator's real tailnet endpoint lives, NEVER the
    public repo). Returns '' when unknown/unset."""
    node = (node or "").strip()
    if not node:
        return ""
    try:
        import tomllib
    except ModuleNotFoundError:
        try:
            import tomli as tomllib  # type: ignore
        except ModuleNotFoundError:
            return ""
    url = ""
    for path in (os.environ.get("MIOS_TOML", "/usr/share/mios/mios.toml"),
                 "/etc/mios/mios.toml"):
        try:
            with open(path, "rb") as fh:
                d = tomllib.load(fh)
        except Exception:
            continue
        ep = (((d.get("os_control") or {}).get("nodes") or {}).get(node) or {})
        if isinstance(ep, dict) and ep.get("endpoint"):
            url = str(ep["endpoint"]).rstrip("/")
    return url


def _fire_and_verify_remote(app: str, node: str) -> dict:
    """4B: fire + verify on a REMOTE node via its mios-oscontrol-server
    (POST {url}/launch {app}). The node launches on its OWN desktop and polls
    its own window verifier, returning the verdict. Honest on failure: node
    unknown/unreachable -> launched:false + error (fires nothing)."""
    import urllib.request
    url = _oscontrol_node_url(node)
    if not url:
        return {"app": app, "node": node, "fired": False, "launched": False,
                "error": f"no os_control node {node!r} configured "
                         f"([os_control.nodes.{node}].endpoint in /etc/mios)",
                "checked_by": "mios-daemon-agent"}
    try:
        payload = json.dumps({"app": app}).encode("utf-8")
        req = urllib.request.Request(
            url + "/launch", data=payload,
            headers={"Content-Type": "application/json",
                     "Accept": "application/json"})
        timeout = float(os.environ.get("MIOS_OSCONTROL_NODE_TIMEOUT_S", "90"))
        with urllib.request.urlopen(req, timeout=timeout) as r:
            d = json.loads(r.read().decode("utf-8", "replace"))
        if not isinstance(d, dict):
            d = {"app": app, "node": node, "fired": False, "launched": False,
                 "error": "node returned non-object"}
        d.setdefault("app", app)
        d.setdefault("node", node)
        d["checked_by"] = f"mios-oscontrol-node:{node}"
        return d
    except Exception as e:   # node down / offline: HONEST, never fabricate
        log.warning("os_control remote node %r fire+verify failed: %s", node, e)
        return {"app": app, "node": node, "fired": False, "launched": False,
                "error": f"os_control node {node!r} unreachable: {e}",
                "checked_by": "mios-daemon-agent"}


def _executor_launched(fire: dict) -> bool:
    """True when fire_result shows the IN-SESSION executor (:11437) presented a
    window. The executor runs ON the operator's interactive desktop, so its
    "presented"/launched verdict is AUTHORITATIVE -- the Linux-side
    _verify_one_launch (pgrep + WSL window probe) cannot reliably see a
    Windows-host window and false-reports no-window for a Store game the executor
    already presented (operator 2026-05-30 Wreckfest). Parses the
    '[mios-windows] launched via in-session executor: {json}' line. Best-effort."""
    out = str((fire or {}).get("output") or "")
    if "in-session executor" not in out:
        return False
    m = re.search(r"\{.*\}", out, re.DOTALL)
    if not m:
        return False
    try:
        d = json.loads(m.group(0))
    except Exception:  # noqa: BLE001
        return False
    if d.get("launched") is True:
        return True
    v = d.get("verdict") if isinstance(d.get("verdict"), dict) else {}
    return v.get("launched") is True or str(v.get("summary", "")).lower() == "presented"


def _fire_and_verify(app: str, node: str = "") -> dict:
    """FIRE a launch + run the success-check as ONE operation, returning the
    consolidated verdict the agent reads: {app, fired, launched, verdict,
    ...}. NEVER raises. With `node` set -> delegates to that REMOTE node's
    executor (4B). Otherwise the LOCAL path: fire `mios-launch <app>` (the
    same command open_app's dispatcher renders) THROUGH THE BROKER (the only
    context with the WSLg display env), then POLL _verify_one_launch until the
    window is presented or attempts run out. The daemon is the SOLE firer (if
    it's unreachable the shim returns an honest error and the agent falls back
    to plain open_app)."""
    import shlex
    app = (app or "").strip()
    if not app:
        return {"app": "", "fired": False, "launched": False,
                "error": "missing app name", "checked_by": "mios-daemon-agent"}
    # PROSE-ARG GUARD (operator 2026-05-30): a #E ref can substitute an agent
    # node's FULL answer ("Here are your installed games ... Wallpaper Engine has
    # the highest rating ... Launching it now:") into the launch arg instead of a
    # clean name -- the launcher then can't resolve it AND polls the full verify
    # loop (~105s) for a window that can never appear. If the arg looks like prose
    # (newline / many words), extract the SINGLE launch target via the micro-LLM.
    if "\n" in app or len(app.split()) > 6:
        _clean = (llm_chat(
            "You extract a launch target. From the text, reply with ONLY the "
            "exact name of the single app or game being launched -- no quotes, "
            "no explanation, no punctuation, nothing else.", app[:2000]) or "").strip()
        _clean = _clean.splitlines()[0].strip() if _clean else ""
        if _clean and len(_clean.split()) <= 8:
            log.info("os_control: extracted launch target %r from prose arg", _clean)
            app = _clean
    node = (node or "").strip()
    if node:
        return _fire_and_verify_remote(app, node)
    fire = _broker_dispatch("mios-launch " + shlex.quote(app))
    # The in-session executor's verdict is AUTHORITATIVE for "a window appeared"
    # (it runs on the real interactive desktop); trust it over the Linux-side
    # probe, which false-reports no-window for Windows-host/Store windows.
    _exec_presented = _executor_launched(fire)
    time.sleep(OS_CONTROL_SETTLE_S)
    verdict: dict = {}
    launched = False
    used = 0
    for i in range(max(1, OS_CONTROL_ATTEMPTS)):
        used = i + 1
        verdict = _verify_one_launch(app)
        # presented_to_operator ONLY -- process_alive false-positives via the
        # verifier's pgrep self-match (see launch_verifier_loop); SOUL rule:
        # "process alive is INSUFFICIENT, success only when window presented".
        # The executor's in-session "presented" verdict ALSO counts as success.
        launched = bool(verdict.get("presented_to_operator")) or _exec_presented
        if launched:
            if _exec_presented and not verdict.get("presented_to_operator"):
                verdict["executor_presented"] = True
                verdict.setdefault("summary", "presented (in-session executor)")
            break
        if i < OS_CONTROL_ATTEMPTS - 1:
            time.sleep(OS_CONTROL_INTERVAL_S)
    if not launched:
        log.warning("os_control: fire+verify FALSE-SUCCESS app=%r fire_ec=%s "
                    "summary=%s", app, fire.get("exit_code"),
                    verdict.get("summary"))
    return {
        "app": app,
        "fired": fire.get("exit_code") == 0,
        "launched": launched,
        "verdict": verdict,
        "fire_result": fire,
        "attempts": used,
        "checked_by": "mios-daemon-agent",
        "ts": int(time.time()),
    }


def _openai_compat_llm_json(system: str, user: str,
                            timeout: int = 30) -> dict:
    """Call Ollama via its OpenAI-compatible /v1/chat/completions
    endpoint with response_format=json_object (operator directive:
    'native for OpenAI API standards'). Returns parsed dict; {} on
    any failure (fail-open -- the loop just skips a tick)."""
    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user",   "content": user},
        ],
        "response_format": {"type": "json_object"},
        "temperature": 0.1,
        "max_tokens": 700,
        "stream": False,
    }
    try:
        req = urllib.request.Request(
            f"{ENDPOINT}/v1/chat/completions",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as r:
            body = json.loads(r.read())
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        log.debug("nudger LLM call failed: %s", e)
        return {}
    choices = body.get("choices") or []
    if not choices:
        return {}
    content = ((choices[0].get("message") or {}).get("content") or "").strip()
    if not content:
        return {}
    try:
        parsed = json.loads(content)
        return parsed if isinstance(parsed, dict) else {}
    except json.JSONDecodeError:
        return {}


def _render_nudges_md(payload: dict) -> str:
    """Render the structured nudge payload as a markdown digest the
    agent can `cat` for ground-truth status."""
    nudges = payload.get("nudges") or []
    digest = payload.get("digest") or ""
    out = [
        f"# MiOS agent nudges",
        f"_updated: {datetime.datetime.now().isoformat(timespec='seconds')}_",
        "",
        f"## Digest",
        digest or "_no notable state_",
        "",
        f"## Open nudges ({len(nudges)})",
    ]
    if not nudges:
        out.append("_none -- proceed_")
    for n in nudges:
        if not isinstance(n, dict):
            continue
        sev = n.get("severity", "low")
        nt = n.get("type", "?")
        summ = n.get("summary", "")
        act = n.get("action", "")
        icon = {"high": "🔴", "med": "🟡", "low": "🟢"}.get(sev, "·")
        out.append(f"- {icon} **{nt}** ({sev}): {summ}")
        if act:
            out.append(f"  - **action:** `{act}`")
    return "\n".join(out) + "\n"


def fs_watcher_loop() -> None:
    """Phase A.2: kernel-event-driven mutation bus.

    Watches /var/lib/mios/* scratchpads + state dirs via inotify.
    Each mutation -> one SurrealDB event row with source=fs-watcher,
    kind=fs_change, payload={path, op, size, preview}. Other agents
    subscribe via `SELECT FROM event WHERE source = 'fs-watcher'
    AND ts > <last_seen>` instead of polling individual files.

    Debounces per (path, op) at 1Hz so a noisy write loop doesn't
    flood the event table. Tolerates missing/added dirs: creates the
    watched dirs at startup; warnings on add-watch failure don't kill
    the thread.
    """
    # Boot delay: let the rest of the daemon initialize so the
    # SurrealDB writer is warm before we start firing events.
    for _ in range(15):
        if _stop_event.is_set(): return
        time.sleep(1)
    try:
        fd = _inotify_init()
    except OSError as e:
        log.warning("inotify_init1 failed (%s); fs-watcher disabled", e)
        return
    wd_to_dir: dict[int, str] = {}
    for d in _FS_WATCHER_DIRS:
        # Best-effort create. If the parent dir is owned by another
        # service (e.g. /var/lib/mios/ai owned by mios-hermes) and
        # root's mkdir lands in a perms-conflict, skip silently --
        # the dir will be created by its owner agent later, at which
        # point we can re-add the watch on the next daemon restart.
        if not os.path.isdir(d):
            try:
                Path(d).mkdir(parents=True, exist_ok=True)
            except OSError:
                log.info("fs-watcher: skip %s (not present + parent "
                         "owned by another agent)", d)
                continue
        try:
            wd = _inotify_add(fd, d)
            wd_to_dir[wd] = d
            log.info("fs-watcher: watching %s (wd=%d)", d, wd)
        except OSError as e:
            log.warning("fs-watcher: %s -> %s", d, e)
    if not wd_to_dir:
        log.warning("fs-watcher: no dirs registered; thread exiting")
        return
    last_emit: dict[str, float] = {}
    DEBOUNCE_S = 1.0
    while not _stop_event.is_set():
        try:
            r, _, _ = _select.select([fd], [], [], 1.0)
            if not r:
                continue
            for wd, mask, _cookie, name in _inotify_read(fd):
                dir_path = wd_to_dir.get(wd)
                if not dir_path:
                    continue
                full = os.path.join(dir_path, name) if name else dir_path
                # Pick the most informative op-name for the mask.
                op = next(
                    (n for bit, n in _OP_NAMES.items() if mask & bit),
                    f"mask={mask:#x}",
                )
                key = f"{full}|{op}"
                now = time.time()
                if last_emit.get(key, 0.0) > now - DEBOUNCE_S:
                    continue
                last_emit[key] = now
                size = 0
                preview = ""
                if op in ("write", "moved_in", "create"):
                    try:
                        st = os.stat(full)
                        size = int(st.st_size)
                        if size > 0 and st.st_mode & 0o4444:
                            with open(full, "rb") as f:
                                preview = f.read(500).decode(
                                    "utf-8", errors="replace")
                    except OSError:
                        pass
                row = {
                    "source": "fs-watcher",
                    "kind": "fs_change",
                    "severity": "info",
                    "summary": f"{op}: {full}",
                    "payload": {
                        "path": full,
                        "op": op,
                        "mask": int(mask),
                        "size": size,
                        "preview": preview[:500],
                    },
                }
                _db_post(_db_create("event", row, now_fields=("ts",)))
        except Exception as e:
            log.warning("fs-watcher iter: %s", e)
            # Brief backoff so a persistent OS error doesn't spin.
            time.sleep(2)


def task_collector_loop() -> None:
    """5-min cadence aggregator + nudger. See module docstring above."""
    # Boot delay -- let mios-daemon settle, sessions populate.
    time.sleep(75)
    NUDGES_MD.parent.mkdir(parents=True, exist_ok=True)
    while not _stop_event.is_set():
        try:
            agg = {
                "kanban": _collect_kanban_state(),
                "recent_sessions": _collect_recent_sessions(),
                "scratch": _collect_scratch(),
                "launch_failures": _collect_launch_failures(),
            }
            with _state_lock:
                cls = (_state.get("classify") or {})
            if cls.get("summary"):
                agg["recent_log_summary"] = cls["summary"][:300]
            # Compose the user message: terse JSON dump of the aggregate.
            user_msg = (
                "Aggregate MiOS state (last ~30 min):\n\n"
                f"```json\n{json.dumps(agg, indent=2, default=str)[:6000]}\n```\n"
                "\nProduce the nudges JSON now."
            )
            parsed = _openai_compat_llm_json(
                TASK_SYSTEM, user_msg,
                timeout=int(REQUEST_TIMEOUT_S),
            )
            if not parsed:
                parsed = {"nudges": [], "digest": "(nudger LLM unreachable)"}
            # Atomic write of both the markdown digest + structured JSON
            md = _render_nudges_md(parsed)
            for target, content in ((NUDGES_MD, md),
                                    (NUDGES_JSON, json.dumps(parsed, indent=2))):
                tmp = target.with_suffix(target.suffix + ".tmp")
                tmp.write_text(content, encoding="utf-8")
                os.chmod(tmp, 0o644)
                tmp.replace(target)
            _update_state("nudges", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "count": len(parsed.get("nudges") or []),
                "digest_preview": (parsed.get("digest") or "")[:160],
                "sources": {
                    "kanban": len(agg["kanban"]),
                    "sessions": len(agg["recent_sessions"]),
                    "scratch": len(agg["scratch"]),
                    "launch_failures": len(agg["launch_failures"]),
                },
            })
            # Best-effort SurrealDB sync: kanban_shadow (UPSERT per
            # hermes_task_id), scratch (the digest itself), and a
            # per-tick event row. fail-quiet via _db_post backoff.
            for k in agg["kanban"]:
                _tid = str(k.get("id") or "").strip()
                if not _tid:
                    continue
                _row = {
                    "hermes_task_id": _tid,
                    "title": str(k.get("title") or "")[:240],
                    "status": str(k.get("status") or "unknown")[:40],
                    "priority": str(k.get("priority") or "") or None,
                    "tags": (k.get("tags").split(",")
                             if isinstance(k.get("tags"), str) else []),
                }
                # UPSERT pattern: DELETE-then-CREATE keyed on the unique
                # hermes_task_id index defined in schema-init.surql.
                _db_post(
                    "DELETE kanban_shadow WHERE hermes_task_id = "
                    f"{json.dumps(_tid)}; "
                    + _db_create("kanban_shadow", _row,
                                 now_fields=("synced_at",))
                )
            # Scratch row carrying the digest text (so other agents can
            # see what the nudger concluded without re-parsing the .md).
            _digest = (parsed.get("digest") or "").strip()
            if _digest:
                _db_post(_db_create("scratch", {
                    "source": "mios-daemon",
                    "topic": "nudges",
                    "body": _digest[:4000],
                }, now_fields=("ts",)))
            # Per-tick event row -- audit trail of when the nudger ran.
            _db_post(_db_create("event", {
                "source": "mios-daemon",
                "kind": "nudge",
                "severity": "warn" if (parsed.get("nudges") or []) else "info",
                "summary": (
                    f"nudges={len(parsed.get('nudges') or [])} "
                    f"kanban={len(agg['kanban'])} "
                    f"sessions={len(agg['recent_sessions'])}"
                ),
                "payload": {
                    "sources": {
                        "kanban": len(agg["kanban"]),
                        "sessions": len(agg["recent_sessions"]),
                        "scratch": len(agg["scratch"]),
                        "launch_failures": len(agg["launch_failures"]),
                    },
                },
            }, now_fields=("ts",)))
        except Exception as e:
            log.warning("task_collector: %s: %s", type(e).__name__, e)
        for _ in range(int(TASK_COLLECT_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


def suggestions_loop() -> None:
    # Boot delay so OWUI + ollama warm before first generation
    time.sleep(45)
    while not _stop_event.is_set():
        # W0-T2 (1): host-pressure gate -- skip this generation tick (the LLM
        # call below) when over ceiling AND pressure_skip; still falls through
        # to the interruptible sleep so the loop keeps its cadence.
        if _pressure_should_skip("suggestions"):
            for _ in range(int(SUGG_TICK_S)):
                if _stop_event.is_set(): return
                time.sleep(1)
            continue
        try:
            recent = _recent_owui_user_messages()
            classify_summary = ""
            with _state_lock:
                cls = (_state.get("classify") or {})
            if cls.get("summary"):
                classify_summary = f"Recent log summary: {cls['summary'][:200]}."

            locale_hint = " | ".join(recent) if recent else "(no recent chats)"
            user_prompt = (
                f"Generate {SUGG_COUNT} short prompts (3 to 12 words each) "
                "the operator could click to start a useful turn. Mix "
                "categories: launch/open, find/search, install, status, "
                "kanban, research, configure. "
                f"{classify_summary} "
                f"Locale + recent context: {locale_hint}. "
                "\n\nOutput JSON ONLY: {\"suggestions\":[\"...\", ...]}"
            )
            content = llm_chat(SUGG_SYSTEM, user_prompt,
                               max_tokens=400, want_json=True)
            m = re.search(r"\{[\s\S]*\}", content) if content else None
            cards: list[dict] = []
            if m:
                try:
                    parsed = json.loads(m.group(0))
                    for s in (parsed.get("suggestions") or [])[:SUGG_COUNT]:
                        if not isinstance(s, str): continue
                        s = s.strip()[:160]
                        if s: cards.append({"title": [s, ""], "content": s})
                except json.JSONDecodeError:
                    pass

            if cards and SUGG_OWUI_DB.is_file():
                import sqlite3
                c = sqlite3.connect(str(SUGG_OWUI_DB))
                row = c.execute(
                    "SELECT data FROM config WHERE id=1").fetchone()
                if row is not None:
                    try:
                        cfg = json.loads(row[0])
                    except json.JSONDecodeError:
                        cfg = {}
                    cfg.setdefault("ui", {})["prompt_suggestions"] = cards
                    c.execute(
                        "UPDATE config SET data=?, updated_at=? WHERE id=1",
                        (json.dumps(cfg),
                         datetime.datetime.utcnow().isoformat()))
                    c.commit()
                    log.info("suggestions: wrote %d LLM cards "
                             "(classify-summary=%s, recent-msgs=%d)",
                             len(cards),
                             "yes" if classify_summary else "no",
                             len(recent))
            _update_state("suggestions", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "count": len(cards),
                "preview": [c["content"][:60] for c in cards[:3]],
                "used_classify": bool(classify_summary),
                "used_recent_chats": len(recent),
            })
        except Exception as e:
            log.warning("suggestions: %s: %s", type(e).__name__, e)
        # Interruptible sleep
        for _ in range(int(SUGG_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


