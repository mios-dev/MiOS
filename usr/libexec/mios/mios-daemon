def _pg_exec(sql: str) -> None:
    if not _PG_ENABLED:
        return
    try:
        import subprocess
        subprocess.run([_MIOS_DB, "--pg", sql],
                       capture_output=True, text=True, timeout=15)
    except Exception:  # noqa: BLE001
        pass


def _pg_run(envelope: dict) -> str:
    """WS-A3: run a PARAMETERIZED statement/batch via `mios-db --pg-json`, which
    binds values OUT-OF-BAND through mios-pg-query's extended protocol (no value
    is spliced into SQL -> injection-safe). Returns stdout; degrade-open -> ''."""
    if not _PG_ENABLED:
        return ""
    try:
        import subprocess
        r = subprocess.run([_MIOS_DB, "--pg-json"], input=json.dumps(envelope),
                           capture_output=True, text=True, timeout=15)
        return (r.stdout or "").strip()
    except Exception:  # noqa: BLE001
        return ""


def _pg_insert(table: str, fields: dict) -> None:
    """Mirror a daemon write to pgvector (chokepoint, called from _db_create).
    WS-A3: values are now BOUND via $1..$n params (mios-db --pg-json), never
    f-string-spliced (the old _pgesc single-quote doubling was not a binding).
    dict/list -> jsonb via a ::jsonb cast on the bound param; time columns use
    the pgvector column DEFAULT (now()). `table`/column names are trusted
    identifiers (never request data). Degrade-open."""
    if not _PG_ENABLED:
        return
    cols, phs, params = [], [], []
    n = 0
    for k, v in fields.items():
        if v is None:
            continue
        n += 1
        cols.append(k)
        if isinstance(v, (dict, list)):
            phs.append(f"${n}::jsonb")
            params.append(json.dumps(v, default=str))
        elif isinstance(v, bool):
            phs.append(f"${n}")
            params.append("true" if v else "false")
        elif isinstance(v, (int, float)):
            phs.append(f"${n}")
            params.append(str(v))
        else:
            phs.append(f"${n}")
            params.append(str(v))
    if cols:
        _pg_run({"sql": f"INSERT INTO {table} ({', '.join(cols)}) "
                        f"VALUES ({', '.join(phs)})",
                 "params": params})


def _db_post(sql: str, *, timeout: float = 3.0) -> Optional[list]:
    """WS-A3: SurrealDB (:8000) is RETIRED -> hard no-op. Returns None (callers
    do `or []` / _ok_result(None) -> []), exactly as the dead backend resolved to
    but WITHOUT the per-call 3s timeout + 30s backoff. Writes are already mirrored
    to pgvector at the _db_create chokepoint (_pg_insert); translated reads go
    through _db_read's pg path. Kept as a stub (signature incl. `timeout`) so the
    many _db_post(_db_create(...)) write sites + read fallbacks need no change."""
    return None


def _pg_query(select_sql: str, params: "Optional[list]" = None) -> list:
    """R15/G10: read rows from pgvector. Wraps the SELECT in json_agg(row_to_json)
    so the output is a single JSON array. Returns a list of dicts ([] on error/
    pg-disabled). WS-A3: when `params` is given, the values are BOUND out-of-band
    ($1..$n) via `mios-db --pg-json` -- the select_sql must use placeholders, not
    f-string-spliced values. Without params, the legacy `mios-db --pg` path runs
    a constant SQL string."""
    if not _PG_ENABLED:
        return []
    try:
        wrapped = ("SELECT COALESCE(json_agg(row_to_json(t)), '[]'::json) FROM ("
                   + select_sql.rstrip().rstrip(";") + ") t;")
        if params is not None:
            out = _pg_run({"sql": wrapped, "params": params})
        else:
            import subprocess
            p = subprocess.run([_MIOS_DB, "--pg", wrapped, "--json"],
                               capture_output=True, text=True, timeout=15)
            out = (p.stdout or "").strip() if p.returncode == 0 else ""
        return json.loads(out) if out else []
    except Exception:  # noqa: BLE001 -- degrade-open
        return []


def _db_read(surreal_sql: str, *, pg_sql: "Optional[str]" = None,
             pg_params: "Optional[list]" = None) -> list:
    """Agent-plane READ seam (mirrors agent-pipe's). When pg is ENABLED AND a
    pg_sql translation is supplied, run it and wrap the rows in SurrealDB's
    [{"result": [...]}] envelope so _ok_result parses both shapes UNCHANGED. Else
    SurrealDB.

    WS-A3: gated on _PG_ENABLED (not _PG_PRIMARY) -- in the DEFAULT 'dual' mode
    SurrealDB (:8000) is retired and dead, so a _PG_PRIMARY gate left every
    translated read (satisfaction monitor, refine scan, ...) hitting the dead
    backend and returning [] (the documented training/telemetry-starvation bug).
    Reading the live pgvector mirror in dual is correct (daemon writes already
    mirror to pg) and strictly non-regressive: a missing/bad translation still
    falls back to SurrealDB -> [] (degrade-open), same as before, and pg responds
    instead of timing out + arming the 30s backoff. Reads WITHOUT a pg_sql still
    go to SurrealDB (-> [] until translated). pg_params (when the pg_sql uses
    $1..$n placeholders) are bound out-of-band -> injection-safe."""
    if _PG_ENABLED and pg_sql:
        return [{"result": _pg_query(pg_sql, pg_params)}]
    return _db_post(surreal_sql) or []


def _db_create(table: str, fields: dict, *,
               now_fields: tuple = (),
               extra: str = "") -> str:
    """Build `CREATE <table> SET ...` -- SurrealDB 3.0+ rejects plain
    ISO-Z strings for TYPE datetime fields, so the canonical pattern
    is `field = time::now()` literal for datetimes + JSON-encoded
    values for everything else (JSON-object syntax IS SurrealQL-object
    syntax, so nested payload dicts pass through unchanged)."""
    parts = [f"{k} = time::now()" for k in now_fields]
    for k, v in fields.items():
        if k in now_fields or v is None:
            continue
        parts.append(f"{k} = {json.dumps(v, default=str)}")
    sql = f"CREATE {table} SET " + ", ".join(parts)
    if extra:
        sql += " " + extra
    _pg_insert(table, fields)  # WS-9c: mirror to pgvector at the chokepoint
    return sql + ";"


# ── inotify wrapper (stdlib ctypes; no pip deps for offline / Day-0) ──
# Phase A.2 of the AgentOS roadmap: replace the daemon's poll loops
# with kernel-event-driven mutations. Watches the /var/lib/mios/*
# scratchpads + state dirs; emits SurrealDB event rows (source=
# fs-watcher, kind=fs_change) on every change so other agents
# (agent-pipe critic, future DCI deliberation, ...) can subscribe
# via `SELECT FROM event WHERE source = 'fs-watcher' AND ts > <last>`
# instead of polling individual JSON files.
#
# Implementation: minimal ctypes wrapper around inotify_init1 +
# inotify_add_watch + raw read. No pip packages needed -- Day-0 bake
# carries no extra Python deps for this feature.

import ctypes as _ctypes
import struct as _struct
import select as _select

_libc = _ctypes.CDLL("libc.so.6", use_errno=True)
_libc.inotify_init1.argtypes = [_ctypes.c_int]
_libc.inotify_init1.restype = _ctypes.c_int
_libc.inotify_add_watch.argtypes = [_ctypes.c_int, _ctypes.c_char_p, _ctypes.c_uint32]
_libc.inotify_add_watch.restype = _ctypes.c_int

# /usr/include/sys/inotify.h flags + event mask bits.
_IN_NONBLOCK = 0x800
_IN_CLOEXEC = 0x80000
_IN_CLOSE_WRITE = 0x00000008
_IN_MOVED_TO    = 0x00000080
_IN_CREATE      = 0x00000100
_IN_DELETE      = 0x00000200
_IN_MOVED_FROM  = 0x00000040
# Watch every change that could carry agent-relevant state.
_WATCH_MASK = (_IN_CLOSE_WRITE | _IN_MOVED_TO
               | _IN_CREATE | _IN_DELETE | _IN_MOVED_FROM)
_EVENT_HEADER = _struct.Struct("iIII")  # wd, mask, cookie, name_len

# Dirs the daemon (and other agents) write or expect mutations on.
# Sourced from mios.toml [fs_watcher].watch_dirs via the userenv.sh
# slot (MIOS_FS_WATCHER_DIRS, CSV). Falls back to the compiled-in
# defaults that match the mios.toml seed when env is unset.
_DEFAULT_FS_WATCHER_DIRS = [
    "/var/lib/mios/hermes-tail",
    "/var/lib/mios/delegation-prefilter",
    "/var/lib/mios/log-watcher",
    "/var/lib/mios/daemon",
    "/var/lib/mios/scratch",
    "/var/lib/mios/agent-nudger",
    "/var/lib/mios/cron-director",
    "/var/lib/mios/ai/scratch",
]
_env_fs_dirs = os.environ.get("MIOS_FS_WATCHER_DIRS", "").strip()
if _env_fs_dirs:
    _FS_WATCHER_DIRS = [d.strip() for d in _env_fs_dirs.split(",") if d.strip()]
else:
    _FS_WATCHER_DIRS = list(_DEFAULT_FS_WATCHER_DIRS)

# Map of mask-bit -> short op name for the SurrealDB event row.
_OP_NAMES = {
    _IN_CLOSE_WRITE: "write",
    _IN_MOVED_TO:    "moved_in",
    _IN_CREATE:      "create",
    _IN_DELETE:      "delete",
    _IN_MOVED_FROM:  "moved_out",
}


def _inotify_init() -> int:
    fd = _libc.inotify_init1(_IN_NONBLOCK | _IN_CLOEXEC)
    if fd < 0:
        raise OSError(_ctypes.get_errno(), "inotify_init1")
    return fd


def _inotify_add(fd: int, path: str, mask: int = _WATCH_MASK) -> int:
    wd = _libc.inotify_add_watch(fd, path.encode("utf-8"), mask)
    if wd < 0:
        raise OSError(_ctypes.get_errno(), f"inotify_add_watch({path})")
    return wd


def _inotify_read(fd: int) -> list[tuple[int, int, int, str]]:
    """Return list of (wd, mask, cookie, name)."""
    try:
        buf = os.read(fd, 8192)
    except BlockingIOError:
        return []
    out: list[tuple[int, int, int, str]] = []
    i = 0
    while i < len(buf):
        wd, mask, cookie, name_len = _EVENT_HEADER.unpack_from(buf, i)
        i += 16
        name = buf[i:i + name_len].rstrip(b"\x00").decode("utf-8", errors="replace")
        i += name_len
        out.append((wd, mask, cookie, name))
    return out


# ── Shared state (handlers write here; flusher persists) ─────────────
_state_lock = threading.Lock()
_state: dict = {
    "ts": time.time(),
    "classify": None,
    "refusal":  None,
    "cron":     {"last_fire": None, "decisions": []},
}
_stop_event = threading.Event()


def _atomic_write_state() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with _state_lock:
        snapshot = dict(_state)
        snapshot["ts"] = time.time()
    tmp = STATE_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(snapshot, separators=(",", ":")))
    os.chmod(tmp, 0o644)
    tmp.replace(STATE_FILE)


def _update_state(section: str, value) -> None:
    with _state_lock:
        _state[section] = value
    _atomic_write_state()


# ── W0-T2 (1): host-pressure gate ────────────────────────────────────
# A ~5s-TTL cached read of the 1-min loadavg (per core) + a best-effort
# nvidia-smi GPU-util probe. The four cadence loops call this at the TOP
# of each tick; under pressure they SKIP the tick (no LLM call) and write
# a "deferred (host pressure)" marker -- so the always-on daemon stops
# adding fuel to a runaway instead of piling LLM/cron work onto a
# saturated box. Degrade-open: any probe error -> over_ceiling=False
# (proceed exactly as today). pressure_skip gates whether a hot signal
# actually causes a skip (default false = observe-only).
_pressure_lock = threading.Lock()
_pressure_cache: dict = {"ts": 0.0, "load_per_core": 0.0,
                         "gpu_util": -1.0, "over": False}


def _probe_gpu_util() -> float:
    """Best-effort highest GPU-utilization-% across NVIDIA GPUs via
    nvidia-smi. Returns -1.0 when nvidia-smi is missing / errors / has no
    GPUs (degrade-open: caller treats <0 as 'no GPU signal')."""
    try:
        p = subprocess.run(
            ["nvidia-smi", "--query-gpu=utilization.gpu",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=3,
        )
        if p.returncode != 0:
            return -1.0
        vals = []
        for line in (p.stdout or "").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                vals.append(float(line))
            except ValueError:
                continue
        return max(vals) if vals else -1.0
    except (OSError, subprocess.SubprocessError):
        return -1.0


def _host_pressure_gate() -> dict:
    """Return {over_ceiling, load_per_core, gpu_util, reason} using a
    ~PRESSURE_TTL_S cached probe (so 4 loops sharing one tick don't run
    nvidia-smi N times). over_ceiling is True only when a configured
    ceiling (>0) is exceeded. NEVER raises -- on any probe error it
    reports over_ceiling=False so the caller proceeds as today.

    Note: over_ceiling reflects the raw measurement; whether a tick is
    actually SKIPPED is the caller's decision gated on PRESSURE_SKIP."""
    now = time.time()
    with _pressure_lock:
        if (now - _pressure_cache["ts"]) < max(0.5, PRESSURE_TTL_S):
            return {
                "over_ceiling": _pressure_cache["over"],
                "load_per_core": _pressure_cache["load_per_core"],
                "gpu_util": _pressure_cache["gpu_util"],
                "reason": _pressure_cache.get("reason", ""),
            }
    load_per_core = 0.0
    try:
        load1 = os.getloadavg()[0]
        ncpu = os.cpu_count() or 1
        load_per_core = load1 / max(1, ncpu)
    except (OSError, AttributeError):
        load_per_core = 0.0  # degrade-open (e.g. no getloadavg on this OS)
    gpu_util = _probe_gpu_util()
    reasons = []
    over = False
    if PRESSURE_LOAD_CEIL > 0 and load_per_core > PRESSURE_LOAD_CEIL:
        over = True
        reasons.append(f"load/core {load_per_core:.2f}>{PRESSURE_LOAD_CEIL:.2f}")
    if PRESSURE_GPU_UTIL_CEIL > 0 and gpu_util >= 0 \
            and gpu_util > PRESSURE_GPU_UTIL_CEIL:
        over = True
        reasons.append(f"gpu {gpu_util:.0f}%>{PRESSURE_GPU_UTIL_CEIL:.0f}%")
    reason = ", ".join(reasons)
    with _pressure_lock:
        _pressure_cache.update({"ts": now, "load_per_core": load_per_core,
                                "gpu_util": gpu_util, "over": over,
                                "reason": reason})
    return {"over_ceiling": over, "load_per_core": load_per_core,
            "gpu_util": gpu_util, "reason": reason}


def _pressure_should_skip(loop_name: str) -> bool:
    """True when a tick of `loop_name` should be skipped for host pressure.
    Writes a 'deferred (host pressure)' marker into state.pressure for
    operator visibility on EVERY over-ceiling observation (even when
    PRESSURE_SKIP is off, so the operator can see what WOULD be deferred
    before enabling). Returns True only when PRESSURE_SKIP is also set."""
    try:
        g = _host_pressure_gate()
    except Exception:  # noqa: BLE001 -- degrade-open: never block on a probe
        return False
    if not g["over_ceiling"]:
        return False
    marker = {
        "ts": datetime.datetime.now().isoformat(timespec="seconds"),
        "loop": loop_name,
        "deferred": bool(PRESSURE_SKIP),
        "load_per_core": round(g["load_per_core"], 2),
        "gpu_util": g["gpu_util"],
        "reason": g["reason"] or "over ceiling",
        "note": "deferred (host pressure)" if PRESSURE_SKIP
                else "over ceiling (observe-only; pressure_skip=false)",
    }
    try:
        _update_state("pressure", marker)
    except Exception:  # noqa: BLE001 -- state write must not crash the loop
        pass
    if PRESSURE_SKIP:
        log.info("%s: deferred (host pressure: %s)", loop_name,
                 g["reason"] or "over ceiling")
    return bool(PRESSURE_SKIP)


# ── W0-T2 (4): quiescence tracker ────────────────────────────────────
# Tracks the last time a NOTABLE signal occurred (a new med/high log
# digest OR a new unsatisfied verdict). When nothing notable lands within
# QUIESCENCE_WINDOW_MIN, the classify loop widens its cadence (doubling,
# capped at CALM_MAX_TICK_S) so an idle box isn't polled aggressively.
# Any new notable signal calls _mark_activity() which resets the cadence.
_last_activity_ts: float = time.time()
_activity_lock = threading.Lock()


def _mark_activity() -> None:
    """Record a notable signal -- resets the quiescence clock so the
    classify cadence drops back to the responsive CLASSIFY_BATCH_S."""
    global _last_activity_ts
    with _activity_lock:
        _last_activity_ts = time.time()


def _is_quiescent() -> bool:
    """True when no notable signal has landed within QUIESCENCE_WINDOW_MIN."""
    with _activity_lock:
        last = _last_activity_ts
    return (time.time() - last) >= (QUIESCENCE_WINDOW_MIN * 60.0)


# ── Single shared Ollama client ──────────────────────────────────────
def llm_chat(system: str, user: str, *, max_tokens: int = 150,
             temperature: float = 0.1, want_json: bool = False,
             num_thread: int = 4, model: str = "", endpoint: str = "") -> str:
    """Call qwen3:0.6b-cpu (or whatever MODEL is) via Ollama /api/chat.
    Returns the model's text output (content with thinking fallback).
    Returns empty string on any error. Always uses CPU + keep_alive=-1.

    num_thread tunes the CPU inference width: the always-on BACKGROUND loop
    keeps the default 4 (~2c, light), while the FOREGROUND daemon-agent
    reasoner (the consolidated mios-cpu/reasoner lane) passes a wider count
    (8c/16t) so a pipeline turn bursts -- operator 2026-05-24 '2c background /
    8c foreground'. Ollama clamps to the available core count.
    """
    # ENDPOINT-AWARE (operator 2026-05-25: the daemon-agent can run on the iGPU =
    # llama.cpp OpenAI /v1, NOT Ollama /api/chat). Ollama lanes (:11434/:11435)
    # use native /api/chat with num_gpu=0 + num_thread + think:False; a non-ollama
    # /v1 endpoint (the iGPU, which offloads to its own Vulkan device -- the
    # num_gpu/num_thread CPU knobs do not apply) uses /chat/completions.
    _msgs = [{"role": "system", "content": system},
             {"role": "user", "content": user}]
    # FOREGROUND swarm turns pass a BIGGER model (AGENT_MODEL) for a heavy,
    # VISIBLE, sustained CPU spike (operator 2026-05-26 "bigger CPU model");
    # the always-on BACKGROUND loop omits `model` -> stays on the snappy MODEL.
    _mdl = model or MODEL
    # FOREGROUND swarm turns can target a DIFFERENT lane than the always-on
    # background loop (operator 2026-05-26): the daemon's MODEL/ENDPOINT stay on
    # the iGPU (the 2026-05-25 offload), but a swarm facet reply forces the CPU
    # lane (AGENT_ENDPOINT=:11435) so the CPU node ACTUALLY + VISIBLY computes.
    _ep = (endpoint or ENDPOINT).rstrip("/")
    _ollama = (":11434" in _ep) or (":11435" in _ep)
    if _ollama:
        payload = {
            "model": _mdl, "messages": _msgs,
            "options": {"num_gpu": 0, "num_thread": num_thread,
                        "num_predict": max_tokens, "temperature": temperature},
            "stream": False, "keep_alive": -1, "think": False,
        }
        if want_json:
            payload["format"] = "json"
        url = f"{_ep}/api/chat"
    else:
        payload = {"model": _mdl, "messages": _msgs, "stream": False,
                   "max_tokens": max_tokens, "temperature": temperature}
        if want_json:
            payload["response_format"] = {"type": "json_object"}
        url = (f"{_ep}/chat/completions" if _ep.endswith("/v1")
               else f"{_ep}/v1/chat/completions")
    try:
        req = urllib.request.Request(
            url,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT_S) as r:
            body = json.loads(r.read())
        if _ollama:
            msg = body.get("message") or {}
            out = (msg.get("content") or "").strip()
            if not out and not want_json:
                # Free-text calls ONLY -- `thinking` is never valid JSON, so a
                # want_json fallback to it just produces an unparseable digest.
                out = (msg.get("thinking") or msg.get("reasoning") or "").strip()
        else:
            msg = ((body.get("choices") or [{}])[0].get("message") or {})
            out = (msg.get("content") or "").strip()
        return out
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        log.warning("LLM call failed (non-fatal): %s", e)
        return ""


# ── Journal subscriber ───────────────────────────────────────────────
_event_buffer: list[dict] = []
_buffer_lock = threading.Lock()


def journal_subscriber() -> None:
    """Run `journalctl -f -o json` and push parsed events into the
    shared buffer. Classify + refusal-detect handlers drain it."""
    units_args: list[str] = []
    for u in WATCHED_UNITS:
        u = u.strip()
        if u:
            units_args += ["-u", u]
    cmd = ["journalctl", "-f", "-n", "0", "-o", "json", "--no-pager", *units_args]
    log.info("journal subscriber: %s", " ".join(cmd))
    proc = subprocess.Popen(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
        text=True, bufsize=1,
    )
    try:
        for line in proc.stdout:
            if _stop_event.is_set():
                break
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue
            with _buffer_lock:
                _event_buffer.append(ev)
                # Cap to avoid runaway memory
                if len(_event_buffer) > 500:
                    _event_buffer[:] = _event_buffer[-200:]
    finally:
        proc.terminate()


# ── Classify handler (was: mios-log-watcher) ─────────────────────────
CLASSIFY_SYSTEM = (
    "You are a Linux log classifier. Read the events below and reply "
    "with ONE LINE of JSON: {\"summary\":\"<one sentence>\","
    "\"tags\":[\"<one|two|three>\"],\"severity\":\"low|med|high\"}. "
    "Nothing else."
)


# Log consolidation -> SurrealDB (operator 2026-05-21: "logs should be
# compacted/compressed/consolidated and stored in global database(s)").
# Compress by SIGNAL: med/high severity -> one compact `log_digest` row
# (summary + tags + severity + count -- NOT raw lines); low/noise ->
# AGGREGATED into a periodic consolidated tally so the DB isn't flooded
# with a row every CLASSIFY_BATCH_S. Agents can query log_digest for a
# global, queryable log history (the state.json snapshot is latest-only).
_noise_agg = {"batches": 0, "events": 0, "since": time.time()}
_NOISE_FLUSH_S = float(os.environ.get("MIOS_DAEMON_NOISE_FLUSH_S", "1800"))

# W0-T2 (2): per-(source,kind,summary-shingle) fingerprint dedup + cooldown.
# An identical high-severity classification recurring inside CLASSIFY_DEDUP_S
# is SUPPRESSED -- collapsed to a count-only state marker rather than a fresh
# LLM-grounded log_digest row + activity reset. This stops one stuck unit
# (the GPU-runaway pattern is the SAME line firing every batch) from flooding
# the DB and from defeating the quiescence backoff. Bounded LRU on the map.
_dedup_seen: dict = {}          # fingerprint -> {"first": ts, "last": ts, "count": n}
_dedup_lock = threading.Lock()
_DEDUP_MAX_ENTRIES = 512


def _shingle(summary: str, n: int = 8) -> str:
    """First N normalized tokens of a summary -- a coarse fingerprint that
    treats near-identical classifications (same root cause, trivially
    different tail) as the same event."""
    toks = re.findall(r"[a-z0-9]+", str(summary or "").lower())
    return " ".join(toks[:n])


def _classify_fingerprint(result: dict, *, source: str = "classify") -> str:
    kind = str(result.get("severity", "low")).lower()
    return f"{source}|{kind}|{_shingle(result.get('summary', ''))}"


def _dedup_suppressed(fp: str) -> bool:
    """Record a fingerprint hit; return True when an identical fingerprint
    was seen within CLASSIFY_DEDUP_S (so the caller suppresses the heavy
    write and emits a count-only update instead). Degrade-open: if dedup is
    disabled (CLASSIFY_DEDUP_S<=0) it never suppresses."""
    if CLASSIFY_DEDUP_S <= 0:
        return False
    now = time.time()
    with _dedup_lock:
        rec = _dedup_seen.get(fp)
        if rec and (now - rec["last"]) < CLASSIFY_DEDUP_S:
            rec["last"] = now
            rec["count"] += 1
            return True
        _dedup_seen[fp] = {"first": now, "last": now,
                           "count": (rec["count"] + 1) if rec else 1}
        # Bounded LRU: evict the oldest-touched entries when oversized.
        if len(_dedup_seen) > _DEDUP_MAX_ENTRIES:
            for k in sorted(_dedup_seen,
                            key=lambda x: _dedup_seen[x]["last"])[:128]:
                _dedup_seen.pop(k, None)
        return False


def _persist_log_digest(result: dict) -> None:
    sev = str(result.get("severity", "low")).lower()
    if sev in ("med", "medium", "high"):
        # W0-T2 (2): dedup high-severity spam. An identical fingerprint inside
        # the cooldown collapses to a count-only state marker -- no new LLM/DB
        # row, and (crucially) no activity reset, so a single stuck unit can't
        # keep the daemon perpetually "busy".
        fp = _classify_fingerprint(result)
        if _dedup_suppressed(fp):
            with _dedup_lock:
                cnt = _dedup_seen.get(fp, {}).get("count", 1)
            _update_state("classify_dedup", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "fingerprint": fp[:160],
                "severity": "high" if sev == "high" else "med",
                "suppressed_count": cnt,
                "note": "duplicate high-severity classification suppressed",
            })
            log.info("classify: duplicate %s suppressed (x%d): %s",
                     sev, cnt, str(result.get("summary", ""))[:80])
            return
        _mark_activity()   # fresh med/high signal -> reset quiescence cadence
        _db_post(_db_create("log_digest", {
            "summary": str(result.get("summary", ""))[:300],
            "tags": result.get("tags") or [],
            "severity": "high" if sev == "high" else "med",
            "event_count": int(result.get("event_count", 0) or 0),
        }, now_fields=("ts",)))
        return
    # low / noise: aggregate; flush ONE consolidated row per window.
    _noise_agg["batches"] += 1
    _noise_agg["events"] += int(result.get("event_count", 0) or 0)
    if (_noise_agg["batches"]
            and time.time() - _noise_agg["since"] >= _NOISE_FLUSH_S):
        _db_post(_db_create("log_digest", {
            "summary": (f"{_noise_agg['batches']} low/noise log batches "
                        f"({_noise_agg['events']} events) consolidated"),
            "tags": ["noise", "consolidated"],
            "severity": "low",
            "event_count": _noise_agg["events"],
            "batch_count": _noise_agg["batches"],
        }, now_fields=("ts",)))
        _noise_agg.update({"batches": 0, "events": 0, "since": time.time()})


def classify_loop() -> None:
    # W0-T2 (4): adaptive cadence. Starts responsive (CLASSIFY_BATCH_S) and,
    # when the box goes quiescent (no new med/high digest / unsatisfied
    # verdict for QUIESCENCE_WINDOW_MIN), backs OFF exponentially toward
    # CALM_MAX_TICK_S so an idle daemon isn't polling the model every batch.
    tick = CLASSIFY_BATCH_S
    while not _stop_event.is_set():
        # Interruptible sleep at the current (possibly widened) cadence.
        slept = 0.0
        while slept < tick and not _stop_event.is_set():
            time.sleep(min(1.0, tick - slept))
            slept += 1.0
        if _stop_event.is_set():
            return
        # W0-T2 (4): recompute cadence for the NEXT cycle from quiescence.
        if _is_quiescent():
            tick = min(CALM_MAX_TICK_S, max(CLASSIFY_BATCH_S, tick * 2))
        else:
            tick = CLASSIFY_BATCH_S
        # W0-T2 (1): host-pressure gate -- skip this tick (no LLM call) when
        # load/GPU-util exceed the ceiling AND pressure_skip is enabled.
        if _pressure_should_skip("classify"):
            continue
        with _buffer_lock:
            batch = _event_buffer[-CLASSIFY_BATCH_MAX:][:]
        if not batch:
            continue
        # Compose compact prompt
        lines = []
        for e in batch:
            unit = e.get("_SYSTEMD_UNIT", e.get("SYSLOG_IDENTIFIER", "?"))
            # journald MESSAGE can be a LIST (multi-line / byte-array fields) or
            # bytes, not just str -- .strip() on a list crashed classify_loop
            # ('list' object has no attribute 'strip', operator 2026-06-01) and
            # KILLED the classify thread, blinding the daemon's load/oom watch.
            # Coerce to a single string defensively.
            _raw = e.get("MESSAGE") or ""
            if isinstance(_raw, (list, tuple)):
                _raw = " ".join(
                    x.decode("utf-8", "replace") if isinstance(x, (bytes, bytearray))
                    else str(x) for x in _raw)
            elif isinstance(_raw, (bytes, bytearray)):
                _raw = _raw.decode("utf-8", "replace")
            msg = str(_raw).strip().split("\n", 1)[0]
            lines.append(f"[{unit}] {msg[:200]}")
        content = llm_chat(CLASSIFY_SYSTEM,
                           "Recent events:\n" + "\n".join(lines),
                           max_tokens=120, want_json=True)
        m = re.search(r"\{[\s\S]*?\}", content) if content else None
        if m:
            try:
                result = json.loads(m.group(0))
            except json.JSONDecodeError:
                result = {"summary": f"(JSON err: {content[:80]})",
                          "tags": ["noise"], "severity": "low"}
        else:
            result = {"summary": f"(unparseable: {content[:80]})",
                      "tags": ["noise"], "severity": "low"}
        result["event_count"] = len(batch)
        result["events_sample"] = lines[:3]
        result["ts"] = datetime.datetime.now().isoformat(timespec="seconds")
        _update_state("classify", result)
        _persist_log_digest(result)   # compacted -> SurrealDB log_digest
        log.info("classify: %d events -> %s (%s)",
                 len(batch), result.get("summary", "")[:80],
                 result.get("severity", "?"))


# ── Refusal handler (was: mios-agent-nudger) ─────────────────────────
REFUSAL_SYSTEM = (
    "You are a Linux log filter. Decide if the following hermes-agent "
    "log message is the agent ACTIVELY REFUSING the user (vs quoting / "
    "discussing such a phrase). Refusal = the agent telling the user "
    "it cannot do something when the relevant tool IS available. "
    "Reply with a single token: \"YES\" or \"NO\". Nothing else."
)


def _load_refusal_patterns() -> list[re.Pattern]:
    out: list[re.Pattern] = []
    try:
        for line in REFUSAL_PATTERNS_FILE.read_text(encoding="utf-8").splitlines():
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            try:
                out.append(re.compile(s, re.IGNORECASE))
            except re.error:
                pass
    except OSError:
        pass
    return out


_refusal_res = _load_refusal_patterns()


def refusal_loop() -> None:
    """Walk the same buffer, look for hermes-agent.service messages
    that match a refusal pattern, then confirm with the LLM."""
    last_index = 0
    while not _stop_event.is_set():
        time.sleep(5.0)
        with _buffer_lock:
            new = _event_buffer[last_index:]
            last_index = len(_event_buffer)
        # W0-T2 (1): host-pressure gate -- when over ceiling AND pressure_skip
        # is on, skip the LLM-confirm work this tick. last_index already
        # advanced (the cheap pattern pre-filter is the gate trigger, not the
        # work), so we drop the batch rather than queue refusal confirms onto a
        # saturated box. Cheap pattern matching alone is fine; the LLM is not.
        if _pressure_should_skip("refusal"):
            continue
        for ev in new:
            unit = ev.get("_SYSTEMD_UNIT", "")
            if unit != "hermes-agent.service":
                continue
            msg = (ev.get("MESSAGE") or "")
            if not msg:
                continue
            # Pattern pre-filter
            hit = None
            for pat in _refusal_res:
                if pat.search(msg):
                    hit = pat.pattern
                    break
            if not hit:
                continue
            # LLM confirm
            verdict = llm_chat(REFUSAL_SYSTEM, msg[:2000],
                               max_tokens=4, temperature=0.0)
            is_refusal = verdict.upper().startswith("YES")
            log.info("refusal? pattern=%r verdict=%s msg=%r",
                     hit[:60], verdict[:8], msg[:120])
            if is_refusal:
                _update_state("refusal", {
                    "trigger": hit,
                    "phrase": msg[:200],
                    "model": MODEL,
                    "service": unit,
                    "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                })


# ── Cron handler (was: mios-cron-director) ──────────────────────────
def _load_cron_gates() -> list[dict]:
    """Read /etc/mios/daemon/cron.toml. Each [gates.<name>] block is
    one rule: { question, action, min_interval_s }."""
    if not CRON_TOML.is_file():
        return []
    try:
        try:
            import tomllib   # py 3.11+
        except ImportError:
            import tomli as tomllib   # type: ignore
        data = tomllib.loads(CRON_TOML.read_text(encoding="utf-8"))
    except Exception as e:
        log.warning("cron.toml parse failed: %s", e)
        return []
    out: list[dict] = []
    gates = (data.get("gates") or {})
    for name, block in gates.items():
        if not isinstance(block, dict):
            continue
        out.append({
            "name": name,
            "question": block.get("question", ""),
            "action":   block.get("action", ""),
            "min_interval_s": float(block.get("min_interval_s", 3600)),
        })
    return out


_last_fire: dict[str, float] = {}

# W0-T2 (3): cap concurrent cron-fired actions. Track live Popen handles
# (per gate-name + a global list) so the daemon NEVER re-fires a gate while
# its prior Popen is still alive, and never exceeds CRON_MAX_CONCURRENT
# in-flight actions total. A wedged action that never exits used to let the
# cron loop spawn a fresh process every min_interval_s -> fork-bomb-shaped
# runaway. _cron_inflight maps gate-name -> Popen; _reap drops finished ones.
_cron_inflight: dict[str, "subprocess.Popen"] = {}
_cron_inflight_lock = threading.Lock()


def _reap_cron_inflight() -> int:
    """Drop finished Popen handles; return the count still alive."""
    with _cron_inflight_lock:
        for name in list(_cron_inflight.keys()):
            p = _cron_inflight[name]
            if p.poll() is not None:   # exited
                _cron_inflight.pop(name, None)
        return len(_cron_inflight)


def cron_loop() -> None:
    while not _stop_event.is_set():
        # W0-T2 (1): host-pressure gate -- skip the whole cron evaluation tick
        # (gate-eval LLM calls + any fires) when over ceiling AND pressure_skip.
        if _pressure_should_skip("cron"):
            _stop_event.wait(CRON_TICK_S)
            continue
        _reap_cron_inflight()   # W0-T2 (3): drop finished handles each tick
        gates = _load_cron_gates()
        decisions: list[dict] = []
        for gate in gates:
            name = gate["name"]
            last = _last_fire.get(name, 0.0)
            if (time.time() - last) < gate["min_interval_s"]:
                continue
            verdict = llm_chat(
                "You are a fast YES/NO gate evaluator. Reply ONLY with "
                "the requested JSON: {\"answer\":\"YES\"|\"NO\","
                "\"reasoning\":\"<one sentence>\"}",
                f"Question: {gate['question']}",
                max_tokens=80,
                temperature=0.0,
                want_json=True,
            )
            m = re.search(r"\{[\s\S]*?\}", verdict) if verdict else None
            ok = False
            reasoning = ""
            if m:
                try:
                    j = json.loads(m.group(0))
                    ok = str(j.get("answer", "")).upper().startswith("YES")
                    reasoning = str(j.get("reasoning", ""))[:200]
                except json.JSONDecodeError:
                    reasoning = f"unparseable: {verdict[:80]}"
            d = {
                "name": name,
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "verdict": "YES" if ok else "NO",
                "reasoning": reasoning,
            }
            decisions.append(d)
            if ok and gate["action"]:
                # W0-T2 (3): concurrency cap. Reap finished handles first, then
                # refuse to fire when (a) THIS gate's prior Popen is still
                # alive, or (b) the global in-flight count is at the cap. The
                # gate stays eligible next tick (we don't stamp _last_fire on a
                # deferral) so it fires once capacity frees.
                alive = _reap_cron_inflight()
                with _cron_inflight_lock:
                    own_alive = name in _cron_inflight
                if own_alive or alive >= max(1, CRON_MAX_CONCURRENT):
                    d["deferred"] = "cron_concurrency_cap"
                    log.info("cron DEFER %s: %d in-flight (cap=%d, own_alive=%s)",
                             name, alive, CRON_MAX_CONCURRENT, own_alive)
                    continue
                _last_fire[name] = time.time()
                d["fired"] = True
                log.info("cron FIRE %s: %s", name, gate["action"][:120])
                try:
                    _proc = subprocess.Popen(
                        ["bash", "-lc", gate["action"]],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        start_new_session=True,
                    )
                    with _cron_inflight_lock:
                        _cron_inflight[name] = _proc
                    with _state_lock:
                        _state["cron"]["last_fire"] = {
                            "rule": name,
                            "ts": d["ts"],
                            "action": gate["action"][:200],
                        }
                except OSError as e:
                    log.warning("cron action failed: %s", e)
        with _state_lock:
            # Keep last 20 decisions
            existing = _state["cron"].get("decisions") or []
            existing = existing + decisions
            _state["cron"]["decisions"] = existing[-20:]
        if decisions:
            _atomic_write_state()
        # Wait for next tick or stop
        _stop_event.wait(CRON_TICK_S)


