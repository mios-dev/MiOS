def _toml_db_backend() -> str:
    """SSOT: [dispatch] db_backend from the layered mios.toml (vendor < /etc).
    Mirrors the agent-pipe so the whole agent plane flips together at the
    SurrealDB->pgvector cutover (R15/G11). Env MIOS_DB_BACKEND still wins."""
    val = "dual"
    try:
        try:
            import tomllib
        except ModuleNotFoundError:
            import tomli as tomllib  # type: ignore
        for _p in (os.environ.get("MIOS_TOML", "/usr/share/mios/mios.toml"),
                   "/etc/mios/mios.toml"):
            try:
                with open(_p, "rb") as _fh:
                    _b = (tomllib.load(_fh).get("dispatch") or {}).get("db_backend")
                if _b:
                    val = str(_b).strip().lower()
            except FileNotFoundError:
                continue
            except Exception:
                continue
    except Exception:
        pass
    return val


DB_BACKEND = (os.environ.get("MIOS_DB_BACKEND")
