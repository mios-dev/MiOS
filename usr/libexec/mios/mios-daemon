#!/usr/bin/env python3
"""mios-daemon -- consolidated MiOS micro-LLM daemon.

Operator directive 2026-05-17: "ALL to be consolidated to one mios
daemon/agent". Replaces three separate journal-subscribing /
periodic-evaluating services (mios-log-watcher + mios-agent-nudger
+ mios-cron-director) with ONE process that:

  * Subscribes to journald ONCE (not three times)
  * Holds a SINGLE Ollama client (keep_alive=-1 forever, num_gpu=0
    CPU-only per Law 7 + the operator's "always-on agentic OS"
    directive)
  * Dispatches three handlers off a single event stream:
      - classify: every Nseconds-batch of journal lines summarized
                  via qwen3:0.6b-cpu (was: mios-log-watcher)
      - refusal:  hermes-agent.service / mios-delegation-prefilter
                  lines checked for refusal-pattern hits (was:
                  mios-agent-nudger; pattern list = refusal-
                  patterns.txt + LLM yes/no confirmation)
      - cron:     /etc/mios/daemon/cron.toml gates evaluated on a
                  cadence; YES gates fire their action (was:
                  mios-cron-director)
  * Writes a UNIFIED state file at /var/lib/mios/daemon/state.json
    with all three handler outputs. mios_sidecar_filter.py polls
    this single file (replaces the three SIBLING_AGENTS entries).

Architecture per Law 7 OFFLINE-FIRST: all LLM calls go to local
Ollama at http://127.0.0.1:11434/api/chat with options.num_gpu=0,
options.num_thread=4, keep_alive=-1. No /v1 surface (drops
options field). Thinking-mode models' output is read from
message.content first, then message.thinking / message.reasoning
fallback (qwen3.5-family puts CoT in those fields).

For the OWUI sidecar filter: state.json keys map 1:1 to the prior
SIBLING_AGENTS labels so the filter just reads ONE file instead
of three. Per-section sub-objects let the filter format each
category exactly as before. Schema:

    {
      "ts": <epoch>,
      "classify":    {"summary":..., "tags":[...], "severity":...,
                      "event_count":..., "events_sample":[...]},
      "refusal":     {"trigger":..., "phrase":..., "model":...,
                      "ts":..., "service":...},
      "cron":        {"last_fire": {"rule":..., "ts":...},
                      "decisions":[...]}
    }
"""
from __future__ import annotations

import datetime
import json
import logging
import os
import re
import signal
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.request
from pathlib import Path
from typing import Optional

logging.basicConfig(level=logging.INFO, format="[mios-daemon] %(message)s")
log = logging.getLogger("mios-daemon")

# ── Config (env-overridable) ────────────────────────────────────────
MODEL = os.environ.get("MIOS_DAEMON_MODEL", "qwen3:0.6b-cpu")
ENDPOINT = os.environ.get("MIOS_DAEMON_ENDPOINT", "http://127.0.0.1:11434")
STATE_DIR = Path(os.environ.get("MIOS_DAEMON_STATE_DIR", "/var/lib/mios/daemon"))
STATE_FILE = STATE_DIR / "state.json"
CLASSIFY_BATCH_S = float(os.environ.get("MIOS_DAEMON_CLASSIFY_S", "30"))
CLASSIFY_BATCH_MAX = int(os.environ.get("MIOS_DAEMON_CLASSIFY_MAX", "8"))
REFUSAL_PATTERNS_FILE = Path(os.environ.get(
    "MIOS_REFUSAL_PATTERNS",
    "/usr/share/mios/ai/refusal-patterns.txt",
))
CRON_TOML = Path(os.environ.get("MIOS_DAEMON_CRON_TOML",
                                 "/etc/mios/daemon/cron.toml"))
CRON_TICK_S = float(os.environ.get("MIOS_DAEMON_CRON_TICK_S", "60"))
REQUEST_TIMEOUT_S = float(os.environ.get("MIOS_DAEMON_REQUEST_TIMEOUT_S", "30"))

# Units to watch for journal subscription
WATCHED_UNITS = os.environ.get(
    "MIOS_DAEMON_WATCH_UNITS",
    "hermes-agent.service,mios-delegation-prefilter.service,mios-open-webui.service",
).split(",")


# ── Shared state (handlers write here; flusher persists) ─────────────
_state_lock = threading.Lock()
_state: dict = {
    "ts": time.time(),
    "classify": None,
    "refusal":  None,
    "cron":     {"last_fire": None, "decisions": []},
}
_stop_event = threading.Event()


def _atomic_write_state() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with _state_lock:
        snapshot = dict(_state)
        snapshot["ts"] = time.time()
    tmp = STATE_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(snapshot, separators=(",", ":")))
    os.chmod(tmp, 0o644)
    tmp.replace(STATE_FILE)


def _update_state(section: str, value) -> None:
    with _state_lock:
        _state[section] = value
    _atomic_write_state()


# ── Single shared Ollama client ──────────────────────────────────────
def llm_chat(system: str, user: str, *, max_tokens: int = 150,
             temperature: float = 0.1, want_json: bool = False) -> str:
    """Call qwen3:0.6b-cpu (or whatever MODEL is) via Ollama /api/chat.
    Returns the model's text output (content with thinking fallback).
    Returns empty string on any error. Always uses CPU + keep_alive=-1.
    """
    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "options": {
            "num_gpu": 0,           # Law 7 OFFLINE-FIRST + CPU-first
            "num_thread": 4,
            "num_predict": max_tokens,
            "temperature": temperature,
        },
        "stream": False,
        "keep_alive": -1,           # always-on agentic OS
    }
    if want_json:
        # Ollama's structured-output mode: the runtime constrains
        # token sampling so the response is parseable JSON. Critical
        # for sub-2B models that would otherwise prose-prefix the
        # JSON ("Okay, let me break this down...") and trip the
        # parser. Operator-flagged post-reboot: classify output was
        # "(unparseable: Okay, let's break down...)".
        payload["format"] = "json"
    try:
        req = urllib.request.Request(
            f"{ENDPOINT}/api/chat",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT_S) as r:
            body = json.loads(r.read())
        msg = body.get("message") or {}
        out = (msg.get("content") or "").strip()
        if not out:
            out = (msg.get("thinking") or msg.get("reasoning") or "").strip()
        return out
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        log.warning("LLM call failed (non-fatal): %s", e)
        return ""


# ── Journal subscriber ───────────────────────────────────────────────
_event_buffer: list[dict] = []
_buffer_lock = threading.Lock()


def journal_subscriber() -> None:
    """Run `journalctl -f -o json` and push parsed events into the
    shared buffer. Classify + refusal-detect handlers drain it."""
    units_args: list[str] = []
    for u in WATCHED_UNITS:
        u = u.strip()
        if u:
            units_args += ["-u", u]
    cmd = ["journalctl", "-f", "-n", "0", "-o", "json", "--no-pager", *units_args]
    log.info("journal subscriber: %s", " ".join(cmd))
    proc = subprocess.Popen(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
        text=True, bufsize=1,
    )
    try:
        for line in proc.stdout:
            if _stop_event.is_set():
                break
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue
            with _buffer_lock:
                _event_buffer.append(ev)
                # Cap to avoid runaway memory
                if len(_event_buffer) > 500:
                    _event_buffer[:] = _event_buffer[-200:]
    finally:
        proc.terminate()


# ── Classify handler (was: mios-log-watcher) ─────────────────────────
CLASSIFY_SYSTEM = (
    "You are a Linux log classifier. Read the events below and reply "
    "with ONE LINE of JSON: {\"summary\":\"<one sentence>\","
    "\"tags\":[\"<one|two|three>\"],\"severity\":\"low|med|high\"}. "
    "Nothing else."
)


def classify_loop() -> None:
    while not _stop_event.is_set():
        time.sleep(CLASSIFY_BATCH_S)
        with _buffer_lock:
            batch = _event_buffer[-CLASSIFY_BATCH_MAX:][:]
        if not batch:
            continue
        # Compose compact prompt
        lines = []
        for e in batch:
            unit = e.get("_SYSTEMD_UNIT", e.get("SYSLOG_IDENTIFIER", "?"))
            msg = (e.get("MESSAGE") or "").strip().split("\n", 1)[0]
            lines.append(f"[{unit}] {msg[:200]}")
        content = llm_chat(CLASSIFY_SYSTEM,
                           "Recent events:\n" + "\n".join(lines),
                           max_tokens=120, want_json=True)
        m = re.search(r"\{[\s\S]*?\}", content) if content else None
        if m:
            try:
                result = json.loads(m.group(0))
            except json.JSONDecodeError:
                result = {"summary": f"(JSON err: {content[:80]})",
                          "tags": ["noise"], "severity": "low"}
        else:
            result = {"summary": f"(unparseable: {content[:80]})",
                      "tags": ["noise"], "severity": "low"}
        result["event_count"] = len(batch)
        result["events_sample"] = lines[:3]
        result["ts"] = datetime.datetime.now().isoformat(timespec="seconds")
        _update_state("classify", result)
        log.info("classify: %d events -> %s (%s)",
                 len(batch), result.get("summary", "")[:80],
                 result.get("severity", "?"))


# ── Refusal handler (was: mios-agent-nudger) ─────────────────────────
REFUSAL_SYSTEM = (
    "You are a Linux log filter. Decide if the following hermes-agent "
    "log message is the agent ACTIVELY REFUSING the user (vs quoting / "
    "discussing such a phrase). Refusal = the agent telling the user "
    "it cannot do something when the relevant tool IS available. "
    "Reply with a single token: \"YES\" or \"NO\". Nothing else."
)


def _load_refusal_patterns() -> list[re.Pattern]:
    out: list[re.Pattern] = []
    try:
        for line in REFUSAL_PATTERNS_FILE.read_text(encoding="utf-8").splitlines():
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            try:
                out.append(re.compile(s, re.IGNORECASE))
            except re.error:
                pass
    except OSError:
        pass
    return out


_refusal_res = _load_refusal_patterns()


def refusal_loop() -> None:
    """Walk the same buffer, look for hermes-agent.service messages
    that match a refusal pattern, then confirm with the LLM."""
    last_index = 0
    while not _stop_event.is_set():
        time.sleep(5.0)
        with _buffer_lock:
            new = _event_buffer[last_index:]
            last_index = len(_event_buffer)
        for ev in new:
            unit = ev.get("_SYSTEMD_UNIT", "")
            if unit != "hermes-agent.service":
                continue
            msg = (ev.get("MESSAGE") or "")
            if not msg:
                continue
            # Pattern pre-filter
            hit = None
            for pat in _refusal_res:
                if pat.search(msg):
                    hit = pat.pattern
                    break
            if not hit:
                continue
            # LLM confirm
            verdict = llm_chat(REFUSAL_SYSTEM, msg[:2000],
                               max_tokens=4, temperature=0.0)
            is_refusal = verdict.upper().startswith("YES")
            log.info("refusal? pattern=%r verdict=%s msg=%r",
                     hit[:60], verdict[:8], msg[:120])
            if is_refusal:
                _update_state("refusal", {
                    "trigger": hit,
                    "phrase": msg[:200],
                    "model": MODEL,
                    "service": unit,
                    "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                })


# ── Cron handler (was: mios-cron-director) ──────────────────────────
def _load_cron_gates() -> list[dict]:
    """Read /etc/mios/daemon/cron.toml. Each [gates.<name>] block is
    one rule: { question, action, min_interval_s }."""
    if not CRON_TOML.is_file():
        return []
    try:
        try:
            import tomllib   # py 3.11+
        except ImportError:
            import tomli as tomllib   # type: ignore
        data = tomllib.loads(CRON_TOML.read_text(encoding="utf-8"))
    except Exception as e:
        log.warning("cron.toml parse failed: %s", e)
        return []
    out: list[dict] = []
    gates = (data.get("gates") or {})
    for name, block in gates.items():
        if not isinstance(block, dict):
            continue
        out.append({
            "name": name,
            "question": block.get("question", ""),
            "action":   block.get("action", ""),
            "min_interval_s": float(block.get("min_interval_s", 3600)),
        })
    return out


_last_fire: dict[str, float] = {}


def cron_loop() -> None:
    while not _stop_event.is_set():
        gates = _load_cron_gates()
        decisions: list[dict] = []
        for gate in gates:
            name = gate["name"]
            last = _last_fire.get(name, 0.0)
            if (time.time() - last) < gate["min_interval_s"]:
                continue
            verdict = llm_chat(
                "You are a fast YES/NO gate evaluator. Reply ONLY with "
                "the requested JSON: {\"answer\":\"YES\"|\"NO\","
                "\"reasoning\":\"<one sentence>\"}",
                f"Question: {gate['question']}",
                max_tokens=80,
                temperature=0.0,
                want_json=True,
            )
            m = re.search(r"\{[\s\S]*?\}", verdict) if verdict else None
            ok = False
            reasoning = ""
            if m:
                try:
                    j = json.loads(m.group(0))
                    ok = str(j.get("answer", "")).upper().startswith("YES")
                    reasoning = str(j.get("reasoning", ""))[:200]
                except json.JSONDecodeError:
                    reasoning = f"unparseable: {verdict[:80]}"
            d = {
                "name": name,
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "verdict": "YES" if ok else "NO",
                "reasoning": reasoning,
            }
            decisions.append(d)
            if ok and gate["action"]:
                _last_fire[name] = time.time()
                d["fired"] = True
                log.info("cron FIRE %s: %s", name, gate["action"][:120])
                try:
                    subprocess.Popen(
                        ["bash", "-lc", gate["action"]],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        start_new_session=True,
                    )
                    with _state_lock:
                        _state["cron"]["last_fire"] = {
                            "rule": name,
                            "ts": d["ts"],
                            "action": gate["action"][:200],
                        }
                except OSError as e:
                    log.warning("cron action failed: %s", e)
        with _state_lock:
            # Keep last 20 decisions
            existing = _state["cron"].get("decisions") or []
            existing = existing + decisions
            _state["cron"]["decisions"] = existing[-20:]
        if decisions:
            _atomic_write_state()
        # Wait for next tick or stop
        _stop_event.wait(CRON_TICK_S)


# ── Suggestions handler ──────────────────────────────────────────────
# Operator-flagged 2026-05-17: "OWUI doesn't show or generate any
# suggested chats on new chat windows" + "should have access to all
# local systems logs and can serve them; maybe this helps inform the
# suggestion/followups in OWUI chats".
#
# OWUI's blank-chat panel reads ui.prompt_suggestions (a static list
# in webui.db), not an LLM endpoint. Populate it here every N min
# from RECENT MiOS state -- classify_loop's summary, refusal_loop's
# alerts, recent operator chat language -- so the panel evolves with
# the operator's work. Pure LLM generation, no hardcoded English
# (operator directive: "no hardcoded answers" 2026-05-17).

SUGG_TICK_S = float(os.environ.get("MIOS_DAEMON_SUGG_TICK_S", "1200"))
SUGG_COUNT  = int(os.environ.get("MIOS_DAEMON_SUGG_COUNT", "6"))
SUGG_OWUI_DB = Path(os.environ.get(
    "MIOS_OWUI_DB", "/var/lib/mios/open-webui/webui.db"))
SUGG_SYSTEM = (
    "You generate short prompts a MiOS operator could click on a "
    "blank chat to start a useful turn. The MiOS host exposes: "
    "launch apps (mios-find), open URLs (mios-open-url), install "
    "packages (mios-installer), screenshot (mios-screenshot), window "
    "control (mios-window), system status (mios-system-status), "
    "kanban tasks, web search, Discord posting, cron scheduling, "
    "Steam (mios-steamcmd). Mirror the operator's recent chat "
    "language; never assume English."
)

def _recent_owui_user_messages(limit: int = 5) -> list[str]:
    """Pull last N user-message snippets from OWUI for locale hint."""
    if not SUGG_OWUI_DB.is_file(): return []
    try:
        import sqlite3
        c = sqlite3.connect(str(SUGG_OWUI_DB))
        rows = c.execute(
            "SELECT chat FROM chat ORDER BY updated_at DESC LIMIT ?",
            (limit,)).fetchall()
        out = []
        for (raw,) in rows:
            try:
                d = json.loads(raw or "{}")
                for m in (d.get("messages") or [])[-4:]:
                    if isinstance(m, dict) and m.get("role") == "user":
                        s = str(m.get("content") or "").strip()
                        if s: out.append(s[:120])
            except Exception:
                continue
        return out[-limit:]
    except Exception as e:
        log.debug("suggestions: chat-scan: %s", e)
        return []

# ── Launch verifier (operator directive 2026-05-17) ───────────────────
#
# "THIS is why we have a mios-deamon to checks logs and open apps to
#  double check things were launched successfully!!!"
#
# Watches recent OWUI assistant messages for launch-success claims
# ("Steam GUI is now open", "X is now launched", "installation in
# progress", etc.). For each unverified claim:
#   1. Pull the app name + claim sentence from the message
#   2. Run mios-window-active --present "<app>"
#   3. If presented_to_operator==false AND process_alive==false,
#      record a launch_failure to /var/lib/mios/daemon/launch_failures.json
# The agent's SOUL.md tells it to `cat` that file before retrying
# any launch operation -- closing the loop without prompt injection.
LAUNCH_VERIFY_TICK_S = float(os.environ.get(
    "MIOS_DAEMON_LAUNCH_VERIFY_TICK_S", "60"))
LAUNCH_VERIFY_LOOKBACK_MIN = float(os.environ.get(
    "MIOS_DAEMON_LAUNCH_VERIFY_LOOKBACK_MIN", "10"))
LAUNCH_FAILURES_FILE = STATE_DIR / "launch_failures.json"

# Regexes that flag an assistant message as claiming a launch.
# Each capture group 1 should hold the app name where reasonable;
# the verifier falls back to the user's request if not.
_LAUNCH_CLAIM_RES = [
    re.compile(r"\b(?:Steam|Epic|Ubisoft|Uplay) (?:GUI )?is now open(?:ing)?(?: with (?:the )?(.{3,40}?) (?:install|launch))?",
               re.IGNORECASE),
    re.compile(r"\b(?:launched|opened|started|running) (?:the )?(.{3,40}?)(?:\.|,|$|\n)",
               re.IGNORECASE),
    re.compile(r"\binstallation in progress\b.{0,80}?\b(.{3,40}?)(?:\)|$|\n)",
               re.IGNORECASE),
    re.compile(r"\b(.{3,40}?) (?:is|has been|was) (?:successfully )?(?:launched|installed|started)\b",
               re.IGNORECASE),
]


def _scan_chat_for_launch_claims(lookback_min: float) -> list[dict]:
    """Walk recent OWUI chats, return list of {chat_id, ts, app, claim,
    user_prompt} for assistant messages that look like launch claims."""
    if not SUGG_OWUI_DB.is_file():
        return []
    cutoff = time.time() - lookback_min * 60
    claims: list[dict] = []
    try:
        import sqlite3
        c = sqlite3.connect(str(SUGG_OWUI_DB))
        # OWUI stores chats as JSON blobs; updated_at is epoch seconds.
        rows = c.execute(
            "SELECT id, chat, updated_at FROM chat "
            "WHERE updated_at > ? ORDER BY updated_at DESC LIMIT 30",
            (int(cutoff),)
        ).fetchall()
    except Exception as e:
        log.debug("launch_verifier: chat-scan: %s", e)
        return []

    for chat_id, raw, updated_at in rows:
        try:
            d = json.loads(raw or "{}")
        except json.JSONDecodeError:
            continue
        messages = (d.get("messages") or [])[-6:]
        # Pair each assistant message with the preceding user prompt.
        last_user = ""
        for m in messages:
            if not isinstance(m, dict): continue
            role = m.get("role")
            content = m.get("content") or ""
            if not isinstance(content, str): continue
            if role == "user":
                last_user = content.strip()[:240]
                continue
            if role != "assistant" or not content.strip():
                continue
            for pat in _LAUNCH_CLAIM_RES:
                mm = pat.search(content)
                if not mm:
                    continue
                app = (mm.group(1) if mm.lastindex and mm.group(1) else "").strip(" \"'`.,*-:;()[]{}")
                # Filter junk captures
                if app and 2 <= len(app) <= 60:
                    claims.append({
                        "chat_id": chat_id,
                        "ts": updated_at,
                        "app": app,
                        "user_prompt": last_user,
                        "claim_match": mm.group(0)[:180],
                    })
                    break  # one claim per assistant message is enough
    return claims


def _verify_one_launch(app: str) -> dict:
    """Run mios-window-active --present <app>; return parsed JSON dict
    or an error stub. Times out at 6s -- the verifier itself is
    sub-second normally."""
    try:
        proc = subprocess.run(
            ["mios-window-active", "--present", app],
            capture_output=True, text=True, timeout=6,
        )
        out = (proc.stdout or "").strip()
        try:
            return json.loads(out)
        except json.JSONDecodeError:
            return {"presented_to_operator": False, "process_alive": False,
                    "summary": "verifier-non-json", "raw": out[:200]}
    except subprocess.TimeoutExpired:
        return {"presented_to_operator": False, "process_alive": False,
                "summary": "verifier-timeout"}
    except FileNotFoundError:
        return {"presented_to_operator": False, "process_alive": False,
                "summary": "verifier-missing"}


def _atomic_write_launch_failures(failures: list[dict]) -> None:
    LAUNCH_FAILURES_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = LAUNCH_FAILURES_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(failures, separators=(",", ":"), indent=2))
    os.chmod(tmp, 0o644)
    tmp.replace(LAUNCH_FAILURES_FILE)


def launch_verifier_loop() -> None:
    """Every LAUNCH_VERIFY_TICK_S seconds, scan recent OWUI chats for
    assistant launch-success claims and verify each via
    mios-window-active. Persist mismatches so the agent (and operator)
    can see which launches were false-success.

    Already-verified claims are deduped by (chat_id, app, claim_ts)
    via the persisted failures file (kept compact at <= 50 entries)."""
    # Boot delay: let OWUI come up + mios-window-active be present
    time.sleep(60)
    seen: set[tuple] = set()
    while not _stop_event.is_set():
        try:
            claims = _scan_chat_for_launch_claims(LAUNCH_VERIFY_LOOKBACK_MIN)
            failures: list[dict] = []
            # Load existing failures so we keep history across ticks
            if LAUNCH_FAILURES_FILE.is_file():
                try:
                    failures = json.loads(LAUNCH_FAILURES_FILE.read_text())
                except Exception:
                    failures = []
            for cl in claims:
                key = (cl["chat_id"], cl["app"].lower(), cl["ts"])
                if key in seen:
                    continue
                seen.add(key)
                verdict = _verify_one_launch(cl["app"])
                ok = bool(verdict.get("presented_to_operator")
                          or verdict.get("process_alive"))
                if not ok:
                    failures.append({
                        "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                        "chat_id": cl["chat_id"],
                        "app": cl["app"],
                        "user_prompt": cl["user_prompt"],
                        "claim_match": cl["claim_match"],
                        "verifier_summary": verdict.get("summary"),
                        "verifier_raw": verdict,
                    })
                    log.warning("launch_verifier: FALSE-SUCCESS app=%r chat=%s "
                                "summary=%s",
                                cl["app"], cl["chat_id"][:8],
                                verdict.get("summary"))
            # Cap to the most recent 50 entries
            failures = failures[-50:]
            _atomic_write_launch_failures(failures)
            _update_state("launch_verifier", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "claims_scanned": len(claims),
                "false_success_count": sum(
                    1 for f in failures
                    if (time.time() - time.mktime(time.strptime(
                        f["ts"][:19], "%Y-%m-%dT%H:%M:%S"))) < 3600),
                "failures_file": str(LAUNCH_FAILURES_FILE),
            })
            # Cap memory usage on the dedup set
            if len(seen) > 1000:
                seen = set(list(seen)[-500:])
        except Exception as e:
            log.warning("launch_verifier: %s: %s", type(e).__name__, e)
        for _ in range(int(LAUNCH_VERIFY_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


def suggestions_loop() -> None:
    # Boot delay so OWUI + ollama warm before first generation
    time.sleep(45)
    while not _stop_event.is_set():
        try:
            recent = _recent_owui_user_messages()
            classify_summary = ""
            with _state_lock:
                cls = (_state.get("classify") or {})
            if cls.get("summary"):
                classify_summary = f"Recent log summary: {cls['summary'][:200]}."

            locale_hint = " | ".join(recent) if recent else "(no recent chats)"
            user_prompt = (
                f"Generate {SUGG_COUNT} short prompts (3 to 12 words each) "
                "the operator could click to start a useful turn. Mix "
                "categories: launch/open, find/search, install, status, "
                "kanban, research, configure. "
                f"{classify_summary} "
                f"Locale + recent context: {locale_hint}. "
                "\n\nOutput JSON ONLY: {\"suggestions\":[\"...\", ...]}"
            )
            content = llm_chat(SUGG_SYSTEM, user_prompt,
                               max_tokens=400, want_json=True)
            m = re.search(r"\{[\s\S]*\}", content) if content else None
            cards: list[dict] = []
            if m:
                try:
                    parsed = json.loads(m.group(0))
                    for s in (parsed.get("suggestions") or [])[:SUGG_COUNT]:
                        if not isinstance(s, str): continue
                        s = s.strip()[:160]
                        if s: cards.append({"title": [s, ""], "content": s})
                except json.JSONDecodeError:
                    pass

            if cards and SUGG_OWUI_DB.is_file():
                import sqlite3
                c = sqlite3.connect(str(SUGG_OWUI_DB))
                row = c.execute(
                    "SELECT data FROM config WHERE id=1").fetchone()
                if row is not None:
                    try:
                        cfg = json.loads(row[0])
                    except json.JSONDecodeError:
                        cfg = {}
                    cfg.setdefault("ui", {})["prompt_suggestions"] = cards
                    c.execute(
                        "UPDATE config SET data=?, updated_at=? WHERE id=1",
                        (json.dumps(cfg),
                         datetime.datetime.utcnow().isoformat()))
                    c.commit()
                    log.info("suggestions: wrote %d LLM cards "
                             "(classify-summary=%s, recent-msgs=%d)",
                             len(cards),
                             "yes" if classify_summary else "no",
                             len(recent))
            _update_state("suggestions", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "count": len(cards),
                "preview": [c["content"][:60] for c in cards[:3]],
                "used_classify": bool(classify_summary),
                "used_recent_chats": len(recent),
            })
        except Exception as e:
            log.warning("suggestions: %s: %s", type(e).__name__, e)
        # Interruptible sleep
        for _ in range(int(SUGG_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


# ── Main ─────────────────────────────────────────────────────────────
def _on_signal(signum, _frame):
    log.info("signal %s -- stopping", signum)
    _stop_event.set()


def main() -> int:
    signal.signal(signal.SIGINT, _on_signal)
    signal.signal(signal.SIGTERM, _on_signal)
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(STATE_DIR, 0o755)
    _atomic_write_state()

    log.info("starting: model=%s endpoint=%s state=%s",
             MODEL, ENDPOINT, STATE_FILE)
    log.info("watching units: %s", ",".join(WATCHED_UNITS))
    log.info("refusal patterns loaded: %d", len(_refusal_res))

    threads = [
        threading.Thread(target=journal_subscriber, daemon=True, name="journal"),
        threading.Thread(target=classify_loop, daemon=True, name="classify"),
        threading.Thread(target=refusal_loop, daemon=True, name="refusal"),
        threading.Thread(target=cron_loop, daemon=True, name="cron"),
        threading.Thread(target=suggestions_loop, daemon=True, name="suggestions"),
        threading.Thread(target=launch_verifier_loop, daemon=True, name="launch_verifier"),
    ]
    for t in threads:
        t.start()
    while not _stop_event.is_set():
        time.sleep(2)
    log.info("stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main())
