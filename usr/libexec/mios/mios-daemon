def _on_signal(signum, _frame):
    log.info("signal %s -- stopping", signum)
    _stop_event.set()


# ── Satisfaction monitor (Phase E.1 -- daemon-side goal tracking) ───
# Operator directive 2026-05-18: "mios-daemon/agent should be
# monitoring successes and stopping work if ALL criteria is met and
# goals set are completed/tasks/user queries are satisfied".
#
# Polls SurrealDB.event for kind=refine rows (each user query goes
# through agent-pipe's refine pass which writes one of these). For
# every refine that doesn't yet have a corresponding satisfaction
# verdict, AND-fold the post-refine tool_call.success values from
# the same session. Emit:
#
#   event kind=user_query_satisfied   severity=info
#     payload={refine_id, intended_outcome, tool_calls_checked,
#              all_succeeded: true}
#
#   event kind=user_query_unsatisfied severity=warn
#     payload={refine_id, intended_outcome, tool_calls_checked,
#              failed_tools: [...], stderr_preview: ...}
#
# agent-pipe + Hermes can SUBSCRIBE to these (poll the event table
# or pick up via the Phase A.2 inotify event bus) and halt-on-
# satisfied OR surface-failure-explicitly. The audit row also lets
# the operator query post-hoc: "show me all unsatisfied goals from
# the last day".
SATISFACTION_TICK_S = float(os.environ.get(
    "MIOS_DAEMON_SATISFACTION_TICK_S", "30"))
SATISFACTION_LOOKBACK_MIN = int(os.environ.get(
    "MIOS_DAEMON_SATISFACTION_LOOKBACK_MIN", "10"))


def _ok_result(db_response) -> list:
    """Extract the result rows from a _db_post response, returning
    [] when the response is None / errored / status != OK / result is
    not a list. Defensive: SurrealDB returns the error string in the
    `result` field when status=ERR, which would crash iteration
    expecting dicts."""
    if not db_response:
        return []
    last = db_response[-1] or {}
    if last.get("status") != "OK":
        return []
    rows = last.get("result")
    return rows if isinstance(rows, list) else []


def _scan_unverified_refines(lookback_min: int) -> list[dict]:
    """Pull refine events that haven't yet been satisfaction-checked.
    Returns oldest-first so the loop processes a fresh deploy in
    chronological order."""
    sql = (
        f"SELECT id, ts, payload FROM event "
        f"WHERE kind = 'refine' "
        f"  AND ts > time::now() - {int(lookback_min)}m "
        f"ORDER BY ts ASC LIMIT 50;"
    )
    refines = _ok_result(_db_read(sql, pg_sql=(
        f"SELECT id, ts, payload FROM event WHERE kind = 'refine' "
        f"AND ts > now() - interval '{int(lookback_min)} minutes' "
        f"ORDER BY ts ASC LIMIT 50")))
    # Filter out refines that already have a satisfaction event
    # referencing their id. SurrealDB doesn't have a JOIN; do it in
    # a second query against the recent satisfaction events.
    sat_sql = (
        f"SELECT payload FROM event "
        f"WHERE kind IN ['user_query_satisfied','user_query_unsatisfied'] "
        f"  AND ts > time::now() - {int(lookback_min)}m "
        f"LIMIT 200;"
    )
    seen_refine_ids: set = set()
    for sr in _ok_result(_db_read(sat_sql, pg_sql=(
            "SELECT payload FROM event WHERE kind IN "
            "('user_query_satisfied','user_query_unsatisfied') "
            f"AND ts > now() - interval '{int(lookback_min)} minutes' "
            "LIMIT 200"))):
        if not isinstance(sr, dict):
            continue
        rid = ((sr.get("payload") or {}).get("refine_id"))
        if rid:
            seen_refine_ids.add(str(rid))
    return [
        r for r in refines
        if isinstance(r, dict)
        and str(r.get("id")) not in seen_refine_ids
    ]


def _tool_calls_for_refine(refine_ts: str,
                           lookback_after_min: int = 5) -> list[dict]:
    """Pull tool_call rows that landed AFTER a refine event in the
    same session. The refine event's payload doesn't directly link
    to a session_id (refine runs on the prompt, session is opened
    separately), so we fall back to a ts-window match: tool_calls
    within `lookback_after_min` minutes after the refine.
    Best-effort -- if the linkage misses, the satisfaction verdict
    is "no_tools_seen" rather than wrong."""
    sql = (
        f"SELECT id, ts, tool, args, success, exit_code, "
        f"result_preview FROM tool_call "
        f"WHERE ts > '{refine_ts}' "
        f"  AND ts < '{refine_ts}' + {int(lookback_after_min)}m "
        f"ORDER BY ts ASC LIMIT 20;"
    )
    # WS-A3: this read is now LIVE in dual mode (see _db_read gate) -> bind
    # refine_ts ($1, a DB-row value treated as tainted) out-of-band; the interval
    # count is int-coerced inline.
    return [r for r in _ok_result(_db_read(sql, pg_sql=(
        "SELECT id, ts, tool, args, success, exit_code, result_preview "
        "FROM tool_call WHERE ts > $1::timestamptz "
        "AND ts < $1::timestamptz + interval '"
        + str(int(lookback_after_min)) + " minutes' "
        "ORDER BY ts ASC LIMIT 20"), pg_params=[refine_ts]))
        if isinstance(r, dict)]


def _verb_post_check(tool: str, args: dict) -> dict:
    """Per-verb visible-outcome verification beyond tool_call.success.
    Operator-flagged 2026-05-18: mios-open-url returned exit 0 from
    the broker but Epiphany's window never appeared (sandbox died at
    credential bootstrap AFTER the broker had already collected its
    exit code). Raw success column alone misses these cases; this
    helper cross-checks the OS-side reality.

    Returns dict {checked: <bool>, passed: <bool>, signal: <name>,
    detail?: <str>}. checked=False means we have no post-check for
    this verb -- caller uses tool_call.success alone."""
    import subprocess
    if tool in ("open_app", "open_url", "focus_window", "launch_app"):
        # Window-visible check. Pattern derived from the verb's
        # most-likely-titled arg.
        pat = ""
        for key in ("name", "title", "url"):
            v = (args or {}).get(key)
            if v:
                pat = str(v); break
        if not pat:
            return {"checked": False}
        # Take the last URL path segment OR the bare name; mios-window-
        # active accepts a comma-separated pattern list.
        if pat.startswith(("http://", "https://", "file://")):
            try:
                from urllib.parse import urlparse
                pat = urlparse(pat).netloc or pat
            except Exception:
                pass
        pat = pat.split("/")[-1].split(".")[0]
        try:
            r = subprocess.run(
                ["mios-window-active", pat],
                capture_output=True, text=True, timeout=4,
            )
            out = r.stdout.strip()
            if out:
                try:
                    j = json.loads(out)
                    presented = bool(j.get("presented_to_operator")
                                    or j.get("window_visible"))
                    return {"checked": True, "passed": presented,
                            "signal": "window_visible",
                            "detail": j.get("summary", "")}
                except json.JSONDecodeError:
                    pass
            return {"checked": True, "passed": False,
                    "signal": "window_visible",
                    "detail": "no_window_for_pattern:" + pat[:60]}
        except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
            return {"checked": False}
    if tool == "text_create":
        path = (args or {}).get("path")
        if not path:
            return {"checked": False}
        exists = os.path.exists(str(path))
        return {"checked": True, "passed": exists,
                "signal": "file_exists",
                "detail": str(path)}
    if tool == "text_str_replace":
        path = (args or {}).get("path")
        if not path:
            return {"checked": False}
        exists = os.path.exists(str(path)) and os.path.getsize(str(path)) > 0
        return {"checked": True, "passed": exists,
                "signal": "file_nonempty",
                "detail": str(path)}
    if tool == "flatpak_install":
        ident = (args or {}).get("id")
        if not ident:
            return {"checked": False}
        try:
            r = subprocess.run(
                ["flatpak", "info", str(ident)],
                capture_output=True, text=True, timeout=4,
            )
            return {"checked": True, "passed": r.returncode == 0,
                    "signal": "flatpak_installed",
                    "detail": str(ident)}
        except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
            return {"checked": False}
    return {"checked": False}


def _emit_satisfaction(refine_row: dict, tool_calls: list[dict]) -> str:
    """AND-fold tool_call outcomes + per-verb visible-outcome checks
    against the refined plan + emit the satisfaction event. Returns
    the emitted kind so the caller can log the verdict count."""
    refine_id = refine_row.get("id")
    payload = refine_row.get("payload") or {}
    intended = payload.get("intended_outcome", "") or ""
    intent = payload.get("intent", "") or ""

    # No tools after refine: can't AND-fold. For intent=chat this is
    # EXPECTED (no tool dispatch needed) -> satisfied.
    #
    # For intent=agent/dispatch the daemon has NO basis to declare
    # failure: under unify-on a verb runs INSIDE the sub-agent and
    # leaves no tool_call row, and the daemon -- unlike the agent-pipe
    # confirmation engine -- never sees the agent's delivered answer.
    # Emitting "unsatisfied: no_tools_seen" here was a false-negative
    # that, written 30s AFTER the orchestrator's authoritative inline
    # verdict, OVERRODE it (newer ts wins) and made the NEXT turn's
    # polish read a stale failure (operator 2026-05-22 confirmation-
    # engine bug). The orchestrator's inline check (source=
    # mios-agent-pipe) is authoritative for these turns; the daemon
    # DEFERS by returning a "skipped" sentinel and writing no event.
    # The daemon stays the cross-turn backstop ONLY for turns that DID
    # record tool_call rows (the else-branch below).
    if not tool_calls:
        if intent == "chat":
            kind = "user_query_satisfied"
            severity = "info"
            extra = {"reason": "chat_no_tools_expected"}
        else:
            return "skipped"
    else:
        failed: list[dict] = []
        post_check_results: list[dict] = []
        for tc in tool_calls:
            tool = tc.get("tool", "")
            args = tc.get("args") or {}
            tool_ok = bool(tc.get("success"))
            check = _verb_post_check(tool, args)
            # Per-verb check overrides bare tool_call.success when it
            # ran -- the visible-outcome signal is more authoritative
            # than the broker's exit code (which can be 0 even when
            # the launch sandbox died after the broker collected it).
            if check.get("checked"):
                visible_ok = check.get("passed", False)
                post_check_results.append({
                    "tool": tool,
                    "signal": check.get("signal"),
                    "passed": visible_ok,
                    "detail": (check.get("detail") or "")[:120],
                })
                if not (tool_ok and visible_ok):
                    failed.append({
                        "tool": tool,
                        "exit_code": tc.get("exit_code"),
                        "visible": visible_ok,
                        "stderr_preview": (tc.get("result_preview") or "")[:200],
                    })
            else:
                # No verb-specific check; fall back to bare success.
                if not tool_ok:
                    failed.append({
                        "tool": tool,
                        "exit_code": tc.get("exit_code"),
                        "stderr_preview": (tc.get("result_preview") or "")[:200],
                    })

        if not failed:
            kind = "user_query_satisfied"
            severity = "info"
            extra = {"tools_checked": len(tool_calls),
                     "post_checks": post_check_results,
                     "all_succeeded": True}
        else:
            kind = "user_query_unsatisfied"
            severity = "warn"
            extra = {"tools_checked": len(tool_calls),
                     "post_checks": post_check_results,
                     "failed_tools": failed}

    body = {
        "refine_id": str(refine_id) if refine_id else None,
        "refine_intent": intent,
        "intended_outcome": intended[:200],
        **extra,
    }
    _db_post(_db_create("event", {
        "source": "mios-daemon",
        "kind": kind,
        "severity": severity,
        "summary": f"{kind}: {intent} ({intended[:60]})",
        "payload": body,
    }, now_fields=("ts",)))
    # W0-T2 (4): a fresh UNSATISFIED verdict is a notable signal -- reset the
    # quiescence clock so the classify cadence drops back to responsive.
    if kind == "user_query_unsatisfied":
        _mark_activity()
    return kind


# ─── Directory indexer ────────────────────────────────────────────
# Walks the configured [daemon.index] roots on a cadence, upserts
# directory_entry rows into SurrealDB. Agents query via the
# `directory_lookup` verb -- DB hit ~5ms vs the 60ms+ live
# mios-find / fs_search. Summaries extracted for text-shaped files
# so the agent can rank relevance without re-reading each file.
INDEX_DEFAULT_TICK_S = 15 * 60


def _read_daemon_index_config() -> dict:
    """Read [daemon.index] from the layered mios.toml. Returns
    the merged config dict or {} when unreadable."""
    try:
        try:
            import tomllib
        except ImportError:
            import tomli as tomllib
    except ImportError:
        return {}
    merged: dict = {}
    for p in ("/usr/share/mios/mios.toml",
              "/etc/mios/mios.toml",
              f"/var/home/{os.environ.get('MIOS_USER', 'mios')}/.config/mios/mios.toml"):
        try:
            with open(p, "rb") as f:
                d = tomllib.load(f)
        except (OSError, Exception):
            continue
        idx = (d.get("daemon", {}) or {}).get("index", {}) or {}
        # Shallow merge -- later layer wins on scalar keys; roots
        # list is REPLACED (not concatenated) so per-host overlay
        # can fully customize the walk targets.
        if idx:
            merged.update(idx)
    return merged


_TEXT_EXTS = {".md", ".markdown", ".toml", ".yaml", ".yml",
              ".json", ".txt", ".rst", ".conf", ".cfg", ".ini",
              ".sh", ".py", ".desktop", ".service"}


def _file_summary(path: str, max_bytes: int) -> str:
    """First non-empty trimmed line of a text-shaped file, capped.
    Returns empty for non-text or unreadable files."""
    ext = os.path.splitext(path)[1].lower()
    if ext not in _TEXT_EXTS:
        return ""
    try:
        with open(path, "r", errors="replace") as f:
            raw = f.read(max_bytes * 4)  # read a bit extra for header skip
    except OSError:
        return ""
    for line in raw.splitlines():
        s = line.strip()
        if not s:
            continue
        # Skip shebangs + obvious header noise; the next non-empty
        # line is usually the real one-liner identifier.
        if s.startswith("#!") or s == "---":
            continue
        return s[:max_bytes]
    return ""


def _match_excludes(name: str, excludes: list) -> bool:
    """Check a basename against the excludes glob list."""
    import fnmatch
    for pat in excludes or []:
        if fnmatch.fnmatch(name, pat):
            return True
    return False


def _walk_root(root_label: str, root_path: str, max_depth: int,
               excludes: list, summary_max_bytes: int,
               cap_remaining: int) -> list[dict]:
    """Walk a single root, return a list of entry dicts for batch
    upsert. cap_remaining is the global remaining entry budget --
    we stop early when it's exhausted to honor [daemon.index]
    .max_entries."""
    if not os.path.isdir(root_path):
        return []
    entries: list[dict] = []
    root_path = os.path.abspath(root_path)
    root_components = root_path.count(os.sep)
    for dirpath, dirnames, filenames in os.walk(root_path):
        # Depth check.
        depth = dirpath.count(os.sep) - root_components
        if depth > max_depth:
            dirnames[:] = []
            continue
        # Prune excluded dirs IN PLACE (os.walk respects the
        # mutation of dirnames during top-down traversal).
        dirnames[:] = [d for d in dirnames
                       if not _match_excludes(d, excludes)]
        for d in dirnames:
            if cap_remaining <= 0:
                return entries
            p = os.path.join(dirpath, d)
            try:
                st = os.stat(p)
            except OSError:
                continue
            entries.append({
                "path": p,
                "parent": dirpath,
                "basename": d,
                "kind": "dir",
                "size": 0,
                "mtime": datetime.datetime.fromtimestamp(
                    st.st_mtime,
                    tz=datetime.timezone.utc).isoformat(),
                "ext": None,
                "summary": None,
                "root_label": root_label,
            })
            cap_remaining -= 1
        for f in filenames:
            if _match_excludes(f, excludes):
                continue
            if cap_remaining <= 0:
                return entries
            p = os.path.join(dirpath, f)
            try:
                st = os.stat(p)
            except OSError:
                continue
            ext = os.path.splitext(f)[1].lower() or None
            entries.append({
                "path": p,
                "parent": dirpath,
                "basename": f,
                "kind": "file",
                "size": int(st.st_size),
                "mtime": datetime.datetime.fromtimestamp(
                    st.st_mtime,
                    tz=datetime.timezone.utc).isoformat(),
                "ext": ext,
                "summary": _file_summary(p, summary_max_bytes)
                            if ext else "",
                "root_label": root_label,
            })
            cap_remaining -= 1
    return entries


def _upsert_directory_entries(entries: list[dict]) -> tuple[int, int]:
    """Batch-upsert directory_entry rows via SurrealDB.

    Datetime handling: SurrealDB 3.x rejects bare ISO strings for
    TYPE datetime fields -- the canonical literal is
    `<datetime>"2026-05-19T..."`. We bypass _db_create for this
    batch path and format CREATE statements directly with the
    right literal shape. _db_create's now_fields mechanism works
    for indexed_at (= "now") but not for mtime (which needs to
    preserve the file's actual mtime).

    Counts: per-statement ERRs come back inside the 200-OK
    response. We walk the response list to count actual successes
    vs the previous bug where wrote == sent regardless."""
    if not entries:
        return (0, 0)
    written = errors = 0
    now_iso = datetime.datetime.now(
        datetime.timezone.utc).isoformat()
    CHUNK = 200
    for i in range(0, len(entries), CHUNK):
        batch = entries[i:i + CHUNK]
        statements = []
        for e in batch:
            # Field-by-field SurrealQL with proper literal shapes.
            parts = []
            for k, v in e.items():
                if v is None:
                    continue
                if k in ("mtime", "indexed_at"):
                    parts.append(
                        f'{k} = <datetime>{json.dumps(v)}')
                else:
                    parts.append(
                        f"{k} = {json.dumps(v, default=str)}")
            if "indexed_at" not in e:
                parts.append(
                    f'indexed_at = <datetime>{json.dumps(now_iso)}')
            statements.append(
                "CREATE directory_entry SET "
                + ", ".join(parts) + ";")
        sql = "\n".join(statements)
        try:
            r = _db_post_sync(sql)
            # Count per-statement ERRs inside the 200-OK response.
            # First statement is the USE prefix; data statements
            # start at index 1.
            ok = err_in_batch = 0
            if isinstance(r, list):
                for s in r[1:]:
                    if isinstance(s, dict) and s.get("status") == "OK":
                        ok += 1
                    else:
                        err_in_batch += 1
            written += ok
            errors += err_in_batch
        except Exception as ex:
            errors += len(batch)
            log.debug("dir_entry upsert chunk failed: %s", ex)
    return (written, errors)


def _pg_replace_directory_entries(root_label: str,
                                  entries: list[dict]) -> None:
    """R15: mirror the directory index into pgvector. The directory_entry
    writer bypasses _db_create (datetime literal shaping), so it never hit the
    _pg_insert chokepoint -- this is its dedicated pg path. DELETE the root's
    rows then batch-INSERT (ON CONFLICT(path) update). Runs in dual+postgres
    modes. Degrade-open via _pg_exec (mios-db --pg)."""
    if not _PG_ENABLED:
        return
    # WS-A3: root_label + every per-entry value (filesystem PATHS and first-line
    # file CONTENT -- attacker-influenceable) are BOUND as $n params, never
    # f-string-spliced (the old _pgesc was not a binding). DELETE + batch INSERT
    # run in ONE atomic statements-envelope so the root's index never half-updates.
    cols = ("path", "parent", "basename", "kind", "size",
            "mtime", "ext", "summary", "root_label")
    statements = [{"sql": "DELETE FROM directory_entry WHERE root_label = $1",
                   "params": [root_label]}]
    CHUNK = 200
    for i in range(0, len(entries), CHUNK):
        tuples, params = [], []
        n = 0
        for e in entries[i:i + CHUNK]:
            phs = []
            for k in cols:
                v = e.get(k)
                n += 1
                if v is None:
                    # keep NULL inline (not a value) so the column default/NULL
                    # applies; drop the placeholder number back.
                    n -= 1
                    phs.append("NULL")
                elif k == "size" and isinstance(v, (int, float)):
                    phs.append(f"${n}")
                    params.append(str(int(v)))
                else:
                    phs.append(f"${n}")
                    params.append(str(v))
            tuples.append("(" + ", ".join(phs) + ")")
        if tuples:
            statements.append({
                "sql": "INSERT INTO directory_entry (" + ", ".join(cols)
                + ") VALUES " + ", ".join(tuples)
                + " ON CONFLICT (path) DO UPDATE SET parent=EXCLUDED.parent, "
                "basename=EXCLUDED.basename, kind=EXCLUDED.kind, "
                "size=EXCLUDED.size, mtime=EXCLUDED.mtime, ext=EXCLUDED.ext, "
                "summary=EXCLUDED.summary, root_label=EXCLUDED.root_label, "
                "updated_at=now()",
                "params": params})
    _pg_run({"statements": statements})


def _atomic_replace_for_root(root_label: str,
                             entries: list[dict]) -> tuple[int, int]:
    """Delete all directory_entry rows for this root_label, then
    insert the fresh entries. Safer than UPDATE-by-path because
    deleted files actually disappear from the index instead of
    persisting as stale rows."""
    # pgvector mirror (R15) -- runs in dual + postgres modes.
    _pg_replace_directory_entries(root_label, entries)
    # SurrealDB replace -- skipped once Postgres is primary (pg is then the
    # source of truth); kept for the dual-mode transition window.
    if _PG_PRIMARY:
        return (len(entries), 0)
    # Delete by root_label first.
    try:
        _db_post_sync(
            f"DELETE directory_entry "
            f"WHERE root_label = {json.dumps(root_label)};"
        )
    except Exception as e:
        log.debug("dir_entry root delete failed: %s", e)
    return _upsert_directory_entries(entries)


def _db_post_sync(sql: str) -> list:
    """WS-A3: SurrealDB (:8000) is RETIRED -> hard no-op (returns []). The
    directory index is written to pgvector by _pg_replace_directory_entries
    (called FIRST in _atomic_replace_for_root, in dual + postgres modes), so this
    surreal mirror was redundant dead work. Stub kept so the index-loop call
    sites need no change."""
    return []


def index_loop() -> None:
    """Tick the directory-map indexer. Reads [daemon.index] config
    each tick so operators can re-tune cadence / roots without
    restarting the daemon."""
    time.sleep(60)  # boot delay; let surrealdb settle
    while not _stop_event.is_set():
        try:
            cfg = _read_daemon_index_config()
            if not cfg.get("enable", True):
                _stop_event.wait(60)
                continue
            interval_s = int(cfg.get("interval_min", 15)) * 60
            max_depth = int(cfg.get("max_depth", 6))
            max_entries = int(cfg.get("max_entries", 50000))
            summary_max_bytes = int(cfg.get("summary_max_bytes", 240))
            roots = cfg.get("roots") or []
            total_w = total_e = 0
            cap = max_entries
            for r in roots:
                if not isinstance(r, dict):
                    continue
                label = str(r.get("label") or "")
                path = str(r.get("path") or "")
                if not label or not path:
                    continue
                rdepth = int(r.get("max_depth", max_depth))
                excludes = r.get("excludes") or []
                if cap <= 0:
                    log.info("index: cap exhausted at root=%s", label)
                    break
                t0 = time.time()
                entries = _walk_root(
                    label, path, rdepth, excludes,
                    summary_max_bytes, cap)
                cap -= len(entries)
                if not entries:
                    log.info(
                        "index: root=%s path=%s -> 0 entries "
                        "(missing or empty)", label, path)
                    continue
                w, err = _atomic_replace_for_root(label, entries)
                total_w += w
                total_e += err
                log.info(
                    "index: root=%s wrote=%d err=%d in %.1fs",
                    label, w, err, time.time() - t0)
            _update_state("directory_index", {
                "last_tick": datetime.datetime.now().isoformat(timespec="seconds"),
                "written": total_w,
                "errors": total_e,
                "cap_remaining": cap,
            })
        except Exception as e:
            log.warning("index_loop error: %s", e)
        _stop_event.wait(interval_s if 'interval_s' in dir() else INDEX_DEFAULT_TICK_S)


def satisfaction_loop() -> None:
    """Tick the satisfaction monitor. Best-effort -- DB hiccups
    swallow + the next tick retries; no infinite-error loops."""
    time.sleep(45)  # boot delay; let agent-pipe + surrealdb settle
    while not _stop_event.is_set():
        try:
            unverified = _scan_unverified_refines(SATISFACTION_LOOKBACK_MIN)
            sat = unsat = skipped = 0
            for refine in unverified:
                ts = refine.get("ts")
                if not ts:
                    continue
                tool_calls = _tool_calls_for_refine(ts)
                kind = _emit_satisfaction(refine, tool_calls)
                if kind == "user_query_satisfied":
                    sat += 1
                elif kind == "skipped":
                    # Deferred to the orchestrator's inline confirmation
                    # engine (no recorded tools to AND-fold). No event
                    # written; not a verdict.
                    skipped += 1
                else:
                    unsat += 1
            if sat or unsat or skipped:
                log.info("satisfaction: %d satisfied, %d unsatisfied, "
                         "%d deferred", sat, unsat, skipped)
            _update_state("satisfaction", {
                "last_tick": datetime.datetime.now().isoformat(timespec="seconds"),
                "satisfied": sat,
                "unsatisfied": unsat,
                "deferred": skipped,
            })
        except Exception as e:
            log.warning("satisfaction_loop error: %s", e)
        _stop_event.wait(SATISFACTION_TICK_S)


def rolling_report_loop() -> None:
    """Operator 2026-05-21: consolidate the stored log_digests into a concise
    ROLLING REPORT. Every MIOS_DAEMON_REPORT_S, read the recent med/high
    digests from SurrealDB, ask the micro for ONE short report, and store it
    (state.json `report` + a log_digest report row). Cheap + idle-aware:
    skips the LLM entirely when nothing notable accumulated."""
    if _stop_event.wait(120):   # boot delay; let surrealdb + classify warm
        return
    interval = float(os.environ.get("MIOS_DAEMON_REPORT_S", "3600"))
    while not _stop_event.is_set():
        if _stop_event.wait(interval):
            break
        try:
            rows = _ok_result(_db_post(
                "SELECT ts, summary, severity FROM log_digest "
                "WHERE ts > time::now() - 1h AND severity IN ['med','high'] "
                "ORDER BY ts DESC LIMIT 30;"))
            sigs = [f"[{r.get('severity','?')}] {str(r.get('summary',''))[:160]}"
                    for r in rows if isinstance(r, dict)]
            if not sigs:
                continue  # nothing notable this window -> stay asleep
            report = llm_chat(
                "You are a Linux ops reporter. Summarise these recent log "
                "digests into ONE short plain-text paragraph (<=4 sentences): "
                "what happened + what needs attention.",
                "Recent digests:\n" + "\n".join(sigs),
                max_tokens=200, want_json=False)
            if not report:
                continue
            _update_state("report", {
                "text": report[:1000],
