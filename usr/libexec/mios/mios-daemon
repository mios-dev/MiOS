def _daemon_global_log_context(max_rows: int = 20) -> str:
    """Recent CONSOLIDATED global journal/log telemetry -- the daemon's
    core competency (it subscribes to the whole journal). Returns a short
    markdown block; empty when nothing notable / DB unavailable."""
    try:
        rows = _ok_result(_db_post(
            "SELECT ts, summary, severity FROM log_digest "
            "WHERE ts > time::now() - 2h "
            "ORDER BY ts DESC LIMIT " + str(int(max_rows)) + ";")) or []
    except Exception:
        rows = []
    lines = [f"- [{r.get('severity', '?')}] {str(r.get('summary', ''))[:200]}"
             for r in rows if isinstance(r, dict) and r.get("summary")]
    report = ""
    try:
        rep = json.loads(Path(STATE_FILE).read_text())
        report = ((rep.get("report") or {}).get("text") or "").strip()
    except Exception:
        report = ""
    out = []
    if report:
        out.append("Rolling report: " + report)
    if lines:
        out.append("Recent global journal/log digests:\n" + "\n".join(lines[:max_rows]))
    return "\n\n".join(out).strip()


# NOTE (operator 2026-05-21): web/other tool use is NOT hardcoded here.
# Tools are GLOBAL -- every agent/sub-agent can call the whole surface
# (web_search, verbs, recipes) and is PRE-PROMPTED to use them via its
# Modelfile. So WHICH queries to run (multi-faceted or not) is the MODEL's
# decision, governed by the AI-driven CONFIRMATION ENGINE (the satisfaction /
# Definition-of-Done checker) -- never by hardcoded Python query-extraction or
# inline English prompts. The daemon-agent's automatic supplement therefore
# carries only its CORE DATA -- the consolidated GLOBAL journal/log telemetry
# it already collects (its job, not a tool-use decision). Model-driven web
# tool use runs through the shared agent tool-loop + confirmation engine.


def _daemon_agent_reply(query: str) -> str:
    """The consolidated CPU lane (operator 2026-05-24 "mios-daemon-agent =
    mios-cpu/reasoner! CONSOLIDATE"): the always-on daemon-agent IS the CPU
    reasoning lane now. It REASONS on the CPU model (the same model/endpoint the
    retired mios-reasoner-cpu used -- qwen3:1.7b @ ollama-cpu :11435, num_gpu 0)
    via the proven think=False llm_chat() path, GROUNDED in the live global
    journal/log telemetry the daemon already maintains. So it contributes a real
    second-opinion answer that is system-state-aware -- NOT the raw telemetry
    dump that forced the old fanout=false (the model folds telemetry in ONLY
    when the request concerns the system, and ignores it otherwise). Bursts to
    8c/16t (AGENT_THREADS) for the foreground turn. Empty -> the fan-out cleanly
    drops this secondary."""
    if not (query or "").strip():
        return ""
    telemetry = _daemon_global_log_context()
    system = (
        "You are the MiOS CPU reasoning lane -- an always-on local agent that "
        "runs off the dGPU. Give a concise, direct second-opinion answer to the "
        "request, reasoning from your own knowledge. The live system telemetry "
        "below is GROUNDING: use it ONLY when the request concerns the system, "
        "its logs, services or recent events -- otherwise ignore it entirely. "
        "Never repeat raw telemetry lines into an unrelated answer."
    )
    if telemetry:
        system += "\n\n## Live global system telemetry (journal/logs)\n" + telemetry
    try:
        return llm_chat(system, query, max_tokens=AGENT_MAX_TOKENS,
                        temperature=0.3, num_thread=AGENT_THREADS,
                        model=AGENT_MODEL, endpoint=AGENT_ENDPOINT).strip()
    except Exception as e:   # noqa: BLE001 -- fail-open: drop this secondary
        log.warning("daemon-agent CPU reason failed: %s", e)
        return ""


def daemon_agent_server_loop() -> None:
    """Serve the daemon-agent's OpenAI-compatible /v1 endpoint on
    AGENT_PORT (default 8644 -- matches mios.toml [agents.mios-daemon-
    agent].endpoint). agent-pipe fan-out POSTs /v1/chat/completions here
    to merge a GLOBAL-log + WEB supplement into the answer. ThreadingHTTP
    so a slow web fetch never blocks the stop-check or other requests."""
    from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

    class _Handler(BaseHTTPRequestHandler):
        protocol_version = "HTTP/1.1"

        def log_message(self, *a):   # silence default access log
            return

        def _send_json(self, code: int, obj: dict) -> None:
            data = json.dumps(obj).encode("utf-8")
            self.send_response(code)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        def do_GET(self):
            from urllib.parse import urlparse, parse_qs
            route = urlparse(self.path).path.rstrip("/")
            if route == "/v1/models":
                self._send_json(200, {"object": "list", "data": [
                    {"id": "mios-daemon-agent", "object": "model",
                     "owned_by": "mios"}]})
            elif route == "/verify_launch":
                # SYNCHRONOUS launch success-check (operator 2026-05-25 4A:
                # "the daemon-agent ... runs the Definition-of-Done success
                # check; the main agent/sub-agents just delegate and read the
                # success signal"). The post-hoc launch_verifier_loop only
                # catches false claims minutes later by scanning chats; this
                # lets any agent ask IN-TURN "did app X actually launch?" and
                # get the daemon's consolidated verdict (live window/process
                # probe + the daemon's own recorded false-success history),
                # so it can retry or report honestly instead of blind-claiming.
                # The check is the same read-only mios-window-active --present
                # probe the loop uses -- it never launches anything.
                app = (parse_qs(urlparse(self.path).query).get("app")
                       or [""])[0].strip()
                if not app:
                    self._send_json(400, {"error": "missing ?app=<name>"})
                    return
                verdict = _verify_one_launch(app)
                # presented_to_operator ONLY (process_alive false-positives via
                # the verifier's pgrep self-match; SOUL: window-presented only).
                launched = bool(verdict.get("presented_to_operator"))
                recent = [f for f in _collect_launch_failures()
                          if app.lower() in (f.get("app") or "").lower()]
                self._send_json(200, {
                    "app": app,
                    "launched": launched,
                    "verdict": verdict,
                    "recent_failures": recent,
                    "checked_by": "mios-daemon-agent",
                    "ts": int(time.time()),
                })
            else:
                self._send_json(404, {"error": "not found"})

        def do_POST(self):
            route = self.path.split("?", 1)[0].rstrip("/")
            if route == "/os_control":
                # 4A #2: the daemon FIRES the OS-control launch (through the
                # broker, in operator/WSLg context) AND runs the success-check,
                # returning ONE verdict the agent reads. Body:
                # {action:"launch", app:"<name>"}.
                try:
                    n = int(self.headers.get("Content-Length") or 0)
                    body = json.loads(self.rfile.read(n) or b"{}")
                except Exception:
                    self._send_json(400, {"error": "bad request"})
                    return
                action = str(body.get("action") or "launch").strip().lower()
                app = str(body.get("app") or body.get("name") or "").strip()
                node = str(body.get("node") or "").strip()
                if action != "launch":
                    self._send_json(400, {
                        "error": f"unsupported action {action!r} (only 'launch')"})
                    return
                if not app:
                    self._send_json(400, {"error": "missing 'app'"})
                    return
                try:
                    result = _fire_and_verify(app, node)
                except Exception as e:   # noqa: BLE001 -- be honest, never fake
                    log.warning("os_control fire+verify failed: %s", e)
                    result = {"app": app, "fired": False, "launched": False,
                              "error": str(e), "checked_by": "mios-daemon-agent"}
                self._send_json(200, result)
                return
            if route != "/v1/chat/completions":
                self._send_json(404, {"error": "not found"})
                return
            try:
                n = int(self.headers.get("Content-Length") or 0)
                body = json.loads(self.rfile.read(n) or b"{}")
            except Exception:
                self._send_json(400, {"error": "bad request"})
                return
            query = ""
            for m in reversed(body.get("messages") or []):
                if isinstance(m, dict) and m.get("role") == "user":
                    query = str(m.get("content") or "")
                    break
            try:
                content = _daemon_agent_reply(query)
            except Exception as e:   # noqa: BLE001
                log.warning("daemon-agent reply failed: %s", e)
                content = ""
            self._send_json(200, {
                "id": "chatcmpl-daemonagent",
                "object": "chat.completion",
                "created": int(time.time()),
                "model": "mios-daemon-agent",
                "choices": [{
                    "index": 0,
                    "message": {"role": "assistant", "content": content},
                    "finish_reason": "stop",
                }],
            })

    try:
        srv = ThreadingHTTPServer(("127.0.0.1", AGENT_PORT), _Handler)
    except OSError as e:
        log.warning("daemon-agent server bind :%d failed (non-fatal): %s",
                    AGENT_PORT, e)
        return
    srv.timeout = 1
    log.info("daemon-agent serving /v1 on 127.0.0.1:%d", AGENT_PORT)
    while not _stop_event.is_set():
        try:
            srv.handle_request()
        except Exception as e:   # noqa: BLE001 -- never let the loop die
            log.debug("daemon-agent request error: %s", e)
    try:
        srv.server_close()
    except Exception:
        pass


def main() -> int:
    signal.signal(signal.SIGINT, _on_signal)
    signal.signal(signal.SIGTERM, _on_signal)
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    # Best-effort chmod: when STATE_DIR was created/owned by ANOTHER user (e.g. a
    # root- or old-user-owned dir under this unit's User=mios-ai after the user
    # consolidation), chmod EPERMs. That must NEVER crash the always-on daemon --
    # mkdir already guaranteed the dir exists, and ownership is fixed by tmpfiles/
    # chown, not here. (Writes still need ownership; that's the tmpfiles job.)
    try:
        os.chmod(STATE_DIR, 0o755)
    except OSError as e:
        log.warning("STATE_DIR chmod skipped (non-owner, non-fatal): %s", e)
    _atomic_write_state()

    # Operator 2026-05-24: the daemon-agent runs always-on background work at
    # ~2c/4t but must BURST to 8c/16t when it participates in a foreground AI
    # pipeline (concurrent with the GPU/iGPU). So pin to UP TO 8 randomly-chosen
    # cores (which cores varies per boot -> spreads wear); CPUQuota=800% in the
    # drop-in (mios-daemon.service.d/20-cpu-limit.conf) allows all 8, while
    # CPUWeight=20 + Nice=10 keep it LIGHT at baseline (the background loop uses
    # ~2c; the 8 are there for the foreground burst) and make it YIELD to the
    # GPU agents / interactive turns when contended. Best-effort: skipped where
    # sched_setaffinity is unavailable or there are <2 cores; pins to all cores
    # when the box has fewer than 8.
    try:
        import random
        _ncpu = os.cpu_count() or 1
        if _ncpu >= 2 and hasattr(os, "sched_setaffinity"):
            _n = min(int(os.environ.get("MIOS_DAEMON_MAX_CORES", "8")), _ncpu)
            _cores = set(random.sample(range(_ncpu), _n))
            os.sched_setaffinity(0, _cores)
            log.info("pinned to %d cores (foreground burst ceiling): %s",
                     _n, sorted(_cores))
    except (OSError, ValueError) as e:
        log.warning("cpu affinity pin failed (non-fatal): %s", e)

    log.info("starting: model=%s endpoint=%s state=%s",
             MODEL, ENDPOINT, STATE_FILE)
    log.info("watching units: %s", ",".join(WATCHED_UNITS))
    log.info("refusal patterns loaded: %d", len(_refusal_res))

    threads = [
        threading.Thread(target=journal_subscriber, daemon=True, name="journal"),
        threading.Thread(target=classify_loop, daemon=True, name="classify"),
        threading.Thread(target=refusal_loop, daemon=True, name="refusal"),
        threading.Thread(target=cron_loop, daemon=True, name="cron"),
        threading.Thread(target=suggestions_loop, daemon=True, name="suggestions"),
        threading.Thread(target=launch_verifier_loop, daemon=True, name="launch_verifier"),
        threading.Thread(target=task_collector_loop, daemon=True, name="task_collector"),
        threading.Thread(target=fs_watcher_loop, daemon=True, name="fs_watcher"),
        threading.Thread(target=satisfaction_loop, daemon=True, name="satisfaction"),
        threading.Thread(target=index_loop, daemon=True, name="directory_index"),
        threading.Thread(target=rolling_report_loop, daemon=True, name="rolling_report"),
        threading.Thread(target=daemon_agent_server_loop, daemon=True, name="daemon_agent_server"),
    ]
    for t in threads:
        t.start()
    while not _stop_event.is_set():
        time.sleep(2)
    log.info("stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main())
