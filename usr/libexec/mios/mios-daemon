# ── SurrealDB best-effort writer ─────────────────────────────────────
# Mirrors the helper in usr/share/mios/owui/pipes/mios_agent_pipe.py.
# Daemon-side is sync (urllib) since the loops run on threads; pipe
# side is async (aiohttp). Both target the same /sql endpoint with the
# SurrealDB 3.0+ "USE NS ... DB ...;" body prefix (NS:/DB: HTTP
# headers dropped in 3.0). Phase-2 directive 2026-05-18: the daemon
# writes kanban_shadow + scratch + event + agent_metric rows on its
# 5-minute task_collector tick so other agents (mios-agent-pipe,
# hermes) can query a single source of truth instead of polling N
# JSON files.

import base64 as _base64
DB_URL  = os.environ.get("MIOS_DB_URL",  "http://localhost:8000")
DB_USER = os.environ.get("MIOS_DB_USER", "root")
DB_PASS = os.environ.get("MIOS_DB_PASS", "root")
DB_NS   = os.environ.get("MIOS_DB_NS",   "mios")
DB_DB   = os.environ.get("MIOS_DB_DB",   "mios")
_DB_AUTH = "Basic " + _base64.b64encode(f"{DB_USER}:{DB_PASS}".encode()).decode()
_DB_DOWN_UNTIL: float = 0.0


def _db_post(sql: str, *, timeout: float = 3.0) -> Optional[list]:
    """Best-effort SurrealDB write/query. Returns the parsed list of
    per-statement results, or None on any error. A 30s backoff after
    each failure prevents retry storms when the DB is down."""
    global _DB_DOWN_UNTIL
    if not sql or not sql.strip():
        return None
    if time.time() < _DB_DOWN_UNTIL:
        return None
    body = (f"USE NS {DB_NS} DB {DB_DB}; " + sql).encode("utf-8")
    try:
        req = urllib.request.Request(
            f"{DB_URL}/sql",
            data=body,
            headers={
                "Authorization": _DB_AUTH,
                "Accept": "application/json",
            },
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return json.loads(r.read())
    except Exception:
        _DB_DOWN_UNTIL = time.time() + 30
        return None


def _db_create(table: str, fields: dict, *,
               now_fields: tuple = (),
               extra: str = "") -> str:
    """Build `CREATE <table> SET ...` -- SurrealDB 3.0+ rejects plain
    ISO-Z strings for TYPE datetime fields, so the canonical pattern
    is `field = time::now()` literal for datetimes + JSON-encoded
    values for everything else (JSON-object syntax IS SurrealQL-object
    syntax, so nested payload dicts pass through unchanged)."""
    parts = [f"{k} = time::now()" for k in now_fields]
    for k, v in fields.items():
        if k in now_fields or v is None:
            continue
        parts.append(f"{k} = {json.dumps(v, default=str)}")
    sql = f"CREATE {table} SET " + ", ".join(parts)
    if extra:
        sql += " " + extra
    return sql + ";"


# ── inotify wrapper (stdlib ctypes; no pip deps for offline / Day-0) ──
# Phase A.2 of the AgentOS roadmap: replace the daemon's poll loops
# with kernel-event-driven mutations. Watches the /var/lib/mios/*
# scratchpads + state dirs; emits SurrealDB event rows (source=
# fs-watcher, kind=fs_change) on every change so other agents
# (agent-pipe critic, future DCI deliberation, ...) can subscribe
# via `SELECT FROM event WHERE source = 'fs-watcher' AND ts > <last>`
# instead of polling individual JSON files.
#
# Implementation: minimal ctypes wrapper around inotify_init1 +
# inotify_add_watch + raw read. No pip packages needed -- Day-0 bake
# carries no extra Python deps for this feature.

import ctypes as _ctypes
import struct as _struct
import select as _select

_libc = _ctypes.CDLL("libc.so.6", use_errno=True)
_libc.inotify_init1.argtypes = [_ctypes.c_int]
_libc.inotify_init1.restype = _ctypes.c_int
_libc.inotify_add_watch.argtypes = [_ctypes.c_int, _ctypes.c_char_p, _ctypes.c_uint32]
_libc.inotify_add_watch.restype = _ctypes.c_int

# /usr/include/sys/inotify.h flags + event mask bits.
_IN_NONBLOCK = 0x800
_IN_CLOEXEC = 0x80000
_IN_CLOSE_WRITE = 0x00000008
_IN_MOVED_TO    = 0x00000080
_IN_CREATE      = 0x00000100
_IN_DELETE      = 0x00000200
_IN_MOVED_FROM  = 0x00000040
# Watch every change that could carry agent-relevant state.
_WATCH_MASK = (_IN_CLOSE_WRITE | _IN_MOVED_TO
               | _IN_CREATE | _IN_DELETE | _IN_MOVED_FROM)
_EVENT_HEADER = _struct.Struct("iIII")  # wd, mask, cookie, name_len

# Dirs the daemon (and other agents) write or expect mutations on.
# Sourced from mios.toml [fs_watcher].watch_dirs via the userenv.sh
# slot (MIOS_FS_WATCHER_DIRS, CSV). Falls back to the compiled-in
# defaults that match the mios.toml seed when env is unset.
_DEFAULT_FS_WATCHER_DIRS = [
    "/var/lib/mios/hermes-tail",
    "/var/lib/mios/delegation-prefilter",
    "/var/lib/mios/log-watcher",
    "/var/lib/mios/daemon",
    "/var/lib/mios/scratch",
    "/var/lib/mios/agent-nudger",
    "/var/lib/mios/cron-director",
    "/var/lib/mios/ai/scratch",
]
_env_fs_dirs = os.environ.get("MIOS_FS_WATCHER_DIRS", "").strip()
if _env_fs_dirs:
    _FS_WATCHER_DIRS = [d.strip() for d in _env_fs_dirs.split(",") if d.strip()]
else:
    _FS_WATCHER_DIRS = list(_DEFAULT_FS_WATCHER_DIRS)

# Map of mask-bit -> short op name for the SurrealDB event row.
_OP_NAMES = {
    _IN_CLOSE_WRITE: "write",
    _IN_MOVED_TO:    "moved_in",
    _IN_CREATE:      "create",
    _IN_DELETE:      "delete",
    _IN_MOVED_FROM:  "moved_out",
}


def _inotify_init() -> int:
    fd = _libc.inotify_init1(_IN_NONBLOCK | _IN_CLOEXEC)
    if fd < 0:
        raise OSError(_ctypes.get_errno(), "inotify_init1")
    return fd


def _inotify_add(fd: int, path: str, mask: int = _WATCH_MASK) -> int:
    wd = _libc.inotify_add_watch(fd, path.encode("utf-8"), mask)
    if wd < 0:
        raise OSError(_ctypes.get_errno(), f"inotify_add_watch({path})")
    return wd


def _inotify_read(fd: int) -> list[tuple[int, int, int, str]]:
    """Return list of (wd, mask, cookie, name)."""
    try:
        buf = os.read(fd, 8192)
    except BlockingIOError:
        return []
    out: list[tuple[int, int, int, str]] = []
    i = 0
    while i < len(buf):
        wd, mask, cookie, name_len = _EVENT_HEADER.unpack_from(buf, i)
        i += 16
        name = buf[i:i + name_len].rstrip(b"\x00").decode("utf-8", errors="replace")
        i += name_len
        out.append((wd, mask, cookie, name))
    return out


# ── Shared state (handlers write here; flusher persists) ─────────────
_state_lock = threading.Lock()
_state: dict = {
    "ts": time.time(),
    "classify": None,
    "refusal":  None,
    "cron":     {"last_fire": None, "decisions": []},
}
_stop_event = threading.Event()


def _atomic_write_state() -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with _state_lock:
        snapshot = dict(_state)
        snapshot["ts"] = time.time()
    tmp = STATE_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(snapshot, separators=(",", ":")))
    os.chmod(tmp, 0o644)
    tmp.replace(STATE_FILE)


def _update_state(section: str, value) -> None:
    with _state_lock:
        _state[section] = value
    _atomic_write_state()


# ── Single shared Ollama client ──────────────────────────────────────
def llm_chat(system: str, user: str, *, max_tokens: int = 150,
             temperature: float = 0.1, want_json: bool = False) -> str:
    """Call qwen3:0.6b-cpu (or whatever MODEL is) via Ollama /api/chat.
    Returns the model's text output (content with thinking fallback).
    Returns empty string on any error. Always uses CPU + keep_alive=-1.
    """
    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "options": {
            "num_gpu": 0,           # Law 7 OFFLINE-FIRST + CPU-first
            "num_thread": 4,
            "num_predict": max_tokens,
            "temperature": temperature,
        },
        "stream": False,
        "keep_alive": -1,           # always-on agentic OS
    }
    if want_json:
        # Ollama's structured-output mode: the runtime constrains
        # token sampling so the response is parseable JSON. Critical
        # for sub-2B models that would otherwise prose-prefix the
        # JSON ("Okay, let me break this down...") and trip the
        # parser. Operator-flagged post-reboot: classify output was
        # "(unparseable: Okay, let's break down...)".
        payload["format"] = "json"
    try:
        req = urllib.request.Request(
            f"{ENDPOINT}/api/chat",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=REQUEST_TIMEOUT_S) as r:
            body = json.loads(r.read())
        msg = body.get("message") or {}
        out = (msg.get("content") or "").strip()
        if not out:
            out = (msg.get("thinking") or msg.get("reasoning") or "").strip()
        return out
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        log.warning("LLM call failed (non-fatal): %s", e)
        return ""


# ── Journal subscriber ───────────────────────────────────────────────
_event_buffer: list[dict] = []
_buffer_lock = threading.Lock()


def journal_subscriber() -> None:
    """Run `journalctl -f -o json` and push parsed events into the
    shared buffer. Classify + refusal-detect handlers drain it."""
    units_args: list[str] = []
    for u in WATCHED_UNITS:
        u = u.strip()
        if u:
            units_args += ["-u", u]
    cmd = ["journalctl", "-f", "-n", "0", "-o", "json", "--no-pager", *units_args]
    log.info("journal subscriber: %s", " ".join(cmd))
    proc = subprocess.Popen(
        cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
        text=True, bufsize=1,
    )
    try:
        for line in proc.stdout:
            if _stop_event.is_set():
                break
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                continue
            with _buffer_lock:
                _event_buffer.append(ev)
                # Cap to avoid runaway memory
                if len(_event_buffer) > 500:
                    _event_buffer[:] = _event_buffer[-200:]
    finally:
        proc.terminate()


# ── Classify handler (was: mios-log-watcher) ─────────────────────────
CLASSIFY_SYSTEM = (
    "You are a Linux log classifier. Read the events below and reply "
    "with ONE LINE of JSON: {\"summary\":\"<one sentence>\","
    "\"tags\":[\"<one|two|three>\"],\"severity\":\"low|med|high\"}. "
    "Nothing else."
)


def classify_loop() -> None:
    while not _stop_event.is_set():
        time.sleep(CLASSIFY_BATCH_S)
        with _buffer_lock:
            batch = _event_buffer[-CLASSIFY_BATCH_MAX:][:]
        if not batch:
            continue
        # Compose compact prompt
        lines = []
        for e in batch:
            unit = e.get("_SYSTEMD_UNIT", e.get("SYSLOG_IDENTIFIER", "?"))
            msg = (e.get("MESSAGE") or "").strip().split("\n", 1)[0]
            lines.append(f"[{unit}] {msg[:200]}")
        content = llm_chat(CLASSIFY_SYSTEM,
                           "Recent events:\n" + "\n".join(lines),
                           max_tokens=120, want_json=True)
        m = re.search(r"\{[\s\S]*?\}", content) if content else None
        if m:
            try:
                result = json.loads(m.group(0))
            except json.JSONDecodeError:
                result = {"summary": f"(JSON err: {content[:80]})",
                          "tags": ["noise"], "severity": "low"}
        else:
            result = {"summary": f"(unparseable: {content[:80]})",
                      "tags": ["noise"], "severity": "low"}
        result["event_count"] = len(batch)
        result["events_sample"] = lines[:3]
        result["ts"] = datetime.datetime.now().isoformat(timespec="seconds")
        _update_state("classify", result)
        log.info("classify: %d events -> %s (%s)",
                 len(batch), result.get("summary", "")[:80],
                 result.get("severity", "?"))


# ── Refusal handler (was: mios-agent-nudger) ─────────────────────────
REFUSAL_SYSTEM = (
    "You are a Linux log filter. Decide if the following hermes-agent "
    "log message is the agent ACTIVELY REFUSING the user (vs quoting / "
    "discussing such a phrase). Refusal = the agent telling the user "
    "it cannot do something when the relevant tool IS available. "
    "Reply with a single token: \"YES\" or \"NO\". Nothing else."
)


def _load_refusal_patterns() -> list[re.Pattern]:
    out: list[re.Pattern] = []
    try:
        for line in REFUSAL_PATTERNS_FILE.read_text(encoding="utf-8").splitlines():
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            try:
                out.append(re.compile(s, re.IGNORECASE))
            except re.error:
                pass
    except OSError:
        pass
    return out


_refusal_res = _load_refusal_patterns()


def refusal_loop() -> None:
    """Walk the same buffer, look for hermes-agent.service messages
    that match a refusal pattern, then confirm with the LLM."""
    last_index = 0
    while not _stop_event.is_set():
        time.sleep(5.0)
        with _buffer_lock:
            new = _event_buffer[last_index:]
            last_index = len(_event_buffer)
        for ev in new:
            unit = ev.get("_SYSTEMD_UNIT", "")
            if unit != "hermes-agent.service":
                continue
            msg = (ev.get("MESSAGE") or "")
            if not msg:
                continue
            # Pattern pre-filter
            hit = None
            for pat in _refusal_res:
                if pat.search(msg):
                    hit = pat.pattern
                    break
            if not hit:
                continue
            # LLM confirm
            verdict = llm_chat(REFUSAL_SYSTEM, msg[:2000],
                               max_tokens=4, temperature=0.0)
            is_refusal = verdict.upper().startswith("YES")
            log.info("refusal? pattern=%r verdict=%s msg=%r",
                     hit[:60], verdict[:8], msg[:120])
            if is_refusal:
                _update_state("refusal", {
                    "trigger": hit,
                    "phrase": msg[:200],
                    "model": MODEL,
                    "service": unit,
                    "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                })


# ── Cron handler (was: mios-cron-director) ──────────────────────────
def _load_cron_gates() -> list[dict]:
    """Read /etc/mios/daemon/cron.toml. Each [gates.<name>] block is
    one rule: { question, action, min_interval_s }."""
    if not CRON_TOML.is_file():
        return []
    try:
        try:
            import tomllib   # py 3.11+
        except ImportError:
            import tomli as tomllib   # type: ignore
        data = tomllib.loads(CRON_TOML.read_text(encoding="utf-8"))
    except Exception as e:
        log.warning("cron.toml parse failed: %s", e)
        return []
    out: list[dict] = []
    gates = (data.get("gates") or {})
    for name, block in gates.items():
        if not isinstance(block, dict):
            continue
        out.append({
            "name": name,
            "question": block.get("question", ""),
            "action":   block.get("action", ""),
            "min_interval_s": float(block.get("min_interval_s", 3600)),
        })
    return out


_last_fire: dict[str, float] = {}


def cron_loop() -> None:
    while not _stop_event.is_set():
        gates = _load_cron_gates()
        decisions: list[dict] = []
        for gate in gates:
            name = gate["name"]
            last = _last_fire.get(name, 0.0)
            if (time.time() - last) < gate["min_interval_s"]:
                continue
            verdict = llm_chat(
                "You are a fast YES/NO gate evaluator. Reply ONLY with "
                "the requested JSON: {\"answer\":\"YES\"|\"NO\","
                "\"reasoning\":\"<one sentence>\"}",
                f"Question: {gate['question']}",
                max_tokens=80,
                temperature=0.0,
                want_json=True,
            )
            m = re.search(r"\{[\s\S]*?\}", verdict) if verdict else None
            ok = False
            reasoning = ""
            if m:
                try:
                    j = json.loads(m.group(0))
                    ok = str(j.get("answer", "")).upper().startswith("YES")
                    reasoning = str(j.get("reasoning", ""))[:200]
                except json.JSONDecodeError:
                    reasoning = f"unparseable: {verdict[:80]}"
            d = {
                "name": name,
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "verdict": "YES" if ok else "NO",
                "reasoning": reasoning,
            }
            decisions.append(d)
            if ok and gate["action"]:
                _last_fire[name] = time.time()
                d["fired"] = True
                log.info("cron FIRE %s: %s", name, gate["action"][:120])
                try:
                    subprocess.Popen(
                        ["bash", "-lc", gate["action"]],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        start_new_session=True,
                    )
                    with _state_lock:
                        _state["cron"]["last_fire"] = {
                            "rule": name,
                            "ts": d["ts"],
                            "action": gate["action"][:200],
                        }
                except OSError as e:
                    log.warning("cron action failed: %s", e)
        with _state_lock:
            # Keep last 20 decisions
            existing = _state["cron"].get("decisions") or []
            existing = existing + decisions
            _state["cron"]["decisions"] = existing[-20:]
        if decisions:
            _atomic_write_state()
        # Wait for next tick or stop
        _stop_event.wait(CRON_TICK_S)


