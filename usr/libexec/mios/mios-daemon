def _collect_kanban_state() -> list[dict]:
    """Read open kanban tasks from the hermes kanban.db. Schema is
    hermes's own; we pluck the most-recent rows from the `tasks`
    table (or 'cards' depending on version). Returns [] on any
    error (fail-open: the digest just won't include kanban context)."""
    if not KANBAN_DB.is_file():
        return []
    try:
        import sqlite3
        c = sqlite3.connect(str(KANBAN_DB))
        # Discover the right table name (hermes has gone through a few)
        tables = [
            r[0] for r in c.execute(
                "SELECT name FROM sqlite_master WHERE type='table'"
            ).fetchall()
        ]
        for cand in ("tasks", "cards", "kanban_tasks", "items"):
            if cand in tables:
                # Pick the column shape gracefully
                cols = [r[1] for r in c.execute(
                    f"PRAGMA table_info({cand})").fetchall()]
                wanted = [col for col in
                          ("id", "title", "status", "priority",
                           "updated_at", "tags", "description")
                          if col in cols]
                if not wanted:
                    continue
                rows = c.execute(
                    f"SELECT {','.join(wanted)} FROM {cand} "
                    f"ORDER BY rowid DESC LIMIT 12"
                ).fetchall()
                return [
                    dict(zip(wanted, r)) for r in rows
                ]
        return []
    except Exception as e:
        log.debug("kanban scan: %s: %s", type(e).__name__, e)
        return []


def _collect_recent_sessions(within_s: float = 1800) -> list[dict]:
    """Skim the most-recent hermes session JSONs for tool_call/result
    summary (count + success rate)."""
    if not HERMES_SESSIONS_DIR_DAEMON.is_dir():
        return []
    now = time.time()
    out: list[dict] = []
    try:
        paths = sorted(
            HERMES_SESSIONS_DIR_DAEMON.glob("session_*.json"),
            key=lambda p: p.stat().st_mtime, reverse=True,
        )[:6]
    except OSError:
        return []
    for path in paths:
        try:
            mtime = path.stat().st_mtime
            if (now - mtime) > within_s:
                continue
            d = json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue
        msgs = d.get("messages") or []
        tool_calls = sum(1 for m in msgs if isinstance(m, dict)
                         and (m.get("tool_calls") or []))
        results = []
        for m in msgs:
            if isinstance(m, dict) and m.get("role") == "tool":
                c = m.get("content") or ""
                try:
                    j = json.loads(c) if isinstance(c, str) else None
                    if isinstance(j, dict) and "success" in j:
                        results.append(bool(j["success"]))
                except (json.JSONDecodeError, ValueError):
                    results.append(None)
        succ = sum(1 for r in results if r is True)
        fail = sum(1 for r in results if r is False)
        out.append({
            "session_id": d.get("session_id", path.stem),
            "mtime": datetime.datetime.fromtimestamp(mtime).isoformat(timespec="seconds"),
            "model": d.get("model"),
            "platform": d.get("platform"),
            "tool_calls": tool_calls,
            "tool_success": succ,
            "tool_fail": fail,
        })
    return out


def _collect_scratch() -> list[dict]:
    """Index scratchpad files (small markdown / json) the agents wrote."""
    out: list[dict] = []
    for root in SCRATCH_DIRS:
        if not root.is_dir():
            continue
        try:
            for p in root.glob("*"):
                if not p.is_file():
                    continue
                if p.name in (NUDGES_MD.name, NUDGES_JSON.name):
                    continue  # don't recurse into our own output
                try:
                    size = p.stat().st_size
                except OSError:
                    continue
                if size > 8192:   # skip big files
                    continue
                try:
                    head = p.read_text(encoding="utf-8", errors="replace")[:600]
                except OSError:
                    continue
                out.append({
                    "path": str(p),
                    "size": size,
                    "head": head,
                })
        except OSError:
            continue
    return out[:12]


def _collect_launch_failures() -> list[dict]:
    if not LAUNCH_FAILURES_FILE.is_file():
        return []
    try:
        data = json.loads(LAUNCH_FAILURES_FILE.read_text())
        return data[-5:] if isinstance(data, list) else []
    except Exception:
        return []


def _openai_compat_llm_json(system: str, user: str,
                            timeout: int = 30) -> dict:
    """Call Ollama via its OpenAI-compatible /v1/chat/completions
    endpoint with response_format=json_object (operator directive:
    'native for OpenAI API standards'). Returns parsed dict; {} on
    any failure (fail-open -- the loop just skips a tick)."""
    payload = {
        "model": MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user",   "content": user},
        ],
        "response_format": {"type": "json_object"},
        "temperature": 0.1,
        "max_tokens": 700,
        "stream": False,
    }
    try:
        req = urllib.request.Request(
            f"{ENDPOINT}/v1/chat/completions",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as r:
            body = json.loads(r.read())
    except (urllib.error.URLError, OSError, json.JSONDecodeError) as e:
        log.debug("nudger LLM call failed: %s", e)
        return {}
    choices = body.get("choices") or []
    if not choices:
        return {}
    content = ((choices[0].get("message") or {}).get("content") or "").strip()
    if not content:
        return {}
    try:
        parsed = json.loads(content)
        return parsed if isinstance(parsed, dict) else {}
    except json.JSONDecodeError:
        return {}


def _render_nudges_md(payload: dict) -> str:
    """Render the structured nudge payload as a markdown digest the
    agent can `cat` for ground-truth status."""
    nudges = payload.get("nudges") or []
    digest = payload.get("digest") or ""
    out = [
        f"# MiOS agent nudges",
        f"_updated: {datetime.datetime.now().isoformat(timespec='seconds')}_",
        "",
        f"## Digest",
        digest or "_no notable state_",
        "",
        f"## Open nudges ({len(nudges)})",
    ]
    if not nudges:
        out.append("_none -- proceed_")
    for n in nudges:
        if not isinstance(n, dict):
            continue
        sev = n.get("severity", "low")
        nt = n.get("type", "?")
        summ = n.get("summary", "")
        act = n.get("action", "")
        icon = {"high": "🔴", "med": "🟡", "low": "🟢"}.get(sev, "·")
        out.append(f"- {icon} **{nt}** ({sev}): {summ}")
        if act:
            out.append(f"  - **action:** `{act}`")
    return "\n".join(out) + "\n"


def fs_watcher_loop() -> None:
    """Phase A.2: kernel-event-driven mutation bus.

    Watches /var/lib/mios/* scratchpads + state dirs via inotify.
    Each mutation -> one SurrealDB event row with source=fs-watcher,
    kind=fs_change, payload={path, op, size, preview}. Other agents
    subscribe via `SELECT FROM event WHERE source = 'fs-watcher'
    AND ts > <last_seen>` instead of polling individual files.

    Debounces per (path, op) at 1Hz so a noisy write loop doesn't
    flood the event table. Tolerates missing/added dirs: creates the
    watched dirs at startup; warnings on add-watch failure don't kill
    the thread.
    """
    # Boot delay: let the rest of the daemon initialize so the
    # SurrealDB writer is warm before we start firing events.
    for _ in range(15):
        if _stop_event.is_set(): return
        time.sleep(1)
    try:
        fd = _inotify_init()
    except OSError as e:
        log.warning("inotify_init1 failed (%s); fs-watcher disabled", e)
        return
    wd_to_dir: dict[int, str] = {}
    for d in _FS_WATCHER_DIRS:
        # Best-effort create. If the parent dir is owned by another
        # service (e.g. /var/lib/mios/ai owned by mios-hermes) and
        # root's mkdir lands in a perms-conflict, skip silently --
        # the dir will be created by its owner agent later, at which
        # point we can re-add the watch on the next daemon restart.
        if not os.path.isdir(d):
            try:
                Path(d).mkdir(parents=True, exist_ok=True)
            except OSError:
                log.info("fs-watcher: skip %s (not present + parent "
                         "owned by another agent)", d)
                continue
        try:
            wd = _inotify_add(fd, d)
            wd_to_dir[wd] = d
            log.info("fs-watcher: watching %s (wd=%d)", d, wd)
        except OSError as e:
            log.warning("fs-watcher: %s -> %s", d, e)
    if not wd_to_dir:
        log.warning("fs-watcher: no dirs registered; thread exiting")
        return
    last_emit: dict[str, float] = {}
    DEBOUNCE_S = 1.0
    while not _stop_event.is_set():
        try:
            r, _, _ = _select.select([fd], [], [], 1.0)
            if not r:
                continue
            for wd, mask, _cookie, name in _inotify_read(fd):
                dir_path = wd_to_dir.get(wd)
                if not dir_path:
                    continue
                full = os.path.join(dir_path, name) if name else dir_path
                # Pick the most informative op-name for the mask.
                op = next(
                    (n for bit, n in _OP_NAMES.items() if mask & bit),
                    f"mask={mask:#x}",
                )
                key = f"{full}|{op}"
                now = time.time()
                if last_emit.get(key, 0.0) > now - DEBOUNCE_S:
                    continue
                last_emit[key] = now
                size = 0
                preview = ""
                if op in ("write", "moved_in", "create"):
                    try:
                        st = os.stat(full)
                        size = int(st.st_size)
                        if size > 0 and st.st_mode & 0o4444:
                            with open(full, "rb") as f:
                                preview = f.read(500).decode(
                                    "utf-8", errors="replace")
                    except OSError:
                        pass
                row = {
                    "source": "fs-watcher",
                    "kind": "fs_change",
                    "severity": "info",
                    "summary": f"{op}: {full}",
                    "payload": {
                        "path": full,
                        "op": op,
                        "mask": int(mask),
                        "size": size,
                        "preview": preview[:500],
                    },
                }
                _db_post(_db_create("event", row, now_fields=("ts",)))
        except Exception as e:
            log.warning("fs-watcher iter: %s", e)
            # Brief backoff so a persistent OS error doesn't spin.
            time.sleep(2)


def task_collector_loop() -> None:
    """5-min cadence aggregator + nudger. See module docstring above."""
    # Boot delay -- let mios-daemon settle, sessions populate.
    time.sleep(75)
    NUDGES_MD.parent.mkdir(parents=True, exist_ok=True)
    while not _stop_event.is_set():
        try:
            agg = {
                "kanban": _collect_kanban_state(),
                "recent_sessions": _collect_recent_sessions(),
                "scratch": _collect_scratch(),
                "launch_failures": _collect_launch_failures(),
            }
            with _state_lock:
                cls = (_state.get("classify") or {})
            if cls.get("summary"):
                agg["recent_log_summary"] = cls["summary"][:300]
            # Compose the user message: terse JSON dump of the aggregate.
            user_msg = (
                "Aggregate MiOS state (last ~30 min):\n\n"
                f"```json\n{json.dumps(agg, indent=2, default=str)[:6000]}\n```\n"
                "\nProduce the nudges JSON now."
            )
            parsed = _openai_compat_llm_json(
                TASK_SYSTEM, user_msg,
                timeout=int(REQUEST_TIMEOUT_S),
            )
            if not parsed:
                parsed = {"nudges": [], "digest": "(nudger LLM unreachable)"}
            # Atomic write of both the markdown digest + structured JSON
            md = _render_nudges_md(parsed)
            for target, content in ((NUDGES_MD, md),
                                    (NUDGES_JSON, json.dumps(parsed, indent=2))):
                tmp = target.with_suffix(target.suffix + ".tmp")
                tmp.write_text(content, encoding="utf-8")
                os.chmod(tmp, 0o644)
                tmp.replace(target)
            _update_state("nudges", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "count": len(parsed.get("nudges") or []),
                "digest_preview": (parsed.get("digest") or "")[:160],
                "sources": {
                    "kanban": len(agg["kanban"]),
                    "sessions": len(agg["recent_sessions"]),
                    "scratch": len(agg["scratch"]),
                    "launch_failures": len(agg["launch_failures"]),
                },
            })
            # Best-effort SurrealDB sync: kanban_shadow (UPSERT per
            # hermes_task_id), scratch (the digest itself), and a
            # per-tick event row. fail-quiet via _db_post backoff.
            for k in agg["kanban"]:
                _tid = str(k.get("id") or "").strip()
                if not _tid:
                    continue
                _row = {
                    "hermes_task_id": _tid,
                    "title": str(k.get("title") or "")[:240],
                    "status": str(k.get("status") or "unknown")[:40],
                    "priority": str(k.get("priority") or "") or None,
                    "tags": (k.get("tags").split(",")
                             if isinstance(k.get("tags"), str) else []),
                }
                # UPSERT pattern: DELETE-then-CREATE keyed on the unique
                # hermes_task_id index defined in schema-init.surql.
                _db_post(
                    "DELETE kanban_shadow WHERE hermes_task_id = "
                    f"{json.dumps(_tid)}; "
                    + _db_create("kanban_shadow", _row,
                                 now_fields=("synced_at",))
                )
            # Scratch row carrying the digest text (so other agents can
            # see what the nudger concluded without re-parsing the .md).
            _digest = (parsed.get("digest") or "").strip()
            if _digest:
                _db_post(_db_create("scratch", {
                    "source": "mios-daemon",
                    "topic": "nudges",
                    "body": _digest[:4000],
                }, now_fields=("ts",)))
            # Per-tick event row -- audit trail of when the nudger ran.
            _db_post(_db_create("event", {
                "source": "mios-daemon",
                "kind": "nudge",
                "severity": "warn" if (parsed.get("nudges") or []) else "info",
                "summary": (
                    f"nudges={len(parsed.get('nudges') or [])} "
                    f"kanban={len(agg['kanban'])} "
                    f"sessions={len(agg['recent_sessions'])}"
                ),
                "payload": {
                    "sources": {
                        "kanban": len(agg["kanban"]),
                        "sessions": len(agg["recent_sessions"]),
                        "scratch": len(agg["scratch"]),
                        "launch_failures": len(agg["launch_failures"]),
                    },
                },
            }, now_fields=("ts",)))
        except Exception as e:
            log.warning("task_collector: %s: %s", type(e).__name__, e)
        for _ in range(int(TASK_COLLECT_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


def suggestions_loop() -> None:
    # Boot delay so OWUI + ollama warm before first generation
    time.sleep(45)
    while not _stop_event.is_set():
        try:
            recent = _recent_owui_user_messages()
            classify_summary = ""
            with _state_lock:
                cls = (_state.get("classify") or {})
            if cls.get("summary"):
                classify_summary = f"Recent log summary: {cls['summary'][:200]}."

            locale_hint = " | ".join(recent) if recent else "(no recent chats)"
            user_prompt = (
                f"Generate {SUGG_COUNT} short prompts (3 to 12 words each) "
                "the operator could click to start a useful turn. Mix "
                "categories: launch/open, find/search, install, status, "
                "kanban, research, configure. "
                f"{classify_summary} "
                f"Locale + recent context: {locale_hint}. "
                "\n\nOutput JSON ONLY: {\"suggestions\":[\"...\", ...]}"
            )
            content = llm_chat(SUGG_SYSTEM, user_prompt,
                               max_tokens=400, want_json=True)
            m = re.search(r"\{[\s\S]*\}", content) if content else None
            cards: list[dict] = []
            if m:
                try:
                    parsed = json.loads(m.group(0))
                    for s in (parsed.get("suggestions") or [])[:SUGG_COUNT]:
                        if not isinstance(s, str): continue
                        s = s.strip()[:160]
                        if s: cards.append({"title": [s, ""], "content": s})
                except json.JSONDecodeError:
                    pass

            if cards and SUGG_OWUI_DB.is_file():
                import sqlite3
                c = sqlite3.connect(str(SUGG_OWUI_DB))
                row = c.execute(
                    "SELECT data FROM config WHERE id=1").fetchone()
                if row is not None:
                    try:
                        cfg = json.loads(row[0])
                    except json.JSONDecodeError:
                        cfg = {}
                    cfg.setdefault("ui", {})["prompt_suggestions"] = cards
                    c.execute(
                        "UPDATE config SET data=?, updated_at=? WHERE id=1",
                        (json.dumps(cfg),
                         datetime.datetime.utcnow().isoformat()))
                    c.commit()
                    log.info("suggestions: wrote %d LLM cards "
                             "(classify-summary=%s, recent-msgs=%d)",
                             len(cards),
                             "yes" if classify_summary else "no",
                             len(recent))
            _update_state("suggestions", {
                "ts": datetime.datetime.now().isoformat(timespec="seconds"),
                "count": len(cards),
                "preview": [c["content"][:60] for c in cards[:3]],
                "used_classify": bool(classify_summary),
                "used_recent_chats": len(recent),
            })
        except Exception as e:
            log.warning("suggestions: %s: %s", type(e).__name__, e)
        # Interruptible sleep
        for _ in range(int(SUGG_TICK_S)):
            if _stop_event.is_set(): return
            time.sleep(1)


# ── Main ─────────────────────────────────────────────────────────────
def _on_signal(signum, _frame):
    log.info("signal %s -- stopping", signum)
    _stop_event.set()


# ── Satisfaction monitor (Phase E.1 -- daemon-side goal tracking) ───
# Operator directive 2026-05-18: "mios-daemon/agent should be
# monitoring successes and stopping work if ALL criteria is met and
# goals set are completed/tasks/user queries are satisfied".
#
# Polls SurrealDB.event for kind=refine rows (each user query goes
# through agent-pipe's refine pass which writes one of these). For
# every refine that doesn't yet have a corresponding satisfaction
# verdict, AND-fold the post-refine tool_call.success values from
# the same session. Emit:
#
#   event kind=user_query_satisfied   severity=info
#     payload={refine_id, intended_outcome, tool_calls_checked,
#              all_succeeded: true}
#
#   event kind=user_query_unsatisfied severity=warn
#     payload={refine_id, intended_outcome, tool_calls_checked,
#              failed_tools: [...], stderr_preview: ...}
#
# agent-pipe + Hermes can SUBSCRIBE to these (poll the event table
# or pick up via the Phase A.2 inotify event bus) and halt-on-
# satisfied OR surface-failure-explicitly. The audit row also lets
# the operator query post-hoc: "show me all unsatisfied goals from
# the last day".
SATISFACTION_TICK_S = float(os.environ.get(
    "MIOS_DAEMON_SATISFACTION_TICK_S", "30"))
SATISFACTION_LOOKBACK_MIN = int(os.environ.get(
    "MIOS_DAEMON_SATISFACTION_LOOKBACK_MIN", "10"))


def _ok_result(db_response) -> list:
    """Extract the result rows from a _db_post response, returning
    [] when the response is None / errored / status != OK / result is
    not a list. Defensive: SurrealDB returns the error string in the
    `result` field when status=ERR, which would crash iteration
    expecting dicts."""
    if not db_response:
        return []
    last = db_response[-1] or {}
    if last.get("status") != "OK":
        return []
    rows = last.get("result")
    return rows if isinstance(rows, list) else []


def _scan_unverified_refines(lookback_min: int) -> list[dict]:
    """Pull refine events that haven't yet been satisfaction-checked.
    Returns oldest-first so the loop processes a fresh deploy in
    chronological order."""
    sql = (
        f"SELECT id, ts, payload FROM event "
        f"WHERE kind = 'refine' "
        f"  AND ts > time::now() - {int(lookback_min)}m "
        f"ORDER BY ts ASC LIMIT 50;"
    )
    refines = _ok_result(_db_post(sql))
    # Filter out refines that already have a satisfaction event
    # referencing their id. SurrealDB doesn't have a JOIN; do it in
    # a second query against the recent satisfaction events.
    sat_sql = (
        f"SELECT payload FROM event "
        f"WHERE kind IN ['user_query_satisfied','user_query_unsatisfied'] "
        f"  AND ts > time::now() - {int(lookback_min)}m "
        f"LIMIT 200;"
    )
    seen_refine_ids: set = set()
    for sr in _ok_result(_db_post(sat_sql)):
        if not isinstance(sr, dict):
            continue
        rid = ((sr.get("payload") or {}).get("refine_id"))
        if rid:
            seen_refine_ids.add(str(rid))
    return [
        r for r in refines
        if isinstance(r, dict)
        and str(r.get("id")) not in seen_refine_ids
    ]


def _tool_calls_for_refine(refine_ts: str,
                           lookback_after_min: int = 5) -> list[dict]:
    """Pull tool_call rows that landed AFTER a refine event in the
    same session. The refine event's payload doesn't directly link
    to a session_id (refine runs on the prompt, session is opened
    separately), so we fall back to a ts-window match: tool_calls
    within `lookback_after_min` minutes after the refine.
    Best-effort -- if the linkage misses, the satisfaction verdict
    is "no_tools_seen" rather than wrong."""
    sql = (
        f"SELECT id, ts, tool, args, success, exit_code, "
        f"result_preview FROM tool_call "
        f"WHERE ts > '{refine_ts}' "
        f"  AND ts < '{refine_ts}' + {int(lookback_after_min)}m "
        f"ORDER BY ts ASC LIMIT 20;"
    )
    return [r for r in _ok_result(_db_post(sql)) if isinstance(r, dict)]


def _verb_post_check(tool: str, args: dict) -> dict:
    """Per-verb visible-outcome verification beyond tool_call.success.
    Operator-flagged 2026-05-18: mios-open-url returned exit 0 from
    the broker but Epiphany's window never appeared (sandbox died at
    credential bootstrap AFTER the broker had already collected its
    exit code). Raw success column alone misses these cases; this
    helper cross-checks the OS-side reality.

    Returns dict {checked: <bool>, passed: <bool>, signal: <name>,
    detail?: <str>}. checked=False means we have no post-check for
    this verb -- caller uses tool_call.success alone."""
    import subprocess
    if tool in ("open_app", "open_url", "focus_window", "launch_app"):
        # Window-visible check. Pattern derived from the verb's
        # most-likely-titled arg.
        pat = ""
        for key in ("name", "title", "url"):
            v = (args or {}).get(key)
            if v:
                pat = str(v); break
        if not pat:
            return {"checked": False}
        # Take the last URL path segment OR the bare name; mios-window-
        # active accepts a comma-separated pattern list.
        if pat.startswith(("http://", "https://", "file://")):
            try:
                from urllib.parse import urlparse
                pat = urlparse(pat).netloc or pat
            except Exception:
                pass
        pat = pat.split("/")[-1].split(".")[0]
        try:
            r = subprocess.run(
                ["mios-window-active", pat],
                capture_output=True, text=True, timeout=4,
            )
            out = r.stdout.strip()
            if out:
                try:
                    j = json.loads(out)
                    presented = bool(j.get("presented_to_operator")
                                    or j.get("window_visible"))
                    return {"checked": True, "passed": presented,
                            "signal": "window_visible",
                            "detail": j.get("summary", "")}
                except json.JSONDecodeError:
                    pass
            return {"checked": True, "passed": False,
                    "signal": "window_visible",
                    "detail": "no_window_for_pattern:" + pat[:60]}
        except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
            return {"checked": False}
    if tool == "text_create":
        path = (args or {}).get("path")
        if not path:
            return {"checked": False}
        exists = os.path.exists(str(path))
        return {"checked": True, "passed": exists,
                "signal": "file_exists",
                "detail": str(path)}
    if tool == "text_str_replace":
        path = (args or {}).get("path")
        if not path:
            return {"checked": False}
        exists = os.path.exists(str(path)) and os.path.getsize(str(path)) > 0
        return {"checked": True, "passed": exists,
                "signal": "file_nonempty",
                "detail": str(path)}
    if tool == "flatpak_install":
        ident = (args or {}).get("id")
        if not ident:
            return {"checked": False}
        try:
            r = subprocess.run(
                ["flatpak", "info", str(ident)],
                capture_output=True, text=True, timeout=4,
            )
            return {"checked": True, "passed": r.returncode == 0,
                    "signal": "flatpak_installed",
                    "detail": str(ident)}
        except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
            return {"checked": False}
    return {"checked": False}


def _emit_satisfaction(refine_row: dict, tool_calls: list[dict]) -> str:
    """AND-fold tool_call outcomes + per-verb visible-outcome checks
    against the refined plan + emit the satisfaction event. Returns
    the emitted kind so the caller can log the verdict count."""
    refine_id = refine_row.get("id")
    payload = refine_row.get("payload") or {}
    intended = payload.get("intended_outcome", "") or ""
    intent = payload.get("intent", "") or ""

    # No tools after refine: can't AND-fold. For intent=chat this is
    # EXPECTED (no tool dispatch needed); for intent=agent/dispatch
    # it's a missing-signal case.
    if not tool_calls:
        if intent == "chat":
            kind = "user_query_satisfied"
            severity = "info"
            extra = {"reason": "chat_no_tools_expected"}
        else:
            kind = "user_query_unsatisfied"
            severity = "warn"
            extra = {"reason": "no_tools_seen",
                     "lookback_min": SATISFACTION_LOOKBACK_MIN}
    else:
        failed: list[dict] = []
        post_check_results: list[dict] = []
        for tc in tool_calls:
            tool = tc.get("tool", "")
            args = tc.get("args") or {}
            tool_ok = bool(tc.get("success"))
            check = _verb_post_check(tool, args)
            # Per-verb check overrides bare tool_call.success when it
            # ran -- the visible-outcome signal is more authoritative
            # than the broker's exit code (which can be 0 even when
            # the launch sandbox died after the broker collected it).
            if check.get("checked"):
                visible_ok = check.get("passed", False)
                post_check_results.append({
                    "tool": tool,
                    "signal": check.get("signal"),
                    "passed": visible_ok,
                    "detail": (check.get("detail") or "")[:120],
                })
                if not (tool_ok and visible_ok):
                    failed.append({
                        "tool": tool,
                        "exit_code": tc.get("exit_code"),
                        "visible": visible_ok,
                        "stderr_preview": (tc.get("result_preview") or "")[:200],
                    })
            else:
                # No verb-specific check; fall back to bare success.
                if not tool_ok:
                    failed.append({
                        "tool": tool,
                        "exit_code": tc.get("exit_code"),
                        "stderr_preview": (tc.get("result_preview") or "")[:200],
                    })

        if not failed:
            kind = "user_query_satisfied"
            severity = "info"
            extra = {"tools_checked": len(tool_calls),
                     "post_checks": post_check_results,
                     "all_succeeded": True}
        else:
            kind = "user_query_unsatisfied"
            severity = "warn"
            extra = {"tools_checked": len(tool_calls),
                     "post_checks": post_check_results,
                     "failed_tools": failed}

    body = {
        "refine_id": str(refine_id) if refine_id else None,
        "refine_intent": intent,
        "intended_outcome": intended[:200],
        **extra,
    }
    _db_post(_db_create("event", {
        "source": "mios-daemon",
        "kind": kind,
        "severity": severity,
        "summary": f"{kind}: {intent} ({intended[:60]})",
        "payload": body,
    }, now_fields=("ts",)))
    return kind


def satisfaction_loop() -> None:
    """Tick the satisfaction monitor. Best-effort -- DB hiccups
    swallow + the next tick retries; no infinite-error loops."""
    time.sleep(45)  # boot delay; let agent-pipe + surrealdb settle
    while not _stop_event.is_set():
        try:
            unverified = _scan_unverified_refines(SATISFACTION_LOOKBACK_MIN)
            sat = unsat = 0
            for refine in unverified:
                ts = refine.get("ts")
                if not ts:
                    continue
                tool_calls = _tool_calls_for_refine(ts)
                kind = _emit_satisfaction(refine, tool_calls)
                if kind == "user_query_satisfied":
                    sat += 1
                else:
                    unsat += 1
            if sat or unsat:
                log.info("satisfaction: %d satisfied, %d unsatisfied",
                         sat, unsat)
            _update_state("satisfaction", {
                "last_tick": datetime.datetime.now().isoformat(timespec="seconds"),
                "satisfied": sat,
                "unsatisfied": unsat,
            })
        except Exception as e:
            log.warning("satisfaction_loop error: %s", e)
        _stop_event.wait(SATISFACTION_TICK_S)


def main() -> int:
    signal.signal(signal.SIGINT, _on_signal)
    signal.signal(signal.SIGTERM, _on_signal)
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(STATE_DIR, 0o755)
    _atomic_write_state()

    log.info("starting: model=%s endpoint=%s state=%s",
             MODEL, ENDPOINT, STATE_FILE)
    log.info("watching units: %s", ",".join(WATCHED_UNITS))
    log.info("refusal patterns loaded: %d", len(_refusal_res))

    threads = [
        threading.Thread(target=journal_subscriber, daemon=True, name="journal"),
        threading.Thread(target=classify_loop, daemon=True, name="classify"),
        threading.Thread(target=refusal_loop, daemon=True, name="refusal"),
        threading.Thread(target=cron_loop, daemon=True, name="cron"),
        threading.Thread(target=suggestions_loop, daemon=True, name="suggestions"),
        threading.Thread(target=launch_verifier_loop, daemon=True, name="launch_verifier"),
        threading.Thread(target=task_collector_loop, daemon=True, name="task_collector"),
        threading.Thread(target=fs_watcher_loop, daemon=True, name="fs_watcher"),
        threading.Thread(target=satisfaction_loop, daemon=True, name="satisfaction"),
    ]
    for t in threads:
        t.start()
    while not _stop_event.is_set():
        time.sleep(2)
    log.info("stopped")
    return 0


if __name__ == "__main__":
    sys.exit(main())
