# ── W0-T2 runaway controls (config-read from mios.toml [daemon]) ─────
# The daemon is ALWAYS-ON and fires LLM calls + cron actions on cadence;
# under host pressure (the 2026-06-XX GPU-runaway root cause) those calls
# pile onto an already-saturated box and make the runaway worse. These
# four controls bound that:
#   1. _host_pressure_gate -> SKIP a tick (no LLM) when load/GPU-util high
#   2. classify fingerprint dedup -> collapse identical high-sev spam
#   3. cron concurrency cap -> never re-fire while a prior Popen is alive
#   4. quiescence backoff -> widen classify cadence when nothing notable
# ALL knobs flow from mios.toml [daemon] (env still wins) with SAFE
# defaults so behavior is UNCHANGED until the operator tunes/enables them.
# pressure_skip defaults FALSE = degrade-open (gate observes but never
# skips until enabled); dedup + cron-cap are safe to default ON.
def _read_daemon_config() -> dict:
    """Read top-level [daemon] scalar keys from the layered mios.toml
    (vendor < /etc < per-user; later layer wins). Mirrors
    _read_daemon_index_config's layering. Returns {} when unreadable so
    every consumer falls back to its compiled-in default (degrade-open)."""
    try:
        try:
            import tomllib
        except ImportError:
            import tomli as tomllib  # type: ignore
    except ImportError:
        return {}
    merged: dict = {}
    for p in (os.environ.get("MIOS_TOML", "/usr/share/mios/mios.toml"),
              "/etc/mios/mios.toml",
              f"/var/home/{os.environ.get('MIOS_USER', 'mios')}"
              "/.config/mios/mios.toml"):
        try:
            with open(p, "rb") as f:
                d = tomllib.load(f)
        except FileNotFoundError:
            continue
        except Exception:  # noqa: BLE001 -- malformed layer: skip it
            continue
        sect = (d.get("daemon") or {})
        for k, v in sect.items():
            # Only adopt SCALAR keys here -- nested tables ([daemon.index],
            # [daemon.roots], ...) are owned by their own readers.
            if not isinstance(v, dict) and not isinstance(v, list):
                merged[k] = v
    return merged


_DAEMON_CFG = _read_daemon_config()


def _cfg_num(env_key: str, toml_key: str, default: float) -> float:
    """Resolve a numeric knob: env wins, then mios.toml [daemon], then the
    compiled default. Never raises -- a bad value falls back to default."""
    raw = os.environ.get(env_key)
    if raw is None:
        raw = _DAEMON_CFG.get(toml_key)
    try:
        return float(raw) if raw is not None else float(default)
    except (TypeError, ValueError):
        return float(default)


def _cfg_bool(env_key: str, toml_key: str, default: bool) -> bool:
    """Resolve a boolean knob: env ("1/true/yes/on") wins, then mios.toml
    [daemon], then the compiled default. Never raises."""
    raw = os.environ.get(env_key)
    if raw is not None:
        return raw.strip().lower() in ("1", "true", "yes", "on")
    val = _DAEMON_CFG.get(toml_key, default)
    if isinstance(val, bool):
        return val
    return str(val).strip().lower() in ("1", "true", "yes", "on")


