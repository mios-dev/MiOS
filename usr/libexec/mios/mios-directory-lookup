#!/usr/bin/env python3
"""mios-directory-lookup -- query the cached directory map that
mios-daemon's index_loop maintains in SurrealDB.

Operator directive: "mios-daemon should be indexing directories for
directory maps for llms cache/lut/DB/etc for faster navigation/
recall!!". This shim is the read-side of that index. Sub-100ms
lookups (DB query) vs the 60ms+ live mios-find / fs_search.

USAGE
  mios-directory-lookup <query> [--root <label>] [--ext <.md>]
                                [--kind <file|dir>]
                                [--limit N] [--json]

OUTPUT
  Default: human-readable list of ranked hits.
  --json:  {ok, query, hits: [{path, kind, size, mtime, summary,
                              root_label, score}, ...]}
"""
from __future__ import annotations

import argparse
import base64
import json
import os
import sys
import urllib.error
import urllib.request

SURREAL_URL = os.environ.get("MIOS_DB_URL", "http://localhost:8000")
# Creds from the MIOS_DB_* SSOT (same as agent-pipe / mios-daemon / mios-sys-env)
# -- was a hardcoded `Basic cm9vdDpyb290` (root:root) which broke on any host
# that rotated the SurrealDB password. Operator: no hardcodes.
_DB_USER = os.environ.get("MIOS_DB_USER", "root")
_DB_PASS = os.environ.get("MIOS_DB_PASS", "root")
_DB_AUTH = "Basic " + base64.b64encode(f"{_DB_USER}:{_DB_PASS}".encode()).decode()
DEFAULT_LIMIT = int(os.environ.get(
    "MIOS_DIRECTORY_LOOKUP_LIMIT", "20"))
# Per-hit summary cap + a hard envelope cap so the --json output ALWAYS stays
# parseable under the dispatch broker's ~6 KB stdout truncation (a larger blob
# would be cut mid-string -> invalid JSON for the calling agent).
SUMMARY_CHARS = int(os.environ.get("MIOS_DIRECTORY_LOOKUP_SUMMARY_CHARS", "100"))
OUT_CAP = int(os.environ.get("MIOS_DIRECTORY_LOOKUP_OUT_CAP", "5800"))


def _trim_hit(h: dict) -> dict:
    """Bounded per-hit shape for the --json envelope (drops the redundant
    `parent` -- path implies it -- and caps the content summary)."""
    return {
        "path": h.get("path"),
        "basename": h.get("basename"),
        "kind": h.get("kind"),
        "size": h.get("size"),
        "ext": h.get("ext"),
        "root_label": h.get("root_label"),
        "summary": (h.get("summary") or "").strip()[:SUMMARY_CHARS],
    }


def _sql(query: str) -> list:
    # PREFIX `USE NS mios DB agent;` -- the NS:/DB: HTTP headers
    # aren't honored on this SurrealDB version (returns
    # "NamespaceEmpty: Specify a namespace to use"). Matches the
    # agent-pipe + mios-daemon pattern.
    body = f"USE NS mios DB agent; {query}".encode("utf-8")
    req = urllib.request.Request(
        f"{SURREAL_URL}/sql",
        data=body,
        headers={
            "Authorization": _DB_AUTH,  # MIOS_DB_* SSOT, not hardcoded
            "Accept": "application/json",
            "Content-Type": "text/plain",
        },
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=10) as r:
        # First statement is USE; results start at index 1.
        full = json.loads(r.read().decode("utf-8", errors="replace"))
        return full[1:] if isinstance(full, list) and len(full) > 1 else full


def _q(s: str) -> str:
    """SurrealDB string-literal escape -- backslash + double-quote."""
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


_DB_BACKEND = os.environ.get("MIOS_DB_BACKEND", "dual").strip().lower()
_PG_TRY = _DB_BACKEND in ("dual", "postgres")
_PG_PRIMARY = _DB_BACKEND == "postgres"


def _pg_lookup(ql: str, root: str, ext: str, kind: str,
               limit: int) -> "list | None":
    """R15: directory lookup against pgvector via `mios-db --pg --json`.
    Returns the rows list, or None when pg is unreachable so the caller can
    fall back to SurrealDB (dual mode). strpos() substring match mirrors the
    SurrealDB CONTAINS query; ranking happens in the shared pass below."""
    import subprocess

    def _e(s: str) -> str:
        return str(s).replace("'", "''")
    conds = [f"(strpos(lower(basename), '{_e(ql)}') > 0 "
             f"OR strpos(lower(path), '{_e(ql)}') > 0)"]
    if root:
        conds.append(f"root_label = '{_e(root)}'")
    if ext:
        e = ext if ext.startswith(".") else "." + ext
        conds.append(f"ext = '{_e(e.lower())}'")
    if kind:
        conds.append(f"kind = '{_e(kind)}'")
    sql = ("SELECT COALESCE(json_agg(row_to_json(t)), '[]') FROM ("
           "SELECT path, parent, basename, kind, size, mtime, ext, summary, "
           "root_label FROM directory_entry WHERE " + " AND ".join(conds)
           + f" LIMIT {int(limit) * 3}) t;")
    try:
        p = subprocess.run(
            ["/usr/libexec/mios/mios-db", "--pg", sql, "--json"],
            capture_output=True, text=True, timeout=10)
        if p.returncode != 0:
            if os.environ.get("MIOS_LOOKUP_DEBUG"):
                sys.stderr.write(
                    f"pg lookup rc={p.returncode}: {p.stderr[:200]}\n")
            return None
        out = (p.stdout or "").strip()
        return json.loads(out) if out else []
    except Exception as e:
        if os.environ.get("MIOS_LOOKUP_DEBUG"):
            sys.stderr.write(f"pg lookup error: {e}\n")
        return None


def lookup(query: str, root: str, ext: str, kind: str,
           limit: int) -> list[dict]:
    """Compose a WHERE clause from the filters + return ranked hits.
    Ranking heuristic: basename exact == > basename starts-with >
    basename contains > summary contains > parent contains."""
    q = (query or "").strip()
    if not q:
        return []
    ql = q.lower()
    conds = []
    # Basename / path substring (case-insensitive via SurrealDB's
    # string::lowercase + CONTAINS). The `~` operator was 2.x; 3.x
    # requires CONTAINS. Summary field NOT included in the WHERE
    # clause -- nullable-field comparison was rejected by SurrealDB
    # 3.x even with IS NOT NONE guard; the rank pass below uses
    # summary content when present, so summary-matches still bubble
    # up via path/basename indirect hits.
    conds.append(
        f"(string::lowercase(basename) CONTAINS {_q(ql)} "
        f"OR string::lowercase(path) CONTAINS {_q(ql)})"
    )
    if root:
        conds.append(f"root_label = {_q(root)}")
    if ext:
        if not ext.startswith("."):
            ext = "." + ext
        conds.append(f"ext = {_q(ext.lower())}")
    if kind:
        conds.append(f"kind = {_q(kind)}")
    where = " AND ".join(conds)
    rows = None
    # R15: prefer pgvector when the plane is on Postgres (dual/postgres). In
    # dual mode a pg miss falls back to SurrealDB; once MIOS_DB_BACKEND=postgres
    # pg is authoritative (no fallback to a retired surreal). Mirrors the
    # agent-pipe _db_read cutover seam.
    if _PG_TRY:
        rows = _pg_lookup(ql, root, ext, kind, limit)
        if rows is None and _PG_PRIMARY:
            rows = []
    if rows is None:
        sql = (
            f"SELECT path, parent, basename, kind, size, mtime, "
            f"ext, summary, root_label "
            f"FROM directory_entry WHERE {where} "
            f"LIMIT {int(limit) * 3};"
        )
        if os.environ.get("MIOS_LOOKUP_DEBUG"):
            sys.stderr.write(f"DEBUG SQL: {sql}\n")
        try:
            r = _sql(sql)
            if os.environ.get("MIOS_LOOKUP_DEBUG"):
                sys.stderr.write(f"DEBUG RESP: {json.dumps(r)[:600]}\n")
        except urllib.error.HTTPError as e:
            sys.stderr.write(
                f"SurrealDB HTTP {e.code}: "
                f"{e.read().decode('utf-8', errors='replace')[:200]}\n")
            return []
        except Exception as e:
            sys.stderr.write(f"SurrealDB error: {e}\n")
            return []
        rows = (r[-1] or {}).get("result") or [] if isinstance(r, list) else []
    if not isinstance(rows, list):
        return []
    # Rank in-process: we pulled 3x the requested limit so the
    # rank pass can prune.
    def _score(e: dict) -> float:
        bn = (e.get("basename") or "").lower()
        s = 0.0
        if bn == ql:
            s += 100
        elif bn.startswith(ql):
            s += 50
        elif ql in bn:
            s += 20
        # Bonus for filename containing the query as a whole word.
        if f" {ql} " in f" {bn} ":
            s += 10
        # Penalise deep paths slightly so top-of-tree wins ties.
        s -= (e.get("path") or "").count("/") * 0.1
        return -s   # negative -- higher score sorts first
    rows.sort(key=_score)
    return rows[:int(limit)]


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-directory-lookup")
    p.add_argument("query", help="Substring (case-insensitive).")
    p.add_argument("--root", default="", help="Filter to one root label.")
    p.add_argument("--ext", default="",
                   help="File-extension filter (.md, .toml, ...).")
    p.add_argument("--kind", default="",
                   choices=["", "file", "dir", "symlink"],
                   help="Filter by entry kind.")
    p.add_argument("--limit", type=int, default=DEFAULT_LIMIT)
    p.add_argument("--json", action="store_true")
    args = p.parse_args()

    hits = lookup(args.query, args.root, args.ext, args.kind, args.limit)
    if args.json:
        env = {
            "ok": True,
            "query": args.query,
            "filters": {
                "root": args.root,
                "ext": args.ext,
                "kind": args.kind,
            },
            "hits": [_trim_hit(h) for h in hits],
        }
        # Hard envelope guard: drop lowest-ranked hits until under the cap so
        # the agent always receives COMPLETE, parseable JSON (top hits kept).
        s = json.dumps(env)
        while len(s) > OUT_CAP and env["hits"]:
            env["hits"].pop()
            env["truncated"] = True
            s = json.dumps(env)
        print(s)
        return 0
    print(f"query: {args.query!r}  hits: {len(hits)}")
    for i, h in enumerate(hits, 1):
        kind = h.get("kind") or "?"
        size = h.get("size") or 0
        path = h.get("path") or "?"
        summary = (h.get("summary") or "").strip()[:100]
        print(f"  {i:>2}. [{kind:5s} {size:>10}] {path}")
        if summary:
            print(f"        {summary}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
