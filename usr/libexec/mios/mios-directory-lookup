#!/usr/bin/env python3
# AI-hint: Provides high-speed (<100ms) retrieval of the pgvector-cached directory map (parameterized pg via mios-db --pg-json) to allow agents to perform rapid file/directory lookups and navigation instead of slow filesystem crawls.
# AI-related: /usr/libexec/mios/mios-db, mios-db, mios-daemon, mios-find, mios-sys-env, mios-pg-query
"""mios-directory-lookup -- query the cached directory map that
mios-daemon's index_loop maintains in PostgreSQL/pgvector.

Operator directive: "mios-daemon should be indexing directories for
directory maps for llms cache/lut/DB/etc for faster navigation/
recall!!". This shim is the read-side of that index. Sub-100ms
lookups (DB query) vs the 60ms+ live mios-find / fs_search.

The query is parameterized end-to-end: every external value (the
search substring + the --root / --ext / --kind filters) is bound
out-of-band via `mios-db --pg-json` ($1..$n through the pg v3 extended
protocol), never spliced into the SQL text. Only the integer LIMIT is
inlined (int()-coerced).

USAGE
  mios-directory-lookup <query> [--root <label>] [--ext <.md>]
                                [--kind <file|dir>]
                                [--limit N] [--json]

OUTPUT
  Default: human-readable list of ranked hits.
  --json:  {ok, query, hits: [{path, kind, size, mtime, summary,
                              root_label, score}, ...]}
"""
from __future__ import annotations

import argparse
import json
import os
import sys

MIOS_DB = "/usr/libexec/mios/mios-db"
DEFAULT_LIMIT = int(os.environ.get(
    "MIOS_DIRECTORY_LOOKUP_LIMIT", "20"))
# Per-hit summary cap + a hard envelope cap so the --json output ALWAYS stays
# parseable under the dispatch broker's ~6 KB stdout truncation (a larger blob
# would be cut mid-string -> invalid JSON for the calling agent).
SUMMARY_CHARS = int(os.environ.get("MIOS_DIRECTORY_LOOKUP_SUMMARY_CHARS", "100"))
OUT_CAP = int(os.environ.get("MIOS_DIRECTORY_LOOKUP_OUT_CAP", "5800"))


def _trim_hit(h: dict) -> dict:
    """Bounded per-hit shape for the --json envelope (drops the redundant
    `parent` -- path implies it -- and caps the content summary)."""
    return {
        "path": h.get("path"),
        "basename": h.get("basename"),
        "kind": h.get("kind"),
        "size": h.get("size"),
        "ext": h.get("ext"),
        "root_label": h.get("root_label"),
        "summary": (h.get("summary") or "").strip()[:SUMMARY_CHARS],
    }


def _pg_lookup(ql: str, root: str, ext: str, kind: str,
               limit: int) -> "list | None":
    """Directory lookup against pgvector via the parameterized
    `mios-db --pg-json` envelope (pg v3 extended protocol -- values bound
    out-of-band as $1..$n, never spliced into the SQL text). Returns the
    rows list, or None when pg is unreachable so the caller degrades open
    (empty result, no crash). strpos() substring match; ranking happens in
    the shared pass below. Only the integer LIMIT is inlined (int-coerced --
    text->int inference is unreliable on the bound path)."""
    import subprocess

    params: list = [ql]
    conds = ["(strpos(lower(basename), $1) > 0 OR strpos(lower(path), $1) > 0)"]
    if root:
        params.append(root)
        conds.append(f"root_label = ${len(params)}")
    if ext:
        e = ext if ext.startswith(".") else "." + ext
        params.append(e.lower())
        conds.append(f"ext = ${len(params)}")
    if kind:
        params.append(kind)
        conds.append(f"kind = ${len(params)}")
    sql = ("SELECT COALESCE(json_agg(row_to_json(t)), '[]') FROM ("
           "SELECT path, parent, basename, kind, size, mtime, ext, summary, "
           "root_label FROM directory_entry WHERE " + " AND ".join(conds)
           + f" LIMIT {int(limit) * 3}) t;")
    try:
        p = subprocess.run(
            [MIOS_DB, "--pg-json"],
            input=json.dumps({"sql": sql, "params": params}),
            capture_output=True, text=True, timeout=15)
        if p.returncode != 0:
            if os.environ.get("MIOS_LOOKUP_DEBUG"):
                sys.stderr.write(
                    f"pg lookup rc={p.returncode}: {p.stderr[:200]}\n")
            return None
        out = (p.stdout or "").strip()
        return json.loads(out) if out else []
    except Exception as e:
        if os.environ.get("MIOS_LOOKUP_DEBUG"):
            sys.stderr.write(f"pg lookup error: {e}\n")
        return None


def lookup(query: str, root: str, ext: str, kind: str,
           limit: int) -> list[dict]:
    """Query the pgvector directory index + return ranked hits.
    Ranking heuristic: basename exact == > basename starts-with >
    basename contains > summary contains > parent contains.
    Degrades open: a pg miss/unreachable backend returns [] (no crash)."""
    q = (query or "").strip()
    if not q:
        return []
    ql = q.lower()
    # pgvector is the unconditional path (SurrealDB is retired). A None return
    # means the backend was unreachable -> degrade open to an empty result.
    rows = _pg_lookup(ql, root, ext, kind, limit)
    if not isinstance(rows, list):
        return []
    # Rank in-process: we pulled 3x the requested limit so the
    # rank pass can prune.
    def _score(e: dict) -> float:
        bn = (e.get("basename") or "").lower()
        s = 0.0
        if bn == ql:
            s += 100
        elif bn.startswith(ql):
            s += 50
        elif ql in bn:
            s += 20
        # Bonus for filename containing the query as a whole word.
        if f" {ql} " in f" {bn} ":
            s += 10
        # Penalise deep paths slightly so top-of-tree wins ties.
        s -= (e.get("path") or "").count("/") * 0.1
        return -s   # negative -- higher score sorts first
    rows.sort(key=_score)
    return rows[:int(limit)]


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-directory-lookup")
    p.add_argument("query", help="Substring (case-insensitive).")
    p.add_argument("--root", default="", help="Filter to one root label.")
    p.add_argument("--ext", default="",
                   help="File-extension filter (.md, .toml, ...).")
    p.add_argument("--kind", default="",
                   choices=["", "file", "dir", "symlink"],
                   help="Filter by entry kind.")
    p.add_argument("--limit", type=int, default=DEFAULT_LIMIT)
    p.add_argument("--json", action="store_true")
    args = p.parse_args()

    hits = lookup(args.query, args.root, args.ext, args.kind, args.limit)
    if args.json:
        env = {
            "ok": True,
            "query": args.query,
            "filters": {
                "root": args.root,
                "ext": args.ext,
                "kind": args.kind,
            },
            "hits": [_trim_hit(h) for h in hits],
        }
        # Hard envelope guard: drop lowest-ranked hits until under the cap so
        # the agent always receives COMPLETE, parseable JSON (top hits kept).
        s = json.dumps(env)
        while len(s) > OUT_CAP and env["hits"]:
            env["hits"].pop()
            env["truncated"] = True
            s = json.dumps(env)
        print(s)
        return 0
    print(f"query: {args.query!r}  hits: {len(hits)}")
    for i, h in enumerate(hits, 1):
        kind = h.get("kind") or "?"
        size = h.get("size") or 0
        path = h.get("path") or "?"
        summary = (h.get("summary") or "").strip()[:100]
        print(f"  {i:>2}. [{kind:5s} {size:>10}] {path}")
        if summary:
            print(f"        {summary}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
