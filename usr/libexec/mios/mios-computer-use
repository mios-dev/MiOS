def _die(msg: str):
    print(json.dumps({"error": msg, "prog": PROG}), file=sys.stderr)
    raise SystemExit(1)


# ── main ──────────────────────────────────────────────────────────────────────
INPUT_ACTIONS = {"click", "double-click", "mouse-move", "type", "key", "key-combo"}
WINDOW_ACTIONS = {"window-list", "window-focus", "window-move", "window-resize"}


def main() -> int:
    ap = argparse.ArgumentParser(prog=PROG, add_help=False)
    ap.add_argument("subcommand", nargs="?", default="help")
    ap.add_argument("--json", action="store_true")
    ap.add_argument("rest", nargs=argparse.REMAINDER)
    ns = ap.parse_args()
    sub = ns.subcommand
    args = [a for a in ns.rest if a != "--json"]
    as_json = ns.json or ("--json" in ns.rest)

    if sub in ("help", "-h", "--help"):
        print(__doc__)
        return 0

    # 1. Federation: a configured + reachable executor wins (drive remote desktop).
    ep = _executor_endpoint()
    if ep:
        if _endpoint_up(ep):
            return _route_remote(ep, sub, args, as_json)
        _die(f"computer-use executor {ep} configured but unreachable (no blind local fallback)")

    # 2. Local Wayland desktop.
    if _have_wayland():
        if sub == "screenshot":
            return _capture(args[0] if args else _die("screenshot needs <out-path>"))
        if sub == "atspi-query":
            return _atspi_query(args[0] if args else _die("atspi-query needs a query"), as_json)
        if sub == "ground":
            return _ground(args[0] if args else _die("ground needs a query"), as_json)
        if sub in INPUT_ACTIONS:
            return _do_input(sub, args)
        if sub == "window-list":
            return _list_windows(as_json)
        if sub in WINDOW_ACTIONS:
            _die(f"{sub} not yet implemented for Wayland (compositor-specific; "
                 f"use window-list + focus via wmctrl/hyprctl)")
        _die(f"unknown subcommand: {sub}")

    # 3. WSL2 -> delegate to the Windows executor so one verb works everywhere.
    if _is_wsl():
        return _delegate_pc_control(sub, args, as_json)

    _die("no desktop backend: no WAYLAND_DISPLAY, no configured executor, not WSL2")
    return 1


if __name__ == "__main__":
    sys.exit(main())
