#!/usr/bin/env python3
# AI-hint: Provides a unified system inspection tool for agents to query journalctl, process lists, and podman containers by abstracting complex command construction and flag validation into a single interface.
# AI-related: mios-system-status, mios-podman-ps, mios-podman-ps.service
"""mios-sysview -- native system-inspection tool: the SSOT for the
journalctl / ps / podman command construction that agent-pipe's verbs used
to hardcode INLINE. Operator 2026-05-21: "no hardcodes ... should all be
native tools/skills/recipes ... unless baked in the modelfile or docs".

These ops build their command from TYPED, OPTIONAL args (conditional flags
-- e.g. `-u UNIT` only when a unit is given), which static [recipes.*]
templates can't express. So they live here as a helper TOOL (the same
pattern as mios-system-status), and agent-pipe's arms just delegate to it
-- the command literals are gone from the dispatch code.

Subcommands:
  logs   [--unit U] [--since S] [--lines N] [--level L]   journal (READ)
  proc   [--filter F] [--sort rss|cpu|pid] [--limit N]    processes (READ)
  containers [--name N]                                   podman ps (READ)
  container-restart --name N                              podman restart (WRITE)
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys

_LEVELS = ("emerg", "alert", "crit", "err", "warning", "notice", "info", "debug")
_SINCE_UNIT = {"s": "sec", "m": "min", "h": "hour", "d": "day"}


def _journal_since(s: str) -> str:
    """journalctl --since REJECTS a bare compact span like '10m' ("Failed to
    parse timestamp: 10m"), which is the verb's default. Translate
    <N><s|m|h|d> -> 'N <unit> ago' (a form journalctl accepts); pass anything
    else through untouched (ISO dates, 'yesterday', 'today', '-1h', 'N min
    ago'). The helper owns the journalctl interface, so the fix lives here."""
    s = (s or "").strip()
    m = re.fullmatch(r"(\d+)\s*([smhd])", s)
    if not m:
        return s
    return f"{m.group(1)} {_SINCE_UNIT[m.group(2)]} ago"


def _run(cmd: str) -> int:
    """Run a fully-built shell pipeline (every literal is constructed HERE,
    from validated/typed args -- no caller string reaches a shell unquoted)."""
    try:
        return subprocess.run(["bash", "-lc", cmd], text=True, timeout=30).returncode
    except (subprocess.TimeoutExpired, OSError) as e:
        sys.stderr.write(f"mios-sysview: {e}\n")
        return 1


def cmd_logs(a) -> int:
    parts = ["journalctl", "--no-pager", "-n", str(max(1, a.lines)),
             "--since", shlex.quote(_journal_since(a.since))]
    if a.unit.strip():
        parts += ["-u", shlex.quote(a.unit.strip())]
    if a.level.strip().lower() in _LEVELS:
        parts += ["-p", a.level.strip().lower()]
    return _run(" ".join(parts))


def cmd_proc(a) -> int:
    sort = {"cpu": "-pcpu", "pid": "-pid"}.get(a.sort.lower(), "-rss")
    base = f"ps -eo pid,user,rss,pcpu,comm,args --sort={sort} --no-headers"
    if a.filter.strip():
        base += f" | grep -i -- {shlex.quote(a.filter.strip())}"
    return _run(f"{base} | head -{max(1, a.limit)}")


_PODMAN_SNAPSHOT = os.environ.get(
    "MIOS_PODMAN_PS_SNAPSHOT", "/var/lib/mios/podman-ps.json")


def cmd_containers(a) -> int:
    name = a.name.strip()
    fmt = "{{.Names}}\\t{{.Status}}\\t{{.Image}}"
    try:
        out = subprocess.run(
            ["bash", "-lc", f"podman ps -a --format '{fmt}'"],
            capture_output=True, text=True, timeout=20).stdout
    except (subprocess.TimeoutExpired, OSError):
        out = ""
    lines = [ln for ln in out.splitlines() if ln.strip()]
    # Rootless fallback: a hardened / non-root caller can't see the ROOTFUL
    # containers (the dashboard hits the same wall -- /run/podman is 0700
    # root:root). mios-podman-ps.service writes a root `podman ps -a --format
    # json` snapshot for exactly this; read it so container_status is never
    # blind. Same SSOT the portal consumes.
    if not lines and os.path.exists(_PODMAN_SNAPSHOT):
        try:
            with open(_PODMAN_SNAPSHOT) as f:
                data = json.load(f)
            for c in (data if isinstance(data, list) else []):
                nm = c.get("Names")
                nm = ",".join(nm) if isinstance(nm, list) else (nm or "")
                status = c.get("Status") or c.get("State") or ""
                image = c.get("Image") or ""
                lines.append(f"{nm}\t{status}\t{image}")
        except Exception:
            pass
    if name:
        lines = [ln for ln in lines if name.lower() in ln.lower()]
    if lines:
        sys.stdout.write("\n".join(lines) + "\n")
    return 0


def cmd_container_restart(a) -> int:
    name = a.name.strip()
    if not name:
        sys.stderr.write("mios-sysview: container-restart needs --name\n")
        return 64
    q = shlex.quote(name)
    # Every MiOS container is a systemd Quadlet. A bare `podman restart` desyncs
    # the managing <name>.service (systemd still owns the OLD container object;
    # its next action can kill or duplicate the one podman just restarted). If
    # this name is Quadlet-managed, delegate to mios-restart (systemctl restart +
    # readiness poll); only an unmanaged ad-hoc container falls back to podman.
    unit = name if name.endswith(".service") else f"{name}.service"
    quadlet_managed = (
        subprocess.run(["systemctl", "cat", unit],
                       capture_output=True, text=True).returncode == 0
        or any(os.path.exists(os.path.join(d, f"{name}.container"))
               for d in ("/usr/share/containers/systemd",
                         "/etc/containers/systemd"))
    )
    if quadlet_managed:
        return _run(f"mios-restart {shlex.quote(name)}")
    return _run(f"podman restart {q} && podman ps --filter name={q}")


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-sysview")
    sub = p.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("logs")
    pl.add_argument("--unit", default="")
    pl.add_argument("--since", default="10m")
    pl.add_argument("--lines", type=int, default=50)
    pl.add_argument("--level", default="")
    pl.set_defaults(fn=cmd_logs)

    pp = sub.add_parser("proc")
    pp.add_argument("--filter", default="")
    pp.add_argument("--sort", default="rss")
    pp.add_argument("--limit", type=int, default=20)
    pp.set_defaults(fn=cmd_proc)

    pc = sub.add_parser("containers")
    pc.add_argument("--name", default="")
    pc.set_defaults(fn=cmd_containers)

    pr = sub.add_parser("container-restart")
    pr.add_argument("--name", default="")
    pr.set_defaults(fn=cmd_container_restart)

    a = p.parse_args()
    return a.fn(a)


if __name__ == "__main__":
    sys.exit(main())
