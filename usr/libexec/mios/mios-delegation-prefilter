#!/usr/bin/env python3
# AI-hint: HTTP proxy that intercepts Open WebUI requests on port 8641 to force-inject tool_choice requirements for delegate_task, ensuring deterministic fan-out of multi-part prompts to the Hermes-Agent gateway on port 8642.
# AI-related: mios-sys-agent, mios-hermes, mios-agent, mios-sys, mios-find, mios-delegation-prefilter.service
# AI-functions: main
"""mios-delegation-prefilter -- HTTP forwarder that sits between Open
WebUI and Hermes-Agent's /v1/chat/completions, force-routing fan-out
prompts through delegate_task instead of letting the model pick
serial terminal calls.

LISTEN  :8641   (the OpenAI-compat surface OWUI / external clients hit)
FORWARD :8642   (Hermes-Agent gateway)

The model has been demonstrating a strong serial-tool bias even with
the parallel-fanout skill loaded + delegation-default rules in
SOUL.md + the OWUI prompt. Skill nudges, prompt edits, model swap,
and a 92% prompt-bloat reduction all helped a little -- none of them
made the model bite. This prefilter takes a hammer to the choice: on
every user-initiated turn it injects `tool_choice={"type":
"function","function":{"name":"delegate_task"}}` into the request so
Hermes is REQUIRED to call delegate_task on the first turn. After
that, the model has committed to the delegation pattern and naturally
fans out the actual work into the tasks=[] array.

The ONE exception is a pure conversational turn (a greeting / ack /
smalltalk with no task surface): forcing delegate_task there yields a
zero-token reply (nothing to delegate, yet tool_choice=required blocks
a plain-text answer). Which turns those are is decided by the micro-LLM
chat-vs-act classifier the rest of MiOS uses -- NOT a greeting word
list or a length cutoff (those are English-only). Degrade-open: when
the micro lane is unreachable the prefilter force-delegates anyway (the
safe majority behaviour), never guessing chat from keywords.

Disable by stopping mios-delegation-prefilter.service and pointing
OWUI back at :8642. Hermes itself is unmodified.
"""
import json
import os
import re
import sys
import time
import logging
from pathlib import Path
from aiohttp import web, ClientSession, ClientTimeout

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
log = logging.getLogger("delegation-prefilter")

LISTEN_PORT  = int(os.environ.get("MIOS_PORT_PREFILTER", os.environ.get("MIOS_PREFILTER_LISTEN_PORT", "8641")))
HERMES_HOST  = os.environ.get("MIOS_PREFILTER_UPSTREAM", f"http://127.0.0.1:{os.environ.get('MIOS_PORT_HERMES', '8642')}")
HEADERS_DROP = {"host", "content-length"}

# ─── mios-sys-agent refinement layer (stage 2 of the consolidation) ───
# Operator directive 2026-05-16: "mios-sys-agent should dispatch to
# the current MiOS-Hermes with the tasks to delegate -- mios-sys-agent
# simply refines the prompt with the provided template key points to
# other MiOS-Agent(s) (mios-hermes can further delegate from there if
# need be)".
#
# Architecture: operator types in OWUI; OWUI POSTs to :8641 (this
# service); prefilter calls mios-sys-agent (Ollama on :11434) to
# refine the user's prompt via the reasoning template; refined
# prompt forwarded to hermes :8642; hermes does the actual work;
# response streams back.
# Default lane = mios-llm-light (:11450, OpenAI /v1); the old ollama :11434 is dead
# (WS-10 "EVERYTHING IS LLAMA.CPP"), so a missing env must NOT point at it (2026-06-18).
SYS_AGENT_ENDPOINT = os.environ.get("MIOS_SYS_AGENT_ENDPOINT", f"http://127.0.0.1:{os.environ.get('MIOS_PORT_LLM_LIGHT', '8450')}/v1")
SYS_AGENT_MODEL    = os.environ.get("MIOS_SYS_AGENT_MODEL", "granite4.1:8b")
# Refinement is OPT-IN via env var; default OFF so a hung sys-agent
# can't break the operator's chat. Operator enables once stage-2 is
# verified. Toggle: Environment=MIOS_PREFILTER_REFINE=1 in the unit
# drop-in.
REFINE_ENABLED     = os.environ.get("MIOS_PREFILTER_REFINE", "0") == "1"
REFINE_TIMEOUT_S   = float(os.environ.get("MIOS_PREFILTER_REFINE_TIMEOUT", "8"))

# What name should /v1/models report back? OWUI shows this in the
# model dropdown. Default to "MiOS-Agent" (operator-preferred
# friendly name 2026-05-16: "a friendly name 'MiOS-Agent' or 'MiOS
# AI'"). Underlying gateway is still hermes-agent.
DISPLAY_MODEL_NAME = os.environ.get("MIOS_PREFILTER_DISPLAY_MODEL", "MiOS-Agent")
# The prefilter accepts BOTH the friendly name + the historical
# "mios-sys-agent" as valid request model fields (all rewrite to
# "hermes-agent" upstream). Operators can rebind via env.
ACCEPTED_MODEL_NAMES = {DISPLAY_MODEL_NAME, "mios-sys-agent", "MiOS-Agent", "mios-agent"}

REFINE_SYSTEM = (
    # /nothink: qwen3.5-family directive that disables thinking-mode
    # generation. Without it, the model emits its entire chain-of-
    # thought to message.thinking and leaves message.content EMPTY
    # (operator-flagged 2026-05-17 reboot test: "refine: sys-agent
    # emitted empty content (reasoning='Thinking Process: ...')").
    # With /nothink the model writes directly to content -- exactly
    # what the prefilter forwards to hermes.
    "/nothink\n"
    "You are MiOS-Sys-Agent. The user types to you in OWUI; you provide "
    "FULL context to the downstream agent (hermes-agent) for "
    "execution. Produce a CONTEXTUALIZED HANDOFF that hermes-agent can "
    "act on directly. Skip the reasoning template entirely -- the "
    "output IS the answer. Format:\n"
    "\n"
    "USER REQUEST: <verbatim or lightly-cleaned user prompt>\n"
    "INTENT: <one sentence on what the user actually wants>\n"
    "CONSTRAINTS: <any format/tool/path constraints>\n"
    "MIOS CONTEXT: <pertinent helpers + state files + paths the agent "
    "should reach for>\n"
    "PLAN: <2-3 step plan hermes can execute>\n"
    "\n"
    "DO NOT include template HEADERS like '[1. INPUT ANALYSIS]' in "
    "the output. DO NOT add commentary OR pleasantries. DO NOT emit "
    "thinking traces. Output ONLY the labeled handoff."
)

# ─── chat-vs-act classification: SSOT config (layered mios.toml) ───
# The conversational-bypass decision is MODEL-DRIVEN (the micro-LLM the rest
# of MiOS uses), not a greeting word list. Mode + micro model/endpoint/timeout
# resolve from the layered mios.toml ([routing].prefilter_conversational_bypass_mode
# + [ai].micro_model / micro_endpoint), env-overridable for operator-tuned hosts.
sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib", "mios"))
import mios_toml  # noqa: E402  -- the ONE shared layered-mios.toml resolver


def _toml_layered(section: str, key: str):
    """Read a scalar [section].key from the layered mios.toml (per-user > host >
    vendor) via the shared real-TOML resolver. Replaces the former tolerant
    regex line-scanner, which disagreed with tomllib on quoting/precedence."""
    return mios_toml.get(section, key, None)


# Mode flag (flag-gated behaviour): "model" -> the micro-LLM classifies each turn;
# anything else disables the classifier (-> degrade-open force-delegate). Default
# "model" so the classifier runs when the micro lane is up.
BYPASS_MODE = (os.environ.get("MIOS_PREFILTER_BYPASS_MODE")
               or _toml_layered("routing", "prefilter_conversational_bypass_mode")
               or "model").strip().lower()
# Micro classifier model/endpoint -- the shared MiOS micro lane. Falls back to the
# sys-agent constants (themselves env/SSOT-derived) when no [ai] micro key is set.
MICRO_MODEL = (os.environ.get("MIOS_MICRO_MODEL")
               or _toml_layered("ai", "micro_model")
               or _toml_layered("ai.host_thresholds", "micro_model")
               or SYS_AGENT_MODEL)
MICRO_ENDPOINT = (os.environ.get("MIOS_MICRO_ENDPOINT")
                  or _toml_layered("ai", "micro_endpoint")
                  or _toml_layered("ai.host_thresholds", "micro_endpoint")
                  or SYS_AGENT_ENDPOINT).rstrip("/")
CLASSIFY_TIMEOUT_S = float(os.environ.get("MIOS_PREFILTER_CLASSIFY_TIMEOUT")
                           or _toml_layered("routing", "prefilter_classify_timeout_s")
                           or 6)


async def _micro_chat(system: str, user: str, *, max_tokens: int) -> str:
    """One-shot micro-LLM chat-completions call -> the assistant's content string.
    Raises on transport/non-200 so the caller can degrade-open."""
    url = MICRO_ENDPOINT
    url = url + ("" if url.endswith("/chat/completions") else "/chat/completions")
    body = json.dumps({
        "model": MICRO_MODEL,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        "temperature": 0,
        "max_tokens": max_tokens,
        "stream": False,
        # llama.cpp emits the whole chain-of-thought when thinking is on; keep it
        # off for the constrained one-word verdict (sub-second classifier call).
        "chat_template_kwargs": {"enable_thinking": False},
    }).encode()
    timeout = ClientTimeout(total=CLASSIFY_TIMEOUT_S)
    async with ClientSession(timeout=timeout) as s:
        async with s.post(url, data=body,
                          headers={"Content-Type": "application/json"}) as r:
            if r.status != 200:
                raise RuntimeError(f"micro classify non-200: {r.status}")
            j = await r.json()
    return ((j.get("choices") or [{}])[0].get("message") or {}).get("content", "")


async def _looks_conversational(user_text: str) -> bool:
    """MODEL-DRIVEN chat-vs-act: True only when this turn is a PURE conversational
    turn (greeting / ack / smalltalk with NO task surface) that must SKIP the
    forced delegate_task -- forcing it there collapses the reply to zero tokens.

    The micro-LLM classifies each turn; there is NO greeting word list and NO
    length cutoff (those gate English only). Degrade-open: returns False (NOT
    conversational -> force-delegate, the safe majority behaviour) whenever the
    classifier is disabled, the prompt is empty, or the micro lane is
    unreachable / unparseable -- never a keyword fallback."""
    text = (user_text or "").strip()
    if not text or BYPASS_MODE != "model":
        return False
    sys_prompt = (
        "You are a fast turn classifier for an agentic OS. Decide whether the "
        "user's message is a PURE CONVERSATIONAL turn -- a greeting, "
        "acknowledgment, farewell, or social nicety that requests NO task, "
        "action, question to answer, or information -- versus an ACT turn that "
        "asks for something to be done or answered. Reply with ONLY one word: "
        "CHAT if it is purely conversational with no task, or ACT otherwise. "
        "When unsure, answer ACT.")
    try:
        verdict = await _micro_chat(sys_prompt, text, max_tokens=4)
    except Exception as e:  # noqa: BLE001 -- best-effort; degrade open to force-delegate
        log.debug("conversational classify failed (-> force-delegate): %s", e)
        return False
    # Parse the model's OWN one-word verdict (a structural read of the classifier
    # output, not a lexical gate on the user's words): CHAT -> bypass.
    return verdict.strip().upper().startswith("CHAT")





# Sidecar state file the OWUI mios_sidecar Filter polls. Writing here
# is what makes the refiner step VISIBLE to the operator as a
# "🧠 mios-sys-agent: refined prompt (<intent>)" status event in chat.
# Without this write, refinement happens silently and the operator
# (correctly) thinks the small-CPU-model layer doesn't exist.
SIDECAR_STATE_DIR  = "/var/lib/mios/delegation-prefilter"
SIDECAR_STATE_FILE = SIDECAR_STATE_DIR + "/latest.json"


def _write_refine_sidecar(original: str, refined: str) -> None:
    try:
        os.makedirs(SIDECAR_STATE_DIR, mode=0o755, exist_ok=True)
        # intent = first sentence / short snippet for the emitter chip
        intent = refined.split(". ")[0][:120]
        payload = {
            "ts": time.time(),
            "original": original[:240],
            "refined":  refined[:480],
            "intent":   intent,
        }
        tmp = SIDECAR_STATE_FILE + ".tmp"
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(payload, f, separators=(",", ":"))
        os.chmod(tmp, 0o644)
        os.replace(tmp, SIDECAR_STATE_FILE)
    except OSError as e:
        log.warning("refine: could not write sidecar state %s: %s", SIDECAR_STATE_FILE, e)


async def _refine_via_sys_agent(user_text: str) -> str | None:
    """Ask mios-sys-agent to enrich the user prompt with full MiOS
    context before forwarding to hermes. Returns the refined string,
    or None if refinement failed / timed out (caller passes through
    the original text on None)."""
    if not user_text or not REFINE_ENABLED:
        return None
    # max_tokens=1200: thinking-mode models (qwen3.5 family) burn 300-800
    # tokens on the reasoning chain before producing the final clean
    # rewrite in `content`. Cap at 1200 to allow a short final answer.
    # temperature=0.0 for deterministic refinement (operator pastes
    # the same prompt twice, gets the same refined handoff).
    #
    # options.num_gpu=0 -- force CPU execution. Operator architecture
    # 2026-05-16: "ALL Global agents are default to the CPU models
    # (even for GPU models also default to this global defaults)".
    # Without this, Ollama loads mios-sys-agent on GPU (operator-
    # flagged 2026-05-17: "prompt refinement doesn't trigger small
    # CPU model(s) at ALL!!!" -- `ollama ps` showed mios-sys-agent at
    # "100% GPU"). The refiner is supposed to run alongside the big
    # GPU model, not compete for VRAM.
    # Ollama /api/chat body shape:
    #   options.num_predict -- max tokens (the /v1 `max_tokens` alias
    #                          is NOT honored here)
    #   options.temperature -- ditto
    #   options.num_gpu=0   -- FORCE CPU (the whole point of this
    #                          endpoint switch)
    #   options.num_thread  -- CPU thread count; 8 is reasonable for
    #                          a refiner running alongside hermes on GPU
    #   keep_alive=-1       -- keep loaded so back-to-back chats don't
    #                          pay cold-load cost
    body = json.dumps({
        "model": SYS_AGENT_MODEL,
        "messages": [
            {"role": "system", "content": REFINE_SYSTEM},
            {"role": "user", "content": user_text},
        ],
        "options": {
            "num_gpu": 0,
            "num_thread": 8,
            # 600 tokens is the sweet spot: enough room for mios-sys-
            # agent's reasoning template (it burns ~300 tokens on the
            # template alone) plus a meaningful refined handoff
            # (~200-300 tokens). 1200 was tipping over the 120s
            # timeout on this slow WSL2 disk; 600 halves CPU time
            # while still giving the refiner enough output room to
            # produce a non-truncated answer.
            "num_predict": 600,
            "temperature": 0.0,
        },
        "stream": False,
        # Ollama's /api/chat parses keep_alive as Go time.Duration when
        # it's a string ("5m", "24h") OR as seconds when an integer; -1
        # int means "keep loaded indefinitely". The string "-1" trips
        # Ollama's parser with: time: missing unit in duration "-1".
        "keep_alive": -1,
    }).encode()
    try:
        timeout = ClientTimeout(total=REFINE_TIMEOUT_S)
        async with ClientSession(timeout=timeout) as s:
            # Use Ollama's NATIVE /api/chat endpoint, NOT the OpenAI-compat
            # /v1/chat/completions surface. The /v1 surface silently drops
            # the `options` field (operator-flagged 2026-05-17: the refiner
            # request kept landing on GPU even with options.num_gpu=0
            # because the /v1 endpoint discarded it). /api/chat passes
            # options through to the runner, which respects num_gpu=0.
            # Response shape differs (no `choices` array) -- normalized
            # below before we read `content`.
            async with s.post(f"{SYS_AGENT_ENDPOINT}/api/chat",
                              data=body,
                              headers={"Content-Type": "application/json"}) as r:
                if r.status != 200:
                    log.warning("refine: non-200 from sys-agent: %d", r.status)
                    return None
                _native = await r.json()
        # Ollama /api/chat returns {"message": {"role", "content",
        # "thinking"}, "done": true, ...} -- normalize to the OpenAI
        # shape the rest of the function expects.
        _m = _native.get("message") or {}
        resp = {"choices": [{"message": {
            "content": _m.get("content", ""),
            "reasoning": _m.get("thinking") or _m.get("reasoning", ""),
        }}]}
        # Refined prompt resolution -- qwen3.5-family thinking models
        # split output between message.content (the final answer)
        # and message.thinking (the chain-of-thought). mios-sys-agent's
        # modelfile SYSTEM forces thinking mode regardless of /nothink,
        # so message.content is often empty. Strategy:
        #   1. content non-empty   -> use as-is (best case)
        #   2. content empty, thinking has the "USER REQUEST:" /
        #      "INTENT:" / "PLAN:" labeled tail -> extract the
        #      labeled section (the conclusion of the reasoning trace
        #      IS the answer for our REFINE_SYSTEM template)
        #   3. content empty, no labeled tail -> take the LAST
        #      meaningful paragraph of thinking (model's wrap-up)
        #   4. nothing usable -> return None, HARD-GATE rejects
        msg = (resp.get("choices") or [{}])[0].get("message") or {}
        refined = (msg.get("content") or "").strip()
        thinking = (msg.get("reasoning") or "").strip()
        if not refined and thinking:
            # Look for the labeled handoff template in the thinking trace
            m = re.search(r"USER REQUEST:[\s\S]+?(?=\n\n|$)", thinking)
            if m:
                refined = m.group(0).strip()
                log.info("refine: extracted labeled handoff from thinking trace (%d chars)",
                         len(refined))
            else:
                # Tail extraction: last 6 non-empty lines of thinking
                lines = [l for l in thinking.splitlines() if l.strip()]
                if lines:
                    tail = "\n".join(lines[-6:])
                    if len(tail) > 50:  # avoid degenerate "1.\n2." tails
                        refined = tail
                        log.info("refine: thinking-tail fallback (%d chars from %d-line trace)",
                                 len(tail), len(lines))
        if not refined:
            log.info("refine: sys-agent emitted no usable output -- HARD-GATE will reject")
            _write_refine_sidecar(user_text, f"(no rewrite; thinking: {thinking[:120]}...)")
            return None
        log.info("refine: %d-char prompt -> %d-char handoff", len(user_text), len(refined))
        _write_refine_sidecar(user_text, refined)
        return refined
    except Exception as e:
        log.warning("refine failed (non-fatal, passthrough): %s (%s)", type(e).__name__, e or "<no message>")
        return None


def _last_user_message(messages: list) -> str:
    for m in reversed(messages):
        if isinstance(m, dict) and m.get("role") == "user":
            content = m.get("content")
            if isinstance(content, str):
                return content
            if isinstance(content, list):
                # OpenAI multi-part content shape
                return " ".join(p.get("text", "") for p in content if isinstance(p, dict))
    return ""


async def proxy(request: web.Request) -> web.StreamResponse:
    try:
        return await _proxy_inner(request)
    except Exception:
        import traceback
        log.error("proxy handler crashed for %s: %s",
                  request.path, traceback.format_exc())
        raise


async def _proxy_inner(request: web.Request) -> web.StreamResponse:
    upstream_url = HERMES_HOST + request.path_qs

    # ── /v1/models intercept: rewrite name to mios-sys-agent ──
    # Operator directive 2026-05-16: "OWUIs MiOS-Agent is the model
    # that users speak to (mios-sys-agent)". Hermes exposes itself
    # as id="hermes-agent" -- rewrite to id="mios-sys-agent" so
    # OWUIs model dropdown shows the consolidated agent name.
    if request.method == "GET" and request.path.endswith("/models"):
        timeout = ClientTimeout(total=10)
        async with ClientSession(timeout=timeout) as session:
            headers = {k: v for (k, v) in request.headers.items() if k.lower() not in HEADERS_DROP}
            async with session.get(upstream_url, headers=headers) as upstream:
                upstream_body = await upstream.read()
        try:
            j = json.loads(upstream_body)
            for m in j.get("data", []):
                if m.get("id") == "hermes-agent":
                    m["id"] = DISPLAY_MODEL_NAME
                    m["root"] = DISPLAY_MODEL_NAME
            return web.json_response(j, status=upstream.status)
        except Exception as e:
            log.warning("/v1/models rewrite failed (passthrough): %s", e)
            return web.Response(body=upstream_body, status=upstream.status,
                                content_type=upstream.headers.get("Content-Type", "application/json"))

    # Read body; we may rewrite it for /v1/chat/completions
    body_bytes = await request.read()
    rewritten = False

    # Only inspect chat-completions; everything else passes through.
    if request.path.endswith("/chat/completions") and body_bytes:
        try:
            payload = json.loads(body_bytes)
        except Exception:
            payload = None
        if isinstance(payload, dict):
            messages = payload.get("messages") or []
            user_text = _last_user_message(messages)

            # MODEL-DRIVEN chat-vs-act: is this a pure conversational turn that
            # must bypass the forced delegate_task? (degrade-open -> force-
            # delegate). Classified ONCE; reused by the refine-skip + the
            # Stage-1 force-gate below so we make a single micro-LLM call.
            _is_chat_turn = await _looks_conversational(user_text)

            # ── Stage 2: refinement (DELEGATED TO THE OWUI PIPE) ──
            # Operator architecture 2026-05-17: the OWUI MiOS-Agent
            # pipe itself owns CPU refinement. The pipe calls
            # qwen3.5:4b on Ollama BEFORE handing the request to this
            # prefilter, so by the time we see it the user message is
            # ALREADY the refined version. Doing refinement a second
            # time here would double-burn CPU + the prefilter would
            # have no UI surface to emit progress on (the pipe has
            # the __event_emitter__).
            #
            # REFINE_ENABLED env stays for back-compat with non-OWUI
            # callers (raw curl, scripts, future MCP clients) that
            # hit :8641 directly without going through the pipe. The
            # path is preserved below but defaults to disabled --
            # set MIOS_PREFILTER_REFINE=1 on operator-tuned hosts
            # that need server-side refinement for non-OWUI clients.
            if user_text and REFINE_ENABLED and not _is_chat_turn:
                refined = await _refine_via_sys_agent(user_text)
                if refined:
                    # Replace the last user message's content with the
                    # refined handoff. Preserve message structure.
                    for m in reversed(messages):
                        if isinstance(m, dict) and m.get("role") == "user":
                            content = m.get("content")
                            if isinstance(content, str):
                                m["content"] = refined
                            elif isinstance(content, list):
                                # OpenAI multi-part content: replace
                                # the first text segment
                                for part in content:
                                    if isinstance(part, dict) and part.get("type") == "text":
                                        part["text"] = refined
                                        break
                            break
                    body_bytes = json.dumps(payload).encode("utf-8")
                    rewritten = True
                else:
                    # HARD-GATE: refiner failed and refinement is
                    # required. Don't forward to hermes. Return an
                    # OpenAI-shaped error so OWUI surfaces it cleanly.
                    log.warning("refine HARD-GATE: refiner failed; rejecting forward to hermes for prompt=%r",
                                user_text[:80])
                    return web.json_response(
                        {"error": {
                            "type": "service_unavailable",
                            "code": "refiner_unavailable",
                            "message": (
                                "MiOS CPU prompt refiner (mios-sys-agent) failed to produce a "
                                "refined handoff. Hermes was NOT invoked. Common cause: cold-load "
                                "of the 4 GB CPU model exceeded the refine timeout. The refiner "
                                "is normally pre-warmed at boot (keep_alive=-1); wait ~30s and "
                                "retry, or check `journalctl -u mios-delegation-prefilter.service` "
                                "+ `ollama ps`."
                            ),
                        }},
                        status=503,
                    )

            # ── Stage 1: ALWAYS force delegate_task on user-initiated turns ──
            # Operator architecture 2026-05-16: "MiOS-Hermes dispatches multiple
            # different sub-agents using delegate and GPU runs concurrently to
            # the parallel delegated CPU sub-agents". Previously this only
            # fired on fan-out keyword matches; the model would default to
            # serial terminal calls + emit invalid tool calls (e.g.,
            # "Error: Model generated invalid tool call: mios-find"). Forcing
            # delegate_task on every user-initiated turn makes the model
            # commit to the parallel pattern -- it MUST emit a delegate_task
            # tool call to make progress. After that first turn, the model
            # may pick freely (subsequent_tool_choice="auto" injection
            # below resets the gate so synthesis turns aren't forced).
            #
            # Skip when:
            #  * the request already has tool_choice set (caller knows better)
            #  * the last message is a tool result (synthesis turn, not user turn)
            #  * user_text is empty (model retry / nudge)
            _is_user_turn = bool(user_text) and (
                not payload.get("messages") or
                payload["messages"][-1].get("role") == "user"
            )
            _existing_choice = payload.get("tool_choice")
            # A pure conversational turn (model-classified above) has no task
            # surface. Forcing delegate_task on it yields a zero-token reply --
            # OWUI shows blank chat. Excluded from the force-gate so the model
            # answers in plain text. Regression this guards: "hello" returned
            # content="", tokens=0/0/0.
            _is_conversational = _is_user_turn and _is_chat_turn
            if _is_user_turn and not _is_conversational and _existing_choice in (None, "auto", "", {}):
                payload["tool_choice"] = {
                    "type": "function",
                    "function": {"name": "delegate_task"},
                }
                body_bytes = json.dumps(payload).encode("utf-8")
                rewritten = True
                log.info("FORCE delegate_task on user turn (prompt_chars=%d)", len(user_text))
            elif _is_conversational:
                log.info("BYPASS delegate_task -- conversational turn (prompt=%r)", user_text[:60])

            # ── Stage 2b: rewrite friendly name -> "hermes-agent" ──
            # OWUI uses the model name from /v1/models in its requests.
            # We expose the friendly DISPLAY_MODEL_NAME in /v1/models
            # so the operator sees it; hermes only knows hermes-agent
            # as the model id -- rewrite on the way in. Multiple
            # accepted aliases for forward-compat (mios-sys-agent,
            # MiOS-Agent, mios-agent).
            if payload.get("model") in ACCEPTED_MODEL_NAMES:
                payload["model"] = "hermes-agent"
                body_bytes = json.dumps(payload).encode("utf-8")
                rewritten = True

    headers = {k: v for (k, v) in request.headers.items() if k.lower() not in HEADERS_DROP}
    if rewritten:
        headers["Content-Length"] = str(len(body_bytes))

    # SSE streams to OWUI can idle for >60s between chunks while the
    # backend model thinks (especially the 30B coder model running on
    # CPU here -- single tool call -> hundreds of MB swap -> tens of
    # seconds of silence). aiohttp's default sock_read is 5min and
    # `total` only bounds wall-clock end-to-end. Bump both, and disable
    # sock_read entirely so an idle SSE stream doesn't get killed
    # mid-response (chronic operator-observed
    # "TransferEncodingError: Not enough data to satisfy transfer
    # length header" -- prefilter cancelled the stream while hermes
    # was still computing).
    timeout = ClientTimeout(total=None, sock_connect=15, sock_read=None)
    async with ClientSession(timeout=timeout) as session:
        async with session.request(
            request.method, upstream_url, headers=headers, data=body_bytes,
            allow_redirects=False
        ) as upstream:
            resp = web.StreamResponse(status=upstream.status, headers={
                k: v for (k, v) in upstream.headers.items()
                if k.lower() not in {"content-encoding", "transfer-encoding", "content-length"}
            })
            await resp.prepare(request)
            # STRIP: response-side buffer + scanner removed 2026-05-16.
            # The buffering was causing intermittent TransferEncodingError
            # in OWUI (the cap_limit + chunk-slicing logic was producing
            # framing OWUI rejected on certain stream shapes). The OWUI
            # Filter Function (mios_antimeta) now does the pattern-strip
            # natively post-hoc, without touching the in-flight stream.
            # Clean passthrough = no framing drama.
            async for chunk in upstream.content.iter_any():
                await resp.write(chunk)
            await resp.write_eof()
            return resp


def main():
    app = web.Application()
    app.router.add_route("*", "/{tail:.*}", proxy)
    log.info("MiOS delegation-prefilter listening on :%d -> %s", LISTEN_PORT, HERMES_HOST)
    web.run_app(app, host="0.0.0.0", port=LISTEN_PORT, access_log=None)


if __name__ == "__main__":
    main()
