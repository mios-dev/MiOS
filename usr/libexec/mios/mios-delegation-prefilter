#!/usr/bin/env python3
"""mios-delegation-prefilter -- HTTP forwarder that sits between Open
WebUI and Hermes-Agent's /v1/chat/completions, force-routing fan-out
prompts through delegate_task instead of letting the model pick
serial terminal calls.

LISTEN  :8641   (the OpenAI-compat surface OWUI / external clients hit)
FORWARD :8642   (Hermes-Agent gateway)

The model has been demonstrating a strong serial-tool bias even with
the parallel-fanout skill loaded + delegation-default rules in
SOUL.md + the OWUI prompt. Skill nudges, prompt edits, model swap,
and a 92% prompt-bloat reduction all helped a little -- none of them
made the model bite. This prefilter takes a hammer to the choice:
when the user prompt looks fan-outable (multiple independent items,
parallel investigation language), inject `tool_choice={"type":
"function","function":{"name":"delegate_task"}}` into the request so
Hermes is REQUIRED to call delegate_task on the first turn. After
that, the model has committed to the delegation pattern and naturally
fans out the actual work into the tasks=[] array.

Heuristic-driven (NOT model-driven) so it's deterministic + auditable:
operator can flip the heuristic, see exactly when delegation fires.

Disable by stopping mios-delegation-prefilter.service and pointing
OWUI back at :8642. Hermes itself is unmodified.
"""
import json
import os
import re
import sys
import logging
from aiohttp import web, ClientSession, ClientTimeout

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
log = logging.getLogger("delegation-prefilter")

LISTEN_PORT  = int(os.environ.get("MIOS_PREFILTER_LISTEN_PORT", "8641"))
HERMES_HOST  = os.environ.get("MIOS_PREFILTER_UPSTREAM", "http://127.0.0.1:8642")
HEADERS_DROP = {"host", "content-length"}

# Regexes that suggest the user wants parallel investigation. Tuned from
# operator chat history + common multi-target phrasing. Hits = force
# delegate_task on the first model turn.
FANOUT_PATTERNS = [
    re.compile(r"\b(parallel|in parallel|simultaneously|concurrently)\b", re.I),
    re.compile(r"\b(all of|each of|every|several|multiple)\b", re.I),
    re.compile(r"\b(\d+ (independent|things|items|files|services|hosts|tasks))", re.I),
    re.compile(r"\bstatus snapshot\b|\b(check|inspect|audit) (these|those|all|every|N)\b", re.I),
    # operator's own phrasing seen in this session
    re.compile(r"\b(four|three|five|six) (independent|things|tasks|reports|investigations)\b", re.I),
    re.compile(r"\bfan(?:[ -]out)?\b", re.I),
]


def _looks_fanoutable(user_text: str) -> bool:
    """Return True when the user prompt strongly suggests parallel work."""
    for pat in FANOUT_PATTERNS:
        if pat.search(user_text):
            return True
    return False


# Response-side refusal patterns. Mirror of REFUSAL_PATTERNS in
# /usr/libexec/mios/mios-agent-nudger. Duplicated here so the prefilter
# can scan the streamed RESPONSE text (which journalctl on hermes never
# sees -- only tool calls go to the journal there). Two complementary
# watchers: nudger watches journal events, prefilter watches response
# stream. Hits are logged at log.warning() level so the nudger picks
# them up via the prefilter's own journal (provided nudger tails
# mios-delegation-prefilter.service too).
RESPONSE_REFUSAL_RES = [re.compile(p, re.IGNORECASE) for p in [
    r"the mios-windows tool doesn.?t exist",
    r"tools available to me don.?t include",
    r"isn.?t a direct command to launch",
    r"I.?d recommend you navigate to the Start Menu manually",
    r"look for .* in your installed applications",
    r"system has limited Windows application launching",
    r"I see the issue now",
    r"let me try a different approach",
    r"due to the WSL2 container environment",
    r"this environment is designed to be headless",
    r"you might need to manually locate it",
    r"we don.?t have traditional web browsers",
    r"this is an immutable system, we cannot install",
    r"GUI applications cannot be launched",
    r"this is a headless environment",
    r"we cannot run GUI applications directly",
    r"manual intervention on your part",
    r"no Firefox or Chrome installed in the Windows",
    r"system couldn.?t execute it due to path or permission issues",
    r"couldn.?t execute it due to path",
    r"requires their launcher to be running before launching",
    r"needs to be started through the .* launcher interface",
    r"you.?ll need to: Start the .* Launcher first",
    r"there might be missing dependencies",
    r"verify if the application is actually installed",
    r"check if it.?s in a non-standard location",
    r"you.?ll need to install it first",
    # 2026-05-16: new variations from a Steam-launch transcript (after
    # the launch succeeded, agent hedged):
    r"in WSL environments,? launching Windows GUI applications can sometimes be tricky",
    r"can sometimes be tricky due to the different session contexts",
    r"in WSL environments? .{1,40} can sometimes be tricky",
    r"sometimes be tricky due to .{1,40} session",
    # 2026-05-16: new variations from a notepad-launch transcript (agent
    # pre-hedged BEFORE attempting + WHILE the tool actually worked):
    r"failed to launch due to WSL2 display server issues",
    r"required Windows display drivers and services could not be loaded",
    r"we cannot launch [A-Za-z ]+ directly through WSL",
    r"cannot launch .{1,40} directly through WSL",
    r"Opening the Windows Start menu and launching .{1,30} manually",
    r"Using the Windows version of [A-Za-z ]+ via WSL.?s Windows interop",
    # The clarify-confusion pattern -- agent shouldnt mention clarify
    # in OWUI context at all; if it does its prefacing an answer it
    # shouldnt:
    r"the clarify tool isn.?t available in this context",
    r"clarify tool isn.?t available",
]]


def _extract_response_text(body: bytes) -> str:
    """Extract the assistant text from either a streamed SSE body or a
    single JSON chat-completion. Returns concatenated content (best-
    effort; missing/malformed segments are silently skipped)."""
    # SSE: lines like `data: {...}\n\n`. Look for chunks containing
    # choices[0].delta.content or choices[0].message.content.
    s = body.decode("utf-8", errors="ignore")
    out: list[str] = []
    # Streaming path
    for line in s.splitlines():
        if not line.startswith("data:"):
            continue
        payload_str = line[5:].strip()
        if not payload_str or payload_str == "[DONE]":
            continue
        try:
            obj = json.loads(payload_str)
        except json.JSONDecodeError:
            continue
        choices = obj.get("choices") or []
        if not choices:
            continue
        c0 = choices[0]
        delta = c0.get("delta") or {}
        message = c0.get("message") or {}
        text = delta.get("content") or message.get("content") or ""
        if isinstance(text, str) and text:
            out.append(text)
    if out:
        return "".join(out)
    # Non-streaming path: parse full body as single JSON
    try:
        obj = json.loads(s)
    except json.JSONDecodeError:
        return ""
    choices = obj.get("choices") or []
    if not choices:
        return ""
    return ((choices[0].get("message") or {}).get("content") or "")


def _scan_response_for_refusals(body: bytes) -> None:
    text = _extract_response_text(body)
    if not text or len(text) < 30:
        return
    for regex in RESPONSE_REFUSAL_RES:
        m = regex.search(text)
        if m:
            log.warning("[NUDGER] REFUSAL pattern matched in agent response: %r excerpt=%r",
                        regex.pattern[:60], m.group(0)[:160])
            break  # one match per response is enough


def _last_user_message(messages: list) -> str:
    for m in reversed(messages):
        if isinstance(m, dict) and m.get("role") == "user":
            content = m.get("content")
            if isinstance(content, str):
                return content
            if isinstance(content, list):
                # OpenAI multi-part content shape
                return " ".join(p.get("text", "") for p in content if isinstance(p, dict))
    return ""


async def proxy(request: web.Request) -> web.StreamResponse:
    try:
        return await _proxy_inner(request)
    except Exception:
        import traceback
        log.error("proxy handler crashed for %s: %s",
                  request.path, traceback.format_exc())
        raise


async def _proxy_inner(request: web.Request) -> web.StreamResponse:
    upstream_url = HERMES_HOST + request.path_qs

    # Read body; we may rewrite it for /v1/chat/completions
    body_bytes = await request.read()
    rewritten = False

    # Only inspect chat-completions; everything else passes through.
    if request.path.endswith("/chat/completions") and body_bytes:
        try:
            payload = json.loads(body_bytes)
        except Exception:
            payload = None
        if isinstance(payload, dict):
            messages = payload.get("messages") or []
            user_text = _last_user_message(messages)
            if user_text and _looks_fanoutable(user_text):
                # Force delegate_task on the first model call.
                # Hermes / OpenAI-compat honour OpenAI's tool_choice.
                # Only set if not already set by the caller (respect explicit
                # operator override).
                if "tool_choice" not in payload or payload.get("tool_choice") in (None, "auto"):
                    payload["tool_choice"] = {
                        "type": "function",
                        "function": {"name": "delegate_task"},
                    }
                    body_bytes = json.dumps(payload).encode("utf-8")
                    rewritten = True
                    log.info("FORCE delegate_task: matched fan-out keywords in user prompt (%d chars)",
                             len(user_text))

    headers = {k: v for (k, v) in request.headers.items() if k.lower() not in HEADERS_DROP}
    if rewritten:
        headers["Content-Length"] = str(len(body_bytes))

    timeout = ClientTimeout(total=600)
    async with ClientSession(timeout=timeout) as session:
        async with session.request(
            request.method, upstream_url, headers=headers, data=body_bytes,
            allow_redirects=False
        ) as upstream:
            resp = web.StreamResponse(status=upstream.status, headers={
                k: v for (k, v) in upstream.headers.items()
                if k.lower() not in {"content-encoding", "transfer-encoding", "content-length"}
            })
            await resp.prepare(request)
            # Buffer the assistant response text so we can pattern-match
            # for refusal phrases AFTER it lands. Caps at 200 KB to avoid
            # memory pressure on long chains.
            captured = bytearray()
            cap_limit = 200_000
            async for chunk in upstream.content.iter_chunked(65536):
                await resp.write(chunk)
                if len(captured) < cap_limit:
                    captured.extend(chunk[: cap_limit - len(captured)])
            await resp.write_eof()
            # Pattern-detect on chat-completions responses only -- the
            # signal is the agent's emitted text (response-side), which
            # journalctl on hermes-agent.service never sees (only tool
            # calls are journaled there). Operator-confirmed 2026-05-16:
            # agent emitted "in WSL environments... can be tricky due to
            # different session contexts" -- nudger's journal-side
            # watcher missed it entirely. This is the response-side
            # complement: see + flag the actual assistant prose before
            # it lands in the operator's chat.
            #
            # Defensive try/except: the scanner is OBSERVABILITY, not
            # critical path. It MUST NEVER crash the prefilter +
            # break the operator's chat. Any exception (malformed SSE,
            # unicode decode failure, regex pathological input, OOM
            # on cap-limit boundary) gets logged + swallowed.
            if request.path.endswith("/chat/completions") and captured:
                try:
                    _scan_response_for_refusals(bytes(captured))
                except Exception as e:
                    log.warning("response scanner failed (non-fatal): %s", e)
            return resp


def main():
    app = web.Application()
    app.router.add_route("*", "/{tail:.*}", proxy)
    log.info("MiOS delegation-prefilter listening on :%d -> %s", LISTEN_PORT, HERMES_HOST)
    web.run_app(app, host="0.0.0.0", port=LISTEN_PORT, access_log=None)


if __name__ == "__main__":
    main()
