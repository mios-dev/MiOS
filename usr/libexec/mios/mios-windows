place_block = (
    "$x = $r.L; $y = $r.T; $w = $r.R - $r.L; $h = $r.B - $r.T; "
    "$s = [System.Windows.Forms.Screen]::PrimaryScreen.WorkingArea; "
)
# Size override (parse "WxH"); applied before position so position
# uses the NEW geometry.
