#!/bin/bash
# AI-hint: Provides a bridge for the agent to execute Windows-side commands, launch GUI applications, or run elevated PowerShell scripts via WSL interop or Tailscale SSH from within the WSL2 environment.
# AI-related: /usr/libexec/mios/mios-windows, /etc/mios/windows-host, /etc/mios/mios.toml, /usr/share/mios/mios.toml, /usr/libexec/mios/mios-autocenter, mios-autocenter, mios-find, mios-oscontrol-server, mios-pc-control, mios-hermes-firstboot
# AI-functions: _app_paths_resolve, _start_menu_resolve, _startapps_resolve, _mios_executor_endpoint, _mios_launch_via_executor, _mios_arm_autocenter, usage, do_ssh_ps, _build_uri_center_ps
set -euo pipefail
# /usr/libexec/mios/mios-windows <subcommand> [args...]
#
# Reach the Windows host from inside this WSL2 distro. The agent uses
# this when it needs to launch a Windows app, run a PowerShell command,
# or otherwise touch the host the WSL VM lives inside.
#
# TWO BACKENDS, ONE FRONTEND
# ──────────────────────────
#
# WSL interop (default; no setup, no SSH, no Tailscale required):
#   /init -- the program PID 1 inside this WSL2 distro -- transparently
#   exec's any /mnt/c/.../*.exe directly on the Windows host, with
#   stdout/stderr piped back into the Linux side. Works for every
#   GUI app + any non-elevated cmd.exe / powershell.exe one-liner.
#
# Tailscale SSH (subcommand: `ssh-ps`; opt-in for remote / elevated):
#   For commands that need to run AS the host's interactive operator
#   account (not the SYSTEM-context interop spawns), or that need to
#   reach a different machine on the tailnet, the legacy Tailscale-SSH
#   path is preserved. Requires Tailscale SSH enabled host-side
#   (`tailscale set --ssh`); see /etc/mios/windows-host (pinned
#   tailnet IP) and the [identity] block in mios.toml.
#
# OPERATOR DIRECTIVE 2026-05-15
# ─────────────────────────────
# "didn't create a skill or tool to use--should be able to ssh in to
# the hosts' shell environment via loopback (or similar)". The "or
# similar" turned out to be plain WSL interop -- no SSH needed for
# the common case (launching notepad, running ipconfig, querying a
# service status). The Tailscale-SSH path stays for the cases where
# interop's SYSTEM-spawned context isn't what's wanted.
#
# SUBCOMMANDS
#   launch <app>      Launch a Windows GUI app by short name (notepad,
#                     explorer, calc, mspaint, snipping-tool, taskmgr,
#                     regedit, control, cmd, powershell, pwsh) or by
#                     full /mnt/c/.../*.exe path. Detached; returns
#                     immediately.
#
#   ps "<cmd>"        Run a Windows PowerShell command via interop.
#                     Output captured + returned. Default PowerShell
#                     5.1 (System32\WindowsPowerShell\v1.0). Override
#                     via MIOS_WINDOWS_PWSH=<absolute path> for pwsh 7.
#
#   cmd "<cmd>"       Run a Windows cmd.exe command via interop.
#
#   ssh-ps [-e] "<cmd>"   Run a PowerShell command via Tailscale SSH
#                          (preserves the legacy logic for elevated /
#                          remote-tailnet cases). -e wraps in a
#                          SYSTEM-level Task Scheduler trigger
#                          (placeholder; not yet wired).
#
#   list              Print known short-name -> .exe mappings.
#
#   help              Print this help.

set -eu

# GENERATIVE Windows-app name resolution -- NO hardcoded short-name->exe table
# (operator "NO HARDCODES"; research 2026-05-29). The canonical exe-name->path
# map on Windows is the App Paths registry: HKCU/HKLM \SOFTWARE\Microsoft\
# Windows\CurrentVersion\App Paths\<name>.exe whose (Default) value is the
# fully-qualified path (per-user installs under HKCU, all-users under HKLM, so
# scan BOTH). Resolve a bare name straight from the live registry via reg.exe;
# returns a WSL path on stdout, or non-zero if not registered (caller then
# tries System32 / mios-find). This covers notepad/calc/mspaint/regedit/... and
# every operator-installed app that registers App Paths -- without a baked list.
_app_paths_resolve() {  # <name> -> WSL path of the registered exe, or empty
    local name="$1" reg="/mnt/c/Windows/System32/reg.exe" win hive
    [ -x "$reg" ] || return 1
    case "$name" in *.exe|*.EXE) : ;; *) name="${name}.exe" ;; esac
    for hive in HKCU HKLM; do
        win="$("$reg" query "${hive}\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\${name}" /ve 2>/dev/null \
               | tr -d '\r' | sed -n 's/.*REG_SZ[[:space:]][[:space:]]*//p' | head -1)"
        win="${win%\"}"; win="${win#\"}"
        if [ -n "$win" ]; then
            wslpath -u "$win" 2>/dev/null && return 0
        fi
    done
    return 1
}

PWSH="${MIOS_WINDOWS_PWSH:-/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe}"
CMD="/mnt/c/Windows/System32/cmd.exe"

# GENERATIVE Start-Menu .lnk resolution (research 2026-05-29 open-Q1: App Paths
# is INSTALLER-OPTIONAL + incomplete, and the Everything index is install-gated,
# so a name in neither would fail). The Start Menu is the canonical, always-
# present app catalog on Windows: scan both the all-users (%ProgramData%) and
# per-user (%APPDATA%) Programs trees for a .lnk whose name matches, pick the
# shortest (closest) match, and return its WSL path -- Start-Process opens a
# .lnk directly (covers Store/UWP shortcuts too, which have no plain exe path).
# Everything-INDEPENDENT (pure filesystem scan); the fallback before mios-find.
_start_menu_resolve() {  # <name> -> WSL path of the matching Start-Menu .lnk
    local name="${1//\'/}" out
    [ -n "$name" ] || return 1
    [ -x "$PWSH" ] || return 1
    out="$("$PWSH" -NoProfile -NonInteractive -Command "
\$n=('$name' -replace '[^A-Za-z0-9]','').ToLower()
\$w=New-Object -ComObject WScript.Shell
\$d=@(\$env:ProgramData,\$env:APPDATA) | ForEach-Object { Join-Path \$_ 'Microsoft\\Windows\\Start Menu\\Programs' }
\$h=Get-ChildItem -Path \$d -Recurse -Filter *.lnk -ErrorAction SilentlyContinue | Where-Object { \$n.Length -ge 2 -and (\$_.BaseName -replace '[^A-Za-z0-9]','').ToLower().Contains(\$n) } | Where-Object { try { \$t=\$w.CreateShortcut(\$_.FullName).TargetPath } catch { \$t='' }; (\$t -notlike '*wslg.exe') -and (\$t -notlike '*wsl.exe') } | Sort-Object { \$_.BaseName.Length } | Select-Object -First 1
if(\$h){ \$h.FullName }
" 2>/dev/null | tr -d '\r' | grep -iE '\.lnk$' | head -1)"
    [ -n "$out" ] && wslpath -u "$out" 2>/dev/null && return 0
    return 1
}

# GENERATIVE UWP/Store app resolution (operator 2026-06-04 "no hardcodes for
# application detections"). UWP built-ins (Calculator, Settings, Photos, Camera,
# Clock, ...) register NO App Paths exe and NO Start-Menu .lnk -- they live ONLY
# in the AppsFolder, enumerable via Get-StartApps (Name + AppID). Fuzzy-match the
# requested name to a Start app and echo `shell:appsFolder\<AppID>` (the exact
# form the launch dispatch + the in-session executor already open via explorer's
# appsFolder handler). No baked app list -- the LIVE Get-StartApps catalog is the
# source of truth, so this resolves ANY installed UWP app, not a fixed set.
_startapps_resolve() {  # <name> -> shell:appsFolder\<AppID>, or empty
    local name="${1//\'/}" out
    [ -n "$name" ] || return 1
    [ -x "$PWSH" ] || return 1
    # Match SPACE/PUNCTUATION/CASE-insensitively: agents routinely mangle a
    # display name ("Character Map" -> "CharacterMap", "Task Manager" ->
    # "TaskManager"), so normalise BOTH the query and each candidate to
    # alphanumerics-lowercase before substring-matching. >=2 chars guards the
    # empty/degenerate query from matching everything (operator 2026-06-04).
    out="$("$PWSH" -NoProfile -NonInteractive -Command "
\$n=('$name' -replace '[^A-Za-z0-9]','').ToLower()
\$a=\$null
if(\$n.Length -ge 2){ \$a=Get-StartApps | Where-Object { (\$_.Name -replace '[^A-Za-z0-9]','').ToLower().Contains(\$n) } | Sort-Object { \$_.Name.Length } | Select-Object -First 1 }
if(\$a){ 'shell:appsFolder\\' + \$a.AppID }
" 2>/dev/null | tr -d '\r' | grep -i 'appsfolder' | head -1)"
    [ -n "$out" ] && printf '%s\n' "$out" && return 0
    return 1
}

# Resolve the Windows OS-control executor endpoint from SSOT: the
# MIOS_OSCONTROL_EXECUTOR env override first, else [os_control].executor_endpoint
# in /etc (host overlay wins) then /usr mios.toml. Echoes the trimmed URL (no
# trailing slash) or nothing. No hardcoded host/port (operator binding).
_mios_executor_endpoint() {
    _ep="${MIOS_OSCONTROL_EXECUTOR:-}"
    if [ -z "$_ep" ]; then
        for _t in /etc/mios/mios.toml /usr/share/mios/mios.toml; do
            [ -r "$_t" ] || continue
            _ep="$(awk -F\" '/^[[:space:]]*executor_endpoint[[:space:]]*=/{print $2; exit}' "$_t" 2>/dev/null)"
            [ -n "$_ep" ] && break
        done
    fi
    # WSL2 local auto-discovery (operator 2026-06-07): no env override + no
    # configured endpoint, but the in-session executor (mios-oscontrol-server.ps1)
    # listens on :11437. Reach it over the WSL NAT default-route gateway (the
    # Windows host) so VISIBLE launches work WITHOUT Tailscale -- otherwise the
    # WSL-interop fallback lands in a Session-0 window station (no visible window).
    # The caller curls /launch, so an unreachable gateway simply falls back to the
    # legacy route -- no regression, and it self-heals once the host firewall
    # admits the WSL subnet. Same resolver shape as mios-pc-control.
    if [ -z "$_ep" ] && grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease 2>/dev/null; then
        _gw="$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}')"
        [ -n "$_gw" ] && _ep="http://${_gw}:${MIOS_PORT_OSCONTROL:-11437}"
    fi
    printf '%s' "${_ep%/}"
}

# Launch a Windows GUI app THROUGH the in-session executor (operator 2026-05-29:
# the canonical fix). A Windows process spawned via WSL interop / the launcher
# broker lands in a NON-INTERACTIVE window station -- simple Win32 apps may still
# surface, but multi-process Electron apps (Discord, Slack, Teams, VS Code)
# spawn their processes there and their window NEVER reaches the operator's
# visible desktop (proven live: Discord -> 6 procs, MainWindowHandle=0, ZERO
# top-level windows). The executor (:11437) runs as a scheduled task INSIDE the
# operator's interactive session, so its Start-Process shows the window on the
# real desktop + verifies it + centers it. Returns 0 on a confirmed launch (so
# the caller exits), non-zero to fall through to the legacy broker route.
_mios_launch_via_executor() {  # <app-name-or-windows-path> [args...]
    command -v curl >/dev/null 2>&1 || return 1
    _xe="$(_mios_executor_endpoint)"
    [ -z "$_xe" ] && return 1
    # Fast reachability pre-check: a configured-but-unreachable executor (e.g. the
    # auto-resolved WSL-gateway endpoint before the host firewall admits the WSL
    # subnet) must fall back to the legacy interop path in ~2s, NOT stall the whole
    # launch on the 45s POST timeout below (operator 2026-06-07).
    curl -fsS -m 2 "$_xe/health" >/dev/null 2>&1 || return 1
    _app="$1"
    shift
    _args="$*"
    # `verify` = the human title hint (MIOS_LAUNCH_TITLE_HINT, e.g. "Forza
    # Horizon 6") so the executor matches the WINDOW by title, not by a steam://
    # URI / shell:appsFolder string that never appears in a window title
    # (operator 2026-05-30). Falls back to `app` when no hint is set.
    _resp="$(python3 - "$_app" "$_xe" "$_args" <<'PYEOF'
import sys, os, json, urllib.request
try:
    payload = json.dumps({"app": sys.argv[1], "args": sys.argv[3], "center": True, "verify": os.environ.get("MIOS_LAUNCH_TITLE_HINT","")}).encode()
    req = urllib.request.Request(sys.argv[2] + "/launch", data=payload, headers={'Content-Type': 'application/json'}, method="POST")
    with urllib.request.urlopen(req, timeout=45) as r:
        print(r.read().decode())
except Exception:
    pass
PYEOF
    )"
    [ -z "$_resp" ] && return 1
    # launched:true (window confirmed present) OR fired:true (process started --
    # the executor's in-session Start-Process succeeded; honest about windowless
    # apps via launched). Either means we used the correct in-session path.
    case "$_resp" in
        *'"launched": true'*|*'"launched":true'*|*'"fired": true'*|*'"fired":true'*)
            echo "[mios-windows] launched via in-session executor: $_resp"
            return 0 ;;
    esac
    echo "[mios-windows] executor launch did not confirm ($_resp) -- falling back" >&2
    return 1
}

# Arm the executor-based auto-center (operator 2026-05-29: "launches are ALWAYS
# centered"). The in-PowerShell center loop relies on the launched process's
# MainWindowHandle, which is 0 for Store apps (the stub process doesn't own the
# window) -> notepad et al. open top-left. mios-autocenter instead snapshots the
# window hwnds BEFORE the launch + centers the LARGEST NEW window afterward via
# the Windows executor -- robust for Store/native/WSLg alike. No-op without an
# executor endpoint. Same mechanism flatpak-launch uses for Linux GUIs.
_mios_arm_autocenter() {
    [ -x /usr/libexec/mios/mios-autocenter ] || return 0
    command -v curl >/dev/null 2>&1 || return 0
    command -v python3 >/dev/null 2>&1 || return 0
    _ace="$(_mios_executor_endpoint)"
    [ -z "$_ace" ] && return 0
    _before="$(python3 - "$_ace" <<'PYEOF'
import sys, json, urllib.request
try:
    with urllib.request.urlopen(sys.argv[1] + "/windows", timeout=5) as r:
        d = json.loads(r.read().decode())
    print(",".join(str(w.get("hwnd")) for w in d.get("windows", [])))
except Exception:
    pass
PYEOF
    )"
    setsid /usr/libexec/mios/mios-autocenter "$_ace" "$_before" >/dev/null 2>&1 &
}

usage() {
    cat <<'USAGE'
usage: mios-windows <subcommand> [args...]

  launch <app>          Launch a Windows GUI app (interop, detached).
                        Known: notepad, explorer, calc, mspaint,
                        snipping-tool, taskmgr, regedit, control, cmd,
                        powershell, pwsh; or pass a full .exe path.

  ps "<command>"        Run a Windows PowerShell command (interop).
                        e.g. mios-windows ps 'Get-Service Tailscale | fl'
                             mios-windows ps 'ipconfig /all | Select-String IPv4'

  cmd "<command>"       Run a Windows cmd.exe command (interop).
                        e.g. mios-windows cmd 'tasklist /FI "IMAGENAME eq notepad.exe"'

  ssh-ps [-e] "<cmd>"   Run a PowerShell command via Tailscale SSH on the
                        host (legacy path, for elevated / remote-tailnet).
                        -e wraps in a SYSTEM Task Scheduler trigger
                        (placeholder; not yet wired).

  list                  Print short-name -> .exe mappings.
  help                  This message.

WSL interop is the default backend (no setup; /init handles the cross-
environment exec). Tailscale SSH stays available as `ssh-ps` for
elevated commands and reaching other tailnet hosts.
USAGE
}

# ─── Tailscale SSH path (legacy; preserved verbatim from prior version) ──
do_ssh_ps() {
    local elevated=0
    if [ "${1:-}" = "-e" ] || [ "${1:-}" = "--elevated" ]; then
        elevated=1
        shift
    fi
    if [ "$#" -eq 0 ]; then
        echo "mios-windows ssh-ps: missing <command>" >&2
        return 64
    fi
    local cmd="$*"

    # Resolve Windows tailscale IP. Single-tenant dev VM contract: there's
    # exactly one Windows host on the tailnet that this distro runs inside.
    # IP is stored once in /etc/mios/windows-host (created by
    # mios-hermes-firstboot if Tailscale is detected).
    local win_host_file=/etc/mios/windows-host
    local win_host=""
    if [ -r "$win_host_file" ]; then
        win_host="$(cat "$win_host_file")"
    else
        win_host="$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}')"
        if [ -z "$win_host" ]; then
            echo "mios-windows ssh-ps: cannot determine Windows host (no $win_host_file, no default gateway)" >&2
            return 1
        fi
    fi

    # Resolve operator username -- the agent's identity for the SSH session.
    local win_user=""
    if [ -r /usr/share/mios/mios.toml ]; then
        win_user="$(awk -F\" '/^\s*windows_user\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
    fi
    [ -z "$win_user" ] && win_user="$(awk -F\" '/^\s*username\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
    [ -z "$win_user" ] && win_user="$USER"

    if [ "$elevated" = "1" ]; then
        cat >&2 <<EOF
mios-windows ssh-ps: -e/--elevated not yet wired.
For elevated commands, the operator needs to either:
  (a) Run the equivalent in elevated PowerShell on the host themselves
  (b) Set up a SYSTEM-level scheduled task that watches a queue dir
      (see /usr/share/doc/mios/guides/agent-windows-ssh.md for the
       trigger-file pattern; not yet shipped)
Falling back to non-elevated SSH; command may fail with 'Access denied'
if it needs admin. Original command:
  $cmd
EOF
    fi

    _enc_cmd="$(echo -n "$cmd" | iconv -f utf-8 -t utf-16le | base64 -w0)"
    exec ssh \
        -o StrictHostKeyChecking=accept-new \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=15 \
        -l "$win_user" \
        "$win_host" \
        -- "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -EncodedCommand $_enc_cmd"
}

if [ "$#" -lt 1 ]; then
    usage
    exit 64
fi

sub="$1"
shift

case "$sub" in
    list)
        # GENERATIVE: enumerate the live Windows App Paths registry (the real
        # exe-name -> path map) instead of a hardcoded short-name table.
        printf '%-28s %s\n' "NAME" "EXE (App Paths registry)"
        _reg="/mnt/c/Windows/System32/reg.exe"
        if [ -x "$_reg" ]; then
            for hive in HKLM HKCU; do
                "$_reg" query "${hive}\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths" 2>/dev/null \
                    | tr -d '\r' | sed -n 's#.*\\App Paths\\##p' | while read -r _name; do
                        [ -n "$_name" ] || continue
                        _p="$("$_reg" query "${hive}\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths\\${_name}" /ve 2>/dev/null \
                              | tr -d '\r' | sed -n 's/.*REG_SZ[[:space:]][[:space:]]*//p' | head -1)"
                        printf '%-28s %s\n' "$_name" "$_p"
                    done
            done | sort -u
        else
            echo "(reg.exe unavailable -- not on WSL2? resolution is generative via App Paths at launch time)"
        fi
        ;;
    launch)
        if [ "$#" -lt 1 ]; then
            echo "mios-windows launch: missing <app>" >&2
            exit 64
        fi
        # Stdin mode: `mios-windows launch -` reads the path from
        # stdin. Sidesteps bash paren-parsing on paths like
        # C:\Program Files (x86)\Steam\steam.exe where the unquoted
        # `(x86)` triggers a subshell-syntax error before the script
        # is even invoked. Operator-confirmed regression 2026-05-16:
        # agent emitted `mios-windows launch C:\Program Files
        # (x86)\Steam\steam.exe` without quoting -- bash errored
        # "syntax error near unexpected token `('".
        if [ "$1" = "-" ]; then
            shift
            app="$(cat)"
            app="${app%$'\n'}"   # strip trailing newline
        else
            app="$1"
            shift
        fi
        # URI passthrough: `mios-windows launch uplay://launch/16732/0`
        # (or steam://, epic://, http://, etc.) re-dispatches to the
        # ps subcommand with Start-Process -- Windows registers
        # protocol handlers per scheme. Without this, the existence
        # check below rejects URIs as "unknown app" and the agent
        # spirals into refusal. Operator-confirmed regression
        # 2026-05-16: agent saw `mios-find "the crew motorfest"`
        # return `mios-windows ps "Start-Process uplay://..."` but
        # then called `mios-windows launch uplay://...` (wrong
        # subcommand) and got "unknown app", concluding the URL was
        # invalid. Now both subcommands accept URIs.
        # ─── URI / UWP launches: center+focus the resulting window ───
        # Direct .exe launches center via Start-Process -PassThru +
        # MainWindowHandle polling on $p (the launched process). URI
        # launches (steam://, com.epicgames.launcher://, http://, ...) and
        # UWP shell:appsFolder\ launches DON'T return the game's process
        # -- they return the protocol handler (steam.exe, explorer.exe).
        # Without explicit post-launch window discovery, these never get
        # centered. Operator directive 2026-05-17: "launching apps should
        # launch centered too!! MiOS Agents must have launch param/args
        # tools for launching applications(should always launch centered
        # and focused)".
        #
        # Strategy for URI/UWP: snapshot the current top-level window
        # handles, run Start-Process, poll for new top-level windows for
        # up to MIOS_LAUNCH_CENTER_TIMEOUT seconds (default 15), then
        # center+focus the first new window matching MIOS_LAUNCH_TITLE_HINT
        # (case-insensitive substring) -- or the first new window if no
        # hint. mios-find sets the hint to the app name from the
        # inventory so multi-window protocol handlers (Steam launches
        # both the storefront AND the game) center the right one.
        _build_uri_center_ps() {
            # $1 = Start-Process invocation, e.g. "Start-Process 'steam://...'"
            #      OR "Start-Process -FilePath explorer.exe -ArgumentList 'shell:appsFolder\\...'"
            # $2 = title hint (may be empty)
            local sp="$1"
            local hint="${2:-}"
            local timeout="${MIOS_LAUNCH_CENTER_TIMEOUT:-15}"
            # PowerShell here-doc: snapshot -> launch -> poll new windows.
            # Single-line for the broker's "CAPTURE: <cmdline>\n" wire.
            cat <<PSEOF
Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue
# UNIFIED window source (operator 2026-06-22 "unify MiOS systems"): center+detect
# the launched window via the SAME EnumWindows + IsWindowVisible enumeration the
# window_list verb (mios-pc-control.ps1) uses -- NOT Get-Process MainWindowHandle,
# which is 0 for Electron / child-process windows (Spotify, Steam) so the old code
# reported "[no new window]" + skipped centering on apps that DID open. Full C#
# class (-TypeDefinition) so the EnumWindowsProc delegate is a normal nested type.
if (-not ([System.Management.Automation.PSTypeName]'MiosLW').Type) {
  Add-Type -ErrorAction SilentlyContinue -TypeDefinition @'
using System;
using System.Text;
using System.Runtime.InteropServices;
public class MiosLW {
  [DllImport("user32.dll")] public static extern bool MoveWindow(IntPtr h,int x,int y,int w,int n,bool r);
  [DllImport("user32.dll")] public static extern bool SetForegroundWindow(IntPtr h);
  [DllImport("user32.dll")] public static extern bool GetWindowRect(IntPtr h, out RECT r);
  [DllImport("user32.dll")] public static extern bool ShowWindow(IntPtr h, int n);
  [DllImport("dwmapi.dll")] public static extern int DwmSetWindowAttribute(IntPtr h,int a,ref int v,int s);
  [DllImport("user32.dll")] public static extern bool EnumWindows(EnumWindowsProc cb, IntPtr l);
  [DllImport("user32.dll")] public static extern bool IsWindowVisible(IntPtr h);
  [DllImport("user32.dll")] public static extern int GetWindowTextLength(IntPtr h);
  [DllImport("user32.dll", CharSet=CharSet.Auto)] public static extern int GetWindowText(IntPtr h, StringBuilder s, int max);
  public delegate bool EnumWindowsProc(IntPtr h, IntPtr l);
  [StructLayout(LayoutKind.Sequential)] public struct RECT { public int Left, Top, Right, Bottom; }
}
'@
}
function Get-MiosVisibleWindows {
    \$script:_wl = @()
    \$cb = [MiosLW+EnumWindowsProc]{
        param(\$h, \$l)
        if ([MiosLW]::IsWindowVisible(\$h)) {
            \$len = [MiosLW]::GetWindowTextLength(\$h)
            if (\$len -gt 0) {
                \$sb = New-Object System.Text.StringBuilder (\$len + 1)
                [MiosLW]::GetWindowText(\$h, \$sb, \$sb.Capacity) | Out-Null
                \$script:_wl += [pscustomobject]@{ hwnd = [int64]\$h; title = \$sb.ToString() }
            }
        }
        return \$true
    }
    [MiosLW]::EnumWindows(\$cb, [IntPtr]::Zero) | Out-Null
    return \$script:_wl
}
\$preRows = Get-MiosVisibleWindows
\$pre = @(\$preRows | ForEach-Object { \$_.hwnd })
${sp}
\$hint = '${hint}'
\$deadline = (Get-Date).AddSeconds(${timeout})
\$targetHwnd = [IntPtr]::Zero
\$targetTitle = ''
while ((Get-Date) -lt \$deadline) {
    \$newRows = Get-MiosVisibleWindows | Where-Object { \$pre -notcontains \$_.hwnd }
