#!/bin/bash
# /usr/libexec/mios/mios-windows <subcommand> [args...]
#
# Reach the Windows host from inside this WSL2 distro. The agent uses
# this when it needs to launch a Windows app, run a PowerShell command,
# or otherwise touch the host the WSL VM lives inside.
#
# TWO BACKENDS, ONE FRONTEND
# ──────────────────────────
#
# WSL interop (default; no setup, no SSH, no Tailscale required):
#   /init -- the program PID 1 inside this WSL2 distro -- transparently
#   exec's any /mnt/c/.../*.exe directly on the Windows host, with
#   stdout/stderr piped back into the Linux side. Works for every
#   GUI app + any non-elevated cmd.exe / powershell.exe one-liner.
#
# Tailscale SSH (subcommand: `ssh-ps`; opt-in for remote / elevated):
#   For commands that need to run AS the host's interactive operator
#   account (not the SYSTEM-context interop spawns), or that need to
#   reach a different machine on the tailnet, the legacy Tailscale-SSH
#   path is preserved. Requires Tailscale SSH enabled host-side
#   (`tailscale set --ssh`); see /etc/mios/windows-host (pinned
#   tailnet IP) and the [identity] block in mios.toml.
#
# OPERATOR DIRECTIVE 2026-05-15
# ─────────────────────────────
# "didn't create a skill or tool to use--should be able to ssh in to
# the hosts' shell environment via loopback (or similar)". The "or
# similar" turned out to be plain WSL interop -- no SSH needed for
# the common case (launching notepad, running ipconfig, querying a
# service status). The Tailscale-SSH path stays for the cases where
# interop's SYSTEM-spawned context isn't what's wanted.
#
# SUBCOMMANDS
#   launch <app>      Launch a Windows GUI app by short name (notepad,
#                     explorer, calc, mspaint, snipping-tool, taskmgr,
#                     regedit, control, cmd, powershell, pwsh) or by
#                     full /mnt/c/.../*.exe path. Detached; returns
#                     immediately.
#
#   ps "<cmd>"        Run a Windows PowerShell command via interop.
#                     Output captured + returned. Default PowerShell
#                     5.1 (System32\WindowsPowerShell\v1.0). Override
#                     via MIOS_WINDOWS_PWSH=<absolute path> for pwsh 7.
#
#   cmd "<cmd>"       Run a Windows cmd.exe command via interop.
#
#   ssh-ps [-e] "<cmd>"   Run a PowerShell command via Tailscale SSH
#                          (preserves the legacy logic for elevated /
#                          remote-tailnet cases). -e wraps in a
#                          SYSTEM-level Task Scheduler trigger
#                          (placeholder; not yet wired).
#
#   list              Print known short-name -> .exe mappings.
#
#   help              Print this help.

set -eu

# Known short-name -> exe mappings (extend as workflow expands).
declare -A APPS=(
    [notepad]="/mnt/c/Windows/System32/notepad.exe"
    [explorer]="/mnt/c/Windows/explorer.exe"
    [calc]="/mnt/c/Windows/System32/calc.exe"
    [mspaint]="/mnt/c/Windows/System32/mspaint.exe"
    [snipping-tool]="/mnt/c/Windows/System32/SnippingTool.exe"
    [taskmgr]="/mnt/c/Windows/System32/Taskmgr.exe"
    [regedit]="/mnt/c/Windows/regedit.exe"
    [control]="/mnt/c/Windows/System32/control.exe"
    [cmd]="/mnt/c/Windows/System32/cmd.exe"
    [powershell]="/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
    [pwsh]="/mnt/c/Program Files/PowerShell/7/pwsh.exe"
)

PWSH="${MIOS_WINDOWS_PWSH:-/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe}"
CMD="/mnt/c/Windows/System32/cmd.exe"

usage() {
    cat <<'USAGE'
usage: mios-windows <subcommand> [args...]

  launch <app>          Launch a Windows GUI app (interop, detached).
                        Known: notepad, explorer, calc, mspaint,
                        snipping-tool, taskmgr, regedit, control, cmd,
                        powershell, pwsh; or pass a full .exe path.

  ps "<command>"        Run a Windows PowerShell command (interop).
                        e.g. mios-windows ps 'Get-Service Tailscale | fl'
                             mios-windows ps 'ipconfig /all | Select-String IPv4'

  cmd "<command>"       Run a Windows cmd.exe command (interop).
                        e.g. mios-windows cmd 'tasklist /FI "IMAGENAME eq notepad.exe"'

  ssh-ps [-e] "<cmd>"   Run a PowerShell command via Tailscale SSH on the
                        host (legacy path, for elevated / remote-tailnet).
                        -e wraps in a SYSTEM Task Scheduler trigger
                        (placeholder; not yet wired).

  list                  Print short-name -> .exe mappings.
  help                  This message.

WSL interop is the default backend (no setup; /init handles the cross-
environment exec). Tailscale SSH stays available as `ssh-ps` for
elevated commands and reaching other tailnet hosts.
USAGE
}

# ─── Tailscale SSH path (legacy; preserved verbatim from prior version) ──
do_ssh_ps() {
    local elevated=0
    if [ "${1:-}" = "-e" ] || [ "${1:-}" = "--elevated" ]; then
        elevated=1
        shift
    fi
    if [ "$#" -eq 0 ]; then
        echo "mios-windows ssh-ps: missing <command>" >&2
        return 64
    fi
    local cmd="$*"

    # Resolve Windows tailscale IP. Single-tenant dev VM contract: there's
    # exactly one Windows host on the tailnet that this distro runs inside.
    # IP is stored once in /etc/mios/windows-host (created by
    # mios-hermes-firstboot if Tailscale is detected).
    local win_host_file=/etc/mios/windows-host
    local win_host=""
    if [ -r "$win_host_file" ]; then
        win_host="$(cat "$win_host_file")"
    else
        win_host="$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}')"
        if [ -z "$win_host" ]; then
            echo "mios-windows ssh-ps: cannot determine Windows host (no $win_host_file, no default gateway)" >&2
            return 1
        fi
    fi

    # Resolve operator username -- the agent's identity for the SSH session.
    local win_user=""
    if [ -r /usr/share/mios/mios.toml ]; then
        win_user="$(awk -F\" '/^\s*windows_user\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
    fi
    [ -z "$win_user" ] && win_user="$(awk -F\" '/^\s*username\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
    [ -z "$win_user" ] && win_user="$USER"

    if [ "$elevated" = "1" ]; then
        cat >&2 <<EOF
mios-windows ssh-ps: -e/--elevated not yet wired.
For elevated commands, the operator needs to either:
  (a) Run the equivalent in elevated PowerShell on the host themselves
  (b) Set up a SYSTEM-level scheduled task that watches a queue dir
      (see /usr/share/doc/mios/guides/agent-windows-ssh.md for the
       trigger-file pattern; not yet shipped)
Falling back to non-elevated SSH; command may fail with 'Access denied'
if it needs admin. Original command:
  $cmd
EOF
    fi

    exec ssh \
        -o StrictHostKeyChecking=accept-new \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=15 \
        -l "$win_user" \
        "$win_host" \
        -- "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"$cmd\""
}

if [ "$#" -lt 1 ]; then
    usage
    exit 64
fi

sub="$1"
shift

case "$sub" in
    list)
        printf '%-16s %s\n' "SHORT" "EXE"
        for k in "${!APPS[@]}"; do
            printf '%-16s %s\n' "$k" "${APPS[$k]}"
        done | sort
        ;;
    launch)
        if [ "$#" -lt 1 ]; then
            echo "mios-windows launch: missing <app>" >&2
            exit 64
        fi
        # Stdin mode: `mios-windows launch -` reads the path from
        # stdin. Sidesteps bash paren-parsing on paths like
        # C:\Program Files (x86)\Steam\steam.exe where the unquoted
        # `(x86)` triggers a subshell-syntax error before the script
        # is even invoked. Operator-confirmed regression 2026-05-16:
        # agent emitted `mios-windows launch C:\Program Files
        # (x86)\Steam\steam.exe` without quoting -- bash errored
        # "syntax error near unexpected token `('".
        if [ "$1" = "-" ]; then
            shift
            app="$(cat)"
            app="${app%$'\n'}"   # strip trailing newline
        else
            app="$1"
            shift
        fi
        # URI passthrough: `mios-windows launch uplay://launch/16732/0`
        # (or steam://, epic://, http://, etc.) re-dispatches to the
        # ps subcommand with Start-Process -- Windows registers
        # protocol handlers per scheme. Without this, the existence
        # check below rejects URIs as "unknown app" and the agent
        # spirals into refusal. Operator-confirmed regression
        # 2026-05-16: agent saw `mios-find "the crew motorfest"`
        # return `mios-windows ps "Start-Process uplay://..."` but
        # then called `mios-windows launch uplay://...` (wrong
        # subcommand) and got "unknown app", concluding the URL was
        # invalid. Now both subcommands accept URIs.
        # ─── URI / UWP launches: center+focus the resulting window ───
        # Direct .exe launches center via Start-Process -PassThru +
        # MainWindowHandle polling on $p (the launched process). URI
        # launches (steam://, com.epicgames.launcher://, http://, ...) and
        # UWP shell:appsFolder\ launches DON'T return the game's process
        # -- they return the protocol handler (steam.exe, explorer.exe).
        # Without explicit post-launch window discovery, these never get
        # centered. Operator directive 2026-05-17: "launching apps should
        # launch centered too!! MiOS Agents must have launch param/args
        # tools for launching applications(should always launch centered
        # and focused)".
        #
        # Strategy for URI/UWP: snapshot the current top-level window
        # handles, run Start-Process, poll for new top-level windows for
        # up to MIOS_LAUNCH_CENTER_TIMEOUT seconds (default 15), then
        # center+focus the first new window matching MIOS_LAUNCH_TITLE_HINT
        # (case-insensitive substring) -- or the first new window if no
        # hint. mios-find sets the hint to the app name from the
        # inventory so multi-window protocol handlers (Steam launches
        # both the storefront AND the game) center the right one.
        _build_uri_center_ps() {
            # $1 = Start-Process invocation, e.g. "Start-Process 'steam://...'"
            #      OR "Start-Process -FilePath explorer.exe -ArgumentList 'shell:appsFolder\\...'"
            # $2 = title hint (may be empty)
            local sp="$1"
            local hint="${2:-}"
            local timeout="${MIOS_LAUNCH_CENTER_TIMEOUT:-15}"
            # PowerShell here-doc: snapshot -> launch -> poll new windows.
            # Single-line for the broker's "CAPTURE: <cmdline>\n" wire.
            cat <<PSEOF
\$pre = (Get-Process | Where-Object { \$_.MainWindowHandle -ne 0 } | ForEach-Object { \$_.MainWindowHandle.ToInt64() })
${sp}
Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue
Add-Type -Name W32M2 -Namespace MX -MemberDefinition @'
[System.Runtime.InteropServices.DllImport("user32.dll")] public static extern bool MoveWindow(System.IntPtr h,int x,int y,int w,int n,bool r);
[System.Runtime.InteropServices.DllImport("user32.dll")] public static extern bool SetForegroundWindow(System.IntPtr h);
[System.Runtime.InteropServices.DllImport("user32.dll")] public static extern bool GetWindowRect(System.IntPtr h, out RECT r);
[System.Runtime.InteropServices.DllImport("user32.dll")] public static extern bool ShowWindow(System.IntPtr h, int n);
[System.Runtime.InteropServices.DllImport("dwmapi.dll")] public static extern int DwmSetWindowAttribute(System.IntPtr h,int a,ref int v,int s);
[System.Runtime.InteropServices.StructLayout(System.Runtime.InteropServices.LayoutKind.Sequential)] public struct RECT { public int L,T,R,B; }
'@ -ErrorAction SilentlyContinue
\$hint = '${hint}'
\$deadline = (Get-Date).AddSeconds(${timeout})
\$target = \$null
while ((Get-Date) -lt \$deadline) {
    \$candidates = Get-Process | Where-Object {
        \$_.MainWindowHandle -ne 0 -and (\$_.MainWindowHandle.ToInt64() -notin \$pre)
    }
    if (\$hint -ne '') {
        \$target = \$candidates | Where-Object { \$_.MainWindowTitle -match [regex]::Escape(\$hint) } | Select-Object -First 1
    } else {
        \$target = \$candidates | Select-Object -First 1
    }
    if (\$target) { break }
    Start-Sleep -Milliseconds 250
}
if (\$target) {
    # Un-minimize if needed (SW_RESTORE = 9), then center + focus.
    [MX.W32M2]::ShowWindow(\$target.MainWindowHandle, 9) | Out-Null
    \$r = New-Object MX.W32M2+RECT
    [MX.W32M2]::GetWindowRect(\$target.MainWindowHandle, [ref]\$r) | Out-Null
    \$w = \$r.R - \$r.L
    \$h = \$r.B - \$r.T
    \$s = [System.Windows.Forms.Screen]::PrimaryScreen.WorkingArea
    \$x = \$s.X + [int]((\$s.Width  - \$w) / 2)
    \$y = \$s.Y + [int]((\$s.Height - \$h) / 2)
    [MX.W32M2]::MoveWindow(\$target.MainWindowHandle, \$x, \$y, \$w, \$h, \$true) | Out-Null
    \$cp = 2; [MX.W32M2]::DwmSetWindowAttribute(\$target.MainWindowHandle, 33, [ref]\$cp, 4) | Out-Null
    [MX.W32M2]::SetForegroundWindow(\$target.MainWindowHandle) | Out-Null
    Write-Output ("[centered] " + \$target.ProcessName + " '" + \$target.MainWindowTitle + "' at (" + \$x + "," + \$y + ") size " + \$w + "x" + \$h)
} else {
    \$msg = "[no new top-level window appeared within ${timeout}s"
    if (\$hint -ne '') { \$msg = \$msg + " matching '" + \$hint + "'" }
    \$msg = \$msg + "]"
    Write-Output \$msg
}
PSEOF
        }

        case "$app" in
            *://*)
                _PS="$(_build_uri_center_ps "Start-Process '$app'" "${MIOS_LAUNCH_TITLE_HINT:-}")"
                exec "$0" ps "$_PS"
                ;;
            # UWP / Microsoft Store / Xbox / Game Pass apps. AppIDs come
            # in two shapes:
            #   1. shell:appsFolder\<PackageFamilyName>!<Entry>
            #      -- canonical full URI (what mios-apps writes to the
            #         windows-games cache for UWP entries)
            #   2. <PackageFamilyName>!<Entry>
            #      -- bare AppID as Get-StartApps returns
            #         (e.g. "Microsoft.Limitless_8wekyb3d8bbwe!App")
            # Both dispatch via explorer's shell:appsFolder URI handler
            # -- the standard Windows mechanism to launch a UWP package
            # by its package-family-name. Operator-flagged 2026-05-17:
            # "Microsoft Flight Simulator 2024 ... launching it directly
            # hasn'\''t been working" because the .exe doesn'\''t exist
            # at a predictable filesystem path for UWP packages.
            shell:appsFolder\\*|shell:AppsFolder\\*)
                # PowerShell's Start-Process doesn't grok shell: URIs
                # natively (it tries to resolve them as filesystem
                # paths and 404s). explorer.exe DOES grok them -- it's
                # the canonical Windows handler for shell: URIs. Wrap
                # via explorer.exe + the path as its arg.
                _PS="$(_build_uri_center_ps "Start-Process -FilePath explorer.exe -ArgumentList '$app'" "${MIOS_LAUNCH_TITLE_HINT:-}")"
                exec "$0" ps "$_PS"
                ;;
            *_[0-9a-z]*\!*)
                # Bare AppID (PackageFamilyName!Entry) from Get-StartApps
                # -- prepend shell:appsFolder\ then dispatch the same
                # explorer.exe way.
                _PS="$(_build_uri_center_ps "Start-Process -FilePath explorer.exe -ArgumentList 'shell:appsFolder\\$app'" "${MIOS_LAUNCH_TITLE_HINT:-}")"
                exec "$0" ps "$_PS"
                ;;
        esac
        # Translate Windows-style paths (C:\... or D:\...) to WSL paths
        # before the existence check. Operator-confirmed regression
        # 2026-05-16: mios-find returns Windows-style paths (intended
        # for Start-Process on the Windows side) -- mios-windows
        # launch was rejecting them with "unknown app" because the
        # bash `[ -e <C:\...> ]` test cant resolve a literal backslash
        # path from WSL. wslpath -u handles the translation.
        case "$app" in
            [A-Za-z]:\\*|[A-Za-z]:/*)
                if _wsl="$(wslpath -u "$app" 2>/dev/null)" && [ -n "$_wsl" ]; then
                    app="$_wsl"
                fi
                ;;
        esac
        if [ -n "${APPS[$app]:-}" ]; then
            target="${APPS[$app]}"
        elif [ -e "$app" ]; then
            target="$app"
        elif [ -e "/mnt/c/Windows/System32/${app}" ]; then
            target="/mnt/c/Windows/System32/${app}"
        elif [ -e "/mnt/c/Windows/System32/${app}.exe" ]; then
            target="/mnt/c/Windows/System32/${app}.exe"
        else
            # Last-resort: ask mios-find. Operator-confirmed regression
            # 2026-05-16 night: agent called `mios-windows launch beamng`
            # (just the name) and got "unknown app", then FABRICATED a
            # nonexistent "mios-windows install" subcommand to suggest.
            # If mios-find returns ONE runnable line, exec it -- this
            # is the canonical chain anyway (mios-find -> launch), now
            # done implicitly so the helper is forgiving.
            if command -v mios-find >/dev/null 2>&1; then
                _resolved="$(mios-find "$app" 2>/dev/null | head -1)"
                if [ -n "$_resolved" ]; then
                    echo "mios-windows launch: '$app' resolved via mios-find -> $_resolved" >&2
                    exec sh -c "$_resolved"
                fi
            fi
            echo "mios-windows launch: unknown app '$app' -- run 'mios-find $app' or pass a full .exe path" >&2
            exit 1
        fi
        if [ ! -e "$target" ]; then
            echo "mios-windows launch: $target not found on disk -- is the Windows side missing the app?" >&2
            exit 1
        fi

        # ── Service-user broker route ─────────────────────────────────
        # Operator-confirmed regression 2026-05-16: agent ran
        # `mios-windows launch ...` -> process succeeded, returned PID,
        # but operator saw NOTHING on screen. Cause: direct setsid+nohup
        # from mios-hermes (uid 820) launches the .exe in the WSL
        # SERVICE session, not the operator's interactive Windows
        # session. The window opens in session-0 (invisible) instead
        # of session-1 (operator's desktop).
        #
        # Fix: route through the operator-side launcher broker. The
        # broker runs as the operator (uid 992) inside their WSLg
        # session; Start-Process there pops the window in the
        # operator's interactive desktop where it's actually visible.
        _my_uid="$(id -u)"
        _op_uid="$(id -u mios 2>/dev/null || echo 1000)"
        if [ "$_my_uid" -lt "$_op_uid" ] && [ -S /run/mios-launcher/launcher.sock ]; then
            # Translate /mnt/c/... back to C:\... for Start-Process
            _target_win="$(wslpath -w "$target" 2>/dev/null)"
            [ -z "$_target_win" ] && _target_win="$target"
            python3 - "$_target_win" "$@" <<'PYEOF'
import socket, sys, shlex
target = sys.argv[1]
extra_args = sys.argv[2:]
# Build the PowerShell Start-Process call + auto-center post-launch.
# Operator directive 2026-05-16: "MiOS apps STILL don't center launch
# and don't self center". Default Win32 placement is top-left or
# last-position; centering here means every launched window appears
# in the middle of the operator's primary monitor working area.
# -PassThru returns the Process object so we can read MainWindowHandle.
start = f"$p = Start-Process -FilePath {shlex.quote(target)} -PassThru"
if extra_args:
    arglist = ", ".join(shlex.quote(a) for a in extra_args)
    start = f"$p = Start-Process -FilePath {shlex.quote(target)} -ArgumentList {arglist} -PassThru"
center = (
    "; "
    "for ($i = 0; $i -lt 50; $i++) { "
    "  $p = Get-Process -Id $p.Id -ErrorAction SilentlyContinue; "
    "  if ($p -and $p.MainWindowHandle -ne 0) { break }; "
    "  Start-Sleep -Milliseconds 100 "
    "}; "
    "if ($p -and $p.MainWindowHandle -ne 0) { "
    "  Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue; "
    "  Add-Type -Name W32M -Namespace MX -MemberDefinition @'\n"
    "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool MoveWindow(System.IntPtr h,int x,int y,int w,int n,bool r);\n"
    "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool SetForegroundWindow(System.IntPtr h);\n"
    "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool GetWindowRect(System.IntPtr h, out RECT r);\n"
    "[System.Runtime.InteropServices.DllImport(\"dwmapi.dll\")] public static extern int DwmSetWindowAttribute(System.IntPtr h,int a,ref int v,int s);\n"
    "[System.Runtime.InteropServices.StructLayout(System.Runtime.InteropServices.LayoutKind.Sequential)] public struct RECT { public int L,T,R,B; }\n"
    "'@ -ErrorAction SilentlyContinue; "
    "$r = New-Object MX.W32M+RECT; "
    "[MX.W32M]::GetWindowRect($p.MainWindowHandle, [ref]$r) | Out-Null; "
    "$w = $r.R - $r.L; $h = $r.B - $r.T; "
    "$s = [System.Windows.Forms.Screen]::PrimaryScreen.WorkingArea; "
    "$x = $s.X + [int](($s.Width - $w) / 2); "
    "$y = $s.Y + [int](($s.Height - $h) / 2); "
    "[MX.W32M]::MoveWindow($p.MainWindowHandle, $x, $y, $w, $h, $true) | Out-Null; "
    # Win11 DWMWA_WINDOW_CORNER_PREFERENCE = 33; DWMCSP_ROUND = 2.
    # Forces rounded corners on the launched window even when the
    # window class would normally render square (common for WSLg
    # / Xwayland / Electron / non-Adwaita Win32 apps). Silently no-ops
    # on Win10. Operator directive 2026-05-16: "the application
    # windows should be rounded globally again TOO".
    "$cp = 2; [MX.W32M]::DwmSetWindowAttribute($p.MainWindowHandle, 33, [ref]$cp, 4) | Out-Null; "
    "[MX.W32M]::SetForegroundWindow($p.MainWindowHandle) | Out-Null "
    "}"
)
ps = start + center
# PowerShell path resolution order (operator directive 2026-05-16:
# environment args first):
#   1. $WINDOWS_POWERSHELL env (set by hermes-agent.service.d drop-in)
#   2. mios.toml [paths].powershell_exe
#   3. canonical default
import os
def _resolve_powershell():
    env = os.environ.get("WINDOWS_POWERSHELL")
    if env:
        return env
    try:
        import tomllib
        for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
            try:
                with open(p, "rb") as f:
                    d = tomllib.load(f)
                v = d.get("paths", {}).get("powershell_exe")
                if v:
                    return v
            except (OSError, tomllib.TOMLDecodeError):
                continue
    except ImportError:
        pass
    return "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
PWSH_PATH = _resolve_powershell()
line = "CAPTURE: " + PWSH_PATH + " -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command " + shlex.quote(ps)
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(30.0)
s.connect("/run/mios-launcher/launcher.sock")
s.sendall((line + "\n").encode())
buf = b""
while True:
    chunk = s.recv(8192)
    if not chunk: break
    buf += chunk
print(f"[mios-windows] launched via broker: {target} (operator session)")
PYEOF
            exit 0
        fi

        # Same-uid-as-broker / no-broker fallback: invoke
        # Start-Process via PowerShell DIRECTLY (no setsid+nohup).
        # Operator-flagged 2026-05-18: "NOTHING OPENED AT ALL" --
        # notepad.exe was exec'd via setsid+nohup, the process ran
        # (pid 499978) but MainWindowHandle=0 because
        # mios-launcher.service runs under user@992.service (the
        # USER MANAGER slice), not the operator's interactive
        # Windows session. Direct .exe exec from the manager slice
        # spawns a process with no desktop; Start-Process via
        # PowerShell always opens in the operator's foreground
        # session where a window can render.
        _target_win="$(wslpath -w "$target" 2>/dev/null)"
        [ -z "$_target_win" ] && _target_win="$target"
        if [ -x "$PWSH" ]; then
            python3 - "$_target_win" "$PWSH" "$@" <<'PYEOF'
import shlex, subprocess, sys
target = sys.argv[1]
pwsh = sys.argv[2]
extra_args = sys.argv[3:]
start = f"$p = Start-Process -FilePath {shlex.quote(target)} -PassThru"
if extra_args:
    arglist = ", ".join(shlex.quote(a) for a in extra_args)
    start = (f"$p = Start-Process -FilePath {shlex.quote(target)} "
             f"-ArgumentList {arglist} -PassThru")
# Operator directive 2026-05-18: "MiOS-Agent(s) MUST also KNOW
# window launch params/args to be able to launch and move
# precisely!!!". Three env-driven knobs the caller can set BEFORE
# invoking mios-windows launch:
#   MIOS_LAUNCH_POSITION   left|right|top|bottom|center|none
#                          (default: center; "none" leaves WHERE the
#                          OS placed the window)
#   MIOS_LAUNCH_SIZE       <W>x<H>  (e.g. 1280x720; default: keep
#                          the size Start-Process gave the window)
#   MIOS_LAUNCH_PLACE      <X>,<Y>  (absolute top-left, takes
