#!/bin/bash
# /usr/libexec/mios/mios-windows [-e] <powershell-command-or-block>
#
# Run a PowerShell command on the WINDOWS host (the machine this WSL
# distro runs inside) via Tailscale SSH. The agent uses this when it
# needs to do something Windows-side that the WSL VM can't reach:
# Restart-Service vmcompute, New-NetFirewallRule, Restart-Computer,
# inspect Hyper-V state, query Get-Process for the host, etc.
#
# Topology:
#   agent (WSL) ---> Tailscale (loopback to Windows tailscale IP)
#               ---> Windows host's Tailscale SSH ---> powershell.exe
#
# Auth: handled by Tailscale (your tailnet ACL); no SSH keys to manage,
# no port-22 hole on the LAN. The Windows node must have Tailscale SSH
# enabled with `tailscale set --ssh` (one-time, elevated) -- see
# /usr/share/doc/mios/guides/agent-windows-ssh.md.
#
# Elevation: by default, Tailscale SSH runs commands with the Windows
# user's filtered (non-elevated) token, even when the user is in the
# Administrators group, because of UAC. For commands that need
# elevation (Restart-Service, New-NetFirewallRule, registry writes),
# pass -e / --elevated -- this wraps the command in a Task Scheduler
# trigger that runs as SYSTEM. NOT YET WIRED -- placeholder.

set -eu

# Resolve Windows tailscale IP. Single-tenant dev VM contract: there's
# exactly one Windows host on the tailnet that this distro runs inside.
# The IP is stored once in /etc/mios/windows-host (created by
# mios-hermes-firstboot if Tailscale is detected) so we don't have to
# re-derive it from /etc/resolv.conf or `ip route` every call.
WIN_HOST_FILE=/etc/mios/windows-host
if [ -r "$WIN_HOST_FILE" ]; then
    WIN_HOST="$(cat "$WIN_HOST_FILE")"
else
    # Fallback: use the WSL default gateway (the Windows-side IP from
    # WSL's perspective). NOT routed via Tailscale, so will skip the
    # Tailscale ACL/SSH path.
    WIN_HOST="$(ip route show default 2>/dev/null | awk '/default/{print $3; exit}')"
    if [ -z "$WIN_HOST" ]; then
        echo "mios-windows: cannot determine Windows host (no $WIN_HOST_FILE, no default gateway)" >&2
        exit 1
    fi
fi

# Resolve operator username -- the agent's identity for the SSH session.
# Tailscale SSH maps from your tailnet identity to a local Windows user
# per ACL; we just need the Windows username to pass to ssh.
WIN_USER=""
if [ -r /usr/share/mios/mios.toml ]; then
    WIN_USER="$(awk -F\" '/^\s*windows_user\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
fi
[ -z "$WIN_USER" ] && WIN_USER="$(awk -F\" '/^\s*username\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
[ -z "$WIN_USER" ] && WIN_USER="$USER"

ELEVATED=0
if [ "${1:-}" = "-e" ] || [ "${1:-}" = "--elevated" ]; then
    ELEVATED=1
    shift
fi

if [ "$#" -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<EOF
usage: mios-windows [-e|--elevated] <powershell-command>

  Run a PowerShell command on the Windows host (this WSL distro's
  parent) via Tailscale SSH.

  -e, --elevated    Wrap in a SYSTEM-level Task Scheduler trigger
                    (REQUIRED for: Restart-Service, New-NetFirewallRule,
                     registry writes, Restart-Computer).

  examples:
    mios-windows 'Get-Service vmcompute | Format-List'
    mios-windows 'Get-NetIPAddress -AddressFamily IPv4 | Where-Object {\$_.PrefixOrigin -eq "Dhcp"}'
    mios-windows -e 'Restart-Service vmcompute -Force'
    mios-windows -e 'New-NetFirewallRule -DisplayName "MiOS test" -LocalPort 1234 ...'

  config (resolved at call time):
    WIN_HOST  = $WIN_HOST   (from $WIN_HOST_FILE or default gateway)
    WIN_USER  = $WIN_USER   (from mios.toml [identity].windows_user OR .username)
EOF
    exit 0
fi

CMD="$*"

if [ "$ELEVATED" = "1" ]; then
    cat >&2 <<EOF
mios-windows: -e/--elevated not yet wired.

For elevated commands, the operator needs to either:
  (a) Run the equivalent in elevated PowerShell on the host themselves
  (b) Set up a SYSTEM-level scheduled task that watches a queue dir
      (see /usr/share/doc/mios/guides/agent-windows-ssh.md for the
       trigger-file pattern; not yet shipped)

Falling back to non-elevated SSH; command may fail with 'Access denied'
if it needs admin. Original command:
  $CMD
EOF
fi

# SSH via Tailscale to the Windows host. Tailscale's bundled sshd
# handles the connection (no Windows OpenSSH Server needed). The
# command is invoked through Windows' powershell.exe directly; output
# is forwarded back over the SSH stdout.
exec ssh \
    -o StrictHostKeyChecking=accept-new \
    -o ConnectTimeout=10 \
    -o ServerAliveInterval=15 \
    -l "$WIN_USER" \
    "$WIN_HOST" \
    -- "powershell.exe -NoProfile -NonInteractive -Command \"$CMD\""
