#    Operator-flagged 2026-05-18: open_app(name="notepad") with
#    position="as-is" (the new typed-tool default) succeeded -- but
#    notepad opened BEHIND Windows Xbox Fullscreen Experience and
#    was never brought to the foreground because the placement
#    script was gated on `position != "none"` and skipped focus too.
#    Fix: split focus from placement. ALWAYS bring the new window to
#    the foreground (works around XFSE / Game Bar / any active full-
#    screen overlay); only call MoveWindow when position changes.
#
#    Bulletproof Win32 focus pattern: AttachThreadInput (attach our
#    thread to the target's; SetForegroundWindow always succeeds
#    once attached) + ShowWindow SW_RESTORE (handles minimized) +
#    BringWindowToTop + SetForegroundWindow + a SendKeys nudge to
#    grant the foreground-window permission Windows otherwise
#    restricts.
if pwsh:
    proc_name = target.rsplit("\\", 1)[-1]
    if proc_name.lower().endswith(".exe"):
        proc_name = proc_name[:-4]
    # Move only when position changes geometry. "as-is" and "none"
    # leave the window where the OS put it; "default" applies the
    # golden-16:10 centered geometry (the new MiOS global default).
    do_move = position not in ("none", "as-is")
    move_block = ""
    if do_move:
        # place_block already uses $wh for window-height (clean
        # naming -- no $h shadowing of the hwnd variable).
        move_block = (
            "$r = New-Object MX.W32D+RECT; "
            "[MX.W32D]::GetWindowRect($h, [ref]$r) | Out-Null; "
            f"{place_block}"
            "[MX.W32D]::MoveWindow($h, $x, $y, $w, $wh, $true) | Out-Null; "
        )
    do_focus = position not in ("none", "as-is")
    focus_block = ""
    if do_focus:
        focus_block = (
            "[MX.W32D]::ShowWindow($h, 9) | Out-Null; "
            "try { [System.Windows.Forms.SendKeys]::SendWait('%') } catch {}; "
            "$tpid = 0; $tt = [MX.W32D]::GetWindowThreadProcessId($h, [ref]$tpid); "
            "$ct = [MX.W32D]::GetCurrentThreadId(); "
            "[MX.W32D]::AttachThreadInput($ct, $tt, $true) | Out-Null; "
            "[MX.W32D]::BringWindowToTop($h) | Out-Null; "
            "[MX.W32D]::SetForegroundWindow($h) | Out-Null; "
            "[MX.W32D]::SwitchToThisWindow($h, $true) | Out-Null; "
            "[MX.W32D]::AttachThreadInput($ct, $tt, $false) | Out-Null; "
        )
    place_ps = (
        f"$pn = '{proc_name}'; "
        "$p = $null; "
        "for ($i = 0; $i -lt 50; $i++) { "
        "  $p = Get-Process -Name $pn -ErrorAction SilentlyContinue | "
        "       Where-Object MainWindowHandle -ne 0 | "
        "       Sort-Object StartTime -Descending | Select-Object -First 1; "
        "  if ($p) { break }; "
        "  Start-Sleep -Milliseconds 150 "
        "}; "
        "if ($p) { "
        "  Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue; "
        "  Add-Type -Name W32D -Namespace MX -MemberDefinition @'\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool MoveWindow(System.IntPtr h,int x,int y,int w,int n,bool r);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool SetForegroundWindow(System.IntPtr h);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool BringWindowToTop(System.IntPtr h);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool ShowWindow(System.IntPtr h, int n);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern int GetWindowThreadProcessId(System.IntPtr h, out int pid);\n"
        "[System.Runtime.InteropServices.DllImport(\"kernel32.dll\")] public static extern int GetCurrentThreadId();\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool AttachThreadInput(int idAttach, int idAttachTo, bool fAttach);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool GetWindowRect(System.IntPtr h, out RECT r);\n"
        "[System.Runtime.InteropServices.DllImport(\"user32.dll\")] public static extern bool SwitchToThisWindow(System.IntPtr h, bool fAltTab);\n"
        "[System.Runtime.InteropServices.StructLayout(System.Runtime.InteropServices.LayoutKind.Sequential)] public struct RECT { public int L,T,R,B; }\n"
        "'@ -ErrorAction SilentlyContinue; "
        "$h = $p.MainWindowHandle; "
        # ── optional move (only when position changed) ──
        f"{move_block}"
        # ── optional focus (skipped for background / as-is) ──
        f"{focus_block}"
        "}"
    )
    subprocess.Popen(
        [pwsh, "-NoProfile", "-NonInteractive",
         "-ExecutionPolicy", "Bypass", "-Command", place_ps],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL, start_new_session=True,
    )
PYEOF
        else
            # Last-resort fallback if PowerShell is unreachable.
            # Operator should never hit this path on a healthy MiOS;
            # window will almost certainly be invisible. Logged so
            # post-mortem can identify the missing-PWSH cause.
            setsid nohup "$target" "$@" >/dev/null 2>&1 < /dev/null &
            echo "[mios-windows] WARN: PowerShell unreachable; setsid fallback used (window likely invisible)" >&2
        fi
        ;;
    ps|powershell)
        if [ "$#" -lt 1 ]; then
            echo "mios-windows ps: missing <command>" >&2
            exit 64
        fi
        # Service-user routing: mios-hermes (uid 820) cannot exec
        # /mnt/c/.../powershell.exe directly because of the WSL
        # metadata-perm wall. Route through the operator-side
        # launcher broker's CAPTURE protocol -- broker runs the
        # PS command in its own (operator) context, captures
        # stdout+stderr via subprocess.PIPE, sends bytes back to
        # us inline. No tempfile; no cross-user write.
        _my_uid="$(id -u)"
        _op_uid="$(id -u mios 2>/dev/null || echo 1000)"
        if [ "$_my_uid" -lt "$_op_uid" ] && [ -S /run/mios-launcher/launcher.sock ]; then
            python3 - "$PWSH" "$*" <<'PYEOF'
import socket, sys, shlex
pwsh, cmd = sys.argv[1], sys.argv[2]
line = (
    "CAPTURE: " +
    f"{shlex.quote(pwsh)} -NoProfile -NonInteractive -ExecutionPolicy Bypass "
    f"-Command {shlex.quote(cmd)}"
)
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(60.0)
s.connect("/run/mios-launcher/launcher.sock")
s.sendall((line + "\n").encode())
# Read until EOF (broker closes after capture done).
buf = b""
while True:
    chunk = s.recv(8192)
    if not chunk:
        break
    buf += chunk
sys.stdout.buffer.write(buf)
PYEOF
            exit 0
        fi
        if [ ! -x "$PWSH" ]; then
            echo "mios-windows ps: PowerShell not at $PWSH -- set MIOS_WINDOWS_PWSH=<path>" >&2
            exit 1
        fi
        exec "$PWSH" -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command "$*"
        ;;
    cmd)
        if [ "$#" -lt 1 ]; then
            echo "mios-windows cmd: missing <command>" >&2
            exit 64
        fi
        # Same CAPTURE route for service users (no tempfile dance).
        _my_uid="$(id -u)"
        _op_uid="$(id -u mios 2>/dev/null || echo 1000)"
        if [ "$_my_uid" -lt "$_op_uid" ] && [ -S /run/mios-launcher/launcher.sock ]; then
            python3 - "$CMD" "$*" <<'PYEOF'
import socket, sys, shlex
cmd_exe, cmd = sys.argv[1], sys.argv[2]
line = "CAPTURE: " + f"{shlex.quote(cmd_exe)} /c {shlex.quote(cmd)}"
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(60.0)
s.connect("/run/mios-launcher/launcher.sock")
s.sendall((line + "\n").encode())
buf = b""
while True:
    chunk = s.recv(8192)
    if not chunk:
        break
    buf += chunk
sys.stdout.buffer.write(buf)
PYEOF
            exit 0
        fi
        if [ ! -x "$CMD" ]; then
            echo "mios-windows cmd: cmd.exe not at $CMD" >&2
            exit 1
        fi
        exec "$CMD" /c "$*"
        ;;
    ssh-ps)
        do_ssh_ps "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        # Backwards-compat: if the first arg looks like a PowerShell
        # command (starts with a verb like Get-/Set-/New-/Restart-),
        # treat the whole call as the legacy "ssh-ps <cmd>" form to
        # keep operator muscle memory working.
        case "$sub" in
            Get-*|Set-*|New-*|Remove-*|Start-*|Stop-*|Restart-*|Test-*|Invoke-*|*'-'*)
                echo "[mios-windows] legacy form -- routing to ssh-ps; use 'mios-windows ps' for non-Tailscale interop" >&2
                do_ssh_ps "$sub" "$@"
                ;;
            *)
                echo "mios-windows: unknown subcommand: $sub" >&2
                usage >&2
                exit 64
                ;;
        esac
        ;;
esac
