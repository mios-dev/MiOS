#!/bin/bash
# /usr/libexec/mios/mios-find <query>
#
# Fast fuzzy lookup against the cached environment inventory. Use this
# as the FIRST step whenever the operator says "launch <app>" --
# returns a ready-to-execute launch command in <100 ms, without any
# Get-ChildItem -Recurse over the Windows drive.
#
# Output (single line on stdout when match is unambiguous):
#   <launch-command>
#
# Output (multiple matches, top 5 to stderr + nothing to stdout):
#   N matches for "<query>" (top 5):
#     1. [<category>] <name>  ->  <launch>
#     ...
#
# Output (no match, exit 1):
#   no match for "<query>" in inventory; try `mios-apps --filter <substr>`
#
# Operator directive 2026-05-16: "MiOS-Hermes should be given the
# opportunity to map out it's environment for faster follow-up
# questions like ex; 'launch this app for me' should be snappy
# because MiOS-Agent(s) initialize and understand the environment
# and where everything already is".
#
# Implementation: shells out to `mios-apps --json` which returns
# JSONL of every known launchable thing across Linux + Windows. The
# Windows side is pre-cached for 5 minutes inside mios-apps (via
# Get-StartApps), so mios-find inherits that speed.

set -eu

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<'USAGE'
usage: mios-find <query>

Fast fuzzy lookup against the MiOS environment inventory. Returns
the launch command for the best match, or lists candidates if the
query is ambiguous. Use as the FIRST step before any Get-ChildItem
when the operator asks to launch something.

Forms (every token in <ANGLES> is operator-substituted; do not
interpret as a specific app name):
  mios-find <query>             -> ONE runnable launch line on stdout
  mios-find <multi word query>  -> quote it: "<multi word query>"
  mios-find <alias>             -> resolved via mios.toml [mios-find.aliases]

The output line is ready-to-execute (mios-gui <id>, mios-windows
launch <path>, mios-windows ps "Start-Process '<uri>'", etc.). Run
it AS-IS; don't re-shape into a different subcommand.
USAGE
    exit 0
fi

QUERY="$*"
QUERY="${QUERY#\"}"
QUERY="${QUERY%\"}"

# ─── Alias resolution: generic queries -> specific apps ───────────────
# Operator directive 2026-05-16: "open a browser to URL" returns
# mios-hermes-browser (headless agent CDP) instead of chromedev
# (visible operator browser) because "browser" is in the agent
# binary's name. Add a TOML-first alias table so operators can
# remap generic words ("browser", "web browser", "the browser") to
# their preferred concrete app. Read from mios.toml [mios-find.aliases].
ALIAS_TARGET=""
ALIAS_TARGET="$(python3 - "$QUERY" <<'PYEOF' 2>/dev/null
import sys, tomllib
q = sys.argv[1].strip().lower()
if not q:
    sys.exit(0)
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
        aliases = d.get("mios-find", {}).get("aliases", {})
        if not isinstance(aliases, dict):
            continue
        for k, v in aliases.items():
            if isinstance(k, str) and isinstance(v, str) and k.strip().lower() == q:
                print(v)
                sys.exit(0)
    except (OSError, tomllib.TOMLDecodeError, AttributeError):
        continue
PYEOF
)"
if [ -n "$ALIAS_TARGET" ]; then
    # Re-run mios-find with the alias target as the query (single-level;
    # an alias value is a concrete app name, not another alias).
    echo "(alias: '$QUERY' -> '$ALIAS_TARGET')" >&2
    QUERY="$ALIAS_TARGET"
fi

# ─── Fast path A: delegate to mios-everything ─────────────────────────
# Operator directive 2026-05-16: "WE HAVE EVERYTHING CLI STILL DOING
# NOTHING AS A TOOL FOR THE ENTIRE MIOS AGENTIC STACKS" -- promoted
# the es.exe probe + invocation out of this script into the
# first-class mios-everything helper. Any agent can now use
# mios-everything directly; mios-find just calls it as one of its
# resolution sources.
if command -v mios-everything >/dev/null 2>&1; then
    ES_OUT="$(mios-everything -n 5 -ext exe "$QUERY" 2>/dev/null)"
    if [ -n "$ES_OUT" ]; then
        FIRST_EXE="$(printf '%s\n' "$ES_OUT" | head -1)"
        if [ -n "$FIRST_EXE" ]; then
            ESCAPED="$(printf '%s' "$FIRST_EXE" | sed 's/\\/\\\\/g')"
            echo "mios-windows launch \"$ESCAPED\""
            n_alt="$(printf '%s\n' "$ES_OUT" | wc -l)"
            if [ "$n_alt" -gt 1 ]; then
                echo "(found via mios-everything; $((n_alt - 1)) other .exe matches:)" >&2
                printf '%s\n' "$ES_OUT" | tail -n +2 | sed 's/^/  /' >&2
            fi
            exit 0
        fi
    fi
fi

# ─── Fast path B: mios-apps inventory (Linux + Windows Start Menu + games) ─
python3 - "$QUERY" <<'PYEOF'
import json
import re
import subprocess
import sys

query = sys.argv[1].strip().lower()
if not query:
    print("mios-find: empty query", file=sys.stderr)
    sys.exit(2)

try:
    out = subprocess.check_output(
        ["mios-apps", "--json"], text=True, timeout=15
    )
except (subprocess.CalledProcessError, subprocess.TimeoutExpired, FileNotFoundError) as e:
    print(f"mios-find: mios-apps failed: {e}", file=sys.stderr)
    sys.exit(3)

CAT_PRIORITY = {
    "windows-app":     1,
    "linux-flatpak":   2,
    "linux-rpm-gui":   3,
    "mios-shim":       4,
    "windows-gui":     5,
    "agent-cli":       6,
    "service-url":     7,
}

entries = []
for line in out.splitlines():
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
    except json.JSONDecodeError:
        continue
    name = (e.get("name") or "").lower()
    desc = (e.get("description") or "").lower()
    cat = e.get("category") or ""
    launch = e.get("launch") or e.get("command") or ""
    if not name or not launch:
        continue
    entries.append({
        "name": e.get("name"),
        "desc": e.get("description") or "",
        "cat": cat,
        "launch": launch,
        "lname": name,
        "ldesc": desc,
    })

def rank(e):
    n = e["lname"]
    d = e["ldesc"]
    if n == query:
        return (0, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if n.startswith(query):
        return (1, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if re.search(rf"\b{re.escape(query)}", n):
        return (2, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if query in n:
        return (3, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if re.search(rf"\b{re.escape(query)}", d):
        return (4, CAT_PRIORITY.get(e["cat"], 99), len(d))
    if query in d:
        return (5, CAT_PRIORITY.get(e["cat"], 99), len(d))
    return None

scored = []
for e in entries:
    r = rank(e)
    if r is not None:
        scored.append((r, e))
scored.sort(key=lambda x: x[0])

if not scored:
    print(f'no match for "{query}" in inventory; '
          f'try `mios-apps --filter {query}` or list with `mios-apps`',
          file=sys.stderr)
    sys.exit(1)

# Auto-resolve ambiguity by picking the highest-priority CATEGORY
# match at the best tier. The sort already orders by
# (tier, category-priority, length), so scored[0] is always the
# "best" by our rules. Print it. If there are >1 matches, also
# emit a brief "n other candidates" note to stderr for transparency
# -- but DO NOT bounce back to the operator demanding re-query
# (operator directive 2026-05-16: "should be snappy").
best = scored[0][1]
print(best["launch"])
if len(scored) > 1:
    n_alt = min(4, len(scored) - 1)
    print(f'(picked best of {len(scored)}; {n_alt} alternatives:)',
          file=sys.stderr)
    for i, (_, e) in enumerate(scored[1:1+n_alt], 1):
        print(f'  {i}. [{e["cat"]:<14}] {e["name"]:<30} -> {e["launch"]}',
              file=sys.stderr)
sys.exit(0)
PYEOF
