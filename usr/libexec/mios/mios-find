#!/bin/bash
# AI-hint: Provides high-speed fuzzy lookup against the cached environment inventory to resolve "launch <app>" requests into executable commands in <100ms, bypassing slow filesystem crawls.
# AI-related: /usr/libexec/mios/mios-find, /etc/mios/mios.toml, /usr/share/mios/mios.toml, mios-apps, mios-everything, mios-gui, mios-windows, mios-find-err, mios-hermes-browser, mios-shim
set -euo pipefail
# /usr/libexec/mios/mios-find <query>
#
# Fast fuzzy lookup against the cached environment inventory. Use this
# as the FIRST step whenever the operator says "launch <app>" --
# returns a ready-to-execute launch command in <100 ms, without any
# Get-ChildItem -Recurse over the Windows drive.
#
# Output (single line on stdout when match is unambiguous):
#   <launch-command>
#
# Output (multiple matches, top 5 to stderr + nothing to stdout):
#   N matches for "<query>" (top 5):
#     1. [<category>] <name>  ->  <launch>
#     ...
#
# Output (no match, exit 1):
#   no match for "<query>" in inventory; try `mios-apps --filter <substr>`
#
# Operator directive 2026-05-16: "MiOS-Hermes should be given the
# opportunity to map out it's environment for faster follow-up
# questions like ex; 'launch this app for me' should be snappy
# because MiOS-Agent(s) initialize and understand the environment
# and where everything already is".
#
# Implementation: shells out to `mios-apps --json` which returns
# JSONL of every known launchable thing across Linux + Windows. The
# Windows side is pre-cached for 5 minutes inside mios-apps (via
# Get-StartApps), so mios-find inherits that speed.

# `set -u` only -- catches unset variables but tolerates non-zero
# exits from sub-commands. Fast-path A's `mios-everything -ext exe`
# CAN return non-zero on no-match, which under `set -e` aborted the
# whole script before fast-path B (the inventory python) ever ran --
# operator-flagged 2026-05-17: "open wallpaper engine for me" failed
# because mios-find silently exit-0'\''d with no output. Fall-through
# resolution is the design intent; errexit defeats it.
set -u

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<'USAGE'
usage: mios-find [--json] <query>

Fast fuzzy lookup against the MiOS environment inventory. Returns
the launch command for the best match, or lists candidates if the
query is ambiguous. Use as the FIRST step before any Get-ChildItem
when the operator asks to launch something.

Forms:
  mios-find <query>             -> ONE runnable launch line on stdout
  mios-find --json <query>      -> structured envelope:
                                   {ok, query, resolved:{launch,
                                    source, alias?}, alternates[]}
  mios-find <multi word query>  -> quote it: "<multi word query>"
  mios-find <alias>             -> resolved via mios.toml [mios-find.aliases]

The plain (no --json) output line is ready-to-execute (mios-gui
<id>, mios-windows launch <path>, etc.). Run it AS-IS; don't re-
shape into a different subcommand.
USAGE
    exit 0
fi

# --json flag flips emit mode. Operator directive 2026-05-18 (task
# #148): shims that the planner / polish-grounding consume should
# emit structured envelopes so the agent reads typed fields, not
# prose. The existing dual-emit paths (fast-path A es.exe / fast-
# path B inventory-rank) are preserved; this flag wraps their
# output post-hoc.
JSON_OUT=0
if [ "$1" = "--json" ]; then
    JSON_OUT=1
    shift
fi

QUERY="$*"
QUERY="${QUERY#\"}"
QUERY="${QUERY%\"}"

# If --json was passed, re-exec ourselves WITHOUT the flag, capture
# stdout+stderr+exit, then emit a structured envelope. Cleanest way
# to wrap the dual-emit fast-paths below without duplicating their
# logic.
if [ "$JSON_OUT" -eq 1 ]; then
    _OUT="$("$0" "$QUERY" 2>/tmp/.mios-find-err.$$)"
    _RC=$?
    _ERR="$(cat /tmp/.mios-find-err.$$ 2>/dev/null)"
    rm -f /tmp/.mios-find-err.$$ 2>/dev/null
    _OUT="$_OUT" _ERR="$_ERR" _RC="$_RC" _QUERY="$QUERY" python3 - <<'PYEOF'
import json, os
out = os.environ.get("_OUT", "").strip()
err = os.environ.get("_ERR", "")
rc = int(os.environ.get("_RC", "0"))
query = os.environ.get("_QUERY", "")
envelope = {
    "ok": rc == 0,
    "verb": "mios_find",
    "query": query,
    "exit_code": rc,
}
if rc == 0 and out:
    envelope["resolved"] = {"launch": out}
    # The fast-path A path prints '(found via mios-everything; ...'
    # to stderr; the fast-path B path leaves stderr empty. Use that
    # to attribute the source so polish knows where the launch came
    # from.
    if "via mios-everything" in err:
        envelope["resolved"]["source"] = "mios-everything"
    elif "alias:" in err:
        envelope["resolved"]["source"] = "alias"
    else:
        envelope["resolved"]["source"] = "mios-apps"
    if err.strip():
        envelope["stderr_preview"] = err.strip()[:600]
else:
    envelope["error"] = "no_match"
    if err.strip():
        envelope["stderr_preview"] = err.strip()[:600]
print(json.dumps(envelope))
PYEOF
    exit "$_RC"
fi

# ─── Alias resolution: generic queries -> specific apps ───────────────
# Operator directive 2026-05-16: "open a browser to URL" returns
# mios-hermes-browser (headless agent CDP) instead of chromedev
# (visible operator browser) because "browser" is in the agent
# binary's name. Add a TOML-first alias table so operators can
# remap generic words ("browser", "web browser", "the browser") to
# their preferred concrete app. Read from mios.toml [mios-find.aliases].
ALIAS_TARGET=""
ALIAS_TARGET="$(python3 - "$QUERY" <<'PYEOF' 2>/dev/null
import sys, tomllib
q = sys.argv[1].strip().lower()
if not q:
    sys.exit(0)
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
        aliases = d.get("mios-find", {}).get("aliases", {})
        if not isinstance(aliases, dict):
            continue
        for k, v in aliases.items():
            if isinstance(k, str) and isinstance(v, str) and k.strip().lower() == q:
                print(v)
                sys.exit(0)
    except (OSError, tomllib.TOMLDecodeError, AttributeError):
        continue
PYEOF
)"
if [ -n "$ALIAS_TARGET" ]; then
    # Re-run mios-find with the alias target as the query (single-level;
    # an alias value is a concrete app name, not another alias).
    echo "(alias: '$QUERY' -> '$ALIAS_TARGET')" >&2
    QUERY="$ALIAS_TARGET"
fi

# ─── Specific-before-role reduction ──────────────────────────────────
# Operator 2026-06-19 "open edge browser opened zen randomly": "<app> <role>"
# (e.g. "edge browser") -> the scorer can't substring-match the FULL query to
# "Microsoft Edge" (no "browser" in the name), so Edge fell to the Levenshtein
# tier where Zen (windows-browser, the default) tied + won. When the LAST word is
# a [desktop.apps] ROLE and the HEAD is a SPECIFIC (non-role) app, reduce the
# query to the head so the scorer resolves the NAMED app. A BARE role ("browser")
# is left alone -> the windows-browser default (Zen) still wins. SSOT = mios.toml
# roles; no hardcoded English app names.
_REDUCED="$(python3 - "$QUERY" <<'PYEOF' 2>/dev/null
import sys, re, tomllib
q = re.sub(r"\s+", "-", sys.argv[1].strip().lower())
if "-" not in q:
    sys.exit(0)
roles = set()
for p in ("/etc/mios/mios.toml", "/usr/share/mios/mios.toml"):
    try:
        with open(p, "rb") as f:
            d = tomllib.load(f)
    except Exception:
        continue
    for a in (d.get("desktop", {}).get("apps", []) or []):
        if isinstance(a, dict) and a.get("role"):
            roles.add(str(a["role"]).lower().rstrip("s"))
    if roles:
        break
last = q.split("-")[-1].rstrip("s")
head = re.sub(r"^(my|the|a|an)-", "", "-".join(q.split("-")[:-1]))
# Require a SUBSTANTIVE head (>=4 chars) so generic browser synonyms ("web") stay
# a bare-role ask (-> default browser), while a real app name ("edge"/"chrome"/
# "firefox") reduces to the specific app.
if (last in roles and head and len(head.replace("-", "")) >= 4
        and head.rstrip("s") not in roles):
    print(head.replace("-", " "))
PYEOF
)"
if [ -n "$_REDUCED" ]; then
    echo "(specific-before-role: '$QUERY' -> '$_REDUCED')" >&2
    QUERY="$_REDUCED"
fi

# ─── Fast path A: delegate to mios-everything ─────────────────────────
# Operator directive 2026-05-16: "WE HAVE EVERYTHING CLI STILL DOING
# NOTHING AS A TOOL FOR THE ENTIRE MIOS AGENTIC STACKS" -- promoted
# the es.exe probe + invocation out of this script into the
# first-class mios-everything helper. Any agent can now use
# mios-everything directly; mios-find just calls it as one of its
# resolution sources.
if command -v mios-everything >/dev/null 2>&1; then
    # `|| true`: mios-everything exits NON-ZERO when es.exe is dead/unreachable
    # (the common case -- v1.1 es.exe vs v1.4 IPC mismatch). Without this, the
    # command substitution fails under `set -e` and ABORTS mios-find before
    # fast-path B (the mios-apps inventory) can resolve the app -- so EVERY
    # lookup died on hosts with a degraded Everything. Tolerate it; fall through.
    ES_OUT="$(mios-everything -n 5 -ext exe "$QUERY" 2>/dev/null || true)"
    if [ -n "$ES_OUT" ]; then
        FIRST_EXE="$(printf '%s\n' "$ES_OUT" | head -1)"
        if [ -n "$FIRST_EXE" ]; then
            ESCAPED="$(printf '%s' "$FIRST_EXE" | sed 's/\\/\\\\/g')"
            echo "mios-windows launch \"$ESCAPED\""
            n_alt="$(printf '%s\n' "$ES_OUT" | wc -l)"
            if [ "$n_alt" -gt 1 ]; then
                echo "(found via mios-everything; $((n_alt - 1)) other .exe matches:)" >&2
                printf '%s\n' "$ES_OUT" | tail -n +2 | sed 's/^/  /' >&2
            fi
            exit 0
        fi
    fi
fi

# ─── Fast path B: mios-apps inventory (Linux + Windows Start Menu + games) ─
python3 - "$QUERY" <<'PYEOF'
import json
import re
import subprocess
import sys

query = sys.argv[1].strip().lower()
if not query:
    print("mios-find: empty query", file=sys.stderr)
    sys.exit(2)

# Use run() not check_output(): mios-apps exits NON-ZERO when ANY sub-scanner
# fails (e.g. Everything es.exe dead, or the Windows side unreachable) even
# though it still emits a perfectly good Linux/flatpak inventory on stdout.
# check_output discarded that stdout on the non-zero exit -> EVERY app
# resolution failed on hosts with a degraded scanner. Consume stdout
# regardless of returncode; only give up if stdout is genuinely empty.
try:
    proc = subprocess.run(
        ["mios-apps", "--json"], capture_output=True, text=True, timeout=15
    )
    out = proc.stdout or ""
except (subprocess.TimeoutExpired, FileNotFoundError) as e:
    print(f"mios-find: mios-apps failed: {e}", file=sys.stderr)
    sys.exit(3)
if not out.strip():
    print(f"mios-find: mios-apps returned no inventory "
          f"(rc={proc.returncode}): {proc.stderr[:200]}", file=sys.stderr)
    sys.exit(3)

# Priority for resolving a name -> launch target. Real NATIVE apps
# (windows-app/windows-gui, linux-flatpak/rpm-gui) MUST outrank mios-shim, else
# a mios-* shim shadows the real app (the session bugs: steam->mios-steamcmd,
# notepad->wine). mios-shim demoted 4->6, windows-gui promoted 5->2 (research
# 2026-06-15 AI-OS-control launch doctrine: generative resolution, shims are a
# last resort, never load-bearing).
CAT_PRIORITY = {
    "windows-browser": 1,  # a REGISTERED browser (incl. the OS default, e.g. Zen)
                           # is the highest-confidence resolve for a browser ask --
                           # outranks the junk Microsoft.AutoGenerated UWP dupes.
    "windows-app":     1,
    "windows-gui":     2,
    "linux-flatpak":   3,
    "linux-rpm-gui":   4,
    "agent-cli":       5,
    "mios-shim":       6,
    "service-url":     7,
}

entries = []
for line in out.splitlines():
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
    except json.JSONDecodeError:
        continue
    name = (e.get("name") or "").lower()
    desc = (e.get("description") or "").lower()
    cat = e.get("category") or ""
    launch = e.get("launch") or e.get("command") or ""
    if not name or not launch:
        continue
    entries.append({
        "name": e.get("name"),
        "desc": e.get("description") or "",
        "cat": cat,
        "launch": launch,
        "lname": name,
        "ldesc": desc,
    })

def _lev(a, b, cap=3):
    # Bounded Levenshtein: returns cap+1 when distance exceeds cap, so the
    # caller short-circuits without computing further. Iterative DP with a
    # rolling row -- O(len(a) * len(b)) time, O(min) space.
    if a == b:
        return 0
    la, lb = len(a), len(b)
    if abs(la - lb) > cap:
        return cap + 1
    if la < lb:
        a, b = b, a
        la, lb = lb, la
    prev = list(range(lb + 1))
    for i in range(1, la + 1):
        cur = [i] + [0] * lb
        row_min = cur[0]
        for j in range(1, lb + 1):
            cost = 0 if a[i - 1] == b[j - 1] else 1
            cur[j] = min(prev[j] + 1, cur[j - 1] + 1, prev[j - 1] + cost)
            if cur[j] < row_min:
                row_min = cur[j]
        if row_min > cap:
            return cap + 1
        prev = cur
    return prev[lb]

def rank(e):
    n = e["lname"]
    d = e["ldesc"]
    if n == query:
        return (0, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if n.startswith(query):
        return (1, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if re.search(rf"\b{re.escape(query)}", n):
        return (2, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if query in n:
        return (3, CAT_PRIORITY.get(e["cat"], 99), len(n))
    if re.search(rf"\b{re.escape(query)}", d):
        return (4, CAT_PRIORITY.get(e["cat"], 99), len(d))
    if query in d:
        return (5, CAT_PRIORITY.get(e["cat"], 99), len(d))
    # Tier 6: bounded Levenshtein on individual name tokens. Catches
    # operator typos like "wreakfest" -> "wreckfest", "discrod" ->
    # "discord", "wallpapr engine" -> "wallpaper engine". Cap at edit-
    # distance 2 so we don't match every short word. Only against query
    # tokens >= 4 chars (typos in 1-3 char queries are too ambiguous).
    # Operator-flagged 2026-05-17: "launch wreakfest for me" produced no
    # match + agent spiralled into PowerShell-in-bash confusion.
    q_tokens = [t for t in query.split() if len(t) >= 4]
    n_tokens = n.split() + d.split()
    if q_tokens and n_tokens:
        best = min(
            (_lev(qt, nt, cap=2) for qt in q_tokens for nt in n_tokens),
            default=99,
        )
        if best <= 2:
            return (6, CAT_PRIORITY.get(e["cat"], 99), best * 100 + len(n))
    return None

scored = []
for e in entries:
    r = rank(e)
    if r is not None:
        scored.append((r, e))
scored.sort(key=lambda x: x[0])

if not scored:
    print(f'no match for "{query}" in inventory; '
          f'try `mios-apps --filter {query}` or list with `mios-apps`',
          file=sys.stderr)
    sys.exit(1)

# Auto-resolve ambiguity by picking the highest-priority CATEGORY
# match at the best tier. The sort already orders by
# (tier, category-priority, length), so scored[0] is always the
# "best" by our rules. Print it. If there are >1 matches, also
# emit a brief "n other candidates" note to stderr for transparency
# -- but DO NOT bounce back to the operator demanding re-query
# (operator directive 2026-05-16: "should be snappy").
best = scored[0][1]
print(best["launch"])
if len(scored) > 1:
    n_alt = min(4, len(scored) - 1)
    print(f'(picked best of {len(scored)}; {n_alt} alternatives:)',
          file=sys.stderr)
    for i, (_, e) in enumerate(scored[1:1+n_alt], 1):
        print(f'  {i}. [{e["cat"]:<14}] {e["name"]:<30} -> {e["launch"]}',
              file=sys.stderr)
sys.exit(0)
PYEOF
