#!/usr/bin/env python3
# AI-hint: Refreshes OWUI's ui.prompt_suggestions by analyzing MiOS state (kanban, daemon nudges, recent intents) via a refine model to generate 5-28 context-aware starter chips for the operator.
# AI-related: random.sh, /usr/share/mios/mios.toml, /etc/mios/mios.toml, mios-daemon, localhost:8450, localhost:8000, localhost:3030
"""mios-suggestion-refresh -- generate MiOS-aware starter chips +
write them into OWUI's ui.prompt_suggestions.

OPERATOR DIRECTIVE
  "I WANT MIOS STARTER QUERIES THAT REVOLVE/EVOLVE/ITERATE"

OWUI's built-in ENABLE_SUGGESTION_GENERATION path produces generic
chatbot prompts (and on this stack it wasn't producing them at all).
This shim takes over: gathers MiOS state (system snapshot, recent
kanban, daemon nudges, recent refine intents) and calls the small
refine model with a tight prompt asking for 5 starter chips. The
chips:

  - Reflect what the operator just did / has queued
  - Surface unfinished work (recent unsatisfied verdicts)
  - Rotate over time as the source signals change
  - Are localised by the model based on the input context
    (no hardcoded English here)

RUN AT
  Periodic (every N min, default 10) via mios-daemon's loop, OR
  manually after a state change. Idempotent: writes the new chip
  list verbatim, no diff merge.

OUTPUT
  Updates webui.db's config row -> data.ui.prompt_suggestions
  with the new chip array. Stdout = JSON envelope with the
  chips + the metadata used to generate them (for debug).

EXIT CODES
  0  refreshed
  1  refine model unavailable / OWUI DB missing / parse fail
  2  bad arguments
"""
from __future__ import annotations

import argparse
import datetime
import json
import os
import random
import sqlite3
import sys
import urllib.error
import urllib.request

sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib", "mios"))
import mios_toml  # noqa: E402  -- the ONE shared layered-mios.toml resolver

OWUI_DB = os.environ.get("MIOS_OWUI_DB", "/var/lib/mios/open-webui/webui.db")
# Suggestion generation needs a MORE capable model than the micro
# refiner -- a 1.7b produced repetitive, id-leaking chips ("Open
# directory lookup", operator 2026-05-20). qwen2.5-coder:7b is
# non-thinking + instruction-capable + warm on the dGPU lane; this is a
# periodic BACKGROUND task so its latency doesn't touch chat turns.
REFINE_ENDPOINT = os.environ.get(
    "MIOS_SUGGESTION_ENDPOINT", f"http://localhost:{os.environ.get('MIOS_PORT_LLM_LIGHT', '8450')}")
REFINE_MODEL = os.environ.get("MIOS_SUGGESTION_MODEL", "granite4.1:8b")
REFINE_TIMEOUT_S = int(os.environ.get(
    "MIOS_SUGGESTION_TIMEOUT_S", "60"))
# Vast out-of-the-box set (operator 2026-05-20: "a vast set of defaults
# out of the box" covering MiOS functionality, that also iterates per
# use-case). Tunable via env.
NUM_CHIPS = int(os.environ.get("MIOS_SUGGESTION_COUNT", "28"))


def _read_file(path: str, cap: int = 4000) -> str:
    try:
        with open(path, "r", errors="replace") as f:
            return f.read()[:cap]
    except OSError:
        return ""


def _daemon_state() -> dict:
    return _safe_json(_read_file("/var/lib/mios/daemon/state.json"))


def _agent_nudges() -> str:
    return _read_file("/var/lib/mios/scratch/agent-nudges.md", cap=2000)


def _system_status() -> dict:
    """Cheap snapshot of the running stack. Pulls from the daemon's
    last state.json (fresh as of its last loop tick).

    Excludes `classify` deliberately -- the daemon's journal-tail
    classifier picks up ANY recent error chatter (curl probes, dev
    activity, transient HTTP 4xx) and the suggestion model latches
    onto those, producing debug-flavored chips that don't match the
    operator's actual daily-use needs. Keep launch_failures (real
    operator-visible failures) + satisfaction (real verdicts)."""
    state = _daemon_state()
    return {
        "launch_failures": state.get("launch_failures") or [],
        "satisfaction": state.get("satisfaction") or {},
    }


def _baseline_actions() -> list[str]:
    """Concrete worst-case seeds (used only if the SSOT catalog read
    yields nothing) so the model still gets fully-resolved example
    phrases, never <placeholder> templates."""
    return [
        "Show me the dashboard",
        "What's running on my system",
        "Take a screenshot",
        "Open my browser",
        "List my installed apps",
        "Check my kanban board",
        "Summarize what happened today",
        "Search my files for project notes",
    ]


def _mios_verbs_sample() -> list[str]:
    """Read MiOS's REAL capability surface from the SSOT -- mios.toml
    [verbs.*] + [recipes.*] (+ /etc overlay) -- so generated chips
    cover the BREADTH of what MiOS can actually do, derived from the
    catalog rather than a hardcoded English list (operator directive:
    no hardcoded English; vast functionality coverage). Returns short
    "<name>: <desc>" descriptors the model turns into natural, localised
    starter chips. Falls back to concrete baseline seeds if the catalog
    can't be read."""
    # [verbs]+[recipes] across vendor + /etc (etc wins) via the shared resolver.
    doc = mios_toml.load_merged(layers=["/usr/share/mios/mios.toml",
                                        "/etc/mios/mios.toml"])
    caps: list[str] = []
    for section in ("verbs", "recipes"):
        table = mios_toml.section(doc, section)
        for name, cfg in table.items():
            if not isinstance(cfg, dict):
                continue
            desc = str(cfg.get("desc")
                       or cfg.get("description") or "").strip()
            caps.append(f"{name}: {desc[:90]}" if desc else str(name))
    # De-dupe, keep order, cap so the prompt stays bounded.
    seen: set[str] = set()
    out: list[str] = []
    for c in caps:
        if c and c not in seen:
            seen.add(c)
            out.append(c)
    return out[:60] or _baseline_actions()


def _pg(sql: str) -> list:
    """Run one SQL statement on pgvector via mios-pg-query (pure-python pg
    wire client -- no psql/psycopg/podman). Rows -> lists of string columns
    (psql -At: tab-separated columns, newline-separated rows). Degrade-open
    to [] on any error so a transient DB issue can't blank the chip context."""
    import subprocess
    try:
        p = subprocess.run(["/usr/libexec/mios/mios-pg-query", sql],
                           capture_output=True, text=True, timeout=4)
    except Exception:
        return []
    if p.returncode != 0:
        return []
    return [ln.split("\t") for ln in p.stdout.splitlines() if ln]


def _recent_kanban(limit: int = 4) -> list[str]:
    """Read recent operator-relevant kanban entries from the pgvector
    `kanban` table (authoritative; retired the legacy shadow). These
    are real queued tasks the operator opened; ideal chip seeds."""
    # pg `kanban.status` is todo|doing|done|blocked (+ tolerate a legacy
    # 'completed'); exclude the finished states. Ordered by ts (the shadow's
    # synced_at has no pg equivalent).
    sql = (
        f"SELECT title FROM kanban "
        f"WHERE status NOT IN ('done', 'completed') "
        f"ORDER BY ts DESC LIMIT {int(limit)};"
    )
    return [r[0] for r in _pg(sql) if r and r[0]]


def _recent_refine_intents(limit: int = 5) -> list[str]:
    """Pull the last few refine summaries from the pgvector `event`
    table. Used to bias suggestions away from what the operator JUST
    asked (avoid repetition) and toward complementary follow-ups."""
    sql = (
        f"SELECT summary FROM event "
        f"WHERE kind = 'refine' "
        f"ORDER BY ts DESC LIMIT {int(limit)};"
    )
    return [r[0] for r in _pg(sql) if r and r[0]]


def _safe_json(text: str) -> dict:
    try:
        d = json.loads(text)
        return d if isinstance(d, dict) else {}
    except (json.JSONDecodeError, ValueError):
        return {}


def _build_prompt(num: int, status: dict, nudges: str,
                  recent_intents: list[str],
                  kanban_titles: list[str],
                  verbs_sample: list[str]) -> str:
    """Compose the prompt the refine model sees. The chip space is
    biased toward operator-useful daily actions; transient debug
    chatter is intentionally excluded from the context."""
    kanban_block = (
        "Operator's currently-open kanban tasks (good chip seeds):"
        "\n  - " + "\n  - ".join(kanban_titles[:5])
        if kanban_titles else "(no open kanban tasks)"
    )
    intents_block = (
        "Operator's recent chat themes (avoid repeating verbatim, "
        "but suggest natural follow-ups):\n  - "
        + "\n  - ".join(recent_intents[:5])
        if recent_intents else "(no recent chat themes)"
    )
    nudges_block = (
        "Recent system nudges from mios-daemon:\n" + nudges
        if nudges.strip() else "(no daemon nudges)"
    )
    verbs_block = "\n  - ".join(verbs_sample)
    return (
        "You generate starter-prompt chips for the operator's MiOS "
        "chat interface. The operator just opened a NEW empty chat "
        "and is choosing what to do.\n"
        "\n"
        "RULES:\n"
        f"- Emit exactly {num} chips.\n"
        "- Each chip is a SHORT imperative phrase (3-8 words) the "
        "operator could click to populate the chat input. Match the "
        "language of the context blocks below (locale-neutral).\n"
        "- Bias toward DAILY-USE actions the operator would actually "
        "click: launch apps, open URLs, take screenshots, query "
        "system state, manage installed software, check kanban, "
        "summarise recent activity. NOT diagnostic / debug chips "
        "(no 'debug logs', 'check HTTP codes', 'review errors' -- "
        "those are noise from the daemon's journal scanner, not "
        "what the operator opens a new chat to do).\n"
        "- COVERAGE: most chips should span the BREADTH of MiOS "
        "capabilities in the actions list -- vary across different "
        "areas (launching apps, finding + opening files, querying + "
        "controlling the system, web search, media, settings, "
        "automation/recipes) so the operator sees a vast, "
        "representative set of what MiOS can do out of the box. A "
        "smaller portion (about a quarter) should reflect the "
        "operator's CURRENT context below (open kanban tasks, recent "
        "themes) so the set iterates with use. Paraphrase to vary "
        "phrasing across refreshes.\n"
        "- VARIETY (critical): draw each chip from a DIFFERENT "
        "capability in the list below -- the list already spans many "
        "real areas, so let the spread of actual capabilities drive "
        "the variety. No two chips may share the same action or be "
        "near-duplicates, and never emit a run of the same opening "
        "verb.\n"
        "- Each capability below is '<internal-id>: <plain-language "
        "description>'. Phrase the chip from the DESCRIPTION as the "
        "user-facing ACTION it performs -- what it does FOR the "
        "operator. NEVER emit the internal id, and never the raw "
        "files, paths, commands, or flags a description happens to "
        "mention; refer to anything internal by what it IS to the "
        "user. Chips are concrete (never 'Open <app>' placeholders) "
        "but read like natural, plain language.\n"
        "- Output JSON only:\n"
        '  {"chips":["chip 1","chip 2", ..., "chip N"]}\n'
        "- No prose around the JSON.\n"
        "\n"
        "── Example MiOS actions (rewrite, don't copy) ──\n"
        f"  - {verbs_block}\n"
        "\n"
        "── Operator's open kanban tasks ──\n"
        f"{kanban_block}\n"
        "\n"
        "── Operator's recent chat themes ──\n"
        f"{intents_block}\n"
        "\n"
        "── Real launch failures (only mention if non-empty) ──\n"
        f"{json.dumps(status.get('launch_failures') or [], indent=2)[:600]}\n"
        "\n"
        "── Daemon nudges (only mention if non-empty) ──\n"
        f"{nudges_block[:800]}\n"
    )


def _ask_model(prompt: str) -> list[str]:
    """Send the assembled prompt to the refine model + parse the
    chip array out. Returns [] on any failure (caller keeps the
    previous suggestions, so a transient model issue doesn't blank
    the chip row)."""
    # llama.cpp OpenAI /v1 (MiOS is /v1-only): qwen3 (incl. 1.7b) otherwise dumps
    # the JSON into message.reasoning with EMPTY content (operator test 2026-05-20),
    # so disable the thinking channel to emit the chips JSON straight to
    # message.content. max_tokens has room for ~28 chips of JSON.
    payload = {
        "model": REFINE_MODEL,
        "messages": [
            {"role": "system",
             "content": "You emit JSON only. No prose around it."},
            {"role": "user", "content": prompt},
        ],
        "chat_template_kwargs": {"enable_thinking": False},
        "response_format": {"type": "json_object"},
        "stream": False,
        "temperature": 0.4,
        "max_tokens": 1600,
    }
    _base = REFINE_ENDPOINT.rstrip("/")
    _url = (f"{_base}/chat/completions" if _base.endswith("/v1")
            else f"{_base}/v1/chat/completions")
    req = urllib.request.Request(
        _url,
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=REFINE_TIMEOUT_S) as r:
            body = json.loads(r.read().decode("utf-8", errors="replace"))
    except Exception as e:
        sys.stderr.write(f"  refine call failed: {e}\n")
        return []
    # OpenAI /v1 shape {"choices":[{"message":{"content"}}]}.
    choices = body.get("choices") or []
    msg = (choices[0].get("message") if choices else {}) or {}
    content = str(msg.get("content") or "").strip()
    # qwen3-family reasoning models sometimes burn the entire token
    # budget in the `reasoning` field with empty `content` (operator-
    # observed on a cold-restart probe). Fall back to reasoning when
    # content is empty -- the chip extractor below strips <think>
    # tags + code fences so either field's payload works.
    if not content:
        content = str(msg.get("reasoning") or "").strip()
    # Strip qwen3 <think> tails + code fences.
    import re
    content = re.sub(r"<think>.*?</think>\s*", "", content,
                     flags=re.DOTALL | re.IGNORECASE)
    content = re.sub(r"<think>.*$", "", content,
                     flags=re.DOTALL | re.IGNORECASE)
    # Extract JSON object substring
    m_json = re.search(r"\{.*\}", content, re.DOTALL)
    if m_json:
        content = m_json.group(0)
    try:
        parsed = json.loads(content)
    except (json.JSONDecodeError, ValueError):
        sys.stderr.write(f"  unparseable model output: {content[:200]!r}\n")
        return []
    chips = parsed.get("chips") if isinstance(parsed, dict) else None
    if not isinstance(chips, list):
        return []
    # De-dupe case-insensitively, preserve order -- small models repeat
    # (operator test 2026-05-20 saw "Query system state" x3 in one batch).
    out: list[str] = []
    seen: set[str] = set()
    for c in chips:
        if isinstance(c, str) and c.strip():
            cs = c.strip()
            if cs.lower() not in seen:
                seen.add(cs.lower())
                out.append(cs)
    return out


OWUI_URL = os.environ.get("MIOS_OWUI_URL", f"http://localhost:{os.environ.get('MIOS_PORT_OPEN_WEBUI', '8033')}")


def _admin_token() -> str:
    if not os.path.isfile(OWUI_DB):
        return ""
    try:
        c = sqlite3.connect(f"file:{OWUI_DB}?mode=ro", uri=True)
        cur = c.execute(
            "SELECT a.key FROM api_key a "
            "JOIN user u ON u.id = a.user_id "
            "WHERE u.role = 'admin' "
            "ORDER BY a.created_at DESC LIMIT 1;"
        )
        row = cur.fetchone()
        c.close()
        return row[0] if row else ""
    except sqlite3.Error:
        return ""


def _write_chips(chips: list[str]) -> None:
    """Push the chip list through OWUI's POST /api/v1/configs/
    suggestions endpoint. The API path is load-bearing -- writing
    DIRECTLY to webui.db sets the value but OWUI's runtime cache
    doesn't see it until the next service restart, so new chats
    keep showing the cached (often empty) chip row. The API
    handler updates both the persistence layer + the in-memory
    config so a chat opened ~5s later sees the fresh chips.
    Each chip is wrapped per OWUI's schema:
      {title: [primary, secondary], content: <text-sent-on-click>}
    We use the chip text for both title[0] and content so a click
    sends the literal phrase into the input."""
    suggestions = [{"title": [c, ""], "content": c} for c in chips]
    body = {"suggestions": suggestions}
    token = _admin_token()
    if not token:
        sys.stderr.write("  no admin api_key -- can't push to OWUI\n")
        return
    req = urllib.request.Request(
        f"{OWUI_URL}/api/v1/configs/suggestions",
        data=json.dumps(body).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as r:
            r.read()
    except urllib.error.HTTPError as e:
        sys.stderr.write(
            f"  OWUI suggestions POST failed: {e.code} "
            f"{e.read().decode('utf-8', errors='replace')[:200]}\n")
    except Exception as e:
        sys.stderr.write(f"  OWUI suggestions POST error: {e}\n")


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-suggestion-refresh")
    p.add_argument("--num", type=int, default=NUM_CHIPS,
                   help=f"Number of chips to generate (default {NUM_CHIPS}).")
    p.add_argument("--dry-run", action="store_true",
                   help="Print envelope but don't write to webui.db.")
    args = p.parse_args()

    status = _system_status()
    nudges = _agent_nudges()
    recent_intents = _recent_refine_intents(limit=5)
    kanban_titles = _recent_kanban(limit=5)
    verbs_sample = _mios_verbs_sample()
    # Shuffle so a different slice of the real capability library leads
    # each refresh -> the set genuinely rotates/iterates over time
    # (variety sourced from real capabilities, never a hardcoded pool).
    random.shuffle(verbs_sample)
    prompt = _build_prompt(args.num, status, nudges, recent_intents,
                           kanban_titles, verbs_sample)
    chips = _ask_model(prompt)
    if not chips:
        print(json.dumps({
            "ok": False,
            "error": "no_chips_from_model",
            "recent_intents": recent_intents,
        }))
        return 1
    if not args.dry_run:
        _write_chips(chips)
    print(json.dumps({
        "ok": True,
        "wrote": not args.dry_run,
        "chips": chips,
        "context_signals": {
            "status_keys": sorted(status.keys()),
            "nudges_chars": len(nudges),
            "recent_intents": recent_intents,
            "kanban_titles": kanban_titles,
        },
    }))
    return 0


if __name__ == "__main__":
    sys.exit(main())
