OPENAI_API_KEY=${_api_key_val}
EOF
        umask 0022
        chown "$_op_user":"$_op_user" "$_op_env" 2>/dev/null || true
        chmod 0600 "$_op_env" 2>/dev/null || true
        _log "seeded operator CLI key material $_op_env (user=$_op_user, local lane)"
    else
        _log "operator CLI .env $_op_env already current -- not overwriting"
    fi
else
    _log "operator home for '$_op_user' not found -- skipping CLI config seed"
fi

# ── Hermes persona / grounding (SOUL.md) ────────────────────────────────
# Hermes-Agent reloads $HERMES_HOME/SOUL.md fresh on EVERY message -- it
# is the live lever for the agent's persona AND its operating discipline.
# Stock Hermes ships an EMPTY SOUL.md (just a comment template), which
# left the local model ungrounded: it made up tool output, invented
# config flags, and claimed success on commands that errored or returned
# nothing (operator-confirmed 2026-05-14). MiOS ships a hardened SOUL.md
# at /usr/share/mios/ai/hermes-soul.md -- strong rules against
# fabricated output, full-shell-usage guidance, and pointers to the MiOS AI
# reference docs. Seed it for BOTH the gateway service (HERMES_HOME) and
# the operator's `hermes` CLI (~/.hermes), exactly like config.yaml.
#
# Re-seed when the target is missing OR still the stock template (no
# "MiOS-managed" marker) OR the source content has changed (so updates
# to /usr/share/mios/ai/hermes-soul.md propagate without a manual
# delete). An operator who wants their own persona just deletes the
# "MiOS-managed" marker line; MiOS then leaves the file alone forever.
SOUL_SRC=""
for _c in /usr/share/mios/ai/hermes-soul.md \
          "${MIOS_REPO:-}/usr/share/mios/ai/hermes-soul.md"; do
    [[ -n "$_c" && -r "$_c" ]] && { SOUL_SRC="$_c"; break; }
done
_soul_should_seed() {
    local target="$1"
    [[ ! -f "$target" ]] && return 0
    if ! grep -q 'MiOS-managed' "$target" 2>/dev/null; then
        # NOT MiOS-managed. Distinguish the Hermes BINARY's STOCK DEFAULT identity
        # (the framework writes "You are Hermes Agent ... created by Nous Research"
        # when SOUL.md is absent at first CLI launch) from a GENUINE operator-authored
        # SOUL. The stock default left the operator's `hermes` CLI UNGROUNDED -- it
        # answered "I am Hermes Agent by Nous Research" with no MiOS identity (operator
        # 2026-06-16 "NOT GROUNDED IN MIOS / HAS NO IDEA WHO THEY ARE") because this
        # gate treated it as operator-owned and never seeded the MiOS SOUL. SEED
        # (replace) the vendor stock default; LEAVE a real operator SOUL alone. The
        # signature matched is the vendor's OWN identity line, not a MiOS routing word.
        grep -qiE 'created by Nous Research|You are Hermes Agent' "$target" 2>/dev/null && return 0
        return 1   # genuine operator-authored SOUL -> leave alone
    fi
    # Compare ONLY the source body against the head of target -- our
    # appended runtime-context block lives AFTER the SOUL_SRC bytes;
    # cmp -n SRC_LEN matches when the body is current regardless of
    # the appended context.
    local _src_bytes
    _src_bytes="$(wc -c < "$SOUL_SRC")"
    cmp -s -n "$_src_bytes" "$SOUL_SRC" "$target" && return 1
    return 0
}
# Build a runtime-context block we append to SOUL.md so the model has
# operator-specific defaults (Discord channel/guild, etc.) as
# authoritative context without us having to wedge them into the
# vendor SOUL source. Empty values are simply omitted.
#
# CRITICAL: Hermes-Agent's prompt_builder has an `html_comment_
# injection` guard that REFUSES to load ANY context file containing
# HTML comments (<!-- ... -->). The earlier version of this block
# used <!-- markers --> and broke SOUL.md loading entirely
# ("WARNING agent.prompt_builder: Context file SOUL.md blocked:
# html_comment_injection") -- the model then ran with NO MiOS
# persona at all. The delimiter is plain ASCII text inside a fenced
# code-block so it's still grep-able for the strip+re-append cycle
# but the `<!--` token never appears in the rendered SOUL.
SOUL_CTX_MARKER="### MIOS-RUNTIME-CONTEXT-BEGIN (managed by mios-hermes-firstboot; do not edit between markers)"
SOUL_CTX_END="### MIOS-RUNTIME-CONTEXT-END"
_build_soul_runtime_ctx() {
    local out=""
    if [[ -n "${_discord_channel:-}" || -n "${_discord_guild:-}" ]]; then
        out+=$'\n\n'"${SOUL_CTX_MARKER}"$'\n\n## MiOS host runtime context (operator-managed)\n\n'
        out+="_Auto-appended by mios-hermes-firstboot from [identity] keys in mios.toml. "
        out+="To override, edit /etc/mios/mios.toml or ~/.config/mios/mios.toml._"$'\n\n'
        if [[ -n "${_discord_channel:-}" ]]; then
            out+="- Default Discord channel: \`${_discord_channel}\`"
            [[ -n "${_discord_guild:-}" ]] && out+=" (guild \`${_discord_guild}\`)"
            out+=$'\n'
            out+="  When the operator says \"send to discord\", \"post to discord\", "
            out+="\"DM me on discord\", or \"let me know on discord\" without naming a channel, "
            out+="call \`send_message\` with target=\`discord:${_discord_channel}\`. "
            out+="Only use a different channel if the operator names one explicitly."$'\n'
        fi
        out+=$'\n'"${SOUL_CTX_END}"$'\n'
    fi
    printf '%s' "$out"
}

# Strip any prior appended context (everything from SOUL_CTX_MARKER on)
# and re-append the current value. Idempotent: same context input = no
# byte change after the strip+append. Used after the body-seed decision
# so the context tracks mios.toml even when the body is "already current".
_refresh_soul_ctx() {
    local target="$1" ctx="$2"
    [[ -f "$target" ]] || return 0
    local _tmp
    _tmp="$(mktemp)"
    # Print up to (not including) the marker line; if marker absent,
    # awk passes the whole file through.
    awk -v m="${SOUL_CTX_MARKER}" '
        { if (index($0, m) > 0) { exit } else { print } }
    ' "$target" > "$_tmp"
    # Trim trailing blank lines from the body so the append is clean.
    awk 'BEGIN{n=0} { lines[NR]=$0; if ($0 != "") last=NR } END { for(i=1;i<=last;i++) print lines[i] }' "$_tmp" > "${_tmp}.trim"
    mv -f "${_tmp}.trim" "$_tmp"
    if [[ -n "$ctx" ]]; then
        printf '%s' "$ctx" >> "$_tmp"
    fi
    # Preserve target perms/ownership
    cat "$_tmp" > "$target"
    rm -f "$_tmp"
}
if [[ -z "$SOUL_SRC" ]]; then
    _log "WARN: hermes-soul.md source not found -- skipping SOUL.md seed"
else
    _soul_ctx="$(_build_soul_runtime_ctx)"
    # Gateway service copy ($HERMES_HOME/SOUL.md, owned by mios-hermes).
    _soul_svc="${HERMES_DATA}/SOUL.md"
    if _soul_should_seed "$_soul_svc"; then
        cp -f "$SOUL_SRC" "$_soul_svc"
        chown 850:850 "$_soul_svc" 2>/dev/null || true
        chmod 0644 "$_soul_svc" 2>/dev/null || true
        _log "seeded $_soul_svc (hardened MiOS persona + grounding against fabricated output)"
    else
        _log "$_soul_svc body already current -- refreshing runtime context only"
    fi
    # ALWAYS reconcile the appended runtime context (Discord default
    # channel, etc.) regardless of body-seed decision so a mios.toml
    # edit propagates without a full re-seed.
    _refresh_soul_ctx "$_soul_svc" "$_soul_ctx"

    # Operator `hermes` CLI copy (reuses _op_user / _op_home from above).
    if [[ -n "${_op_home:-}" && -d "${_op_home:-}" ]]; then
        _soul_op="${_op_home}/.hermes/SOUL.md"
        if _soul_should_seed "$_soul_op"; then
            mkdir -p "${_op_home}/.hermes"
            cp -f "$SOUL_SRC" "$_soul_op"
            chown "$_op_user":"$_op_user" "$_soul_op" 2>/dev/null || true
            chmod 0644 "$_soul_op" 2>/dev/null || true
            _log "seeded operator SOUL.md $_soul_op (user=$_op_user)"
        else
            _log "operator SOUL.md $_soul_op body already current -- refreshing runtime context only"
        fi
        _refresh_soul_ctx "$_soul_op" "$_soul_ctx"
    fi
fi

# ─── MiOS-managed Hermes skills ────────────────────────────────────────────
# Hermes builds a system-prompt skill index from $HERMES_HOME/skills/<name>/
# SKILL.md (and $HERMES_HOME/skills/<category>/<name>/SKILL.md). The model
# sees each skill's frontmatter description in the index and decides when
# to skill_view its body for the full playbook.
#
# MiOS ships skills under /usr/share/mios/hermes/skills/<name>/SKILL.md so
# the OS can teach hermes patterns that the stock model wouldn't pick up
# on its own (currently: parallel-fanout, which nudges the orchestrator
# toward delegate_task on parallelizable work -- needed because
# qwen3-coder:30b naturally serialised via terminal even when prompted).
#
# Seed each MiOS-shipped skill into BOTH the gateway service home AND the
# operator's `hermes` CLI home, mirroring the SOUL.md seeding pattern.
# Re-seed only when the target either doesn't exist OR is byte-identical-
# minus-mtime to a previous MiOS shipment (marker check). Operators take
# ownership by deleting the "MiOS-managed" marker comment in the file --
# firstboot then leaves it alone forever.
SKILLS_SRC_DIR=""
for _c in /usr/share/mios/hermes/skills \
          "${MIOS_REPO:-}/usr/share/mios/hermes/skills"; do
    [[ -n "$_c" && -d "$_c" ]] && { SKILLS_SRC_DIR="$_c"; break; }
done
_skill_should_seed() {
    local target="$1" src="$2"
    [[ ! -f "$target" ]] && return 0
    grep -q 'MiOS-managed' "$target" 2>/dev/null || return 1   # operator-owned, leave alone
    cmp -s "$src" "$target" && return 1                        # already current, no-op
    return 0                                                   # MiOS-managed and stale -> reseed
}
_seed_one_skill() {
    # $1=src SKILL.md, $2=dest dir (e.g., $HERMES_HOME/skills/parallel-fanout),
    # $3=owner uid:gid string for chown.
    local src="$1" dest_dir="$2" owner="$3"
    local target="${dest_dir}/SKILL.md"
    if _skill_should_seed "$target" "$src"; then
        mkdir -p "$dest_dir"
        cp -f "$src" "$target"
        chown "$owner" "$target" 2>/dev/null || true
        chmod 0644 "$target" 2>/dev/null || true
        _log "seeded skill ${target}"
    else
        _log "skill ${target} already current (or operator-customised) -- not overwriting"
    fi
}
if [[ -z "$SKILLS_SRC_DIR" ]]; then
    _log "WARN: hermes skills source dir not found -- skipping skills seed"
else
    # Each subdir of SKILLS_SRC_DIR is one skill; its SKILL.md is the entry.
    for _skill_src in "${SKILLS_SRC_DIR}"/*/SKILL.md; do
        [[ -e "$_skill_src" ]] || continue
        _skill_name="$(basename "$(dirname "$_skill_src")")"
        # Gateway service copy ($HERMES_HOME/skills/<name>/SKILL.md).
        # Owner = the hermes-agent sysuser (uid 850, NOT the stale 820).
        _seed_one_skill "$_skill_src" \
                        "${HERMES_DATA}/skills/${_skill_name}" \
                        "850:850"
        # Operator `hermes` CLI copy (~/.hermes/skills/<name>/SKILL.md).
        if [[ -n "${_op_home:-}" && -d "${_op_home:-}" ]]; then
            _seed_one_skill "$_skill_src" \
                            "${_op_home}/.hermes/skills/${_skill_name}" \
                            "${_op_user}:${_op_user}"
        fi
    done
    # Tell hermes to drop its in-process skills-prompt cache so the
    # newly-seeded skills appear in the next chat turn's system prompt
    # without a service restart. The cache key is mtime/size of every
    # SKILL.md in $HERMES_HOME/skills, so touching a marker file in the
    # skills dir invalidates the disk snapshot. The simpler hammer: if
    # any skill was actually seeded above, restart the service.
    if systemctl is-active --quiet hermes-agent.service \
       && find "${HERMES_DATA}/skills" -newer "${HERMES_DATA}/SOUL.md" -name SKILL.md 2>/dev/null | grep -q .; then
        _log "skill content changed -- restarting hermes-agent.service to refresh skills index"
        # --no-block: don't wait on the restart settling (avoids the firstboot
        # <-> hermes-agent start deadlock / ~23min hang, 2026-06-14).
        systemctl restart --no-block hermes-agent.service || _log "WARN: hermes-agent restart failed"
    fi
fi

# ─── Global flatpak override (theming + portal) ─────────────────────────
# Seed the GTK_USE_PORTAL=1 + xdg-config/data/themes/icons filesystem
# mounts so libadwaita / GTK4 flatpaks (Epiphany, Nautilus, Files,
# Calendar, Extensions Manager) pick up the operator's color-scheme
# (prefer-dark) and theme (adw-gtk3-dark) via xdg-portal-desktop. Without
# this, every flatpak boots with a generic white-mode GTK3 default.
# Operator-confirmed regression 2026-05-15: "epiphany has older GTK now"
# was because the global override was missing the xdg-data/themes mount.
#
# Idempotent + harmless if flatpak isn't installed (the helper exits 0).
if [[ -x /usr/libexec/mios/mios-flatpak-overrides-apply ]]; then
    /usr/libexec/mios/mios-flatpak-overrides-apply 2>&1 | sed 's/^/  /' \
