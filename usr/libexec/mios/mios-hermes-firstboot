        [[ -n "$_api_key_val" ]] && ! grep -qF "API_SERVER_KEY=${_api_key_val}" "$f" 2>/dev/null && return 0
        return 1
    }
    if [[ -z "$_api_key_val" ]]; then
        _log "WARN: no API_SERVER_KEY in $ENV_FILE -- skipping operator CLI .env seed"
    elif _op_env_should_seed "$_op_env"; then
        mkdir -p "$_op_cfg_dir"
        umask 0077
        cat > "$_op_env" <<EOF
