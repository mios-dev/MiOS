#!/usr/bin/env bash
# MiOS -- mios-hermes-firstboot: generate /etc/mios/hermes/api.env if missing.
#
# The same key is read by both mios-hermes (gateway) and
# mios-hermes-workspace (chat front-end) via EnvironmentFile= in their
# Quadlets. Idempotent: re-runs are no-ops via ConditionPathExists.
set -euo pipefail

ENV_FILE="/etc/mios/hermes/api.env"

_log() { logger -t mios-hermes-firstboot "$*" 2>/dev/null || true; echo "[hermes-firstboot] $*" >&2; }

# Make sure the directory exists with the right ownership. tmpfiles.d
# should have done this already, but be defensive in case the .service
# fires before tmpfiles for some reason.
mkdir -p /etc/mios/hermes
chown -h mios-hermes:mios-hermes /etc/mios/hermes 2>/dev/null || true
chmod 0750 /etc/mios/hermes 2>/dev/null || true

if [[ -f "$ENV_FILE" ]] && grep -q '^API_SERVER_KEY=' "$ENV_FILE"; then
    _log "$ENV_FILE already has API_SERVER_KEY -- nothing to do"
    exit 0
fi

# Generate a 64-char hex key. openssl is in @core on Fedora CoreOS so
# this is always available; fall back to /dev/urandom if it isn't.
if command -v openssl >/dev/null 2>&1; then
    api_key="$(openssl rand -hex 32)"
else
    api_key="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
fi

# Write the env file with secure perms BEFORE chowning to mios-hermes
# so the Quadlet's EnvironmentFile= read-as-root can succeed even if
# the per-uid mios-hermes login is denied (`/usr/sbin/nologin`).
umask 0077
cat > "$ENV_FILE" <<EOF
# /etc/mios/hermes/api.env -- generated by mios-hermes-firstboot.service
# at $(date -Iseconds) on $(hostname).
# Rotate by deleting this file and restarting mios-hermes-firstboot.

API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${api_key}
API_SERVER_CORS_ORIGINS=*
OPENAI_API_KEY=${api_key}

# Hermes Workspace consumes these via the SAME EnvironmentFile= mount.
# Systemd Quadlet Environment= directives do NOT expand \${API_SERVER_KEY}
# from sibling EnvironmentFile= contents, so we have to write the
# explicit duplicates here. The workspace falls back to a legacy HTML-
# scrape token flow when CLAUDE_DASHBOARD_TOKEN is unset, which fails
# against our minimal gateway image and triggers a client-side
# redirect to /error. Operator-flagged 2026-05-11.
HERMES_API_TOKEN=${api_key}
CLAUDE_DASHBOARD_TOKEN=${api_key}
EOF
umask 0022
chown root:mios-hermes "$ENV_FILE" 2>/dev/null || true
chmod 0640 "$ENV_FILE" 2>/dev/null || true

_log "wrote $ENV_FILE (64-char API_SERVER_KEY)"
