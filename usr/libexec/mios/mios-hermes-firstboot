    _op_env="${_op_cfg_dir}/.env"
    _api_key_val=""
    if [[ -r "$ENV_FILE" ]]; then
        _api_key_val="$(awk -F= '/^API_SERVER_KEY=/{print $2; exit}' "$ENV_FILE" 2>/dev/null)"
    fi
    _op_env_should_seed() {
        local f="$1"
        [[ ! -f "$f" ]] && return 0
        grep -q 'MiOS-managed' "$f" 2>/dev/null || return 1        # operator-owned, leave alone
