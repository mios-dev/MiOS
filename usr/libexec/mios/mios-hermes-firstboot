#!/usr/bin/env bash
# AI-hint: Initializes the Hermes gateway and web-ui components by generating /etc/mios/hermes/api.env and seeding /var/lib/mios/hermes/config.yaml based on mios.toml configurations during first boot.
# AI-related: /etc/mios/hermes/api.env, /etc/mios/mios.toml, /usr/share/mios/mios.toml, /usr/libexec/mios/mios-dashboard.sh, /etc/mios/hermes, /etc/mios/hermes/discord.env, /usr/lib/mios/agents/.venv., /usr/lib/mios/agents/.venv/bin/hermes, /usr/lib/mios/hermes-agent/.venv/bin/hermes, /usr/libexec/mios/mios-pc-vision
# AI-functions: _log, _mios_toml_layers, _mios_toml_value, _mios_toml_catalog, _sync_discord_env_var, _op_cfg_should_reseed, _soul_should_seed, _build_soul_runtime_ctx, _refresh_soul_ctx, _skill_should_seed, _seed_one_skill, _wait_for_owui
# MiOS -- mios-hermes-firstboot: generate /etc/mios/hermes/api.env if missing
# AND seed /var/lib/mios/hermes/config.yaml with the model selected in
# mios.toml [ai] + [ai.host_thresholds] auto-pick.
#
# The same key is read by both mios-hermes (gateway) and
# mios-open-webui (chat front-end) via EnvironmentFile= in their
# Quadlets. Idempotent: re-runs are no-ops once API_SERVER_KEY exists
# and the seeded config.yaml's MiOS-seeded sentinel + model match the
# resolved mios.toml [ai].model.
set -euo pipefail

# Defined here (not just inside the seeded config.yaml) so unquoted
# heredocs that reference ${HERMES_HOME} in their commentary expand
# cleanly under `set -u`. Hermes-Agent 0.13.x reads
# ${HERMES_HOME}/config.yaml; the gateway service sets the same value
# via Environment= in hermes-agent.service.
HERMES_HOME="/var/lib/mios/hermes"

ENV_FILE="/etc/mios/hermes/api.env"

_log() { logger -t mios-hermes-firstboot "$*" 2>/dev/null || true; echo "[hermes-firstboot] $*" >&2; }

# ─── mios.toml layered overlay reader ───────────────────────────────────────
#
# Reads [section].key from ~/.config/mios/mios.toml -> /etc/mios/mios.toml
# -> /usr/share/mios/mios.toml, returning the FIRST non-empty match
# (operator overlay wins). Same arity + semantics as the bash resolver
# in /usr/libexec/mios/mios-dashboard.sh -- copied here so this script
# can run before mios-dashboard's helper is sourced.
_mios_toml_layers() {
    local home="${HOME:-/root}"
    printf '%s\n' \
        "$home/.config/mios/mios.toml" \
        "/etc/mios/mios.toml" \
        "/usr/share/mios/mios.toml"
}

_mios_toml_value() {
    local section="$1" key="$2" def_val="$3"
    local toml
    while IFS= read -r toml; do
        [[ -r "$toml" ]] || continue
        local v
        v="$(awk -v want_section="$section" -v want_key="$key" '
            BEGIN { in_section = 0; found = 0 }
            /^\[/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                in_section = (line == "[" want_section "]") ? 1 : 0
                next
            }
            in_section && /^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*[[:space:]]*=/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                eq = index(line, "=")
                if (eq == 0) next
                k = substr(line, 1, eq - 1)
                v = substr(line, eq + 1)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                gsub(/^"|"$/, "", v)
                if (k == want_key) { print v; found = 1; exit }
            }
        ' "$toml")"
        if [[ -n "$v" ]]; then printf '%s' "$v"; return; fi
    done < <(_mios_toml_layers)
    printf '%s' "$def_val"
}

# Read an array-of-tables [[ai.catalog]] and emit id<TAB>label<TAB>ram_gb
# per row. Layered overlay: rows from the highest-precedence file that
# has ANY [[ai.catalog]] entries win wholesale (no merging across layers
# -- TOML AoT semantics don't merge, and operator editing the dropdown
# means they want their list, not the vendor's appended).
_mios_toml_catalog() {
    local toml
    while IFS= read -r toml; do
        [[ -r "$toml" ]] || continue
        local out
        out="$(awk '
            BEGIN { in_t = 0; id = ""; label = ""; ram = "" }
            /^\[\[ai\.catalog\]\]/ {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
                in_t = 1; id = ""; label = ""; ram = ""
                next
            }
            /^\[/ {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
                in_t = 0; id = ""; label = ""; ram = ""
                next
            }
            in_t && /^[[:space:]]*[A-Za-z_]+[[:space:]]*=/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                eq = index(line, "=")
                if (eq == 0) next
                k = substr(line, 1, eq - 1)
                v = substr(line, eq + 1)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                gsub(/^"|"$/, "", v)
                if (k == "id") id = v
                else if (k == "label") label = v
                else if (k == "ram_gb") ram = v
            }
            END {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
            }
        ' "$toml")"
        if [[ -n "$out" ]]; then printf '%s' "$out"; return; fi
    done < <(_mios_toml_layers)
}

# ─── Resolve the model to seed ──────────────────────────────────────────────
#
# Start from [ai].model (the operator's chosen / vendor-default value).
# Then apply [ai.host_thresholds] auto-pick: if the host has enough RAM,
# roll up to mid_ram_model or big_ram_model. Auto-pick only runs when
# the operator hasn't overlaid [ai].model in /etc/mios/mios.toml or
# ~/.config/mios/mios.toml (operator override wins).
_AI_MODEL_DEFAULT="$(_mios_toml_value 'ai' 'model' 'granite4.1:3b')"

# Is [ai].model overlaid by an operator layer? (any non-vendor layer)
_overlaid=0
for _layer in "${HOME:-/root}/.config/mios/mios.toml" "/etc/mios/mios.toml"; do
    [[ -r "$_layer" ]] || continue
    if grep -qE '^\[ai\]' "$_layer" && \
       awk '/^\[ai\]/,/^\[/{if (/^model[[:space:]]*=/) {print; exit}}' "$_layer" | grep -q '='; then
        _overlaid=1
        break
    fi
done

# Resolve tier model lookups from mios.toml [ai.host_thresholds].
_big_m="$(_mios_toml_value 'ai.host_thresholds' 'big_ram_model' 'granite4.1:30b')"
_mid_m="$(_mios_toml_value 'ai.host_thresholds' 'mid_ram_model' 'qwen3.5:9b')"
_small_m="$(_mios_toml_value 'ai.host_thresholds' 'small_ram_model' "$_AI_MODEL_DEFAULT")"

# Detect actual GPU VRAM. Operator directive 2026-05-16 (mios.toml
# [ai.host_thresholds] comment, line ~651): "if detected GPU has more
# than 8GB of VRAM it deploys with medium sized models ... ALL AGENTS
# DEFAULTS TO CPU models -- across all hardware". So promotion is
# driven by VRAM, NOT system RAM. nvidia-smi (NVIDIA, incl. WSL2
# passthrough) and rocm-smi (AMD) are the canonical probes; if
# neither exists or returns 0, the host is CPU-only and we stay
# on small_ram_model.
_vram_gb=0
if command -v nvidia-smi >/dev/null 2>&1; then
    _vram_mib="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null \
        | awk 'BEGIN{m=0} {if ($1+0 > m) m=$1+0} END{print m}')"
    _vram_gb=$(( ${_vram_mib:-0} / 1024 ))
elif command -v rocm-smi >/dev/null 2>&1; then
    _vram_mib="$(rocm-smi --showmeminfo vram --csv 2>/dev/null \
        | awk -F, 'NR>1 {gsub(/[^0-9]/,"",$2); if ($2+0 > m) m=$2+0} END{print m+0}')"
    # rocm-smi reports bytes; convert
    _vram_gb=$(( ${_vram_mib:-0} / 1024 / 1024 / 1024 ))
fi

_AI_MODEL_RESOLVED="$_AI_MODEL_DEFAULT"
if [[ "$_overlaid" -eq 1 ]]; then
    _log "operator overlay sets [ai].model=${_AI_MODEL_RESOLVED} -- skipping auto-pick"
else
    _mid_vram="$(_mios_toml_value 'ai.host_thresholds' 'mid_vram_gb' '8')"
    # Auto-pick only EVER picks small or mid. big_ram_model requires
    # explicit operator opt-in via mios.html (sets [ai].model in
    # /etc/mios/mios.toml, triggering the _overlaid=1 branch above).
    # Per operator directive, even a 24GB+ VRAM host stays on small
    # unless mios.html promotes -- VRAM-promote stops at mid.
    if (( _vram_gb >= _mid_vram )); then
        _AI_MODEL_RESOLVED="$_mid_m"
        _log "auto-pick: detected GPU VRAM ${_vram_gb} GB >= ${_mid_vram} -> mid tier ${_AI_MODEL_RESOLVED}"
    else
        _AI_MODEL_RESOLVED="$_small_m"
        _log "auto-pick: detected GPU VRAM ${_vram_gb} GB < ${_mid_vram} -> small tier ${_AI_MODEL_RESOLVED}"
    fi
fi

# ─── Hermes role model (operator 2026-05-21) ────────────────────────────────
# "EVERY Agent and Sub-Agent should have an equivalent MiOS Modelfile for each
# role." Hermes (the general orchestrator) runs its role model
# mios-hermes:latest -- a Modelfile built FROM the auto-picked base with MiOS
# params; SOUL.md still drives behaviour at runtime. HERMES-SPECIFIC: the
# global [ai].model (10+ other consumers -- mios-micro-llm, mios-pc-vision,
# mios-doctor, ...) stays UNTOUCHED. Safe by construction: the tier-walk below
# validates this tag against Ollama's tags and falls back to the auto-picked
# base tier if mios-hermes wasn't built, and the base-model fallback_model
# chain backs it at runtime. Override with MIOS_HERMES_ROLE_MODEL=none to keep
# the bare auto-picked base, or =<tag> to pin a different role model.
_HERMES_ROLE_MODEL="${MIOS_HERMES_ROLE_MODEL:-gemma4:12b}"
if [[ "$_HERMES_ROLE_MODEL" != "none" ]]; then
    _AI_MODEL_RESOLVED="$_HERMES_ROLE_MODEL"
    _log "hermes role model: pinning Hermes to ${_AI_MODEL_RESOLVED} (auto-picked base kept as fallback)"
fi

# Backend endpoint for the generated config -- SSOT-derived from mios.toml
# [ai].backend (the mios-llm-light front; ollama :11434 retired). Default matches the
# vendor value so a missing/unreadable toml still yields a working endpoint
# (operator 2026-06-07: firstboot previously HARDCODED the port, so a stale REPL
# config survived the ollama->mios-llm-light migration; now it follows the SSOT).
_AI_BACKEND="$(_mios_toml_value ai backend 'http://localhost:11450')"
_AI_BACKEND="${_AI_BACKEND%/}"

# ── Agent-surface (orchestrator) endpoint + model for THIN clients ──────────────
# The interactive `hermes` CLI REPL must be a THIN client to the agent-pipe
# ORCHESTRATOR on :8640 (served model "MiOS-Agent"), exactly like the @/mios CLI
# and the Hermes DESKTOP app -- NOT a direct leaf granite native tool-loop on
# :11450. A leaf tool-loop fabricates (granite emits tool-call JSON it can't
# broker-execute -> "typed into chat" LIAR + same_tool_failure_halt). The
# orchestrator runs the loop SERVER-SIDE (refine -> route -> broker-exec +
# read-back verify -> polish), so a thin client never fabricates. Both values
# flow from the [ai] SSOT (operator "UNIFY THE MiOS AI PIPELINE" / "NO HARDCODES").
_AGENT_ENDPOINT="$(_mios_toml_value ai endpoint 'http://localhost:8640/v1')"
_AGENT_ENDPOINT="${_AGENT_ENDPOINT%/}"
_AGENT_MODEL="$(_mios_toml_value ai agent_model 'MiOS-Agent')"

# Make sure the directory exists with the right ownership. tmpfiles.d
# should have done this already, but be defensive in case the .service
# fires before tmpfiles for some reason.
mkdir -p /etc/mios/hermes
chown -h mios-ai:mios-ai /etc/mios/hermes 2>/dev/null || true
chmod 0750 /etc/mios/hermes 2>/dev/null || true

if [[ -f "$ENV_FILE" ]] && grep -q '^API_SERVER_KEY=' "$ENV_FILE"; then
    _log "$ENV_FILE already has API_SERVER_KEY -- skipping key generation"
    _skip_keygen=1
else
    _skip_keygen=0
fi

if [[ "$_skip_keygen" -eq 0 ]]; then
    # Generate a 64-char hex key. openssl is in @core on Fedora CoreOS so
    # this is always available; fall back to /dev/urandom if it isn't.
    if command -v openssl >/dev/null 2>&1; then
        api_key="$(openssl rand -hex 32)"
    else
        api_key="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    fi

    # Write the env file with secure perms BEFORE chowning to mios-hermes
    # so the Quadlet's EnvironmentFile= read-as-root can succeed even if
    # the per-uid mios-hermes login is denied (`/usr/sbin/nologin`).
    umask 0077
    cat > "$ENV_FILE" <<EOF
# /etc/mios/hermes/api.env -- generated by mios-hermes-firstboot.service
# at $(date -Iseconds) on $(hostname).
# Rotate by deleting this file and restarting mios-hermes-firstboot.

API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${api_key}
API_SERVER_CORS_ORIGINS=*
OPENAI_API_KEY=${api_key}

# Hermes's "gateway run" mode bundles a messaging-platform router
# (Telegram / Discord / Slack) that enforces a USER ALLOWLIST on every
# request -- chat-completions included. Without an allowlist, the
# gateway DENIES all requests with the cryptic "No user allowlists
# configured. All unauthorized users will be denied" warning, then
# 401s the chat. MiOS isn't running messaging platforms (Workspace
# UI is the only frontend), so we opt out of the allowlist gate to
# let any caller with a valid API_SERVER_KEY through.
# Operator-flagged 2026-05-11: "all messages get Retry".
GATEWAY_ALLOW_ALL_USERS=true

# Hermes Workspace consumes these via the SAME EnvironmentFile= mount.
# Systemd Quadlet Environment= directives do NOT expand \${API_SERVER_KEY}
# from sibling EnvironmentFile= contents, so we have to write the
# explicit duplicates here. The workspace falls back to a legacy HTML-
# scrape token flow when CLAUDE_DASHBOARD_TOKEN is unset, which fails
# against our minimal gateway image and triggers a client-side
# redirect to /error. Operator-flagged 2026-05-11.
HERMES_API_TOKEN=${api_key}
CLAUDE_DASHBOARD_TOKEN=${api_key}
EOF
    umask 0022
    chown root:mios-ai "$ENV_FILE" 2>/dev/null || true
    chmod 0640 "$ENV_FILE" 2>/dev/null || true

    _log "wrote $ENV_FILE (64-char API_SERVER_KEY)"
fi

# ─── /etc/mios/hermes/discord.env (Discord bot token, operator-managed) ─
# Empty stub seeded so that:
#   * hermes-agent.service's EnvironmentFile=- finds a readable file
#     (no "file not found" warnings in the journal)
#   * the operator has a known location to drop a token, with inline
#     instructions on how to obtain one
# Discord toolset reads DISCORD_BOT_TOKEN from this file. If unset, the
# tool surfaces a clear "missing token" error to the agent on first
# call, which the agent then asks the operator about.
DISCORD_ENV="/etc/mios/hermes/discord.env"
if [[ ! -f "$DISCORD_ENV" ]]; then
    umask 0077
    cat > "$DISCORD_ENV" <<'DISCORDEOF'
# /etc/mios/hermes/discord.env -- operator-managed.
#
# Drop a Discord bot token here for Hermes-Agent's `discord` toolset:
#   DISCORD_BOT_TOKEN=<your-bot-token>
#
# How to obtain a bot token (one-time):
#   1. https://discord.com/developers/applications -> New Application
#   2. Bot tab -> Reset Token -> copy the token (shown once)
#   3. OAuth2 -> URL Generator -> tick `bot` + `applications.commands`
#      + the permissions your agent needs (Send Messages, Read Message
#      History, Manage Threads, ...). Open the resulting URL and
#      authorise the bot into your guild.
#   4. Paste the token below as DISCORD_BOT_TOKEN=<token>, save, then:
#        sudo systemctl restart hermes-agent.service
#
# Permissions: 0640 root:mios-hermes (root edits, mios-hermes reads).
DISCORDEOF
    umask 0022
    chown root:mios-ai "$DISCORD_ENV" 2>/dev/null || true
    chmod 0640 "$DISCORD_ENV" 2>/dev/null || true
    _log "seeded empty $DISCORD_ENV (operator drops DISCORD_BOT_TOKEN here)"
fi

# ─── /usr/local/bin/chrome -- shim so mios-gui chrome / launch_app chrome ──
# routes through mios-chrome (CDP on :9222 + Wayland + persistent profile)
# instead of the bare flatpak-launch path the generic shim generator
# would produce. mios-gui detects this shim by the "MiOS shim for the"
# string in its first 3 lines. Idempotent: rewritten every boot so a
# stale generator-output gets superseded. Required for Hermes'
# browser_navigate / browser_snapshot / etc. to attach to the
# operator's actual visible Chrome instance (operator-flagged
# 2026-05-17).
install -d -m 0755 /usr/local/bin
cat > /usr/local/bin/chrome <<'CHROMEEOF'
#!/bin/sh
# /usr/local/bin/chrome -- MiOS shim for the com.google.ChromeDev flatpak.
# Routes through /usr/bin/mios-chrome which wraps the flatpak launch
# with --remote-debugging-port=9222 + Wayland args + persistent
# --user-data-dir so Hermes' browser_navigate connects to the SAME
# browser instance the operator drives (shared cookies, logged-in
# state). mios-gui detects this shim via the "MiOS shim for the"
# string in its first 3 lines and exec's it.
exec /usr/bin/mios-chrome "$@"
CHROMEEOF
chmod 0755 /usr/local/bin/chrome

# ─── Reconcile MIOS_DISCORD_DEFAULT_* env from mios.toml [identity] ─────
# Operator sets [identity].discord_channel_default + .discord_guild_default
# in the layered mios.toml overlay (vendor < /etc < ~/.config). We sync
# those values into /etc/mios/hermes/discord.env so the running
# hermes-agent process has them in os.environ alongside DISCORD_BOT_TOKEN.
# The chat model is told about them via the seeded SOUL.md so it has
# the default channel as authoritative context when the operator says
# "send to discord" without naming a channel. Idempotent: the
# assignment line is REPLACED on every firstboot run if it drifts.
_discord_channel="$(_mios_toml_value 'identity' 'discord_channel_default' '')"
_discord_guild="$(_mios_toml_value   'identity' 'discord_guild_default'   '')"
_sync_discord_env_var() {
    local _key="$1" _val="$2"
    # Strip any existing line; append new (only when value non-empty).
    local _tmp
    _tmp="$(mktemp)"
    grep -v "^${_key}=" "$DISCORD_ENV" 2>/dev/null > "$_tmp" || true
    if [[ -n "$_val" ]]; then
        printf '%s=%s\n' "$_key" "$_val" >> "$_tmp"
    fi
    install -m 0640 -o root -g mios-ai "$_tmp" "$DISCORD_ENV"
    rm -f "$_tmp"
}
if [[ -n "$_discord_channel" || -n "$_discord_guild" ]]; then
    _sync_discord_env_var "MIOS_DISCORD_DEFAULT_CHANNEL" "$_discord_channel"
    _sync_discord_env_var "MIOS_DISCORD_DEFAULT_GUILD"   "$_discord_guild"
    _log "synced MIOS_DISCORD_DEFAULT_{CHANNEL,GUILD} from mios.toml [identity] into $DISCORD_ENV"
fi

# ─── /var/lib/mios/hermes/config.yaml (Hermes-Agent main config) ────────
#
# Hermes-Agent 0.13.x reads $HERMES_HOME/config.yaml. The direct host
# install (automation/38-hermes-agent.sh + hermes-agent.service) sets
# HERMES_HOME=/var/lib/mios/hermes, so the agent's config lives at
# /var/lib/mios/hermes/config.yaml. NOTE: 0.13.x ignores the
# HERMES_CONFIG_PATH env var entirely -- HERMES_HOME is authoritative.
#
# SCHEMA -- load-bearing. Hermes-Agent 0.13.x resolves the inference
# provider via hermes_cli/runtime_provider.py::resolve_requested_provider:
# it reads config["model"], and ONLY honours a `provider:` key when
# `model` is a DICT. If `model` is a bare string the provider is
# unknown -> falls through to "auto" -> tries openrouter -> HTTP 401
# "Missing Authentication header" (no OPENROUTER_API_KEY).
# Operator-confirmed 2026-05-14. So `model` MUST be a mapping:
#   model:
#     provider: custom:<name>     # matches a custom_providers[].name
#     default:  <ollama-model-id>
#     base_url: ${_AI_BACKEND}/v1
# `provider: custom:local-ollama` then resolves against the
# `custom_providers:` list entry named `local-ollama`. The pre-0.13
# `backend:` block is genuinely unused by 0.13.x -- we drop it (the
# re-seed detection below treats a leftover `backend:` as stale).
#
# Architectural Law 5 (UNIFIED-AI-REDIRECTS): the agent loop stays
# fully local -- custom_providers[local-ollama] points at the on-box
# Ollama OpenAI surface, no cloud calls.
# ─── Auto-recover Hermes-Agent venv if missing ───────────────────────
# automation/38-hermes-agent.sh installs Hermes-Agent directly onto
# the host (NOT a container) at /usr/lib/mios/agents/.venv. That
# script runs at OCI build time. But:
#   * stale OCI images pre-2026-05 don't have it baked in
#   * if the build-time install failed silently (network, PyPI hiccup),
#     the venv won't be there post-install either
# In both cases hermes-agent.service silently no-ops at boot via:
#   ConditionPathExists=/usr/lib/mios/agents/.venv/bin/hermes
# and the operator gets a "Hermes won't work" surprise hours later.
#
# Detect the missing venv here and re-run the installer if we can find
# it. The installer is itself idempotent + safe to re-run -- worst case
# it re-pulls + re-installs the package. Operator-confirmed regression
# 2026-05-15: fresh MiOS install came up with hermes-agent inactive
# because the build never installed the venv.
if [[ ! -x /usr/lib/mios/agents/.venv/bin/hermes ]]; then
    _hermes_installer=""
    for _c in /var/lib/mios/build/mios-bootstrap/automation/38-hermes-agent.sh \
              /opt/mios-bootstrap/automation/38-hermes-agent.sh \
              "${MIOS_BOOTSTRAP_REPO:-}/automation/38-hermes-agent.sh" \
              /mnt/m/automation/38-hermes-agent.sh; do
        [[ -n "$_c" && -x "$_c" ]] && { _hermes_installer="$_c"; break; }
    done
    if [[ -n "$_hermes_installer" ]]; then
        _log "hermes-agent venv missing -- running $_hermes_installer to recover"
        bash "$_hermes_installer" 2>&1 | sed 's/^/  /' \
            | while IFS= read -r _line; do _log "$_line"; done || \
            _log "WARN: hermes-agent installer exited non-zero"
        if [[ -x /usr/lib/mios/agents/.venv/bin/hermes ]]; then
            _log "hermes-agent venv installed; daemon-reload + start the service"
            systemctl daemon-reload || true
            # --no-block: firstboot must not WAIT on hermes-agent settling
            # (it has its own readiness deps + can deadlock against this very
            # service in the early-boot ordering -- the ~23min hang, 2026-06-14).
            systemctl restart --no-block hermes-agent.service 2>&1 | sed 's/^/  /' \
                | while IFS= read -r _line; do _log "$_line"; done || true
        else
            _log "WARN: installer ran but venv still absent at /usr/lib/mios/agents/.venv/bin/hermes"
        fi
    else
        _log "WARN: hermes-agent venv missing AND no installer found in any candidate path"
        _log "  candidates checked: /var/lib/mios/build/mios-bootstrap/automation/38-hermes-agent.sh,"
        _log "                       /opt/mios-bootstrap/..., \$MIOS_BOOTSTRAP_REPO/..., /mnt/m/..."
        _log "  manual recovery: run that script as root"
    fi
fi

HERMES_DATA=/var/lib/mios/hermes
HERMES_ARTIFACTS=/var/lib/mios/ai/artifacts
HERMES_RESEARCH=/var/lib/mios/ai/research
HERMES_DATA_CFG="${HERMES_DATA}/config.yaml"
mkdir -p "$HERMES_DATA" "$HERMES_ARTIFACTS" "$HERMES_RESEARCH"

# Ownership: hermes-agent.service runs as the mios-hermes sysuser
# (uid 820). The pre-2026-05-14 mios-hermes CONTAINER ran with an
# in-container uid (10000) and bind-mounted this dir, leaving it
# orphan-owned 10000:10000 mode 0700 -- the direct-install service
# (uid 820) then cannot write its own state dir and chat completions
# die with "Permission denied: /var/lib/mios/hermes/cron". Force the
# whole tree to 820:820 on every run -- cheap, idempotent, and heals
# the container -> direct-install migration.
chown -R 850:850 "$HERMES_DATA" "$HERMES_ARTIFACTS" "$HERMES_RESEARCH" 2>/dev/null || true
chmod 0750 "$HERMES_DATA" "$HERMES_ARTIFACTS" "$HERMES_RESEARCH" 2>/dev/null || true

# Validate the resolved model against what the LIVE BACKEND actually serves.
# The [ai.host_thresholds] auto-pick can resolve to a model that was never
# baked or pulled on this host -- pointing Hermes at a missing model breaks
# chat just as hard as a stale schema.
#
# G5/G8: ollama (:11434) is RETIRED. The canonical front is mios-llm-light
# (the llama-swap proxy at $_AI_BACKEND, default :11450), which exposes the
# served set via the OpenAI-compat `GET /v1/models` ({"data":[{"id":...}]}).
# Probe THAT and key every model decision (primary validation + fallback
# chain) on the REAL served ids -- never on hardcoded qwen3* literals (the
# old `localhost:11434` probe + qwen3.5:4b/qwen3:1.7b literals were the
# stale-config root cause; 2026-06-14).
#
# Fallback policy still walks the TIER chain (small -> mid -> big), NOT
# whatever happens to be first in the served list. Operator directive
# 2026-05-16: never silently upgrade past the operator's tier choice. If
# the chosen tier is missing, prefer the SMALLER safer option first so the
# host stays responsive; only escalate if nothing smaller is available.
_served_ids="$(curl -fsS --max-time 5 "${_AI_BACKEND}/v1/models" 2>/dev/null \
    | grep -oE '"id":"[^"]+"' | sed 's/"id":"//;s/"$//')"
if [[ -n "$_served_ids" ]]; then
    if ! grep -qxF "$_AI_MODEL_RESOLVED" <<< "$_served_ids"; then
        _picked=""
        for _candidate in "$_small_m" "$_mid_m" "$_big_m"; do
            [[ -z "$_candidate" ]] && continue
            if grep -qxF "$_candidate" <<< "$_served_ids"; then
                _picked="$_candidate"
                break
            fi
        done
        if [[ -z "$_picked" ]]; then
            # Last-resort: any non-embed served id. Better than a 401 loop,
            # but flag it loudly so the operator catches the gap.
            _picked="$(grep -viE 'embed' <<< "$_served_ids" | head -1)"
            [[ -n "$_picked" ]] && _log "WARN: no tier model in the served set -- using arbitrary '${_picked}'"
        fi
        if [[ -n "$_picked" ]]; then
            _log "resolved model '${_AI_MODEL_RESOLVED}' not in backend served set -- tier-walked to '${_picked}'"
            _AI_MODEL_RESOLVED="$_picked"
        else
            _log "WARN: '${_AI_MODEL_RESOLVED}' not served by ${_AI_BACKEND} and no non-embed fallback found"
        fi
    fi
fi

# Build the fallback chain Hermes walks if the primary model emits invalid
# tool calls / empty bodies. Policy: never escalate ABOVE the resolved
# primary tier (the operator's tier ceiling is binding). Candidates are
# keyed on the REAL served set (no qwen3* literals): the resolved tier
# models (small -> mid) followed by the smallest served non-embed id as a
# universal safety net, so the chat NEVER silently fails over to an
# unreachable cloud provider. Emit only candidates the backend actually
# serves; skip duplicates of the primary.
_safety_net=""
if [[ -n "$_served_ids" ]]; then
    _safety_net="$(grep -viE 'embed' <<< "$_served_ids" | head -1)"
fi
_FALLBACK_CHAIN=()
_seen=" $_AI_MODEL_RESOLVED "
for _cand in "$_small_m" "$_mid_m" "$_safety_net"; do
    [[ -z "$_cand" ]] && continue
    [[ "$_seen" == *" $_cand "* ]] && continue
    if [[ -z "$_served_ids" ]] || grep -qxF "$_cand" <<< "$_served_ids"; then
        _FALLBACK_CHAIN+=("$_cand")
        _seen+="$_cand "
    fi
done
_FALLBACK_YAML=""
for _m in "${_FALLBACK_CHAIN[@]}"; do
    _FALLBACK_YAML+="    - provider: custom:local-ollama
      model: ${_m}
"
done
# Trim trailing newline so heredoc doesn't get a blank line at the end
_FALLBACK_YAML="${_FALLBACK_YAML%$'\n'}"
if [[ -z "$_FALLBACK_YAML" ]]; then
    _FALLBACK_YAML="    # (no tier-safe fallback models in the backend served set)"
fi
_log "fallback chain (tier-safe): ${_FALLBACK_CHAIN[*]:-<none>}"

# Auxiliary + delegation model names -- pulled from the REAL served set
# (G5/G8: no qwen3* literals). The auxiliary lanes (compression, title-gen,
# triage, curator, mcp, web_extract, approval, skills_hub, session_search)
# and the delegate workers should run on a SMALL fast model: prefer the
# resolved small tier, then the smallest served non-embed id, finally the
# resolved primary (always valid). Both names are validated against
# $_served_ids when the backend is reachable; when it isn't (air-gapped
# firstboot) we trust the tier resolution. The big GPU model stays the
# primary; these keep auxiliary/delegate fan-out off the big lane.
_aux_validate() {
    # echo the first arg that is in the served set (or first arg if the
    # backend is unreachable / served set unknown).
    local _c
    for _c in "$@"; do
        [[ -z "$_c" ]] && continue
        if [[ -z "$_served_ids" ]] || grep -qxF "$_c" <<< "$_served_ids"; then
            printf '%s' "$_c"; return 0
        fi
    done
    # nothing served matched -> fall back to the primary (guaranteed valid)
    printf '%s' "$_AI_MODEL_RESOLVED"
}
_AUX_MODEL="$(_aux_validate "$_small_m" "$_safety_net" "$_AI_MODEL_RESOLVED")"
_DELEGATION_MODEL="$(_aux_validate "$_small_m" "$_safety_net" "$_AI_MODEL_RESOLVED")"
_log "auxiliary model: ${_AUX_MODEL}; delegation model: ${_DELEGATION_MODEL}"

# Bump this in lockstep with the _config_version: NN literal in the seeded
# heredoc below. Existing hosts whose config carries an older version re-seed
# automatically (so the ollama->served-set probe + family-diverse model names
# propagate without a manual delete; 2026-06-14).
_CONFIG_VERSION=24
_should_seed=0
if [[ ! -f "$HERMES_DATA_CFG" ]]; then
    _should_seed=1
elif ! grep -qxF "_config_version: ${_CONFIG_VERSION}" "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the current schema version -- re-seed to pick up the
    # latest model resolution + block layout.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- _config_version drift (want ${_CONFIG_VERSION})"
elif grep -qE '^backend:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Leftover pre-0.13 `backend:` block -- stale schema, rewrite.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- detected pre-0.13 container-era schema"
elif ! grep -qE '^auxiliary:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the auxiliary-services mapping -- 0.13.x would
    # log "No auxiliary LLM provider configured" and drop compression
    # summaries. Rewrite to add the auxiliary: + web: blocks.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing auxiliary endpoint mapping"
elif ! grep -qE '^display:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the display block -- the agent then narrates tool
    # results instead of showing them verbatim, which is the dominant
    # vector for fabricated "status" reports on local models. Rewrite
    # to add the display: knobs (tool_progress: verbose, etc.).
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing display block (counter-fabrication)"
elif ! grep -qE '^delegation:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the delegation block -- the orchestrator can't
    # spawn parallel child agents, and auxiliary services still serialize
    # through the big GPU model instead of fanning out to a small CPU
    # model. Rewrite to add delegation: + swap auxiliary models.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing delegation block (multi-agent parallelism)"
elif grep -q 'model: qwen3:1.7b' "$HERMES_DATA_CFG" 2>/dev/null; then
    # qwen3:1.7b reports 40,960 tokens which is below the Hermes v0.15+
    # 64k floor. Re-seed to promote to qwen3.5:4b or add overrides.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- detected legacy qwen3:1.7b (below 64k floor)"
elif ! grep -qE '^approvals:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the autonomy alignment -- without explicit
    # approvals.mode=auto the agent pauses for per-call approval,
    # making the broad sudo grant + multi-agent delegation pointless.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing approvals/autonomy block"
elif ! grep -A 15 '^delegation:' "$HERMES_DATA_CFG" 2>/dev/null | grep -q 'ollama_num_ctx:'; then
    # Config missing context-window overrides in the delegation block --
    # Hermes v0.15+ will refuse tool use on parallel child agents if the
    # model (like qwen3:1.7b) reports < 64k.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing delegation ollama_num_ctx overrides"
elif ! grep -qE '^mcp_servers:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the MCP-client block -- Hermes can't consume the global
    # mios-mcp-server (no verbs/recipes/skills via MCP). Re-seed to add it
    # (operator 2026-06-07: Hermes must have all Global MiOS MCP surfaces).
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing mcp_servers (global MCP surface)"
elif ! grep -qE "^  default: ${_AI_MODEL_RESOLVED}$" "$HERMES_DATA_CFG" 2>/dev/null; then
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- model drift: want default '${_AI_MODEL_RESOLVED}'"
fi

if [[ "$_should_seed" -eq 1 ]]; then
    # Unquoted heredoc so ${_AI_MODEL_RESOLVED} / ${_AI_MODEL_DEFAULT}
    # expand. No ${API_SERVER_KEY}-style values referenced here (those
    # live in api.env, loaded separately via hermes-agent.service
    # EnvironmentFile=).
    umask 0077
    cat > "$HERMES_DATA_CFG" <<EOF
# /var/lib/mios/hermes/config.yaml -- MiOS-seeded (Hermes-Agent 0.13.x schema)
# Generated by mios-hermes-firstboot.service. Hermes-Agent reads
# \$HERMES_HOME/config.yaml; HERMES_HOME=/var/lib/mios/hermes.
#
# AI chain: ollama (:11434, raw inference) -> Hermes-Agent (:8642/v1,
# OpenAI gateway + agent loop) -> Open WebUI (:3030). The gateway's own
# API key lives in /etc/mios/hermes/api.env (API_SERVER_KEY), loaded by
# hermes-agent.service via EnvironmentFile=.
#
# Resolved values:
#   [ai].model            -> ${_AI_MODEL_DEFAULT}
#   validated vs Ollama   -> ${_AI_MODEL_RESOLVED}
_config_version: ${_CONFIG_VERSION}

# Primary model. MUST be a mapping (not a bare string) so
# resolve_requested_provider() sees the provider= key. provider=
# "custom:local-ollama" resolves against the custom_providers entry
# below. Architectural Law 5: local Ollama only, no cloud calls.
model:
  provider: custom:local-ollama
  default: ${_AI_MODEL_RESOLVED}
  base_url: ${_AI_BACKEND}/v1
  api_key: ""
  # Hermes v0.15 PREFLIGHTS the runtime context window and REFUSES tool use
  # under 64k ("Ollama runtime context is too small for Hermes tool use"),
  # which silently failed EVERY agent:hermes swarm node (operator 2026-05-29).
  # The gateway must REQUEST 64k from ollama on each call -- the model's own
  # Modelfile num_ctx is not enough because the gateway sends its own
  # options.num_ctx. Pin both: ollama_num_ctx (the per-request num_ctx the
  # gateway passes through to ollama) + context_length (the window Hermes
  # advertises to itself). 65536 matches mios-hermes.Modelfile PARAMETER
  # num_ctx 65536 (9b @ 64k q8_0 KV ~10.6 GB, fits the 4090).
  ollama_num_ctx: 65536
  context_length: 65536

# Fallback chain (Hermes-Agent 0.13.x: model.fallback_model accepts
# a list of {provider, model} dicts and walks left-to-right when the
# primary returns invalid tool calls, empty bodies, or 3xx retries
# exceeded -- preserving conversation history across the swap).
# Walks DOWN the tier, never UP -- operator directive 2026-05-16:
# auto-selection must never escalate past the operator's chosen tier
# (e.g. a CPU-only host stuck with primary=4B should fall back to
# 1.7B / 0.6B safety nets, not climb to 30B and freeze).
  fallback_model:
${_FALLBACK_YAML}

custom_providers:
  - name: local-ollama
    base_url: ${_AI_BACKEND}/v1
    api_key: ""

# Auxiliary LLM services (context compression / summarization, memory
# flush, title + triage + curation, MCP reasoning, web-extract,
# approvals, skills-hub). 0.13.x does NOT inherit the main provider for
# these -- left unmapped it logs "No auxiliary LLM provider configured"
# and silently drops context-compression summaries. Map every one at
# the same on-box Ollama provider so the agent is fully self-contained.
auxiliary:
  # ALL auxiliary lanes need >= 64K context window or Hermes refuses
  # to start chat completions ("Auxiliary <lane> model X has a context
  # window of N tokens, which is below the minimum 64,000 required by
  # Hermes Agent" -- operator-confirmed 2026-05-15 & re-confirmed
  # 2026-05-17 when qwen3:1.7b @ 40,960 tokens was wired here and
  # every delegate spawn 503'd). qwen3.5:4b @ 262,144 tokens is the
  # safe default: small (~3GB), CPU-friendly, comfortably above the
  # floor. Compression stays on the main model for context-fill
  # events (infrequent).
  compression:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AI_MODEL_RESOLVED}
    ollama_num_ctx: 65536
    context_length: 65536
  session_search:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  title_generation:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  triage_specifier:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  curator:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  mcp:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  web_extract:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  approval:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  skills_hub:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: ${_AUX_MODEL}
    ollama_num_ctx: 65536
    context_length: 65536
  # Vision-grounding lane for screenshot -> click-coordinate
  # translation. Used by /usr/libexec/mios/mios-pc-vision (the
  # PC-Control vision-grounded loop, Path B in the pc-control
  # skill). qwen3-vl:4b has native 2D coordinate grounding;
  # UI-TARS-1.5-7B is the upgrade-path candidate (PC-specific).
  # Architecture: /usr/share/mios/docs/agents/PC-CONTROL-LOCAL.md.
  vision_grounding:
    provider: custom:local-ollama
    base_url: ${_AI_BACKEND}/v1
    model: qwen3-vl:4b

# Web SEARCH -> the on-box SearXNG (mios-searxng, SEARXNG_URL). Web EXTRACT ->
# \`miosfetch\`, MiOS's OWN offline direct-fetch provider (stdlib urllib +
# readability HTML->text; plugins/web/miosfetch, deployed by 38-hermes-agent.sh
# from /usr/share/mios/hermes/plugins). WHY NOT firecrawl: hermes pins firecrawl
# -py v4 (firecrawl API v2, POST /v2/scrape) but MiOS self-hosts firecrawl
# v1.0.0 (v1 API) -> every web_extract 404s (operator-confirmed 2026-05-31:
# research turns could never drill past search-result homepages). extract_backend
# MUST be set EXPLICITLY -- without it web_extract errors "No web extract provider
# configured". The firecrawl plugin is still registered (dormant fallback); flip
# this back to \`firecrawl\` if the self-hosted container is ever upgraded to the
# v2 API. Law 5 unaffected -- retrieval, not inference.
web:
  search_backend: searxng
  extract_backend: miosfetch

# Display: surface real tool output in the chat (counter-fabrication).
# Toolset trim. Hermes by default exposes ~30+ tool definitions to the
# main agent (browser_navigate/click/type/scroll/back/snapshot/...,
# cronjob, image_generate, video_generate, vision_analyze, text_to_speech,
# rl tools, ...). Each tool's full JSON schema sits in EVERY prompt --
# operator-confirmed regression 2026-05-15: the same chat completion
# went from 163,742 prompt tokens to 13,017 prompt tokens (92% reduction)
# after trimming to only the toolsets MiOS actually uses. Less context
# bloat = stronger signal-to-noise for the actual rules in SOUL.md +
# the parallel-fanout skill nudge -- the model is more likely to pick
# delegate_task when there's room for it to think about the choice.
#
# Operators can ADD toolsets back here (in the operator overlay
# /etc/mios/mios.toml or by editing /etc/mios/hermes/config.yaml and
# clearing the MiOS-managed sentinel).
#
# browser is enabled by default (operator directive 2026-05-15
# "Hermes-Browser isn't enabled!! Should be using the locally
# installed ChromeDev flatpak install"). The CDP endpoint at
# browser.cdp_url (http://localhost:9222) is served by
# mios-hermes-browser.service, which launches the ChromeDev flatpak
# headless with --remote-debugging-port=9222 + a dedicated
# user-data-dir under /var/lib/mios/hermes-browser/profile.
#
# discord is enabled by default (operator directive 2026-05-15
# "hermes-discord-tool too!! must be enabled--agents can ask for
# credentials"). The discord_tool reads DISCORD_BOT_TOKEN from the
# environment; it isn't set here. The agent surfaces "missing token"
# errors back to the operator on first call so they can drop a token
# into /etc/mios/hermes/discord.env (which the systemd unit picks up
# via EnvironmentFile=).
platform_toolsets:
  api_server:
    - terminal       # shell commands
    - file           # read/write/patch
    - web            # web_search via SearXNG (:8888) + web_extract via Firecrawl (:3002) -- FREE, local
    - browser        # browser_navigate / _snapshot / _click / ... via CDP -> ChromeDev flatpak
    - messaging      # send_message for Discord, Telegram, etc.
    - discord        # read + participate (fetch messages, search members, create threads)
    - cronjob        # create/list/update/pause/resume/remove/trigger scheduled prompts (in-process, croniter-backed)
    - clarify        # ask the operator clarifying questions instead of hallucinating an answer
    - delegation     # delegate_task -- the parallel-fanout target
    - skills         # skill_view / skill_manage / skills_list
    - memory         # persistent memory across sessions
    - todo           # in-turn task planning
    - session_search # search past conversations
    - code_execution # python execute_code
    - kanban         # kanban_create / _show / _list / _complete / _block / _comment / _link / _heartbeat (SQLite board at \$HERMES_HOME/kanban.db, surfaced in TUI via \`hermes kanban\` and in dashboard plugin at /api/plugins/kanban/)


# Top-level toolsets list = orchestrator-mode gating read by
# tool check_fn (e.g. tools.kanban_tools._profile_has_kanban_toolset).
# Without "kanban" present here, kanban_* tools register against the
# global registry but their check_fn returns False -- the gateway hides
# them from the agent's tool surface and the LLM never sees them, even
# with platform_toolsets.api_server listing "kanban" above. Mirror the
# api_server list verbatim so gating + surfacing stay in lockstep.
toolsets:
  - terminal
  - file
  - web
  - browser
  - messaging
  - discord
  - cronjob
  - clarify
  - delegation
  - skills
  - memory
  - todo
  - session_search
  - code_execution
  - kanban

# Hooks: NONE. Operator directive 2026-05-15: "no context injection
# for environment detection!!!! it WILL ONLY do it in code". The
# agent learns its environment by CALLING \`mios-env-probe\`,
# \`mios-apps\`, \`skill_view name=mios-environment\`, etc. as TOOL
# calls when it needs the data -- not by having text auto-prepended
# to every turn. The earlier pre_llm_call injection was disabled.
#
# Re-enable per-host by adding a hooks: block to /etc/mios/hermes/
# config.local.yaml (operator-overlay; vendor stays clean).

# When the agent narrates "the build succeeded" instead of pasting
# what it actually saw, the operator can't tell truth from fiction.
# These knobs make Hermes show the verbatim tool result inline -- in
# the TUI as a panel, in Open WebUI as a syntax-highlighted code block
# (the "terminal output in chat" experience). The model SOUL.md rules
# require it; these settings make it the default rendering.
display:
  tool_progress: verbose             # show full args + result for every tool call
  tool_progress_command: true        # show the command itself (e.g. \`mios build\`)

  tool_preview_length: 8000          # show up to 8000 chars of each tool result inline
  persistent_output: true            # keep tool output visible after the call returns
  persistent_output_max_lines: 2000  # default 200 truncated long build logs aggressively
  interim_assistant_messages: true   # stream progress as tools complete
  final_response_markdown: keep      # do NOT strip code blocks from the final answer
  inline_diffs: true
  show_reasoning: false              # flip to true if you want the chain-of-thought visible
  show_cost: false

# Web browsing via local com.google.ChromeDev flatpak. The chrome shim at
# /usr/local/bin/chrome launches Chrome with --remote-debugging-port=9222
# + --remote-allow-origins=* + --user-data-dir=... so CDP is bound on
# 127.0.0.1:9222 and accepts callers from outside the sandbox. Hermes's
# browser_navigate / browser_snapshot / browser_click / browser_press /
# browser_type / browser_scroll / browser_back / browser_get_images /
# browser_vision / browser_console / browser_cdp / browser_dialog tools
# all read this URL via tools/browser_cdp_tool.py. Operator launches
# chrome via \`mios-gui chrome\`; CDP is up within ~5s and stays bound
# until the window closes.
browser:
  cdp_url: http://localhost:9222     # local ChromeDev flatpak (mios-gui chrome)

# NOTE: web.search_backend is already declared above (the on-box
# SearXNG block). YAML mapping merge would silently drop the earlier
# entry; ruamel-yaml strict loaders (hermes_cli.config.load_config)
# raise DuplicateKeyError outright. Keep this section as documentation
# only -- the operative \`web:\` block is the earlier one.

# Multi-agent delegation. Hermes 0.13.x's orchestrator can spawn child
# agents (delegate_task tool) -- typically used to fan out discrete
# subtasks (search this file, lint that path, write a test) in parallel
# while the main agent stays focused on the high-level plan.
#
# Architecture for this host (9950X3D 16-core / 40 GB RAM / RTX 4090
# 24 GB VRAM): the MAIN agent runs the big tool-calling model on the
# GPU (model.default = qwen3-coder:30b, MoE, ~19 GB), while DELEGATES
# and the AUXILIARY services (compression, title-gen, session_search,
# triage, curator, mcp, web_extract, approval, skills_hub) run on the
# small fast qwen3.5:4b model -- ollama keeps it warm alongside the
# big one (OLLAMA_MAX_LOADED_MODELS=4) and serves up to 4 concurrent
# requests per model (OLLAMA_NUM_PARALLEL=4, set in ollama.container).
# Result: the orchestrator's children + auxiliary lanes actually run
# in parallel instead of serializing through one slot.
#
# subagent_auto_approve: true -- consistent with the operator's broad
# sudo grant for mios-hermes (10-mios-hermes); the agent is
# operator-authorized to act, including spawning its own children.
delegation:
  provider: custom:local-ollama
  base_url: ${_AI_BACKEND}/v1
  model: ${_DELEGATION_MODEL}        # small fast tier (served-set resolved) -- CPU-friendly, tool-capable; runs alongside the GPU main
  ollama_num_ctx: 65536
  context_length: 65536
  max_concurrent_children: 6        # 16 cores -> ~2.5 cores per child even at full fan-out
  max_spawn_depth: 2                # allow one level of sub-delegation (children can spawn grandchildren)
  child_timeout_seconds: 600
  inherit_mcp_toolsets: true
  orchestrator_enabled: true
  subagent_auto_approve: true       # operator-authorized broad sudo grant covers self-spawned children

# Agent autonomy. Hermes's default approvals.mode = "manual" gates
# EVERY tool call behind a per-call operator OK -- which makes the
# whole stack we've built incoherent:
#   * the operator-authorized broad sudo grant for mios-hermes
#     (/etc/sudoers.d/10-mios-hermes) is wasted if every sudo call
#     still pauses for click-to-approve,
#   * delegation.subagent_auto_approve: true above is meaningless if
#     the parent's tool calls (which is what spawns delegates) still
#     need approval,
#   * Open WebUI chat becomes a per-call clicking grind with no agent.
# auto = tool calls execute without per-call prompts. Destructive
# slash commands (/reset, /delete) still confirm, MCP reloads still
# confirm, cron-triggered runs are denied (the operator must launch
# cron jobs explicitly). To revoke autonomy: switch to "manual" here,
# or simply delete /etc/sudoers.d/10-mios-hermes (which then trips
# the build driver's privilege preflight too -- belt + suspenders).
approvals:
  mode: auto
  timeout: 60
  cron_mode: deny
  mcp_reload_confirm: true
  destructive_slash_confirm: true

# Tool-loop guardrails. The agent can loop forever on bad tool calls;
# hard_stop_enabled aborts after N consecutive same-kind failures so
# a stuck delegate doesn't burn the whole agent budget.
#
# Operator-flagged 2026-05-17: chats hitting 19-24 tool calls were
# below upstream's 5/8/5 thresholds (because each call was a
# DIFFERENT tool -- agent thrashing across browser/web_extract/
# skill_view rather than failing the same one repeatedly). The
# total-call cap (agent.max_turns: 20 above) handles thrashing
# across different tools; the per-failure thresholds below are now
# tightened so the agent backs off SOONER on a single tool that
# keeps erroring (web_extract returning "searxng is search-only"
# four times before the agent gives up was the original incident).
tool_loop_guardrails:
  warnings_enabled: true
  hard_stop_enabled: true
  warn_after:
    exact_failure: 1
    same_tool_failure: 2
    idempotent_no_progress: 1
  hard_stop_after:
    exact_failure: 3
    same_tool_failure: 4
    idempotent_no_progress: 3

# Sessions: prune old sessions automatically. Keeps $HERMES_HOME clean
# without manual \`hermes session prune\` after every long-running build
# leaves a fat session file behind. retention_days=30 is a reasonable
# window; the operator can \`mios hermes wipe\` (TODO future verb) for
# a hard reset.
sessions:
  auto_prune: true
  retention_days: 30
  vacuum_after_prune: true
  min_interval_hours: 24

# Goals — configuration for /goal command continuations.
goals:
  # Max continuation turns before Hermes auto-pauses the goal and
  # asks the user to /goal resume.
  max_turns: 100

# Agent: per-agent runtime tuning. reasoning_effort=xhigh is set
agent:
  restart_drain_timeout: 20
  # Hard cap on tool-call iterations per chat. Upstream default is 90;
  # operator-flagged 2026-05-17 had chats running 19-24 tool calls
  # before giving up. For an OWUI conversational agent 100 is plenty
  # (most asks resolve in 1-3 calls; multi-step in ~10). Sub-agents
  # spawned via delegate_task still get their own 90-turn budget --
  # this cap is for the OPERATOR-facing turn, not the children.
  max_turns: 100

# MCP CLIENT (operator 2026-06-07: "Hermes should have access to all Global MiOS
# MCP surfaces"). Hermes consumes the global mios-mcp-server so its tool registry
# auto-extends with the COMPLETE MiOS surface -- all verbs + recipes + promoted
# skills (tools/list), every call routed through the launcher broker. Needs the
# \`mcp\` SDK in the venv (installed by automation/38-hermes-agent.sh). stdio = the
# MCP-canonical transport; the spawned relay forwards to the agent-pipe.
mcp_servers:
  mios:
    command: /usr/libexec/mios/mios-mcp-server
    args: []
    env:
      MIOS_AGENT_PIPE_URL: http://localhost:8640
    timeout: 120
    connect_timeout: 30
    supports_parallel_tool_calls: true
EOF
    umask 0022
    chown 850:850 "$HERMES_DATA_CFG" 2>/dev/null || true
    chmod 0640 "$HERMES_DATA_CFG" 2>/dev/null || true
    _log "seeded $HERMES_DATA_CFG (provider=custom:local-ollama default=${_AI_MODEL_RESOLVED})"
else
    _log "$HERMES_DATA_CFG already current (default=${_AI_MODEL_RESOLVED}) -- not overwriting"
fi

