# ─── Pre-warm model WEIGHTS only (NO chat completion, NO prompt) ──────
# Operator directive 2026-05-16: "the system prompt should run in the
# background upon installation/MiOS images deployments". CRITICAL
# clarification from operator: "MiOS-Agent Init has poisoned data and
# is opening apps/flatpaks during init--should be initializing and
# understanding its environment--user THEN dictates what it does".
#
# The previous "warmup" chat prompt was being INTERPRETED by hermes
# as a real request -- the agent then took unprompted actions
# (launched apps, ran tools, fabricated). Switched to /api/generate
# with prompt="" + num_predict=0: loads the model weights into VRAM,
# parses the SYSTEM prompt template, exits WITHOUT producing a single
# token of output OR receiving a real user message.
#
# Skip hermes warmup entirely -- it goes through the OpenAI-compat
# gateway which always runs a full chat turn. Only warm the bare
# Ollama models via /api/generate (load-only path).
if command -v curl >/dev/null 2>&1; then
    _log "pre-warming model weights (load-only, NO prompts)..."

    # CPU pre-warm: mios-sys-agent IS the prompt refiner the
    # mios-delegation-prefilter calls before forwarding to hermes.
    # Operator architecture 2026-05-17: "the message should have
    # NEVER BEEN SENT TO HERMES" if the refiner fails -- so the
    # prefilter HARD-GATES on refine success. Cold-loading a 4 GB
    # CPU model from disk takes 60-90s; if the FIRST chat after
    # boot pays that, it times out and gets a 503 refiner_unavail
    # back. Pre-warming with the SAME options (/api/chat + num_gpu=0
    # + num_thread=8 + keep_alive=-1) the refiner uses guarantees
    # the model is already resident in CPU memory + the right runner
    # is bound when the first chat hits. ALL backgrounded -- firstboot
    # doesn't block on it.
    (curl -sf --max-time 240 \
        http://localhost:11434/api/chat \
        -d '{"model":"mios-sys-agent","messages":[{"role":"user","content":"ok"}],"stream":false,"keep_alive":-1,"options":{"num_gpu":0,"num_thread":8,"num_predict":1}}' \
        >/dev/null 2>&1 &) || true

    # GPU pre-warm: every model the chat path or fallback chain
    # might land on, loaded into VRAM via /api/generate's load-only
    # path (num_predict=0 short-circuits before token generation).
    # Stays warm via keep_alive=-1; first chat skips the cold load.
    for _wmodel in qwen3.5:4b qwen3:1.7b qwen2.5-coder:7b; do
        (curl -sf --max-time 180 \
            http://localhost:11434/api/generate \
            -d "{\"model\":\"$_wmodel\",\"prompt\":\"\",\"stream\":false,\"keep_alive\":\"-1\",\"options\":{\"num_predict\":0}}" \
            >/dev/null 2>&1 &) || true
    done
    _log "  pre-warm dispatched: mios-sys-agent (CPU) + 4 chat-path models (GPU/load-only)"
fi

# ─── Consolidated mios-daemon (replaces log-watcher + nudger + cron-director) ─
# Operator directive 2026-05-17: "ALL to be consolidated to one
# mios daemon/agent". The new mios-daemon.service holds a single
# qwen3:0.6b-cpu client + dispatches log-classify / refusal-detect /
# cron-gate handlers off a unified journal subscription. The three
# predecessor services are stopped + disabled here so we don't double-
# emit + double-load the micro-LLM. The mios_sidecar Filter has been
# updated to poll the unified /var/lib/mios/daemon/state.json
# (legacy paths still in SIBLING_AGENTS as a migration fallback).
for _legacy in mios-log-watcher mios-agent-nudger mios-cron-director; do
    if systemctl is-active --quiet "${_legacy}.service" 2>/dev/null; then
        systemctl stop "${_legacy}.service" 2>/dev/null || true
        _log "  stopped legacy ${_legacy}.service (superseded by mios-daemon)"
    fi
    if systemctl is-enabled --quiet "${_legacy}.service" 2>/dev/null; then
        systemctl disable "${_legacy}.service" 2>/dev/null || true
        _log "  disabled legacy ${_legacy}.service"
    fi
done
# Start the consolidated daemon (idempotent -- systemctl restart on a
# running unit is a no-op when ExecStart hasn't changed).
if [[ -x /usr/libexec/mios/mios-daemon ]]; then
    # STATE dir must be owned by mios-ai (the daemon's User=) -- it writes
    # state.json/launch_failures.json there. Creating it root:root (the old
    # behaviour) crash-looped the mios-ai daemon on EVERY firstboot/rebuild
    # ("PermissionError: '/var/lib/mios/daemon/state.json.tmp'", 315 restarts,
    # operator 2026-06-01) -- contradicting the mios.conf tmpfiles decl. The
    # /etc CONFIG dir stays root (daemon only READS it). chown -R repairs a dir
    # that a prior root-run instance already created + any stale root-owned
    # state files inside it (tmpfiles 'd' does NOT re-chown an existing dir).
    install -d -o mios-ai -g mios-ai -m 0755 /var/lib/mios/daemon
    chown -R mios-ai:mios-ai /var/lib/mios/daemon 2>/dev/null || true
    install -d -o root -g root -m 0755 /etc/mios/daemon
    systemctl daemon-reload 2>/dev/null || true
    systemctl enable --now mios-daemon.service 2>/dev/null \
        && _log "  enabled+started mios-daemon.service (single micro-LLM client, keep_alive=-1)" \
        || _log "  WARN: mios-daemon.service failed to start; legacy services left disabled"
fi

# ─── Pin Windows-host tailscale IP for mios-windows helper ─────────────
# When the host is a WSL distro running inside Windows, the Tailscale CLI
# on the Windows side knows its own tailnet IP. mios-windows (the
# agent->Windows SSH helper) reads this IP from /etc/mios/windows-host
# instead of re-deriving it from `ip route` every call (which would just
# give the Hyper-V vSwitch gateway, not the Tailscale interface). We
# query the Windows tailscale.exe via wsl interop and write the file
# once on every firstboot. Idempotent.
# ─── Enable opt-in units per mios.toml [ttyd].enable + mining timer ───
# These are listed-but-not-installed-enabled by the bootc image (so
# operators on minimal hosts aren't paying for them), but mios.toml's
# vendor default opts in. Firstboot reads the toml SSOT and enables.
# Idempotent: systemctl enable on an already-enabled unit is a no-op.
_ttyd_enabled="$(python3 -c '
import sys
try:
    import tomllib
except ImportError:
    import tomli as tomllib
try:
    with open("/usr/share/mios/mios.toml","rb") as f:
        d = tomllib.load(f)
    print(str(bool((d.get("ttyd") or {}).get("enable", False))).lower())
except Exception:
    print("false")
' 2>/dev/null || echo false)"
if [[ "$_ttyd_enabled" == "true" ]]; then
    # Read [identity].username from the SSOT mios.toml. The vendor
    # ttyd unit ships `User=mios` as a convention placeholder, but
    # on hosts where the operator chose a different username during
    # install, the vendor value would target a non-existent account
    # + ttyd would fail with "user does not exist". The drop-in
    # below replaces single-value User=/Group= without modifying
    # the vendor file. Read directly from toml so firstboot doesn't
    # need EnvironmentFile= for userenv.sh.
    _ttyd_user="$(python3 -c '
import sys
try:
    import tomllib
except ImportError:
    import tomli as tomllib
try:
    with open("/usr/share/mios/mios.toml","rb") as f:
        d = tomllib.load(f)
    u = (d.get("identity") or {}).get("username") or "mios"
    print(u)
except Exception:
    print("mios")
' 2>/dev/null || echo mios)"
    _ttyd_group="$_ttyd_user"
    for _ttyd_unit in mios-ttyd-bash mios-ttyd-powershell; do
        _ttyd_dropdir="/etc/systemd/system/${_ttyd_unit}.service.d"
        mkdir -p "$_ttyd_dropdir"
        cat > "$_ttyd_dropdir/10-mios-user.conf" <<EOF
# /etc/systemd/system/${_ttyd_unit}.service.d/10-mios-user.conf
# Render-time override of the vendor User=/Group=. Source of truth:
# [identity].username in /usr/share/mios/mios.toml (read by
# mios-hermes-firstboot through userenv.sh \$MIOS_USER).
[Service]
User=${_ttyd_user}
Group=${_ttyd_group}
EOF
    done
    systemctl daemon-reload
    for _ttyd_unit in mios-ttyd-bash.service mios-ttyd-powershell.service; do
        if systemctl enable --now "$_ttyd_unit" 2>/dev/null; then
            _log "  enabled+started $_ttyd_unit (User=$_ttyd_user)"
        else
            _log "  WARN: $_ttyd_unit failed to enable/start"
        fi
    done
fi
# Skills miner: catalogs + mines tool-call patterns. Vendor default
# is enable -- the timer fires every [skills.mine_interval_minutes].
if [[ -f /usr/lib/systemd/system/mios-skills-miner.timer ]]; then
    if systemctl enable --now mios-skills-miner.timer 2>/dev/null; then
        _log "  enabled+started mios-skills-miner.timer"
    else
        _log "  WARN: mios-skills-miner.timer failed to enable/start"
    fi
fi
# Starter-chip refresh: generates MiOS-aware revolving chips for
# OWUI's new-chat starter row, driven off recent operator state.
# Fires on a 10-min cadence (operator-tunable via the timer drop-in).
if [[ -f /usr/lib/systemd/system/mios-suggestion-refresh.timer ]]; then
    if systemctl enable --now mios-suggestion-refresh.timer 2>/dev/null; then
        _log "  enabled+started mios-suggestion-refresh.timer"
    else
        _log "  WARN: mios-suggestion-refresh.timer failed to enable/start"
    fi
fi

if [[ -x /mnt/c/Program\ Files/Tailscale/tailscale.exe ]]; then
    # Best-effort: tailscale.exe can fail transiently at firstboot
    # time (just-booted Windows + tailscaled not yet responsive),
    # and the WHOLE firstboot script would exit 1 because of set
    # -euo pipefail. Wrap in a subshell with the strict flags
    # locally relaxed so a probe failure doesn't kill firstboot.
    # The cached file at /etc/mios/windows-host from any previous
    # successful firstboot remains usable in the meantime.
    (
        set +e +o pipefail
        _ts_ip="$(/mnt/c/Program\ Files/Tailscale/tailscale.exe ip -4 2>/dev/null \
            | head -1 | tr -d '\r\n ')"
        if [[ "$_ts_ip" =~ ^100\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
            echo "$_ts_ip" > /etc/mios/windows-host
            chmod 0644 /etc/mios/windows-host
            _log "pinned Windows host tailscale IP to /etc/mios/windows-host: $_ts_ip"
        elif [[ -s /etc/mios/windows-host ]]; then
            _log "Tailscale probe transient-failed; keeping cached $(cat /etc/mios/windows-host)"
        else
            _log "WARN: Tailscale.exe present but didn't return a usable tailnet IP, and no cached value"
        fi
    ) || true
fi
# Explicit exit 0 so the script's exit status doesn't depend on the
# last sub-block's truthiness under set -e (the Tailscale block
# always reaches here non-failing now, but a future maintainer
# adding a new tail block shouldn't have to think about set -e
# arithmetic).
exit 0
