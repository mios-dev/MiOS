#!/usr/bin/env bash
# MiOS -- mios-hermes-firstboot: generate /etc/mios/hermes/api.env if missing
# AND seed /var/lib/mios/hermes/config.yaml with the model selected in
# mios.toml [ai] + [ai.host_thresholds] auto-pick.
#
# The same key is read by both mios-hermes (gateway) and
# mios-open-webui (chat front-end) via EnvironmentFile= in their
# Quadlets. Idempotent: re-runs are no-ops once API_SERVER_KEY exists
# and the seeded config.yaml's MiOS-seeded sentinel + model match the
# resolved mios.toml [ai].model.
set -euo pipefail

ENV_FILE="/etc/mios/hermes/api.env"

_log() { logger -t mios-hermes-firstboot "$*" 2>/dev/null || true; echo "[hermes-firstboot] $*" >&2; }

# ─── mios.toml layered overlay reader ───────────────────────────────────────
#
# Reads [section].key from ~/.config/mios/mios.toml -> /etc/mios/mios.toml
# -> /usr/share/mios/mios.toml, returning the FIRST non-empty match
# (operator overlay wins). Same arity + semantics as the bash resolver
# in /usr/libexec/mios/mios-dashboard.sh -- copied here so this script
# can run before mios-dashboard's helper is sourced.
_mios_toml_layers() {
    local home="${HOME:-/root}"
    printf '%s\n' \
        "$home/.config/mios/mios.toml" \
        "/etc/mios/mios.toml" \
        "/usr/share/mios/mios.toml"
}

_mios_toml_value() {
    local section="$1" key="$2" def_val="$3"
    local toml
    while IFS= read -r toml; do
        [[ -r "$toml" ]] || continue
        local v
        v="$(awk -v want_section="$section" -v want_key="$key" '
            BEGIN { in_section = 0; found = 0 }
            /^\[/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                in_section = (line == "[" want_section "]") ? 1 : 0
                next
            }
            in_section && /^[[:space:]]*[A-Za-z_][A-Za-z0-9_]*[[:space:]]*=/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                eq = index(line, "=")
                if (eq == 0) next
                k = substr(line, 1, eq - 1)
                v = substr(line, eq + 1)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                gsub(/^"|"$/, "", v)
                if (k == want_key) { print v; found = 1; exit }
            }
        ' "$toml")"
        if [[ -n "$v" ]]; then printf '%s' "$v"; return; fi
    done < <(_mios_toml_layers)
    printf '%s' "$def_val"
}

# Read an array-of-tables [[ai.catalog]] and emit id<TAB>label<TAB>ram_gb
# per row. Layered overlay: rows from the highest-precedence file that
# has ANY [[ai.catalog]] entries win wholesale (no merging across layers
# -- TOML AoT semantics don't merge, and operator editing the dropdown
# means they want their list, not the vendor's appended).
_mios_toml_catalog() {
    local toml
    while IFS= read -r toml; do
        [[ -r "$toml" ]] || continue
        local out
        out="$(awk '
            BEGIN { in_t = 0; id = ""; label = ""; ram = "" }
            /^\[\[ai\.catalog\]\]/ {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
                in_t = 1; id = ""; label = ""; ram = ""
                next
            }
            /^\[/ {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
                in_t = 0; id = ""; label = ""; ram = ""
                next
            }
            in_t && /^[[:space:]]*[A-Za-z_]+[[:space:]]*=/ {
                line = $0
                sub(/[[:space:]]*#.*$/, "", line)
                eq = index(line, "=")
                if (eq == 0) next
                k = substr(line, 1, eq - 1)
                v = substr(line, eq + 1)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                gsub(/^"|"$/, "", v)
                if (k == "id") id = v
                else if (k == "label") label = v
                else if (k == "ram_gb") ram = v
            }
            END {
                if (in_t && id != "") printf "%s\t%s\t%s\n", id, label, ram
            }
        ' "$toml")"
        if [[ -n "$out" ]]; then printf '%s' "$out"; return; fi
    done < <(_mios_toml_layers)
}

# ─── Resolve the model to seed ──────────────────────────────────────────────
#
# Start from [ai].model (the operator's chosen / vendor-default value).
# Then apply [ai.host_thresholds] auto-pick: if the host has enough RAM,
# roll up to mid_ram_model or big_ram_model. Auto-pick only runs when
# the operator hasn't overlaid [ai].model in /etc/mios/mios.toml or
# ~/.config/mios/mios.toml (operator override wins).
_AI_MODEL_DEFAULT="$(_mios_toml_value 'ai' 'model' 'granite4.1:3b')"

# Is [ai].model overlaid by an operator layer? (any non-vendor layer)
_overlaid=0
for _layer in "${HOME:-/root}/.config/mios/mios.toml" "/etc/mios/mios.toml"; do
    [[ -r "$_layer" ]] || continue
    if grep -qE '^\[ai\]' "$_layer" && \
       awk '/^\[ai\]/,/^\[/{if (/^model[[:space:]]*=/) {print; exit}}' "$_layer" | grep -q '='; then
        _overlaid=1
        break
    fi
done

_AI_MODEL_RESOLVED="$_AI_MODEL_DEFAULT"
if [[ "$_overlaid" -eq 0 ]]; then
    # Auto-pick from host RAM (MemTotal in /proc/meminfo, kB -> GB).
    _ram_kb="$(awk '/^MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null || echo 0)"
    _ram_gb=$(( _ram_kb / 1024 / 1024 ))
    _big_gb="$(_mios_toml_value 'ai.host_thresholds' 'big_ram_gb' '24')"
    _mid_gb="$(_mios_toml_value 'ai.host_thresholds' 'mid_ram_gb' '16')"
    _big_m="$(_mios_toml_value 'ai.host_thresholds' 'big_ram_model' 'granite4.1:30b')"
    _mid_m="$(_mios_toml_value 'ai.host_thresholds' 'mid_ram_model'  'gpt-oss:20b')"
    _small_m="$(_mios_toml_value 'ai.host_thresholds' 'small_ram_model' "$_AI_MODEL_DEFAULT")"
    if (( _ram_gb >= _big_gb )); then
        _AI_MODEL_RESOLVED="$_big_m"
        _log "auto-pick: host RAM ${_ram_gb} GB >= ${_big_gb} -> ${_AI_MODEL_RESOLVED}"
    elif (( _ram_gb >= _mid_gb )); then
        _AI_MODEL_RESOLVED="$_mid_m"
        _log "auto-pick: host RAM ${_ram_gb} GB >= ${_mid_gb} -> ${_AI_MODEL_RESOLVED}"
    else
        _AI_MODEL_RESOLVED="$_small_m"
        _log "auto-pick: host RAM ${_ram_gb} GB < ${_mid_gb} -> ${_AI_MODEL_RESOLVED}"
    fi
else
    _log "operator overlay sets [ai].model=${_AI_MODEL_RESOLVED} -- skipping auto-pick"
fi

# Make sure the directory exists with the right ownership. tmpfiles.d
# should have done this already, but be defensive in case the .service
# fires before tmpfiles for some reason.
mkdir -p /etc/mios/hermes
chown -h mios-hermes:mios-hermes /etc/mios/hermes 2>/dev/null || true
chmod 0750 /etc/mios/hermes 2>/dev/null || true

if [[ -f "$ENV_FILE" ]] && grep -q '^API_SERVER_KEY=' "$ENV_FILE"; then
    _log "$ENV_FILE already has API_SERVER_KEY -- skipping key generation"
    _skip_keygen=1
else
    _skip_keygen=0
fi

if [[ "$_skip_keygen" -eq 0 ]]; then
    # Generate a 64-char hex key. openssl is in @core on Fedora CoreOS so
    # this is always available; fall back to /dev/urandom if it isn't.
    if command -v openssl >/dev/null 2>&1; then
        api_key="$(openssl rand -hex 32)"
    else
        api_key="$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    fi

    # Write the env file with secure perms BEFORE chowning to mios-hermes
    # so the Quadlet's EnvironmentFile= read-as-root can succeed even if
    # the per-uid mios-hermes login is denied (`/usr/sbin/nologin`).
    umask 0077
    cat > "$ENV_FILE" <<EOF
# /etc/mios/hermes/api.env -- generated by mios-hermes-firstboot.service
# at $(date -Iseconds) on $(hostname).
# Rotate by deleting this file and restarting mios-hermes-firstboot.

API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${api_key}
API_SERVER_CORS_ORIGINS=*
OPENAI_API_KEY=${api_key}

# Hermes's "gateway run" mode bundles a messaging-platform router
# (Telegram / Discord / Slack) that enforces a USER ALLOWLIST on every
# request -- chat-completions included. Without an allowlist, the
# gateway DENIES all requests with the cryptic "No user allowlists
# configured. All unauthorized users will be denied" warning, then
# 401s the chat. MiOS isn't running messaging platforms (Workspace
# UI is the only frontend), so we opt out of the allowlist gate to
# let any caller with a valid API_SERVER_KEY through.
# Operator-flagged 2026-05-11: "all messages get Retry".
GATEWAY_ALLOW_ALL_USERS=true

# Hermes Workspace consumes these via the SAME EnvironmentFile= mount.
# Systemd Quadlet Environment= directives do NOT expand \${API_SERVER_KEY}
# from sibling EnvironmentFile= contents, so we have to write the
# explicit duplicates here. The workspace falls back to a legacy HTML-
# scrape token flow when CLAUDE_DASHBOARD_TOKEN is unset, which fails
# against our minimal gateway image and triggers a client-side
# redirect to /error. Operator-flagged 2026-05-11.
HERMES_API_TOKEN=${api_key}
CLAUDE_DASHBOARD_TOKEN=${api_key}
EOF
    umask 0022
    chown root:mios-hermes "$ENV_FILE" 2>/dev/null || true
    chmod 0640 "$ENV_FILE" 2>/dev/null || true

    _log "wrote $ENV_FILE (64-char API_SERVER_KEY)"
fi

# ─── /var/lib/mios/hermes/config.yaml (Hermes-Agent main config) ────────
#
# Hermes-Agent 0.13.x reads $HERMES_HOME/config.yaml. The direct host
# install (automation/38-hermes-agent.sh + hermes-agent.service) sets
# HERMES_HOME=/var/lib/mios/hermes, so the agent's config lives at
# /var/lib/mios/hermes/config.yaml. NOTE: 0.13.x ignores the
# HERMES_CONFIG_PATH env var entirely -- HERMES_HOME is authoritative.
#
# SCHEMA -- load-bearing. Hermes-Agent 0.13.x resolves the inference
# provider via hermes_cli/runtime_provider.py::resolve_requested_provider:
# it reads config["model"], and ONLY honours a `provider:` key when
# `model` is a DICT. If `model` is a bare string the provider is
# unknown -> falls through to "auto" -> tries openrouter -> HTTP 401
# "Missing Authentication header" (no OPENROUTER_API_KEY).
# Operator-confirmed 2026-05-14. So `model` MUST be a mapping:
#   model:
#     provider: custom:<name>     # matches a custom_providers[].name
#     default:  <ollama-model-id>
#     base_url: http://localhost:11434/v1
# `provider: custom:local-ollama` then resolves against the
# `custom_providers:` list entry named `local-ollama`. The pre-0.13
# `backend:` block is genuinely unused by 0.13.x -- we drop it (the
# re-seed detection below treats a leftover `backend:` as stale).
#
# Architectural Law 5 (UNIFIED-AI-REDIRECTS): the agent loop stays
# fully local -- custom_providers[local-ollama] points at the on-box
# Ollama OpenAI surface, no cloud calls.
HERMES_DATA=/var/lib/mios/hermes
HERMES_DATA_CFG="${HERMES_DATA}/config.yaml"
mkdir -p "$HERMES_DATA"

# Ownership: hermes-agent.service runs as the mios-hermes sysuser
# (uid 820). The pre-2026-05-14 mios-hermes CONTAINER ran with an
# in-container uid (10000) and bind-mounted this dir, leaving it
# orphan-owned 10000:10000 mode 0700 -- the direct-install service
# (uid 820) then cannot write its own state dir and chat completions
# die with "Permission denied: /var/lib/mios/hermes/cron". Force the
# whole tree to 820:820 on every run -- cheap, idempotent, and heals
# the container -> direct-install migration.
chown -R 820:820 "$HERMES_DATA" 2>/dev/null || true
chmod 0750 "$HERMES_DATA" 2>/dev/null || true

# Validate the resolved model against what Ollama actually serves. The
# [ai.host_thresholds] auto-pick can resolve to a model (e.g.
# granite4.1:30b) that was never baked or pulled on this host --
# pointing Hermes at a missing model breaks chat just as hard as a
# stale schema. Query Ollama's tag list; if the resolved model isn't
# present, fall back to the first available non-embedding model.
_ollama_tags="$(curl -fsS --max-time 5 http://localhost:11434/api/tags 2>/dev/null \
    | grep -oE '"name":"[^"]+"' | sed 's/"name":"//;s/"$//')"
if [[ -n "$_ollama_tags" ]]; then
    if ! grep -qxF "$_AI_MODEL_RESOLVED" <<< "$_ollama_tags"; then
        _fallback="$(grep -viE 'embed' <<< "$_ollama_tags" | head -1)"
        if [[ -n "$_fallback" ]]; then
            _log "resolved model '${_AI_MODEL_RESOLVED}' not present in Ollama -- falling back to '${_fallback}'"
            _AI_MODEL_RESOLVED="$_fallback"
        else
            _log "WARN: '${_AI_MODEL_RESOLVED}' not in Ollama and no non-embed fallback found"
        fi
    fi
fi

_should_seed=0
if [[ ! -f "$HERMES_DATA_CFG" ]]; then
    _should_seed=1
elif grep -qE '^backend:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Leftover pre-0.13 `backend:` block -- stale schema, rewrite.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- detected pre-0.13 container-era schema"
elif ! grep -qE '^auxiliary:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the auxiliary-services mapping -- 0.13.x would
    # log "No auxiliary LLM provider configured" and drop compression
    # summaries. Rewrite to add the auxiliary: + web: blocks.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing auxiliary endpoint mapping"
elif ! grep -qE '^display:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the display block -- the agent then narrates tool
    # results instead of showing them verbatim, which is the dominant
    # vector for fabricated "status" reports on local models. Rewrite
    # to add the display: knobs (tool_progress: verbose, etc.).
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing display block (counter-fabrication)"
elif ! grep -qE '^delegation:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the delegation block -- the orchestrator can't
    # spawn parallel child agents, and auxiliary services still serialize
    # through the big GPU model instead of fanning out to a small CPU
    # model. Rewrite to add delegation: + swap auxiliary models.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing delegation block (multi-agent parallelism)"
elif ! grep -qE '^approvals:' "$HERMES_DATA_CFG" 2>/dev/null; then
    # Config predates the autonomy alignment -- without explicit
    # approvals.mode=auto the agent pauses for per-call approval,
    # making the broad sudo grant + multi-agent delegation pointless.
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- missing approvals/autonomy block"
elif ! grep -qE "^  default: ${_AI_MODEL_RESOLVED}$" "$HERMES_DATA_CFG" 2>/dev/null; then
    _should_seed=1
    _log "re-seeding $HERMES_DATA_CFG -- model drift: want default '${_AI_MODEL_RESOLVED}'"
fi

if [[ "$_should_seed" -eq 1 ]]; then
    # Unquoted heredoc so ${_AI_MODEL_RESOLVED} / ${_AI_MODEL_DEFAULT}
    # expand. No ${API_SERVER_KEY}-style values referenced here (those
    # live in api.env, loaded separately via hermes-agent.service
    # EnvironmentFile=).
    umask 0077
    cat > "$HERMES_DATA_CFG" <<EOF
# /var/lib/mios/hermes/config.yaml -- MiOS-seeded (Hermes-Agent 0.13.x schema)
# Generated by mios-hermes-firstboot.service. Hermes-Agent reads
# \$HERMES_HOME/config.yaml; HERMES_HOME=/var/lib/mios/hermes.
#
# AI chain: ollama (:11434, raw inference) -> Hermes-Agent (:8642/v1,
# OpenAI gateway + agent loop) -> Open WebUI (:3030). The gateway's own
# API key lives in /etc/mios/hermes/api.env (API_SERVER_KEY), loaded by
# hermes-agent.service via EnvironmentFile=.
#
# Resolved values:
#   [ai].model            -> ${_AI_MODEL_DEFAULT}
#   validated vs Ollama   -> ${_AI_MODEL_RESOLVED}
_config_version: 23

# Primary model. MUST be a mapping (not a bare string) so
# resolve_requested_provider() sees the provider= key. provider=
# "custom:local-ollama" resolves against the custom_providers entry
# below. Architectural Law 5: local Ollama only, no cloud calls.
model:
  provider: custom:local-ollama
  default: ${_AI_MODEL_RESOLVED}
  base_url: http://localhost:11434/v1
  api_key: ""

custom_providers:
  - name: local-ollama
    base_url: http://localhost:11434/v1
    api_key: ""

# Auxiliary LLM services (context compression / summarization, memory
# flush, title + triage + curation, MCP reasoning, web-extract,
# approvals, skills-hub). 0.13.x does NOT inherit the main provider for
# these -- left unmapped it logs "No auxiliary LLM provider configured"
# and silently drops context-compression summaries. Map every one at
# the same on-box Ollama provider so the agent is fully self-contained.
auxiliary:
  # compression EXCEPTION: must have >=64K context window or Hermes
  # refuses to start chat completions ("Auxiliary compression model X
  # has a context window of N tokens, which is below the minimum
  # 64,000 required by Hermes Agent" -- operator-confirmed 2026-05-15).
  # qwen3:1.7b is 40K so it fails this check; route compression to the
  # main big model (128K context). Compression fires only when the
  # context fills up -- infrequent, GPU is fine for it. All OTHER
  # auxiliary services stay on qwen3:1.7b for CPU parallelism.
  compression:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: ${_AI_MODEL_RESOLVED}
  session_search:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  title_generation:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  triage_specifier:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  curator:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  mcp:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  web_extract:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  approval:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b
  skills_hub:
    provider: custom:local-ollama
    base_url: http://localhost:11434/v1
    model: qwen3:1.7b

# Web search/extract -> the on-box SearXNG (mios-searxng). The
# concrete URL is exported as SEARXNG_URL by hermes-agent.service
# (shape-aware: localhost:8888 on the dev-VM host-net build,
# mios-searxng:8080 on bridge builds). Law 5 unaffected -- search is
# retrieval, not inference.
web:
  search_backend: searxng

# Display: surface real tool output in the chat (counter-fabrication).
# When the agent narrates "the build succeeded" instead of pasting
# what it actually saw, the operator can't tell truth from fiction.
# These knobs make Hermes show the verbatim tool result inline -- in
# the TUI as a panel, in Open WebUI as a syntax-highlighted code block
# (the "terminal output in chat" experience). The model SOUL.md rules
# require it; these settings make it the default rendering.
display:
  tool_progress: verbose             # show full args + result for every tool call
  tool_progress_command: true        # show the command itself (e.g. `mios build`)
  tool_preview_length: 8000          # show up to 8000 chars of each tool result inline
  persistent_output: true            # keep tool output visible after the call returns
  persistent_output_max_lines: 2000  # default 200 truncated long build logs aggressively
  interim_assistant_messages: true   # stream progress as tools complete
  final_response_markdown: keep      # do NOT strip code blocks from the final answer
  inline_diffs: true
  show_reasoning: false              # flip to true if you want the chain-of-thought visible
  show_cost: false

# Multi-agent delegation. Hermes 0.13.x's orchestrator can spawn child
# agents (delegate_task tool) -- typically used to fan out discrete
# subtasks (search this file, lint that path, write a test) in parallel
# while the main agent stays focused on the high-level plan.
#
# Architecture for this host (9950X3D 16-core / 40 GB RAM / RTX 4090
# 24 GB VRAM): the MAIN agent runs the big tool-calling model on the
# GPU (model.default = qwen3-coder:30b, MoE, ~19 GB), while DELEGATES
# and the AUXILIARY services (compression, title-gen, session_search,
# triage, curator, mcp, web_extract, approval, skills_hub) run on the
# small fast qwen3:1.7b model -- ollama keeps it warm alongside the
# big one (OLLAMA_MAX_LOADED_MODELS=4) and serves up to 4 concurrent
# requests per model (OLLAMA_NUM_PARALLEL=4, set in ollama.container).
# Result: the orchestrator's children + auxiliary lanes actually run
# in parallel instead of serializing through one slot.
#
# subagent_auto_approve: true -- consistent with the operator's broad
# sudo grant for mios-hermes (10-mios-hermes); the agent is
# operator-authorized to act, including spawning its own children.
delegation:
  provider: custom:local-ollama
  base_url: http://localhost:11434/v1
  model: qwen3:1.7b                 # small, fast, tool-capable -- runs on CPU alongside GPU main
  max_concurrent_children: 6        # 16 cores -> ~2.5 cores per child even at full fan-out
  max_spawn_depth: 2                # allow one level of sub-delegation (children can spawn grandchildren)
  child_timeout_seconds: 600
  inherit_mcp_toolsets: true
  orchestrator_enabled: true
  subagent_auto_approve: true       # operator-authorized broad sudo grant covers self-spawned children

# Agent autonomy. Hermes's default approvals.mode = "manual" gates
# EVERY tool call behind a per-call operator OK -- which makes the
# whole stack we've built incoherent:
#   * the operator-authorized broad sudo grant for mios-hermes
#     (/etc/sudoers.d/10-mios-hermes) is wasted if every sudo call
#     still pauses for click-to-approve,
#   * delegation.subagent_auto_approve: true above is meaningless if
#     the parent's tool calls (which is what spawns delegates) still
#     need approval,
#   * Open WebUI chat becomes a per-call clicking grind with no agent.
# auto = tool calls execute without per-call prompts. Destructive
# slash commands (/reset, /delete) still confirm, MCP reloads still
# confirm, cron-triggered runs are denied (the operator must launch
# cron jobs explicitly). To revoke autonomy: switch to "manual" here,
# or simply delete /etc/sudoers.d/10-mios-hermes (which then trips
# the build driver's privilege preflight too -- belt + suspenders).
approvals:
  mode: auto
  timeout: 60
  cron_mode: deny
  mcp_reload_confirm: true
  destructive_slash_confirm: true

# Tool-loop guardrails. The agent can loop forever on bad tool calls;
# hard_stop_enabled aborts after N consecutive same-kind failures so
# a stuck delegate doesn't burn the whole agent budget. Thresholds
# match the upstream-recommended wizard defaults.
tool_loop_guardrails:
  warnings_enabled: true
  hard_stop_enabled: true
  warn_after:
    exact_failure: 2
    same_tool_failure: 3
    idempotent_no_progress: 2
  hard_stop_after:
    exact_failure: 5
    same_tool_failure: 8
    idempotent_no_progress: 5

# Sessions: prune old sessions automatically. Keeps $HERMES_HOME clean
# without manual `hermes session prune` after every long-running build
# leaves a fat session file behind. retention_days=30 is a reasonable
# window; the operator can `mios hermes wipe` (TODO future verb) for
# a hard reset.
sessions:
  auto_prune: true
  retention_days: 30
  vacuum_after_prune: true
  min_interval_hours: 24
EOF
    umask 0022
    chown 820:820 "$HERMES_DATA_CFG" 2>/dev/null || true
    chmod 0640 "$HERMES_DATA_CFG" 2>/dev/null || true
    _log "seeded $HERMES_DATA_CFG (provider=custom:local-ollama default=${_AI_MODEL_RESOLVED})"
else
    _log "$HERMES_DATA_CFG already current (default=${_AI_MODEL_RESOLVED}) -- not overwriting"
fi

# ── Operator CLI config (~/.hermes/config.yaml) ─────────────────────────
# The `hermes` CLI runs as the operator (not the mios-hermes sysuser)
# and reads ~/.hermes/config.yaml. Seed it with the SAME TOML-derived
# config as the gateway so the CLI is pre-configured against local
# Ollama and never drops into the interactive `hermes setup` wizard.
# Resolve the operator from mios.toml [identity].username; this is a
# plain copy of the gateway config -- one SSOT, two consumers.
#
# Re-seed conditions mirror the gateway: missing, OR carries the
# broken `hermes setup` wizard value (https://0.0.0.0:11434/v1), OR
# the gateway config was just (re)written this run (_should_seed=1).
# Operator customisation that must survive belongs in mios.toml, not
# hand-edits to this generated file.
_op_user="$(_mios_toml_value 'identity' 'username' 'mios')"
_op_home="$(getent passwd "$_op_user" 2>/dev/null | cut -d: -f6)"
if [[ -n "$_op_home" && -d "$_op_home" ]]; then
    _op_cfg_dir="${_op_home}/.hermes"
    _op_cfg="${_op_cfg_dir}/config.yaml"
    if [[ ! -f "$_op_cfg" ]] || grep -q '0\.0\.0\.0:11434' "$_op_cfg" 2>/dev/null \
       || [[ "$_should_seed" -eq 1 ]]; then
        mkdir -p "$_op_cfg_dir"
        cp -f "$HERMES_DATA_CFG" "$_op_cfg"
        chown -R "$_op_user":"$_op_user" "$_op_cfg_dir" 2>/dev/null || true
        chmod 0700 "$_op_cfg_dir" 2>/dev/null || true
        chmod 0600 "$_op_cfg" 2>/dev/null || true
        _log "seeded operator CLI config $_op_cfg (user=$_op_user)"
    else
        _log "operator CLI config $_op_cfg already current -- not overwriting"
    fi
else
    _log "operator home for '$_op_user' not found -- skipping CLI config seed"
fi

# ── Hermes persona / grounding (SOUL.md) ────────────────────────────────
# Hermes-Agent reloads $HERMES_HOME/SOUL.md fresh on EVERY message -- it
# is the live lever for the agent's persona AND its operating discipline.
# Stock Hermes ships an EMPTY SOUL.md (just a comment template), which
# left the local model ungrounded: it made up tool output, invented
# config flags, and claimed success on commands that errored or returned
# nothing (operator-confirmed 2026-05-14). MiOS ships a hardened SOUL.md
# at /usr/share/mios/ai/hermes-soul.md -- strong rules against
# fabricated output, full-shell-usage guidance, and pointers to the MiOS AI
# reference docs. Seed it for BOTH the gateway service (HERMES_HOME) and
# the operator's `hermes` CLI (~/.hermes), exactly like config.yaml.
#
# Re-seed when the target is missing OR still the stock template (no
# "MiOS-managed" marker) OR the source content has changed (so updates
# to /usr/share/mios/ai/hermes-soul.md propagate without a manual
# delete). An operator who wants their own persona just deletes the
# "MiOS-managed" marker line; MiOS then leaves the file alone forever.
SOUL_SRC=""
for _c in /usr/share/mios/ai/hermes-soul.md \
          "${MIOS_REPO:-}/usr/share/mios/ai/hermes-soul.md"; do
    [[ -n "$_c" && -r "$_c" ]] && { SOUL_SRC="$_c"; break; }
done
_soul_should_seed() {
    local target="$1"
    [[ ! -f "$target" ]] && return 0
    grep -q 'MiOS-managed' "$target" 2>/dev/null || return 1   # operator-owned, leave alone
    cmp -s "$SOUL_SRC" "$target" && return 1                    # already current, no-op
    return 0                                                    # MiOS-managed and stale -> reseed
}
if [[ -z "$SOUL_SRC" ]]; then
    _log "WARN: hermes-soul.md source not found -- skipping SOUL.md seed"
else
    # Gateway service copy ($HERMES_HOME/SOUL.md, owned by mios-hermes).
    _soul_svc="${HERMES_DATA}/SOUL.md"
    if _soul_should_seed "$_soul_svc"; then
        cp -f "$SOUL_SRC" "$_soul_svc"
        chown 820:820 "$_soul_svc" 2>/dev/null || true
        chmod 0644 "$_soul_svc" 2>/dev/null || true
        _log "seeded $_soul_svc (hardened MiOS persona + grounding against fabricated output)"
    else
        _log "$_soul_svc already current (or operator-customised) -- not overwriting"
    fi
    # Operator `hermes` CLI copy (reuses _op_user / _op_home from above).
    if [[ -n "${_op_home:-}" && -d "${_op_home:-}" ]]; then
        _soul_op="${_op_home}/.hermes/SOUL.md"
        if _soul_should_seed "$_soul_op"; then
            mkdir -p "${_op_home}/.hermes"
            cp -f "$SOUL_SRC" "$_soul_op"
            chown "$_op_user":"$_op_user" "$_soul_op" 2>/dev/null || true
            chmod 0644 "$_soul_op" 2>/dev/null || true
            _log "seeded operator SOUL.md $_soul_op (user=$_op_user)"
        else
            _log "operator SOUL.md $_soul_op already current (or operator-customised) -- not overwriting"
        fi
    fi
fi

# ─── MiOS-managed Hermes skills ────────────────────────────────────────────
# Hermes builds a system-prompt skill index from $HERMES_HOME/skills/<name>/
# SKILL.md (and $HERMES_HOME/skills/<category>/<name>/SKILL.md). The model
# sees each skill's frontmatter description in the index and decides when
# to skill_view its body for the full playbook.
#
# MiOS ships skills under /usr/share/mios/hermes/skills/<name>/SKILL.md so
# the OS can teach hermes patterns that the stock model wouldn't pick up
# on its own (currently: parallel-fanout, which nudges the orchestrator
# toward delegate_task on parallelizable work -- needed because
# qwen3-coder:30b naturally serialised via terminal even when prompted).
#
# Seed each MiOS-shipped skill into BOTH the gateway service home AND the
# operator's `hermes` CLI home, mirroring the SOUL.md seeding pattern.
# Re-seed only when the target either doesn't exist OR is byte-identical-
# minus-mtime to a previous MiOS shipment (marker check). Operators take
# ownership by deleting the "MiOS-managed" marker comment in the file --
# firstboot then leaves it alone forever.
SKILLS_SRC_DIR=""
for _c in /usr/share/mios/hermes/skills \
          "${MIOS_REPO:-}/usr/share/mios/hermes/skills"; do
    [[ -n "$_c" && -d "$_c" ]] && { SKILLS_SRC_DIR="$_c"; break; }
done
_skill_should_seed() {
    local target="$1" src="$2"
    [[ ! -f "$target" ]] && return 0
    grep -q 'MiOS-managed' "$target" 2>/dev/null || return 1   # operator-owned, leave alone
    cmp -s "$src" "$target" && return 1                        # already current, no-op
    return 0                                                   # MiOS-managed and stale -> reseed
}
_seed_one_skill() {
    # $1=src SKILL.md, $2=dest dir (e.g., $HERMES_HOME/skills/parallel-fanout),
    # $3=owner uid:gid string for chown.
    local src="$1" dest_dir="$2" owner="$3"
    local target="${dest_dir}/SKILL.md"
    if _skill_should_seed "$target" "$src"; then
        mkdir -p "$dest_dir"
        cp -f "$src" "$target"
        chown "$owner" "$target" 2>/dev/null || true
        chmod 0644 "$target" 2>/dev/null || true
        _log "seeded skill ${target}"
    else
        _log "skill ${target} already current (or operator-customised) -- not overwriting"
    fi
}
if [[ -z "$SKILLS_SRC_DIR" ]]; then
    _log "WARN: hermes skills source dir not found -- skipping skills seed"
else
    # Each subdir of SKILLS_SRC_DIR is one skill; its SKILL.md is the entry.
    for _skill_src in "${SKILLS_SRC_DIR}"/*/SKILL.md; do
        [[ -e "$_skill_src" ]] || continue
        _skill_name="$(basename "$(dirname "$_skill_src")")"
        # Gateway service copy ($HERMES_HOME/skills/<name>/SKILL.md).
        _seed_one_skill "$_skill_src" \
                        "${HERMES_DATA}/skills/${_skill_name}" \
                        "820:820"
        # Operator `hermes` CLI copy (~/.hermes/skills/<name>/SKILL.md).
        if [[ -n "${_op_home:-}" && -d "${_op_home:-}" ]]; then
            _seed_one_skill "$_skill_src" \
                            "${_op_home}/.hermes/skills/${_skill_name}" \
                            "${_op_user}:${_op_user}"
        fi
    done
    # Tell hermes to drop its in-process skills-prompt cache so the
    # newly-seeded skills appear in the next chat turn's system prompt
    # without a service restart. The cache key is mtime/size of every
    # SKILL.md in $HERMES_HOME/skills, so touching a marker file in the
    # skills dir invalidates the disk snapshot. The simpler hammer: if
    # any skill was actually seeded above, restart the service.
    if systemctl is-active --quiet hermes-agent.service \
       && find "${HERMES_DATA}/skills" -newer "${HERMES_DATA}/SOUL.md" -name SKILL.md 2>/dev/null | grep -q .; then
        _log "skill content changed -- restarting hermes-agent.service to refresh skills index"
        systemctl restart hermes-agent.service || _log "WARN: hermes-agent restart failed"
    fi
fi
