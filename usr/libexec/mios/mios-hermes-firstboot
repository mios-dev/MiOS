# so it becomes per-chat searchable context. Operator directive
# 2026-05-15: "OWUI's MiOS-Agent model have knowledge files (use
# exactly the current MiOS AI Files / Markdown files / Documentation
# / EVERYTHING ETC)".
if [[ -x /usr/libexec/mios/mios-owui-apply-knowledge ]]; then
