# ── Operator CLI config (~/.hermes/config.yaml) ─────────────────────────
# The `hermes` CLI runs as the operator (not the mios-hermes sysuser)
# and reads ~/.hermes/config.yaml. Seed it with the SAME TOML-derived
# config as the gateway so the CLI is pre-configured against local
# Ollama and never drops into the interactive `hermes setup` wizard.
# Resolve the operator from mios.toml [identity].username; this is a
# plain copy of the gateway config -- one SSOT, two consumers.
#
# Re-seed conditions:
#   1. file missing
#   2. carries the broken `hermes setup` wizard placeholder
#      (0.0.0.0:11434 / 127.0.0.1:11434 / https://localhost without TLS)
#   3. the gateway config was just (re)written this run (_should_seed=1)
#   4. fails YAML parse (corrupted / hand-edited badly)
#   5. missing critical top-level schema keys (model:, auxiliary:, delegation:) --
#      stock `hermes setup` writes a minimal stub that drops every MiOS
#      customisation, then Hermes falls back to default config and the
#      operator's TUI session has no auxiliary lanes, no delegation, no
#      reasoning_effort, etc. (operator-confirmed 2026-05-15: setup wizard
#      replaced /var/home/mios/.hermes/config.yaml with a 69-line stub
#      after a YAML parse error; Hermes then ignored every MiOS override).
#
# Operator customisation that must survive belongs in mios.toml, not
# hand-edits to this generated file. To take ownership of the operator
# CLI config, edit it AND remove the file's "MiOS-managed" marker
# comment -- firstboot then leaves it alone.
_op_user="$(_mios_toml_value 'identity' 'username' 'mios')"
_op_home="$(getent passwd "$_op_user" 2>/dev/null | cut -d: -f6)"
_op_cfg_should_reseed() {
    local f="$1"
    [[ ! -f "$f" ]] && return 0
    grep -qE '0\.0\.0\.0:11434|127\.0\.0\.1:11434|https://localhost:11434' "$f" 2>/dev/null && return 0
    [[ "$_should_seed" -eq 1 ]] && return 0
    # YAML parse + minimum-schema + THIN-CLIENT-invariant check via python3
    # (Hermes itself bundles python). The thin-client checks force a one-time
    # re-seed of any legacy REPL config that still points at a leaf (model.base_url
    # :11450 / non-empty toolsets) -> rewrites it as a :8640 orchestrator client.
    MIOS_AGENT_ENDPOINT="$_AGENT_ENDPOINT" MIOS_AGENT_MODEL="$_AGENT_MODEL" \
    python3 - "$f" <<'EOF' 2>/dev/null || return 0
import sys, os, yaml
p = sys.argv[1]
try:
    with open(p) as fh:
        d = yaml.safe_load(fh) or {}
except Exception:
    sys.exit(2)
if not isinstance(d, dict):
    sys.exit(2)
# Critical MiOS-managed top-level keys -- if any are missing the file is
# probably a stock-wizard stub that dropped our customisations.
for k in ("model", "auxiliary", "delegation", "approvals", "agent"):
    if k not in d:
        sys.exit(3)
# THIN-CLIENT invariant: the REPL must target the agent-pipe ORCHESTRATOR
# surface (:8640 MiOS-Agent), never a leaf -- a leaf granite tool-loop fabricates.
m = d.get("model") if isinstance(d.get("model"), dict) else {}
want_ep = (os.environ.get("MIOS_AGENT_ENDPOINT") or "").rstrip("/")
want_model = os.environ.get("MIOS_AGENT_MODEL") or ""
if want_ep and str(m.get("base_url") or "").rstrip("/") != want_ep:
    sys.exit(4)
if want_model and str(m.get("default") or "") != want_model:
    sys.exit(5)
if d.get("toolsets"):                      # tools must run SERVER-SIDE (empty here)
    sys.exit(6)
sys.exit(0)
EOF
    return 1
}
if [[ -n "$_op_home" && -d "$_op_home" ]]; then
    _op_cfg_dir="${_op_home}/.hermes"
    _op_cfg="${_op_cfg_dir}/config.yaml"
    if _op_cfg_should_reseed "$_op_cfg"; then
        mkdir -p "$_op_cfg_dir"
        # THIN-CLIENT transform (operator 2026-06-18 "UNIFY THE MiOS AI PIPELINE").
        # Start from the full gateway config (keeps auxiliary/delegation/approvals/
        # agent/display + the correct on-box aux lanes) but point the MAIN model at
        # the agent-pipe ORCHESTRATOR (:8640 MiOS-Agent), empty the toolsets, and
        # disable the per-session MCP spawn. The orchestrator runs the tool loop
        # SERVER-SIDE (refine -> route -> broker-exec + read-back verify -> polish),
        # so the REPL never runs a leaf granite loop -- the fabrication root cause
        # (claimed launch but typed into chat / same_tool_failure_halt). This makes
        # the `hermes` REPL identical to the already-unified @/mios CLI + desktop app.
        # Aux lanes (compression/title/...) legitimately stay on the leaf (:11450).
        if MIOS_AGENT_ENDPOINT="$_AGENT_ENDPOINT" MIOS_AGENT_MODEL="$_AGENT_MODEL" \
           python3 - "$HERMES_DATA_CFG" "$_op_cfg" <<'EOF'
import sys, os, yaml
src, dst = sys.argv[1], sys.argv[2]
with open(src) as fh:
    d = yaml.safe_load(fh) or {}
ep = os.environ["MIOS_AGENT_ENDPOINT"].rstrip("/")
model = os.environ["MIOS_AGENT_MODEL"]
m = d.get("model") if isinstance(d.get("model"), dict) else {}
m["provider"] = "custom:mios-orchestrator"   # resolves against custom_providers below
m["default"]  = model
m["base_url"] = ep
m["api_key"]  = ""
m.pop("fallback_model", None)                # orchestrator owns fallback server-side
d["model"] = m
cps = d.get("custom_providers")
if not isinstance(cps, list):
    cps = []
if not any(isinstance(c, dict) and c.get("name") == "mios-orchestrator" for c in cps):
    cps.append({"name": "mios-orchestrator", "base_url": ep, "api_key": ""})
d["custom_providers"] = cps
d["toolsets"] = []                           # tools run SERVER-SIDE in the orchestrator
mcp = d.get("mcp_servers")
if isinstance(mcp, dict):
    for v in mcp.values():
        if isinstance(v, dict):
            v["enabled"] = False             # no per-session MCP spawn for the thin REPL
with open(dst, "w") as fh:
    yaml.safe_dump(d, fh, sort_keys=False, default_flow_style=False)
print("ok")
EOF
        then
            chown -R "$_op_user":"$_op_user" "$_op_cfg_dir" 2>/dev/null || true
            chmod 0700 "$_op_cfg_dir" 2>/dev/null || true
            chmod 0600 "$_op_cfg" 2>/dev/null || true
            _log "seeded operator CLI config $_op_cfg as THIN orchestrator client (${_AGENT_MODEL} @ ${_AGENT_ENDPOINT})"
        else
            # Degrade-open: if the transform fails (no python/yaml), fall back to the
            # legacy leaf copy so the CLI still has a working config rather than none.
            cp -f "$HERMES_DATA_CFG" "$_op_cfg"
            chown -R "$_op_user":"$_op_user" "$_op_cfg_dir" 2>/dev/null || true
            chmod 0700 "$_op_cfg_dir" 2>/dev/null || true
            chmod 0600 "$_op_cfg" 2>/dev/null || true
            _log "WARN: thin-client transform failed -- copied leaf config to $_op_cfg as fallback"
        fi
    else
        _log "operator CLI config $_op_cfg already current (thin :8640 client) -- not overwriting"
    fi

    # ── Operator CLI key material (~/.hermes/.env) ──────────────────────
    # config.yaml above seeds the PROVIDER half (custom:local-ollama). But
    # the bare interactive `hermes` CLI ALSO has a startup config-detection
    # gate that trips with "no API keys or providers found -- run: hermes
    # setup" when it sees no API_SERVER_KEY / OPENAI_API_KEY in its
    # environment (operator-confirmed 2026-06-14: `hermes` -> setup wizard
    # despite a seeded config.yaml at /var/home/mios/.hermes/config.yaml).
    #
    # WHY the gateway service didn't hit this: hermes-agent.service loads
    # /etc/mios/hermes/api.env via EnvironmentFile=, so API_SERVER_KEY /
    # OPENAI_API_KEY are in the SERVICE's os.environ. The interactive CLI
    # runs as the operator and does NOT read /etc/mios/hermes/api.env --
    # it auto-loads ~/.hermes/.env. Seed THAT with the SAME key material
    # the service uses (single SSOT: the api.env this script generated
    # above) so the CLI's "configured?" gate passes and it never drops
    # into `hermes setup`.
    #
    # Architectural Law 5 (UNIFIED-AI-REDIRECTS) is preserved: the seeded
    # config.yaml pins provider=custom:local-ollama at ${_AI_BACKEND}/v1
    # with api_key:"" (the local lane is keyless). This .env carries only
    # the gateway's OWN key (so the CLI can also auth to the local :8642
