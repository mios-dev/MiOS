#!/usr/bin/bash
# AI-hint: Executes the MiOS Unified Initialization and Role Engine to configure system identity, manage user home directories, and detect hardware/virtualization profiles to determine the system's operational role.
# AI-related: /usr/lib/mios/paths.sh, mios-role, mios-headless, mios-desktop, mios-k3s-master, mios-ha-node, mios-pxe-hub, waydroid-container.service, mios-pxe-hub.service, mios-headless.target
# AI-functions: log
# ============================================================================
# mios role-apply: MiOS Unified Initialization & Role Engine
# ============================================================================
# : FORMAL TARGET TRANSITION. Uses systemd .target units for roles.
# ============================================================================
set -euo pipefail
if [[ -f "/usr/lib/mios/paths.sh" ]]; then
    source /usr/lib/mios/paths.sh
else
    source "$(dirname "$0")/../../lib/mios/paths.sh"
fi

ROLE_CONF="${MIOS_ETC_DIR}/role.conf"
STATE_DIR="${MIOS_VAR_DIR}"
BLADE_D="${MIOS_ETC_DIR}/blade.d"
mkdir -p "$STATE_DIR"
mkdir -p "$BLADE_D"

log() { printf '[mios-role] %s\n' "$*"; }

# ----------------------------------------------------------------------------
# PHASE 1: System-wide Initialization
# ----------------------------------------------------------------------------
MAC=$(cat /sys/class/net/e*/address /sys/class/net/w*/address 2>/dev/null | head -1 || echo "")
MACH_ID=$(cat /etc/machine-id 2>/dev/null || echo "")

if [[ -n "$MACH_ID" ]]; then
    TAG=$(echo "${MACH_ID}${MAC}" | md5sum | head -c 5)
    CURRENT=$(hostname -s 2>/dev/null || echo "")
    if [[ "$CURRENT" == "mios" || "$CURRENT" == "localhost" || "$CURRENT" == "linux" ]]; then
        hostnamectl set-hostname "mios-${TAG}" 2>/dev/null || true
        log "Hostname set to mios-${TAG}"
    fi
fi

# Standard user home management
if [[ -f /etc/passwd ]]; then
    for u in $(awk -F: '$3 >= 1000 && $3 < 65000 {print $1}' /etc/passwd); do
        home=$(getent passwd "$u" | cut -d: -f6)
        if [[ ! -d "$home" ]]; then
            mkdir -p "$home"
            cp -a /etc/skel/. "$home/" 2>/dev/null || true
            uid=$(id -u "$u"); gid=$(id -g "$u")
            chown -R "${uid}:${gid}" "$home"
        fi
        for g in wheel libvirt kvm video render input dialout; do
            usermod -aG "$g" "$u" 2>/dev/null || true
        done
    done
fi

# ----------------------------------------------------------------------------
# PHASE 2: Environment & Hardware Detection
# ----------------------------------------------------------------------------
VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")

# ARCHITECTURAL SAFEGUARD: OCI Container Optimization
# If running inside a container, skip the role engine. Containers are
# implicitly "headless" and specialized via ENTRYPOINT/CMD.
if [[ "$VIRT" == "container" ]]; then
    log "Container environment detected - bypassing Role Engine for stability"
    exit 0
fi

IS_BLACKWELL=false
if lspci -d 10de: 2>/dev/null | grep -qi "GB20\|GB10"; then
    IS_BLACKWELL=true
    log "RTX 50 Blackwell detected - enforcing safety parameters"
fi

# ----------------------------------------------------------------------------
# PHASE 3: Role & Capability Resolution
# ----------------------------------------------------------------------------
ROLE=""
FEATURES=""

if [[ -r /proc/cmdline ]]; then
    for tok in $(< /proc/cmdline); do
        case "$tok" in
            mios.blade=*)   ROLE="${tok#mios.blade=}" ;;
            # Backwards compatibility kargs
            mios.role=*)     ROLE="${tok#mios.role=}" ;;
            mios.features=*) FEATURES="${tok#mios.features=}" ;;
        esac
    done
fi

if [[ -z "$ROLE" && -r "$ROLE_CONF" ]]; then
    # shellcheck disable=SC1090
    . "$ROLE_CONF"
fi

# If ROLE is still empty, load default type from mios.toml [blade].type
if [[ -z "$ROLE" ]]; then
    ROLE=$(python3 -c "import sys, os; sys.path.insert(0, os.environ.get('MIOS_USR_DIR', '/usr/lib/mios')); import mios_toml; print(mios_toml.get('blade', 'type', default='hybrid'))" 2>/dev/null || echo "")
fi

# Auto-Role selection based on environment
if [[ -z "$ROLE" ]]; then
    if [[ "$VIRT" == "wsl" || -e /dev/dxg ]]; then
        ROLE="headless"
        log "WSL detected - defaulting to headless role"
    elif [[ "$IS_BLACKWELL" == "true" ]]; then
        ROLE="headless"
        log "Blackwell safety - defaulting to headless role"
    elif ! compgen -G "/dev/dri/renderD*" >/dev/null && [[ ! -e /sys/class/drm/card0 ]]; then
        ROLE="headless"
        log "No DRM device - defaulting to headless role"
    fi
fi

ROLE="${ROLE:-hybrid}"
log "Resolved blade archetype role: $ROLE"

# Clean up existing markers
rm -f "$BLADE_D"/* 2>/dev/null || true

# Resolve capabilities from mios.toml [blade.archetypes]
CAPS=$(python3 -c "
import sys, os
sys.path.insert(0, os.environ.get('MIOS_USR_DIR', '/usr/lib/mios'))
import mios_toml
d = mios_toml.load_merged()
blade = d.get('blade', {})
btype = '$ROLE'
archetypes = blade.get('archetypes', {})
caps = archetypes.get(btype, [])
print(' '.join(caps))
" 2>/dev/null || echo "")

for cap in $CAPS; do
    if [[ -n "$cap" ]]; then
        touch "$BLADE_D/$cap"
        log "Materialized capability marker: $cap"
    fi
done

# Touch additional features requested via config
if [[ -n "$FEATURES" ]]; then
    IFS=',' read -r -a FEAT_ARR <<< "$FEATURES"
    for f in "${FEAT_ARR[@]}"; do
        if [[ -n "$f" ]]; then
            touch "$BLADE_D/$f"
            log "Materialized additional capability marker: $f"
        fi
    done
fi

# Gather all active markers for env writing
ALL_CAPS=""
if [[ -d "$BLADE_D" ]]; then
    ALL_CAPS=$(ls -A "$BLADE_D" | tr '\n' ',' | sed 's/,$//')
fi

# Write /run/mios/blade.env
mkdir -p /run/mios
cat > /run/mios/blade.env <<EOF
MIOS_BLADE_TYPE="$ROLE"
MIOS_BLADE_CAPS="$ALL_CAPS"
EOF

# ----------------------------------------------------------------------------
# PHASE 4: Target Selection & Execution
# ----------------------------------------------------------------------------
TARGET="mios-headless.target"
case "$ROLE" in
    hybrid)     TARGET="mios-hybrid.target" ;;
    compute)    TARGET="mios-compute.target" ;;
    endpoint)   TARGET="mios-endpoint.target" ;;
    controller) TARGET="mios-controller.target" ;;
    headless)   TARGET="mios-headless.target" ;;
    desktop)    TARGET="mios-desktop.target" ;;
    # Backwards compatibility names
    k3s*)       TARGET="mios-k3s-master.target" ;;
    ha*)        TARGET="mios-ha-node.target" ;;
    *)          log "WARN: unknown role '$ROLE' - defaulting to headless" ;;
esac

log "Setting default target to $TARGET"
systemctl set-default --no-block "$TARGET" 2>/dev/null || true
log "Triggering role target: $TARGET"
systemctl start --no-block "$TARGET" 2>/dev/null || true

# Record active state for diagnostics
cat > "$STATE_DIR/role.active" <<EOF
ROLE=$ROLE
FEATURES=$ALL_CAPS
VIRT=$VIRT
BLACKWELL=$IS_BLACKWELL
TARGET=$TARGET
APPLIED=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF

log "role apply complete; system is transitioning to $TARGET"
