#!/bin/sh
# /usr/libexec/mios/flatpak-launch <flatpak-app-id> [args...]
#
# Robust GUI flatpak launcher. Re-derives the WSLg / Wayland / X11 / PulseAudio
# / D-Bus environment whenever the calling shell stripped it (su -, nsenter -m,
# sudo without -E, systemd-run, cron), then exec's `flatpak run --system <id>`.
#
# WHY THIS EXISTS
# ───────────────
# The per-app shims under /usr/local/bin/ (nautilus, epiphany, ptyxis, codium,
# gnome-software, flatseal) get launched from every imaginable context. Login
# shells under WSL get DISPLAY/WAYLAND_DISPLAY via /etc/profile.d/mios-wslg.sh,
# but the moment the operator goes through `su - mios`, `sudo nsenter -m -p`,
# `sudo -i`, or any systemd unit, those vars vanish and the flatpak fails with
# one of:
#
#     Cannot autolaunch D-Bus without X11 $DISPLAY
#     Gtk-WARNING **: cannot open display:
#     ** WARNING **: Failed to create XdpPortal instance:
#         Cannot autolaunch D-Bus without X11 $DISPLAY
#
# The /etc/profile.d/mios-wslg.sh helper would fix all of those, but only
# login shells source profile.d/. Flatpak shims invoked from a non-login
# shell (e.g. `bash -c 'nautilus'` from a script, or interactive bash from
# `su -l mios` whose PAM stack didn't run because we entered via nsenter)
# bypass it entirely.
#
# This script is the inner-shell complement: it runs every time a GUI
# flatpak is launched, and only sets variables that are unset, so it never
# overrides a working bare-metal GNOME or Wayland session that already
# arranged its own environment.
#
# DESIGN
# ──────
# 1. WSL detection via /proc/version (namespace-stable; survives nsenter -m
#    because /proc is bind-mounted into every namespace).
# 2. XDG_RUNTIME_DIR: prefer /run/user/$UID (real tmpfs that supports the
#    sticky-bit chmods rootless podman performs); fall back to WSLg's 9p
#    runtime-dir when the per-uid tmpfs is absent.
# 3. DISPLAY / WAYLAND_DISPLAY: WSLg defaults (:0 / wayland-0).
# 4. PULSE_SERVER: prefer $XDG_RUNTIME_DIR/pulse/native, fall back to
#    /mnt/wslg/PulseServer.
# 5. DBUS_SESSION_BUS_ADDRESS: derived from $XDG_RUNTIME_DIR/bus when the
#    user@$UID.service socket is up. This is the single var that breaks
#    epiphany the loudest -- "Cannot autolaunch D-Bus without X11 $DISPLAY"
#    is libportal's complaint when DBUS_SESSION_BUS_ADDRESS is empty AND
#    DISPLAY is empty (it tries X11 cookie autolaunch as last resort).
#
# Inert on bare-metal Linux desktops (where the session manager already
# set everything) and on macOS hosts running MiOS in a VM (no /proc/version
# Microsoft signal, no /mnt/wslg). On those substrates the exec falls
# straight through to `flatpak run` with the caller's environment intact.

set -eu

APP_ID="${1:?usage: flatpak-launch <flatpak-app-id> [args...]}"
shift || true

# Step 0 ── Service-user re-exec (operator-confirmed regression 2026-05-15:
# "launching epiphany from Hermes CLI WORKS, just not from Open WebUI").
#
# Hermes-Agent's gateway service runs as `mios-hermes` (uid 820). When OWUI
# asks the agent to launch a GUI flatpak, the agent's `terminal` tool forks
# under that service user. mios-hermes is deliberately locked down:
#
#   * HOME=/var/empty (root-owned, NOT writable -- flatpak needs a real
#     home to write app state under ~/.var/app/<id>/, and dies with a
#     bare "error: Permission denied" without it)
#   * no `user@820.service` socket -> no DBUS_SESSION_BUS_ADDRESS -> the
#     entire portal stack (Open File, Notifications, Secrets) refuses to
#     start, GTK then aborts the window
#   * no XDG seat / login session -> can't acquire the screen
#
# The Hermes CLI works fine because the operator runs `hermes` from their
# own login shell as the `mios` user (uid 992) -- their session has DISPLAY,
# WAYLAND_DISPLAY, DBUS_SESSION_BUS_ADDRESS, a real HOME, all already set.
#
# Fix: when this script is invoked as a service user (uid < 1000 OR HOME
# unwritable), re-exec via `sudo` to the operator. The mios-hermes sudoers
# grant (/etc/sudoers.d/10-mios-hermes -> NOPASSWD: ALL) lets this happen
# without prompting; the operator's session has all the GUI plumbing the
# flatpak needs. _MIOS_FLATPAK_REEXEC=1 guards against an infinite loop if
# the sudo escalation ever lands back in a service user (it shouldn't, but
# belt and suspenders).
_FL_REEXEC="${_MIOS_FLATPAK_REEXEC:-0}"
if [ "$_FL_REEXEC" != "1" ] && [ "$(id -u)" -lt 1000 ]; then
    # Resolve operator UID/name from mios.toml's identity.username (default
    # 'mios'); fall back to whatever uid 1000 exists if username lookup fails
    # (single-tenant dev VM contract).
    _op_user=""
    if [ -r /usr/share/mios/mios.toml ]; then
        _op_user="$(awk -F\" '/^\s*username\s*=\s*"/{print $2; exit}' /usr/share/mios/mios.toml 2>/dev/null)"
    fi
    [ -z "$_op_user" ] && _op_user="mios"
    if id -u "$_op_user" >/dev/null 2>&1; then
        _op_uid="$(id -u "$_op_user")"
        _op_xdg="/run/user/${_op_uid}"
        _op_dbus="unix:path=${_op_xdg}/bus"
        _op_home="$(getent passwd "$_op_user" | cut -d: -f6)"
        export _MIOS_FLATPAK_REEXEC=1
        # KEY POINT: `sudo -u <op>` alone is NOT enough. It changes uid+gid
        # but INHERITS the parent's mount namespace -- and the parent here
        # is hermes-agent.service, which has ProtectSystem=strict. That
        # namespace makes /var/home read-only, so the flatpak's first
        # `mkdir(/var/home/<op>/.var/app/<id>)` dies with "Read-only file
        # system" (operator-confirmed 2026-05-15 journal: nautilus failed
        # 0.24s into the agent's terminal call with that exact errno).
        # Same fix as mios-build-driver's namespace escape: route through
        # `systemd-run --pipe --wait` so PID 1 forks the unit FRESH outside
        # the agent's namespace, with PID 1's default mount view (the host's
        # writable /var/home). --uid=<op> sets the unit user; --setenv
        # carries DISPLAY/WAYLAND_DISPLAY/etc. inside the new namespace.
        # If systemd-run is unavailable (atypical install), fall back to
        # plain sudo -- works on bare-metal where ProtectSystem isn't a
        # factor, breaks honestly inside the agent.
        if command -v systemd-run >/dev/null 2>&1; then
            # CRITICAL: do NOT pass --wait/--pipe here. GUI flatpaks are long-
            # running (the user keeps the window open for minutes/hours);
            # --wait would block this exec until the GUI exits, which means
            # the agent's terminal call never returns, OWUI times out the
            # chat, and the operator sees "couldn't open epiphany" even
            # though the window IS up (operator-confirmed regression
            # 2026-05-15: bwrap epiphany running as mios while the agent's
            # call sat blocked on systemd-run --wait).
            #
            # Without --wait, systemd-run registers the transient unit, lets
            # PID 1 take ownership of it, and returns ~instantly with the
            # unit name. The GUI then runs DETACHED in the operator's
            # session, outliving this script and the agent's tool call.
            # --collect cleans up the transient unit when the GUI exits.
            exec sudo -n systemd-run \
                --collect --quiet \
                --unit="mios-flatpak-${APP_ID//./-}-$$" \
                --uid="$_op_user" \
                --setenv=HOME="$_op_home" \
                --setenv=XDG_RUNTIME_DIR="$_op_xdg" \
                --setenv=DBUS_SESSION_BUS_ADDRESS="$_op_dbus" \
                --setenv=DISPLAY="${DISPLAY:-:0}" \
                --setenv=WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}" \
                --setenv=PULSE_SERVER="${PULSE_SERVER:-}" \
                --setenv=_MIOS_FLATPAK_REEXEC=1 \
                /usr/libexec/mios/flatpak-launch "$APP_ID" "$@"
        else
            exec sudo -n -u "$_op_user" \
                --preserve-env=DISPLAY,WAYLAND_DISPLAY,PULSE_SERVER,_MIOS_FLATPAK_REEXEC \
                env XDG_RUNTIME_DIR="$_op_xdg" \
                    DBUS_SESSION_BUS_ADDRESS="$_op_dbus" \
                    HOME="$_op_home" \
                    /usr/libexec/mios/flatpak-launch "$APP_ID" "$@"
        fi
    fi
    # If we get here the operator user doesn't exist (atypical install) --
    # fall through and let flatpak fail with whatever its own error is.
fi

# Step 1 ── WSL detection. /proc/version is namespace-stable.
IS_WSL=0
if [ -r /proc/version ]; then
    case "$(cat /proc/version 2>/dev/null)" in
        *Microsoft*|*microsoft*|*WSL*) IS_WSL=1 ;;
    esac
fi

# Step 2 ── XDG_RUNTIME_DIR. Prefer /run/user/$UID; on WSL fall back to
# /mnt/wslg/runtime-dir if the per-uid tmpfs hasn't been created yet
# (early-boot interactive shells before mios-wsl-runtime-dir.service runs).
if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
    uid="$(id -u)"
    if [ -d "/run/user/$uid" ]; then
        XDG_RUNTIME_DIR="/run/user/$uid"
    elif [ "$IS_WSL" = "1" ] && [ -d /mnt/wslg/runtime-dir ]; then
        XDG_RUNTIME_DIR="/mnt/wslg/runtime-dir"
    fi
    [ -n "${XDG_RUNTIME_DIR:-}" ] && export XDG_RUNTIME_DIR
fi

# Step 3 ── Wayland / X11 / Pulse defaults. Only on WSL: a bare-metal GNOME
# session that's missing DISPLAY is in a broken state we can't paper over,
# but on WSL we know the defaults are stable across every distro that has
# guiApplications=true in /etc/wsl.conf.
if [ "$IS_WSL" = "1" ]; then
    : "${WAYLAND_DISPLAY:=wayland-0}"
    : "${DISPLAY:=:0}"
    if [ -z "${PULSE_SERVER:-}" ]; then
        if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -S "$XDG_RUNTIME_DIR/pulse/native" ]; then
            PULSE_SERVER="unix:$XDG_RUNTIME_DIR/pulse/native"
        elif [ -S /mnt/wslg/PulseServer ]; then
            PULSE_SERVER="unix:/mnt/wslg/PulseServer"
        fi
    fi
    export WAYLAND_DISPLAY DISPLAY
    [ -n "${PULSE_SERVER:-}" ] && export PULSE_SERVER
fi

# Step 4 ── D-Bus session bus. The libportal autolaunch-error path triggers
# when this is empty -- portals (Open File, Save File, Notification) refuse
# to function without it, and nautilus/epiphany then crash on first dialog.
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] \
   && [ -n "${XDG_RUNTIME_DIR:-}" ] \
   && [ -S "$XDG_RUNTIME_DIR/bus" ]; then
    DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
    export DBUS_SESSION_BUS_ADDRESS
fi

# Step 5 ── exec the flatpak. `flatpak run --system` resolves the app
# from the system installation (/var/lib/flatpak); --user installs are
# not used by MiOS because the dev VM is single-tenant.
exec flatpak run --system "$APP_ID" "$@"
