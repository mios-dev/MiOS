#!/usr/bin/env python3
"""'MiOS' scheduled-research runner -- the `do` target for schedule rules.

Reads the rule's stored prompt, runs it through the FULL agent-pipe (refine ->
swarm/council research), and posts the result to Discord via mios-discord-send.
This is what makes "do deep research on X every 30 minutes" actually deliver:
the cron-director fires `mios-scheduled-research --rule <name>` each interval.

Honest output: JSON describing what happened (researched + posted / why not) --
never a fabricated success.
"""
from __future__ import annotations
import argparse
import json
import os
import subprocess
import sys
import time
import urllib.request

PROMPT_DIR = "/var/lib/mios/cron-director/prompts"
PIPE_URL = os.environ.get("MIOS_SCHED_PIPE_URL", "http://127.0.0.1:8640/v1/chat/completions")
PIPE_MODEL = os.environ.get("MIOS_SCHED_MODEL", "mios-agent")
PIPE_TIMEOUT = float(os.environ.get("MIOS_SCHED_TIMEOUT", "240"))
# Autonomous turns must NOT trigger the WIDE research fan-out (operator
# 2026-06-01 autonomous-wedge fix). A scheduled research prompt is a research
# turn -> the agent-pipe would otherwise fan out with include_research=True and
# cold-load every 2-4GB replica across all lanes; fired on a timer with no human
# watching, that periodically thundering-herds ollama and wedges the VM. We tag
# the request metadata.mios_autonomous=true so the pipe takes the BOUNDED path
# (narrow council, no research-replica fan-out). SSOT: MIOS_SCHED_BOUNDED.
SCHED_BOUNDED = os.environ.get("MIOS_SCHED_BOUNDED", "true").lower() \
    not in {"false", "0", "no"}


def _run_pipe(prompt: str) -> str:
    payload = {"model": PIPE_MODEL, "stream": False,
               "messages": [{"role": "user", "content": prompt}]}
    if SCHED_BOUNDED:
        # Honored by the agent-pipe (_council_research / fan-out gate): an
        # autonomous turn stays narrow no matter the research intent.
        payload["metadata"] = {"mios_autonomous": True}
    req = urllib.request.Request(
        PIPE_URL, data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=PIPE_TIMEOUT) as r:
        d = json.loads(r.read().decode("utf-8", "replace"))
    return ((d.get("choices") or [{}])[0].get("message") or {}).get("content", "").strip()


def main() -> int:
    p = argparse.ArgumentParser(prog="mios-scheduled-research")
    p.add_argument("--rule", required=True)
    a = p.parse_args()

    pf = os.path.join(PROMPT_DIR, a.rule + ".txt")
    try:
        with open(pf) as fh:
            prompt = fh.read().strip()
    except OSError as e:
        print(json.dumps({"success": False, "rule": a.rule,
                          "error": f"no prompt file: {e}"})); return 1
    if not prompt:
        print(json.dumps({"success": False, "rule": a.rule, "error": "empty prompt"})); return 1

    print(f"[mios-scheduled-research] rule={a.rule} running: {prompt[:120]}", flush=True)
    try:
        answer = _run_pipe(prompt)
    except Exception as e:  # noqa: BLE001
        print(json.dumps({"success": False, "rule": a.rule,
                          "error": f"pipe call failed: {type(e).__name__}: {e}"})); return 1
    if not answer:
        print(json.dumps({"success": False, "rule": a.rule, "error": "empty answer"})); return 1

    stamp = time.strftime("%Y-%m-%d %H:%M")
    # Discord hard-caps at 2000 chars; leave room for the header.
    header = f"\U0001F4C5 Scheduled research — {a.rule} — {stamp}\n\n"
    msg = (header + answer)[:1990]
    try:
        out = subprocess.run(["mios-discord-send", msg],
                             capture_output=True, text=True, timeout=20)
        posted = out.returncode == 0
        detail = (out.stdout or out.stderr or "").strip()
    except Exception as e:  # noqa: BLE001
        posted, detail = False, f"{type(e).__name__}: {e}"
    print(json.dumps({"success": posted, "rule": a.rule,
                      "answer_chars": len(answer), "discord": detail}))
    return 0 if posted else 1


if __name__ == "__main__":
    sys.exit(main())
