#!/bin/bash
# /usr/libexec/mios/mios-gui-launch <linux-gui-app> [args...]
#
# Operator directive 2026-05-17: agent failed to launch
# gnome-control-center because (a) it claimed "no display server"
# (false -- WSLg is up) and (b) gnome-control-center specifically
# refuses to start without XDG_CURRENT_DESKTOP=GNOME ("Running
# gnome-control-center is only supported under GNOME and Unity,
# exiting"). One canonical shim that handles every Linux GUI app
# launch under WSLg:
#
#   * Ensures WAYLAND_DISPLAY + DISPLAY are set (inherited from
#     WSLg if available; sensible default of wayland-0 / :0).
#   * Sets XDG_CURRENT_DESKTOP=GNOME so gnome-* tools cooperate.
#   * Sets XDG_SESSION_TYPE=wayland so wayland-aware apps prefer
#     the native protocol over Xwayland fallback.
#   * nohup + & + disown so the GUI app survives the agent's shell
#     exit and doesn't block the broker call.
#   * Routes stderr to a per-app log under /var/log/mios/gui/ for
#     post-mortem if the window never appears.
#   * Exits 0 immediately on dispatch; the GUI may take 1-3s to
#     paint. Verify with `mios-window-active --present "<title>"`.
#
# Examples:
#   mios-gui-launch gnome-control-center
#   mios-gui-launch nautilus /home
#   mios-gui-launch gedit
#   mios-gui-launch flatpak run com.google.ChromeDev https://example.com
#
# Use this for ANY /usr/bin/<gui-app> launch from the agent. For
# Windows-side apps use mios-find / launch_app.

set -uo pipefail

usage() {
    cat <<'USAGE'
usage: mios-gui-launch <linux-gui-app> [args...]

Detached WSLg-aware launcher for Linux GUI apps. Sets the env
WSLg + GNOME/Unity tools need, nohups + disowns, returns 0 on
dispatch.

  <linux-gui-app>   Binary on PATH (e.g. gnome-control-center,
                    nautilus, gedit) OR absolute path.
  [args...]         Extra args passed to the GUI app.

Verify the window actually rendered:
  mios-window-active --present "<title-substring>"

USAGE
}

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
    [ "$#" -lt 1 ] && exit 64 || exit 0
fi

APP="$1"
shift

# ── Flatpak app-id / .desktop-id auto-dispatch ────────────────────────
# When called with a reverse-DNS-shaped name (com.foo.Bar /
# mobi.phosh.MobileSettings / org.gnome.Calls / etc.), the caller meant
# either a FLATPAK or a .desktop-id-installed RPM, not a bare PATH
# binary. Try BOTH before falling through to the "not found on PATH"
# error. Operator-flagged 2026-05-19: agent tried
# `mios-gui-launch mobi.phosh.MobileSettings` -> "not found on PATH",
# retried 4x, hit same_tool_failure_halt. Detection is purely
# structural: 2+ dots, alpha-leading segments.
if [[ "$APP" =~ ^[a-zA-Z][a-zA-Z0-9_]*(\.[a-zA-Z][a-zA-Z0-9_]*){2,}$ ]]; then
    # 1. Flatpak first (operator binding: Linux native first;
    #    flatpaks are the user-app surface).
    if command -v flatpak >/dev/null 2>&1 \
       && flatpak info "$APP" >/dev/null 2>&1; then
        exec /usr/libexec/mios/flatpak-launch "$APP" "$@"
    fi
    # 2. .desktop file: look up /usr/share/applications/<id>.desktop
    #    + ~/.local/share/applications/<id>.desktop, extract Exec=,
    #    strip Desktop-Entry placeholders (%F %U %i %c %k), and exec.
    for _df in "/usr/share/applications/$APP.desktop" \
               "/var/lib/flatpak/exports/share/applications/$APP.desktop" \
               "$HOME/.local/share/applications/$APP.desktop"; do
        if [ -r "$_df" ]; then
            _exec=$(awk -F= "/^Exec=/{print substr(\$0, 6); exit}" "$_df" \
                     | sed -E "s/ ?%[FUufdDnNickvm]//g")
            if [ -n "$_exec" ]; then
                # Exec= is a shell-tokenisable command line. Re-exec
                # this same script with the FIRST token (binary) +
                # the rest preserved + caller's args appended.
                # shellcheck disable=SC2086 -- intentional word-split
                exec /usr/libexec/mios/mios-gui-launch $_exec "$@"
            fi
        fi
    done
fi

# Resolve the binary (allow absolute or PATH).
if [ "${APP:0:1}" != "/" ]; then
    RESOLVED=$(command -v "$APP" 2>/dev/null || true)
    if [ -z "$RESOLVED" ]; then
        echo "mios-gui-launch: '$APP' not found on PATH" >&2
        echo "  (if this is a flatpak, pass the full app-id like 'org.gnome.Calls'" >&2
        echo "   -- structural detection requires >=2 dots in the name)" >&2
        exit 1
    fi
    APP="$RESOLVED"
fi
[ -x "$APP" ] || { echo "mios-gui-launch: '$APP' not executable" >&2; exit 1; }

# Per-app log (no path traversal -- use basename only).
LOG_DIR="${MIOS_GUI_LOG_DIR:-/var/log/mios/gui}"
mkdir -p "$LOG_DIR" 2>/dev/null || true
LOG_FILE="$LOG_DIR/$(basename "$APP").log"

# WSLg env: prefer existing values (the user's session may have set
# specific values); fall back to known WSLg defaults.
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
export DISPLAY="${DISPLAY:-:0}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
# gnome-control-center + most Gtk-Adwaita apps gate on these.
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-GNOME}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
# Some apps (Files / gedit / VSCode flatpak) read GTK theme from this.
export GTK_THEME="${GTK_THEME:-Adwaita}"

# Dispatch -- detached, stdout+stderr to per-app log.
echo "[mios-gui-launch] dispatch: $APP $*" >> "$LOG_FILE"
echo "[mios-gui-launch] env: DISPLAY=$DISPLAY WAYLAND_DISPLAY=$WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=$XDG_CURRENT_DESKTOP" >> "$LOG_FILE"

nohup setsid -- "$APP" "$@" >> "$LOG_FILE" 2>&1 &
PID=$!
disown "$PID" 2>/dev/null || true

echo "[mios-gui-launch] dispatched pid=$PID log=$LOG_FILE"
echo "[mios-gui-launch] verify: mios-window-active --present \"$(basename "$APP")\""

exit 0
