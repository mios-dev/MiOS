#!/bin/bash
# /usr/libexec/mios/mios-window-active <name-pattern>
#
# Reports whether the named app's window is actually PRESENTED to
# the operator -- not just whether the process is alive. Operator
# directive 2026-05-16: "if MiOS Agents detect the launched
# process(es) as alive or present -- MiOS Agents should understand
# that simply having the application live isn't enough and that it
# needs to present the active window to the user(s)".
#
# A process can be alive but its window:
#   * never created (MainWindowHandle == 0)
#   * minimized to the taskbar (IsIconic == true)
#   * hidden (IsWindowVisible false)
#   * sized off-screen
# Any of these means the operator does NOT see the app, even
# though `pgrep` / `Get-Process` would say "running".
#
# Output: ONE-LINE JSON to stdout. Single source of truth -- agents
# parse this instead of running their own ad-hoc Get-Process check.
#
# {
#   "query": "epiphany",
#   "process_alive": true,
#   "process_id": 12345,
#   "process_name": "epiphany",
#   "window_handle": 1248892,
#   "window_title": "Welcome to Web - Epiphany",
#   "window_visible": true,
#   "window_minimized": false,
#   "window_foreground": true,
#   "window_rect": {"x": 720, "y": 232, "w": 1280, "h": 720},
#   "on_screen": true,
#   "presented_to_operator": true,
#   "summary": "presented"
# }
#
# `presented_to_operator` is the bottom-line bool the agent should
# trust: TRUE iff process_alive AND window_handle != 0 AND
# window_visible AND NOT window_minimized AND window rect is
# on-screen with positive area.
#
# `summary` is one of:
#   presented        -- visible + not minimized + on-screen (success)
#   not-running      -- process_alive false
#   no-window        -- process alive but MainWindowHandle == 0 (still spawning OR pure CLI)
#   minimized        -- process + window exist but iconic
#   hidden           -- process + window exist but IsWindowVisible false
#   off-screen       -- window rect outside every monitor work area
#
# Works for both Windows apps and WSLg-hosted Linux apps -- WSLg
# wraps each Linux Wayland surface in a Win32 top-level owned by
# msrdc.exe / mstsc.exe, so the Win32 API sees them identically.

set -eu

PRESENT=0
if [ "$#" -ge 1 ] && [ "$1" = "--present" ]; then
    PRESENT=1
    shift
fi

if [ "$#" -lt 1 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    cat <<'USAGE'
usage: mios-window-active [--present] <name-pattern>

Reports JSON describing whether the named app's window is presented
to the operator (visible + not minimized + on-screen). Process-alive
alone is INSUFFICIENT -- use this to verify the operator actually
sees the launched app.

The pattern is a substring match (case-insensitive) against either
the process name OR the main window title. First match wins,
preferring processes that have a non-zero MainWindowHandle.

  --present   If the window is minimized/hidden, RESTORE it +
              SetForegroundWindow before re-checking. This makes the
              verifier also the actuator: after `--present`, summary
              is either "presented" (success) or one of "not-running"
              / "no-window" / "off-screen" (genuine failure, not
              minimized).

Forms (every token in <ANGLES> is operator-substituted; do not
interpret as a specific app name):
  mios-window-active <pattern>              -> JSON snapshot
  mios-window-active --present <pattern>    -> auto-restore + foreground, then snapshot
  mios-window-active <multi word pattern>   -> quote it: "<multi word pattern>"
USAGE
    exit 0
fi

QUERY="$*"
# Multi-pattern support: caller may pass a comma-separated list of
# patterns ("epiphany,web,gnome web"). We try each in order against
# both process name AND window title. First match wins.
# Operator-flagged 2026-05-16: Win32 windows hosted by WSLg msrdc.exe
# show the LINUX-app display name in MainWindowTitle (e.g., Epiphanys
# .desktop Name= is "Web", not "Epiphany"), so a single-pattern
# "epiphany" search misses the window.
IFS=',' read -ra PATTERNS_ARR <<< "$QUERY"
# Build the PowerShell pattern list as a quoted comma-joined string.
PS_PATTERNS=""
for p in "${PATTERNS_ARR[@]}"; do
    p_trim=$(echo "$p" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    [ -z "$p_trim" ] && continue
    p_escaped=$(printf '%s' "$p_trim" | sed "s/'/''/g")
    if [ -z "$PS_PATTERNS" ]; then
        PS_PATTERNS="'$p_escaped'"
    else
        PS_PATTERNS="$PS_PATTERNS, '$p_escaped'"
    fi
done
# First pattern is the canonical query (for output JSON + pgrep).
PS_QUERY=$(printf '%s' "${PATTERNS_ARR[0]:-$QUERY}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' | sed "s/'/''/g")

# Stringify the --present flag for embedding in the PowerShell literal.
if [ "$PRESENT" = "1" ]; then PS_PRESENT='$true'; else PS_PRESENT='$false'; fi

# ─── Linux-side pre-check: pgrep across all patterns ──────────────────
# WSLg-hosted Linux flatpaks (Epiphany, Nautilus, Ptyxis, etc.) are
# wrapped in msrdc.exe on the Windows side -- the Win32 Get-Process
# loop sees "msrdc.exe", not "epiphany". So a Win32-only check reports
# "not-running" even when the Linux process IS alive. Run pgrep
# (against ANY of the patterns) first; if the Linux process exists,
# surface process_alive=true in the JSON even if no Win32 window is
# found yet.
_lin_pid=""
if command -v pgrep >/dev/null 2>&1; then
    for p in "${PATTERNS_ARR[@]}"; do
        p_trim=$(echo "$p" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
        [ -z "$p_trim" ] && continue
        _lin_pid=$(pgrep -if "$p_trim" 2>/dev/null | head -1 || true)
        [ -n "$_lin_pid" ] && break
    done
fi

# PowerShell snippet -- the query is embedded as a single-quoted
# literal so it survives broker dispatch (no env var inheritance
# needed).
PS_SNIPPET=$(cat <<PWSHEOF
\$query = '$PS_QUERY'
\$present = $PS_PRESENT
\$query_lower = \$query.ToLowerInvariant()
Add-Type @"
using System;
using System.Runtime.InteropServices;
public class W {
    [DllImport("user32.dll")] public static extern bool IsIconic(IntPtr h);
    [DllImport("user32.dll")] public static extern bool IsWindowVisible(IntPtr h);
    [DllImport("user32.dll")] public static extern IntPtr GetForegroundWindow();
    [DllImport("user32.dll")] public static extern bool GetWindowRect(IntPtr h, out RECT r);
    [DllImport("user32.dll")] public static extern bool ShowWindow(IntPtr h, int n);
    [DllImport("user32.dll")] public static extern bool SetForegroundWindow(IntPtr h);
    [DllImport("user32.dll")] public static extern bool BringWindowToTop(IntPtr h);
    [StructLayout(LayoutKind.Sequential)] public struct RECT { public int L,T,R,B; }
}
"@ -ErrorAction SilentlyContinue

\$patterns = @($PS_PATTERNS)
\$patterns_lower = @()
foreach (\$p in \$patterns) { \$patterns_lower += \$p.ToLowerInvariant() }
\$procs = Get-Process -ErrorAction SilentlyContinue | Where-Object {
    \$proc_name_lower = \$_.ProcessName.ToLowerInvariant()
    \$title_lower = if (\$_.MainWindowTitle) { \$_.MainWindowTitle.ToLowerInvariant() } else { '' }
    \$matched = \$false
    foreach (\$pat in \$patterns_lower) {
        # Word-boundary regex match instead of bare substring.
        # Substring matching gave false positives: e.g. pattern
        # "web" hit "WebUI" in an unrelated browser's title bar,
        # causing the launch verifier to report "presented" for
        # Epiphany when Epiphany never actually opened (the verifier
        # latched onto the operator's Zen window with title
        # "MiOS Agent (Open WebUI) - Zen Twilight"). Word-boundary
        # \b<pat>\b requires non-word chars on both sides, so "web"
        # matches "open web" or "the web" but NOT "WebUI".
        \$pat_re = "\b" + [regex]::Escape(\$pat) + "\b"
        if (\$proc_name_lower -match \$pat_re -or \$title_lower -match \$pat_re) {
            \$matched = \$true
            break
        }
    }
    \$matched
}

if (\$procs.Count -eq 0) {
    # If pgrep on the Linux side found the process, report that fact
    # so the caller can distinguish "process exists but no Win32 window
    # yet" from "process not even running".
    \$lin_pid = '$_lin_pid'
    if (\$lin_pid -ne '') {
        @{ query = \$query; process_alive = \$true; process_id = [int]\$lin_pid; process_name = \$query; window_handle = 0; presented_to_operator = \$false; summary = 'no-window'; via = 'linux-pgrep' } | ConvertTo-Json -Compress
    } else {
        @{ query = \$query; process_alive = \$false; presented_to_operator = \$false; summary = 'not-running' } | ConvertTo-Json -Compress
    }
    return
}

\$p = \$procs | Where-Object { \$_.MainWindowHandle -ne [IntPtr]::Zero } | Select-Object -First 1
if (-not \$p) { \$p = \$procs | Select-Object -First 1 }

\$h = \$p.MainWindowHandle
if (\$h -eq [IntPtr]::Zero) {
    @{ query = \$query; process_alive = \$true; process_id = \$p.Id; process_name = \$p.ProcessName; window_handle = 0; presented_to_operator = \$false; summary = 'no-window' } | ConvertTo-Json -Compress
    return
}

# --present mode: actuate before re-measuring. SW_RESTORE = 9
# (restores a minimized window); SW_SHOWNORMAL = 1 (shows + activates
# regardless of prior state). Then bring-to-top + foreground for
# z-order. Wait briefly for Win32 to settle.
if (\$present) {
    [W]::ShowWindow(\$h, 9) | Out-Null   # SW_RESTORE
    [W]::ShowWindow(\$h, 1) | Out-Null   # SW_SHOWNORMAL
    [W]::BringWindowToTop(\$h) | Out-Null
    [W]::SetForegroundWindow(\$h) | Out-Null
    Start-Sleep -Milliseconds 250
}

\$visible = [W]::IsWindowVisible(\$h)
\$iconic = [W]::IsIconic(\$h)
\$fg_h = [W]::GetForegroundWindow()
\$is_fg = (\$fg_h -eq \$h)
\$r = New-Object W+RECT
[W]::GetWindowRect(\$h, [ref]\$r) | Out-Null
\$rx = \$r.L; \$ry = \$r.T; \$rw = \$r.R - \$r.L; \$rh = \$r.B - \$r.T

Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue
\$on_screen = \$false
foreach (\$s in [System.Windows.Forms.Screen]::AllScreens) {
    \$wa = \$s.WorkingArea
    if ((\$rx + \$rw) -gt \$wa.X -and \$rx -lt (\$wa.X + \$wa.Width) -and
        (\$ry + \$rh) -gt \$wa.Y -and \$ry -lt (\$wa.Y + \$wa.Height)) {
        \$on_screen = \$true; break
    }
}

if (-not \$visible) { \$summary = 'hidden' }
elseif (\$iconic) { \$summary = 'minimized' }
elseif (-not \$on_screen) { \$summary = 'off-screen' }
else { \$summary = 'presented' }
\$presented = \$visible -and (-not \$iconic) -and \$on_screen -and (\$rw -gt 0) -and (\$rh -gt 0)

@{
    query = \$query
    process_alive = \$true
    process_id = \$p.Id
    process_name = \$p.ProcessName
    window_handle = [int64]\$h
    window_title = \$p.MainWindowTitle
    window_visible = \$visible
    window_minimized = \$iconic
    window_foreground = \$is_fg
    window_rect = @{ x = \$rx; y = \$ry; w = \$rw; h = \$rh }
    on_screen = \$on_screen
    presented_to_operator = \$presented
    summary = \$summary
} | ConvertTo-Json -Compress
PWSHEOF
)

exec mios-windows ps "$PS_SNIPPET"
