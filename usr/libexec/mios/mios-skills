#!/usr/bin/env python3
# AI-hint: CLI tool for mining repetitive tool_call sequences into typed-verb DAGs in parameterized Postgres/pgvector, providing a unified skill catalog for mios-agent-pipe, Hermes, and OpenCode to share standardized, parameterized action sequences. All SQL is bound out-of-band via mios-db --pg-json ($1..$n placeholders).
# AI-related: /usr/libexec/mios/mios-db, /usr/libexec/mios/mios-pg-query, /usr/share/mios/skills, mios-agent-pipe, mios-db, mios-skill, mios-ai, localhost:8640
"""mios-skills -- Sequential Pattern Mining + cross-agent skill catalog CLI.

Phase C.2 of the AgentOS roadmap. Mines the Postgres `tool_call`
table for repeating verb sequences and codifies them as `skill`
rows that EVERY agent in the MiOS stack reads from a single source:

  * mios-agent-pipe (:8640) -- reads via /skills/* REST endpoints
                               AND directly from Postgres.
  * MiOS-Hermes (:8642)     -- pulls /skills/openai-tools at startup
                               so Hermes' OpenAI-compat tool surface
                               advertises promoted skills as callable
                               tools (no Hermes-side hardcoding).
  * MiOS-OpenCode           -- same /skills/openai-tools dump (or
                               direct Postgres read for offline-only
                               OpenCode runs that can't reach
                               agent-pipe).

Skills are typed-verb DAGs -- no English narrative, no per-agent
behaviour, fully parameterized. A skill body looks like:

    {"steps": [
       {"verb": "open_app",     "args": {"name": "$app"}},
       {"verb": "focus_window", "args": {"title": "$app"}},
       {"verb": "pc_type",      "args": {"text": "$body"}},
       {"verb": "pc_key",       "args": {"key": "ctrl+s"}}
     ],
     "params": ["app", "body"]}

That body is the same shape the Phase A.1 planner emits as a DAG --
so a skill is "a DAG the operator has decided to keep". The
parameters are substituted via simple $name token replacement at
run time.

Subcommands:

  mine [--window <hours>] [--min-support <N>] [--min-length <N>]
                            Run the SPM miner against tool_call
                            history. Emits skill rows with
                            source=mined, status=candidate. Prints
                            a per-candidate summary.

  list  [--status candidate|promoted|retired|all]
        [--source mined|operator|import|all]
                            List skill rows.

  show <name>               Print skill body JSON.

  run  <name> [--param key=value ...] [--session <session-id>]
                            Execute a skill against agent-pipe's
                            /skills/run endpoint (so the dispatch
                            goes through the same firewall + taint
                            + audit chain every verb does). Prints
                            per-step result.

  promote <name>            Mark a skill as runnable (status=promoted).
  retire  <name>            Hide a skill (status=retired).
  delete  <name>            Hard-remove the row (auditable rare).

  import [--source <dir>]   Load JSON skill templates from the seed
                            catalog directory (or operator-supplied
                            dir / stdin '-'). Same template shape
                            as a mined skill body; status=operator,
                            source=import.

  export [--name <name>]    Dump skills as NDJSON to stdout. With
                            no --name, dumps everything; with
                            --name, dumps a single skill.

  openai-tools              Print the OpenAI tool-schema dump for
                            all promoted skills (the same JSON
                            /skills/openai-tools serves). Use this
                            to wire Hermes / OpenCode to the
                            catalog from offline scripts.

Fully local: stdlib only (urllib + json + argparse + re + os +
sys + subprocess). Reads/writes Postgres/pgvector via the shared
`mios-db --pg-json` CLI (parameterized $1..$n placeholders bound
out-of-band over the pg v3 extended protocol -- no hand-rolled SQL
escaping, no request data ever spliced into SQL text), and hits
agent-pipe at MIOS_AGENT_PIPE_ENDPOINT for skill runs (so the
firewall / taint chain stays uniform).

SSOT: every knob (min_length, min_support, window_hours,
auto_promote_threshold, ...) reads from MIOS_SKILLS_* env, which
the userenv.sh slot map sources from mios.toml [skills].
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.request

# ─── SSOT env knobs ───────────────────────────────────────────────
# Postgres/pgvector is the sole backend (SurrealDB :8000 retired). All SQL is
# bound out-of-band via the shared mios-db --pg-json CLI: a JSON envelope on
# STDIN ({"sql": "... $1 ...", "params": [...]}) bound over the pg v3 extended
# protocol. No request data is ever spliced into SQL text; table/column names
# are trusted config identifiers and stay inline. INTEGER values (LIMIT,
# interval counts) stay inline via int()-coercion (text->int inference is
# unreliable); only strings/text/vectors are bound.
_MIOS_DB = "/usr/libexec/mios/mios-db"


def _pg_exec(sql: str, params: list | None = None) -> None:
    """Execute a parameterized skill write via mios-db --pg-json. Degrade-open."""
    try:
        subprocess.run(
            [_MIOS_DB, "--pg-json"],
            input=json.dumps({"sql": sql, "params": params or []}),
            capture_output=True, text=True, timeout=15)
    except Exception:  # noqa: BLE001
        pass


def _pg_rows(sql_inner: str, params: list | None = None) -> list:
    """Read rows from pgvector as list[dict] via parameterized mios-db --pg-json.

    `sql_inner` is the inner SELECT (with $1..$n placeholders); it is wrapped in
    json_agg INSIDE the envelope so the values bind out-of-band. Degrade-open ->
    []."""
    try:
        envelope = {
            "sql": (
                "SELECT coalesce(json_agg(row_to_json(t)),'[]') "
                f"FROM ({sql_inner}) t;"),
            "params": params or [],
        }
        out = subprocess.run(
            [_MIOS_DB, "--pg-json"],
            input=json.dumps(envelope),
            capture_output=True, text=True, timeout=15).stdout.strip()
        return json.loads(out) if out else []
    except Exception:  # noqa: BLE001
        return []


AGENT_PIPE_ENDPOINT = os.environ.get(
    "MIOS_AGENT_PIPE_ENDPOINT", "http://localhost:8640/v1",
).rstrip("/")
# Strip the /v1 suffix when calling /skills/* (which lives at the
# service root, not under /v1).
AGENT_PIPE_ROOT = AGENT_PIPE_ENDPOINT[:-3] if AGENT_PIPE_ENDPOINT.endswith("/v1") else AGENT_PIPE_ENDPOINT

# Phase C.2 mining knobs (all SSOT-routed -- see mios.toml [skills]).
MIN_LENGTH = int(os.environ.get("MIOS_SKILLS_MIN_LENGTH", "2"))
MAX_LENGTH = int(os.environ.get("MIOS_SKILLS_MAX_LENGTH", "8"))
MIN_SUPPORT = int(os.environ.get("MIOS_SKILLS_MIN_SUPPORT", "3"))
WINDOW_HOURS = int(os.environ.get("MIOS_SKILLS_WINDOW_HOURS", "168"))
AUTO_PROMOTE_THRESHOLD = float(os.environ.get(
    "MIOS_SKILLS_AUTO_PROMOTE_THRESHOLD", "0.85"))
# P2 outcome-driven promotion gate (operator 2026-06-01): in addition to the
# support/confidence threshold, only auto-promote a skill whose RECENT runs
# actually succeeded. Degrade-open: a skill with fewer than MIN_SUCCESS_SAMPLES
# recorded invocations (incl. brand-new mined skills with NO history) is treated
# as passing -> the gate never blocks a skill purely for lack of data.
MIN_SUCCESS_RATE = float(os.environ.get("MIOS_SKILLS_MIN_SUCCESS_RATE", "0.7") or 0.7)
MIN_SUCCESS_SAMPLES = int(os.environ.get("MIOS_SKILLS_MIN_SUCCESS_SAMPLES", "3") or 3)
SEED_CATALOG_DIR = os.environ.get(
    "MIOS_SKILLS_SEED_CATALOG_DIR", "/usr/share/mios/skills")
LOCAL_CATALOG_DIR = os.environ.get(
    "MIOS_SKILLS_LOCAL_CATALOG_DIR", "/var/lib/mios/skills")


# ── T-049 (GAP-3): hard pass^k skill-promotion gate ───────────────
# Promoting a skill MUTATES the runnable surface every agent in the stack shares,
# so the DGM/tau-bench lesson applies: a candidate must PROVE reliability, not
# merely have passed once. When the gate is ON, `promote` REPLAYS the skill
# through the same /skills/run firewall+taint+audit chokepoint PASS_AND_K_COUNT
# times (a DGM-class self-rewrite, run with --dgm, uses the stricter
# PASS_AND_K_DGM_COUNT) and flips status ONLY IF EVERY replay succeeds; ONE
# failure vetoes. pass^k is tau-bench's worst-case reliability metric ("ALL k
# repeats must succeed"). DEFAULT-OFF -> promote behaves exactly as before, so an
# env with no reachable agent-pipe is unaffected (degrade-open, byte-identical
# without the mios.toml [reliability] edit). When ON the gate is FAIL-CLOSED: an
# unreachable/erroring replay counts as a failed replay (a promotion must be
# PROVEN, not assumed). All knobs SSOT-routed through mios.toml [reliability] via
# userenv.sh (MIOS_RELIABILITY_*); the numeric defaults mirror those TOML values.
def _env_bool(name: str, default: bool) -> bool:
    v = os.environ.get(name)
    if v is None:
        return default
    return str(v).strip().lower() not in ("0", "false", "no", "off", "")


PASS_AND_K_GATE_ENABLED = _env_bool("MIOS_RELIABILITY_GATE_ENABLED", False)
PASS_AND_K_COUNT = int(os.environ.get("MIOS_RELIABILITY_PASS_AND_K_COUNT", "3") or 3)
PASS_AND_K_DGM_COUNT = int(
    os.environ.get("MIOS_RELIABILITY_PASS_AND_K_DGM_COUNT", "5") or 5)


# ─── miner: sequence extraction over tool_call ────────────────────
def _args_shape(args: dict) -> dict:
    """Normalize verb args to a shape signature -- keys + arg types
    matter for grouping, but specific values become $-tokens so the
    mined skill becomes a template the operator can re-use across
    targets. Returns the deduplicated shape dict + a value map for
    later parameterization."""
    shape = {}
    for k, v in sorted((args or {}).items()):
        if isinstance(v, (str, int, float, bool)):
            shape[k] = type(v).__name__
        elif isinstance(v, list):
            shape[k] = "list"
        else:
            shape[k] = "object"
    return shape


def _fetch_recent_tool_calls(hours: int, limit: int = 5000) -> list[dict]:
    """Pull recent successful tool_call rows for mining (Postgres).

    The SurrealQL duration form (`time::now() - {h}h`) silently matched NOTHING
    on pg, so the miner used to see "no tool_call rows" and the training loop
    starved (operator 2026-06-10 "train MiOS AI"). The old emitted-edge
    exclusion was a Surreal graph traversal with no pg analogue -- re-mined
    patterns dedup by name at insert time instead. hours/limit are int()-coerced
    and stay inline (integers don't bind reliably). Degrade-open -> []."""
    try:
        rows = _pg_rows(
            "SELECT id, session_id AS session, ts, tool, args, success "
            "FROM tool_call "
            f"WHERE ts > now() - interval '{int(hours)} hours' "
            "AND (success = true OR success IS NULL) "
            "AND tool NOT LIKE 'agent:%' "  # sub-agent/council fan-out dispatches are not real verb-chains -> not skills
            f"ORDER BY ts ASC LIMIT {int(limit)}")
        for r in rows:
            a = r.get("args")
            if isinstance(a, str):
                try:
                    r["args"] = json.loads(a)
                except Exception:  # noqa: BLE001
                    r["args"] = {}
        return rows
    except Exception:  # noqa: BLE001
        return []


def _group_by_session(rows: list[dict]) -> list[list[dict]]:
    """Bucket tool_call rows by session -- preserves temporal order
    within each session (the rows came back ORDER BY ts ASC)."""
    by_session: dict[str, list[dict]] = {}
    no_session: list[dict] = []
    for row in rows:
        sid = row.get("session")
        if not sid:
            no_session.append(row)
            continue
        key = str(sid)
        by_session.setdefault(key, []).append(row)
    sessions = list(by_session.values())
    # Bucket session-less rows into time-windowed groups of 10 min so
    # they still contribute to mining (rare path; agents that don't
    # tag sessions still produce useful sequences).
    if no_session:
        bucket: list[dict] = []
        last_ts = 0.0
        for row in no_session:
            ts_str = str(row.get("ts", ""))
            try:
                # Postgres returns timestamps as ISO strings.
                t = time.mktime(time.strptime(ts_str[:19], "%Y-%m-%dT%H:%M:%S"))
            except Exception:
                t = last_ts
            if bucket and (t - last_ts) > 600:
                sessions.append(bucket)
                bucket = []
            bucket.append(row)
            last_ts = t
        if bucket:
            sessions.append(bucket)
    return sessions


def _enumerate_ngrams(session: list[dict],
                      n_min: int, n_max: int) -> list[tuple]:
    """Yield contiguous N-grams of (verb, shape-key) pairs across a
    single session. The shape key is JSON of the args-shape so two
    sequences sharing the same verb chain with different concrete
    args still group together (template-level mining)."""
    out: list[tuple] = []
    keys = []
    for row in session:
        verb = row.get("tool") or ""
        shape = _args_shape(row.get("args") or {})
        keys.append((verb, json.dumps(shape, sort_keys=True)))
    for i in range(len(keys)):
        for n in range(n_min, n_max + 1):
            if i + n > len(keys):
                break
            out.append(tuple(keys[i:i + n]))
    return out


def _candidate_summary(rows: list[dict]) -> dict:
    """Build a per-tool example arg-set so the mined skill body has
    actual sample values (the planner uses these as defaults when
    the skill is re-run with no overrides)."""
    examples: dict[str, dict] = {}
    for row in rows:
        verb = row.get("tool") or ""
        args = row.get("args") or {}
        if verb and verb not in examples:
            examples[verb] = args
    return examples


def cmd_mine(args: argparse.Namespace) -> int:
    """Run SPM over tool_call history. Emits candidate skill rows."""
    window = int(args.window) if args.window else WINDOW_HOURS
    min_len = int(args.min_length) if args.min_length else MIN_LENGTH
    max_len = int(args.max_length) if args.max_length else MAX_LENGTH
    min_sup = int(args.min_support) if args.min_support else MIN_SUPPORT

    rows = _fetch_recent_tool_calls(window)
    if not rows:
        sys.stderr.write(
            f"mios-skills: no tool_call rows in last {window}h\n")
        return 0
    sessions = _group_by_session(rows)
    sys.stderr.write(
        f"mios-skills: mining {len(rows)} tool_calls "
        f"across {len(sessions)} session-buckets "
        f"(N in [{min_len},{max_len}], min_support={min_sup})\n")

    # Count N-grams across sessions; track which sessions contributed.
    counts: dict[tuple, int] = {}
    session_witness: dict[tuple, set] = {}
    examples: dict[tuple, dict] = {}
    for sidx, session in enumerate(sessions):
        ngrams = _enumerate_ngrams(session, min_len, max_len)
        seen_in_session: set[tuple] = set()
        for ng in ngrams:
            counts[ng] = counts.get(ng, 0) + 1
            seen_in_session.add(ng)
            if ng not in examples:
                # Find the row run that produced this ngram to lift
                # the concrete arg values as defaults.
                examples[ng] = _candidate_summary(session)
        for ng in seen_in_session:
            session_witness.setdefault(ng, set()).add(sidx)

    # Filter by support + subsume shorter ngrams that always appear
    # as a prefix of a longer one (avoid mining 1-grams when a 4-gram
    # always wraps them).
    survivors: list[tuple] = [
        ng for ng, c in counts.items() if c >= min_sup
    ]
    survivors.sort(key=lambda ng: (-counts[ng], -len(ng)))

    promoted = 0
    skipped_existing = 0
    auto_promoted = 0
    for ng in survivors:
        verbs = [v for v, _ in ng]
        support = counts[ng]
        witness = len(session_witness.get(ng, ()))
        confidence = round(witness / max(1, len(sessions)), 3)
        name = _propose_name(verbs)
        if _skill_exists(name):
            skipped_existing += 1
            continue
        body = _build_body(verbs, examples[ng])
        status = "candidate"
        # P2 outcome gate: AND-fold the skill's recent success rate into the
        # auto-promote decision. Degrade-open -- a freshly-mined skill has no
        # invocation history (it isn't persisted yet), so _skill_success_rate
        # returns (1.0, 0) and the gate is a no-op; it only ever DEMOTES a
        # re-mined skill name whose recorded runs have been failing.
        rate, samples = _skill_success_rate(name)
        if (AUTO_PROMOTE_THRESHOLD > 0.0
                and confidence >= AUTO_PROMOTE_THRESHOLD
                and rate >= MIN_SUCCESS_RATE):
            status = "promoted"
            auto_promoted += 1
        ok = _insert_skill(
            name=name, body=body, support=support,
            confidence=confidence, status=status,
            description=f"mined: {' -> '.join(verbs)}",
        )
        if ok:
            promoted += 1
            sys.stderr.write(
                f"  [+] {name}  support={support}  "
                f"confidence={confidence}  status={status}\n")

    sys.stderr.write(
        f"mios-skills: mined {promoted} new candidate(s); "
        f"{auto_promoted} auto-promoted; "
        f"{skipped_existing} duplicate(s) skipped\n")
    return 0


def _propose_name(verbs: list[str]) -> str:
    """Derive a stable, sluggable name from a verb chain. Pure -- same
    verb list always yields the same name so re-mining is idempotent."""
    return "mined-" + "-".join(v.replace("_", "") for v in verbs)


def _build_body(verbs: list[str], examples: dict) -> dict:
    """Assemble the skill body. Each step gets the sample args lifted
    from the mined session, but string values become $-tokens the
    operator can override at run time."""
    steps = []
    used_params: list[str] = []
    for i, verb in enumerate(verbs):
        ex = examples.get(verb) or {}
        step_args: dict = {}
        for k, v in ex.items():
            if isinstance(v, str) and v:
                token = f"{verb}_{k}"
                # First occurrence of a verb's arg becomes the param;
                # later occurrences re-use the same param name so a
                # repeating verb chain like focus_window -> pc_type ->
                # pc_key -> focus_window gets two "focus_window_title"
                # params unified.
                step_args[k] = f"${token}"
                if token not in used_params:
                    used_params.append(token)
            else:
                step_args[k] = v
        steps.append({"verb": verb, "args": step_args})
    return {"steps": steps, "params": used_params}


def _skill_exists(name: str) -> bool:
    rows = _pg_rows(
        "SELECT id FROM skill WHERE name = $1 LIMIT 1", [name])
    return bool(rows)


def _skill_success_rate(name: str) -> tuple[float, int]:
    """Recent success rate of a skill (looked up by name) from the
    skill_invocation.success field. Returns (rate, samples).

    Degrade-open: (1.0, 0) on ANY error / DB miss / no invocation history ->
    NEVER blocks a skill that simply has no recorded runs yet (incl. a
    brand-new mined skill that doesn't exist in the DB at decision time).

    We first resolve the skill's record id by name, then filter
    skill_invocation rows by that ref within WINDOW_HOURS. The skill id is a
    DB-row value, so it binds out-of-band ($1) like every other external value.
    success may be NULL on still-open rows -> we drop None and only score
    closed invocations. Degrade-open -> (1.0, 0)."""
    try:
        _ir = _pg_rows(
            "SELECT id FROM skill WHERE name = $1 LIMIT 1", [name])
        if not _ir:
            return (1.0, 0)   # not yet persisted / unknown -> don't block
        _sid = _ir[0].get("id")
        if _sid is None:
            return (1.0, 0)
        # WINDOW_HOURS is an int knob -> inline; the skill id binds as a text
        # param ($1) cast to match the skill column type.
        _rows = _pg_rows(
            "SELECT success FROM skill_invocation "
            "WHERE skill::text = $1 "
            f"AND ts > now() - interval '{int(WINDOW_HOURS)} hours'",
            [str(_sid)])
        _vals = [bool(r.get("success")) for r in _rows
                 if isinstance(r, dict) and r.get("success") is not None]
        if len(_vals) < MIN_SUCCESS_SAMPLES:
            return (1.0, len(_vals))   # not enough data -> don't block
        return (sum(1 for v in _vals if v) / len(_vals), len(_vals))
    except Exception:  # noqa: BLE001
        return (1.0, 0)


def _insert_skill(*, name: str, body: dict, support: int,
                  confidence: float, status: str,
                  description: str = "",
                  source: str = "mined") -> bool:
    # support/confidence are numeric knobs -> inline (int/float coercion);
    # name/description/body/source/status are external values -> bound ($1..$5).
    _pg_exec(
        "INSERT INTO skill (name, description, body, source, status, support, "
        "confidence, version, created_at) VALUES ("
        f"$1, $2, $3::jsonb, $4, $5, {int(support)}, {float(confidence)}, "
        "1, now());",
        [name, description, json.dumps(body), source, status])
    return True


# ─── list / show / promote / retire / delete ──────────────────────
def cmd_list(args: argparse.Namespace) -> int:
    where: list[str] = []
    params: list = []
    if args.status and args.status != "all":
        params.append(args.status)
        where.append(f"status = ${len(params)}")
    if args.source and args.source != "all":
        params.append(args.source)
        where.append(f"source = ${len(params)}")
    clause = " AND ".join(where) if where else "true"
    rows = _pg_rows(
        "SELECT name, description, source, status, support, "
        "confidence, version, created_at, last_used_at "
        f"FROM skill WHERE {clause} ORDER BY name", params)
    if args.json:
        print(json.dumps(rows, indent=2, default=str))
        return 0
    if not rows:
        sys.stderr.write("mios-skills: no skills match\n")
        return 0
    # Plain-tabular for grep/awk.
    for row in rows:
        print(
            f"{row.get('name',''):<40}  "
            f"{row.get('status',''):<10}  "
            f"{row.get('source',''):<8}  "
            f"sup={row.get('support',0):<3}  "
            f"conf={row.get('confidence',0.0):<5}  "
            f"v{row.get('version',1)}"
        )
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    rows = _pg_rows(
        "SELECT name, description, body, source, status, "
        "support, confidence, version FROM skill "
        "WHERE name = $1 LIMIT 1", [args.name])
    if not rows:
        sys.stderr.write(f"mios-skills: no skill named {args.name!r}\n")
        return 1
    print(json.dumps(rows[0], indent=2, default=str))
    return 0


def _update_status(name: str, status: str) -> int:
    _pg_exec(
        "UPDATE skill SET status = $1, updated_at = now() WHERE name = $2;",
        [status, name])
    sys.stderr.write(f"mios-skills: {name} -> {status}\n")
    return 0


def _parse_params(param_list) -> dict:
    """Turn a repeatable ``--param key=value`` list into a params dict. Malformed
    entries are skipped with a warning (shared by `run` + the promote gate)."""
    params: dict = {}
    for kv in param_list or []:
        if "=" not in kv:
            sys.stderr.write(
                f"mios-skills: skipping malformed --param {kv!r} "
                f"(expected key=value)\n")
            continue
        k, v = kv.split("=", 1)
        params[k.strip()] = v
    return params


def _post_skill_run(name: str, params: dict, session: str | None) -> dict:
    """POST one skill run to agent-pipe /skills/run and return the parsed result
    envelope (same shape execute_dag/execute_skill return: success, steps[], ...).
    A failed run comes back as HTTP 422 carrying that SAME envelope -> parse it as
    the result, not a transport error. A genuine transport failure (agent-pipe
    unreachable) propagates so the pass^k gate can treat it as a failed replay."""
    payload: dict = {"name": name, "params": params or {}}
    if session:
        payload["session_id"] = session
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        f"{AGENT_PIPE_ROOT}/skills/run",
        data=data, method="POST",
        headers={"Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            return json.loads(r.read())
    except urllib.error.HTTPError as e:
        # 422 (and any 4xx that carries a JSON body) IS the run-result envelope.
        try:
            return json.loads(e.read())
        except Exception:  # noqa: BLE001 -- no parseable body -> a real failure
            raise


def _passk_run_ok(run: dict) -> bool:
    """A single replay PASSES iff the skill run SUCCEEDED and neither the Semantic
    Firewall nor the HITL gate intervened. The top-level success=false already
    captures a FATAL block (a blocked step fails the run); the per-step block flags
    additionally catch a NON-fatal block in a try-each skill that recovered on a
    later step -- a firewall/HITL trip is a reliability red flag even when the skill
    still produced an answer. Reads ONLY structured result fields (no text/keyword
    matching): success + the dispatch-emitted firewall_blocked/hitl_blocked markers."""
    if not isinstance(run, dict) or run.get("success") is not True:
        return False
    for step in run.get("steps") or []:
        if isinstance(step, dict) and (
                step.get("firewall_blocked") or step.get("hitl_blocked")):
            return False
    return True


def _passk_gate(run_once, k: int) -> tuple[bool, int, str]:
    """Replay a skill k times via ``run_once()`` (a 0-arg callable returning the
    /skills/run envelope, or raising when the replay is unreachable). The gate
    PASSES iff EVERY one of the k replays passes _passk_run_ok -- ONE failure vetoes
    (pass^k: ALL k repeats must succeed). Fail-closed: a replay that raises counts
    as a failed replay. All k are attempted so the message can report the true
    success count. Returns (passed, n_ok, human_message)."""
    k = max(1, int(k))
    n_ok = 0
    for _ in range(k):
        try:
            run = run_once()
        except Exception:  # noqa: BLE001 -- unreachable replay = failed replay
            run = None
        if _passk_run_ok(run):
            n_ok += 1
    passed = n_ok >= k
    msg = (f"pass^k gate: {'PASS' if passed else 'FAIL'} "
           f"({n_ok}/{k} succeeded, required {k}/{k})")
    return passed, n_ok, msg


def cmd_promote(args: argparse.Namespace) -> int:
    # T-049 (GAP-3) HARD pass^k gate: when enabled, a promotion must PROVE
    # reliability by replaying the skill k times through the live /skills/run
    # chokepoint -- ALL must succeed or the promotion is vetoed. A DGM-class
    # self-rewrite (--dgm) uses the stricter DGM count. Default-OFF -> the gate is
    # skipped entirely and promote behaves exactly as it always did.
    if PASS_AND_K_GATE_ENABLED:
        k = PASS_AND_K_DGM_COUNT if getattr(args, "dgm", False) else PASS_AND_K_COUNT
        params = _parse_params(getattr(args, "param", None))
        session = getattr(args, "session", None)

        def _run_once() -> dict:
            return _post_skill_run(args.name, params, session)

        passed, _n_ok, msg = _passk_gate(_run_once, k)
        sys.stderr.write(f"mios-skills: {msg}\n")
        if not passed:
            sys.stderr.write(
                f"mios-skills: {args.name} NOT promoted -- pass^k gate vetoed\n")
            return 1
    return _update_status(args.name, "promoted")


def cmd_retire(args: argparse.Namespace) -> int:
    return _update_status(args.name, "retired")


def cmd_reap(args: argparse.Namespace) -> int:
    """P4-full outcome-driven lifecycle: demote PROMOTED skills whose recent
    success rate is below MIN_SUCCESS_RATE (with >= MIN_SUCCESS_SAMPLES runs) back
    to CANDIDATE (re-mineable, not retired -- a bad week shouldn't bury a good
    skill). --apply actually demotes; default is DRY-RUN (logs intended demotions
    so the rate math is confirmed on real data first). Inert until skill_invocation
    outcomes accumulate. operator 2026-06-10."""
    dry = not getattr(args, "apply", False)
    rows = _pg_rows(
        "SELECT name FROM skill WHERE status = 'promoted' ORDER BY name")
    names = [r.get("name") for r in rows if isinstance(r, dict) and r.get("name")]
    demoted = 0
    for nm in names:
        rate, n = _skill_success_rate(nm)
        if n >= MIN_SUCCESS_SAMPLES and rate < MIN_SUCCESS_RATE:
            if dry:
                sys.stderr.write(f"mios-skills: [dry-run] would demote {nm} "
                                 f"(rate={rate:.2f}, n={n}) -> candidate\n")
            else:
                _update_status(nm, "candidate")
            demoted += 1
    print(json.dumps({"ok": True, "reaped": demoted, "dry_run": dry,
                      "checked": len(names)}))
    return 0


def cmd_delete(args: argparse.Namespace) -> int:
    _pg_exec("DELETE FROM skill WHERE name = $1;", [args.name])
    sys.stderr.write(f"mios-skills: deleted {args.name}\n")
    return 0


# ─── run: dispatch a skill via agent-pipe ─────────────────────────
def cmd_run(args: argparse.Namespace) -> int:
    """Run a skill by name via agent-pipe's /skills/run endpoint.
    Going through agent-pipe ensures the firewall + taint chain +
    skill_invocation audit row + tool_call rows all happen the same
    way they do for direct verb dispatch."""
    params = _parse_params(args.param)
    payload = {
        "name": args.name,
        "params": params,
    }
    if args.session:
        payload["session_id"] = args.session
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        f"{AGENT_PIPE_ROOT}/skills/run",
        data=data, method="POST",
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=60) as r:
            body = json.loads(r.read())
    except urllib.error.HTTPError as e:
        sys.stderr.write(
            f"mios-skills: agent-pipe {e.code}: "
            f"{e.read().decode()[:300]}\n")
        return 1
    except Exception as e:
        sys.stderr.write(f"mios-skills: agent-pipe unreachable: {e}\n")
        return 1
    print(json.dumps(body, indent=2, default=str))
    return 0 if body.get("success", False) else 2


# ─── import: load JSON template skills from disk ──────────────────
def cmd_import(args: argparse.Namespace) -> int:
    """Load *.json skill templates. Default source is the seed
    catalog dir + the local catalog dir; --source overrides both."""
    sources: list[str] = []
    if args.source == "-":
        # stdin: one skill JSON per line (NDJSON) or a single JSON
        # object/array.
        raw = sys.stdin.read().strip()
        try:
            parsed = json.loads(raw)
            objs = parsed if isinstance(parsed, list) else [parsed]
        except json.JSONDecodeError:
            objs = []
            for line in raw.splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    objs.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        n = 0
        for obj in objs:
            if _import_one(obj):
                n += 1
        sys.stderr.write(f"mios-skills: imported {n} from stdin\n")
        return 0
    if args.source:
        sources.append(args.source)
    else:
        for d in (SEED_CATALOG_DIR, LOCAL_CATALOG_DIR):
            if os.path.isdir(d):
                sources.append(d)
    n = 0
    for src in sources:
        if not os.path.isdir(src):
            continue
        for name in sorted(os.listdir(src)):
            if not name.endswith(".json"):
                continue
            path = os.path.join(src, name)
            try:
                with open(path, "r", encoding="utf-8") as f:
                    obj = json.load(f)
            except Exception as e:
                sys.stderr.write(
                    f"mios-skills: skipping {path}: {e}\n")
                continue
            if _import_one(obj):
                n += 1
    sys.stderr.write(f"mios-skills: imported {n} template(s)\n")
    return 0


def _import_one(obj: dict) -> bool:
    name = (obj or {}).get("name")
    body = (obj or {}).get("body")
    if not name or not isinstance(body, dict):
        sys.stderr.write(
            f"mios-skills: import skipped (missing name/body): "
            f"{str(obj)[:120]}\n")
        return False
    if _skill_exists(name):
        sys.stderr.write(
            f"mios-skills: import skipped (exists): {name}\n")
        return False
    return _insert_skill(
        name=name,
        description=obj.get("description") or "",
        body=body,
        support=int(obj.get("support") or 0),
        confidence=float(obj.get("confidence") or 0.0),
        status=obj.get("status") or "promoted",
        source=obj.get("source") or "import",
    )


def cmd_export(args: argparse.Namespace) -> int:
    if args.name:
        rows = _pg_rows(
            "SELECT name, description, body, source, status, "
            "support, confidence, version FROM skill "
            "WHERE name = $1 LIMIT 1", [args.name])
    else:
        rows = _pg_rows(
            "SELECT name, description, body, source, status, "
            "support, confidence, version FROM skill ORDER BY name")
    for row in rows:
        print(json.dumps(row, default=str))
    return 0


def _promoted_tools_payload() -> dict:
    """Build the OpenAI tool-schema dump for all promoted skills.
    Shared between cmd_openai_tools (prints to stdout) and
    cmd_export_catalog (writes to the static file every external
    agent reads when agent-pipe HTTP isn't reachable)."""
    rows = _pg_rows(
        "SELECT name, description, body FROM skill "
        "WHERE status = 'promoted' ORDER BY name")
    tools = []
    for row in rows:
        name = row.get("name") or ""
        description = row.get("description") or ""
        body = row.get("body") or {}
        params = body.get("params") or []
        properties = {
            p: {"type": "string",
                "description": f"value for ${p}"} for p in params
        }
        tools.append({
            "type": "function",
            "function": {
                "name": f"mios_skill__{re.sub(r'[^A-Za-z0-9_]', '_', name)}",
                "description": (
                    description or f"MiOS skill {name}"
                ),
                "parameters": {
                    "type": "object",
                    "properties": properties,
                    "required": params,
                },
            },
            "x-mios-skill": name,
        })
    return {"tools": tools, "count": len(tools),
            "generated_at": time.strftime("%Y-%m-%dT%H:%M:%SZ",
                                          time.gmtime())}


def cmd_openai_tools(args: argparse.Namespace) -> int:
    """Print the OpenAI tool-schema dump for all promoted skills.
    Same shape as /skills/openai-tools serves. Use this to wire
    Hermes / OpenCode to the catalog without depending on the
    agent-pipe HTTP service being reachable at the same moment."""
    print(json.dumps(_promoted_tools_payload(), indent=2))
    return 0


def cmd_export_catalog(args: argparse.Namespace) -> int:
    """Materialise the cross-agent catalog file at
    /var/lib/mios/skills/catalog.json. Hermes + OpenCode read this
    in offline / agent-pipe-down deployments where the HTTP surface
    isn't reachable -- the file is the SAME JSON shape /skills/
    openai-tools serves, so client code is identical."""
    target = args.path or os.path.join(LOCAL_CATALOG_DIR, "catalog.json")
    payload = _promoted_tools_payload()
    target_dir = os.path.dirname(target)
    if target_dir:
        try:
            os.makedirs(target_dir, exist_ok=True)
        except PermissionError as e:
            sys.stderr.write(
                f"mios-skills: cannot mkdir {target_dir}: {e}\n")
            return 1
    try:
        # Atomic-write: stage to .new, rename. Avoids partial reads
        # by Hermes mid-write.
        tmp = target + ".new"
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(payload, f, indent=2, default=str)
        os.replace(tmp, target)
    except PermissionError as e:
        sys.stderr.write(
            f"mios-skills: cannot write {target}: {e}\n")
        return 1
    # USER/SYSTEM/AI separation: chgrp to mios-ai + chmod 0640 so
    # every AI agent in the bucket group reads without world-ro.
    # Best-effort -- fails silently when the group doesn't exist
    # (a deployment that doesn't enroll mios-ai yet).
    try:
        import grp
        gid = grp.getgrnam("mios-ai").gr_gid
        os.chown(target, -1, gid)
        os.chmod(target, 0o640)
    except (KeyError, PermissionError, OSError):
        pass
    sys.stderr.write(
        f"mios-skills: exported {payload['count']} promoted skill(s) "
        f"to {target}\n")
    return 0


# ─── argparse wiring ──────────────────────────────────────────────
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="mios-skills",
        description="MiOS Sequential Pattern Mining + skill catalog CLI",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    pm = sub.add_parser("mine", help="run SPM over tool_call history")
    pm.add_argument("--window", help="lookback hours (default from mios.toml)")
    pm.add_argument("--min-length", help="N-gram floor")
    pm.add_argument("--max-length", help="N-gram ceiling")
    pm.add_argument("--min-support", help="frequency floor")
    pm.set_defaults(func=cmd_mine)

    pl = sub.add_parser("list", help="list skill rows")
    pl.add_argument("--status", default="all",
                    choices=["candidate", "promoted", "retired", "all"])
    pl.add_argument("--source", default="all",
                    choices=["mined", "operator", "import", "all"])
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    ps = sub.add_parser("show", help="print skill body JSON")
    ps.add_argument("name")
    ps.set_defaults(func=cmd_show)

    pp = sub.add_parser("promote", help="mark skill runnable")
    pp.add_argument("name")
    # T-049 pass^k gate replay inputs (used only when the gate is enabled):
    pp.add_argument("--param", action="append",
                    help="key=value replay param (repeatable; needed to replay a "
                         "parameterized skill when the pass^k gate is enabled)")
    pp.add_argument("--session", help="session_id for the replay taint chain")
    pp.add_argument("--dgm", action="store_true",
                    help="DGM-class self-rewrite: use the stricter pass_and_k_dgm_count")
    pp.set_defaults(func=cmd_promote)

    pr = sub.add_parser("retire", help="hide skill from runners")
    pr.add_argument("name")
    pr.set_defaults(func=cmd_retire)

    prp = sub.add_parser("reap",
                         help="demote promoted skills below the success floor (dry-run default)")
    prp.add_argument("--apply", action="store_true",
                     help="actually demote (default: dry-run, logs only)")
    prp.set_defaults(func=cmd_reap)

    pd = sub.add_parser("delete", help="hard-remove skill row")
    pd.add_argument("name")
    pd.set_defaults(func=cmd_delete)

    pn = sub.add_parser("run", help="dispatch a skill via agent-pipe")
    pn.add_argument("name")
    pn.add_argument("--param", action="append",
                    help="key=value (repeatable)")
    pn.add_argument("--session", help="session_id for taint chain")
    pn.set_defaults(func=cmd_run)

    pi = sub.add_parser("import", help="load JSON template skills")
    pi.add_argument("--source",
                    help="directory or '-' for stdin NDJSON")
    pi.set_defaults(func=cmd_import)

    pe = sub.add_parser("export", help="dump skill rows as NDJSON")
    pe.add_argument("--name", help="restrict to one skill")
    pe.set_defaults(func=cmd_export)

    po = sub.add_parser("openai-tools",
                        help="dump OpenAI tool schemas for promoted skills")
    po.set_defaults(func=cmd_openai_tools)

    pc = sub.add_parser("export-catalog",
                        help="materialise catalog.json for offline agents")
    pc.add_argument("--path",
                    help="override target (default: "
                         "<local_catalog_dir>/catalog.json)")
    pc.set_defaults(func=cmd_export_catalog)

    return p


def main(argv: list[str] = None) -> int:
    p = build_parser()
    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
