# AI-hint: GENERATED Quadlet container 'mios-webtools-firecrawl-api' (WS-7 pods-as-SSOT). DO NOT EDIT -- regenerate via tools/generate-pod-quadlets.py from [containers.mios-webtools-firecrawl-api] in mios.toml.
# /usr/share/containers/systemd/mios-webtools-firecrawl-api.container

[Unit]
After=mios-webtools-redis.service mios-webtools-firstboot.service
Description='MiOS' web-tools firecrawl API (v1.0.0, self-host no-auth)
Wants=mios-webtools-redis.service

[Container]
AutoUpdate=local
ContainerName=mios-webtools-firecrawl-api
Environment=REDIS_URL=redis://127.0.0.1:6380
Environment=REDIS_RATE_LIMIT_URL=redis://127.0.0.1:6380
Environment=HOST=127.0.0.1
Environment=PORT=${MIOS_PORT_FIRECRAWL}
Environment=USE_DB_AUTHENTICATION=false
Environment=NUM_WORKERS_PER_QUEUE=2
Environment=PLAYWRIGHT_MICROSERVICE_URL=
Environment=PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
Environment=BULL_AUTH_KEY=mios
Environment=LOGGING_LEVEL=INFO
Environment=NODE_ENV=production
Exec=pnpm run start:production
Group=0
Image=localhost/mios-firecrawl:v1.0.0
Label=org.opencontainers.image.title=mios-webtools-firecrawl-api
Label=io.podman_desktop.openInBrowser=http://localhost:3002/
Pod=mios-webtools.pod
User=0
WorkingDir=/app

[Install]
WantedBy=multi-user.target default.target

[Service]
Delegate=yes
EnvironmentFile=/etc/mios/install.env
Restart=on-failure
RestartSec=10s
TimeoutStartSec=180s
