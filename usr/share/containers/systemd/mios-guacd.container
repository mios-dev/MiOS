# /usr/share/containers/systemd/mios-guacd.container

[Unit]
After=network-online.target mios-webtools-firstboot.service
ConditionVirtualization=!container
Description='MiOS' Apache Guacamole Daemon
Wants=network-online.target

[Container]
ContainerName=mios-guacd
Exec=guacd -b 0.0.0.0 -f
Group=811
Image=docker.io/guacamole/guacd:latest
Pod=mios-system.pod
User=811

[Install]
WantedBy=multi-user.target default.target

[Service]
Delegate=yes
Restart=on-failure
RestartSec=10
