[Unit]
Description=MiOS PXE Boot Hub
After=network-online.target
Wants=network-online.target

[Container]
Image=quay.io/poseidon/matchbox:latest
Network=mios.network
AutoUpdate=registry
User=mios-pxe-hub
Group=mios-pxe-hub

[Service]
Restart=on-failure
RestartSec=10
Delegate=yes

[Install]
WantedBy=multi-user.target default.target
