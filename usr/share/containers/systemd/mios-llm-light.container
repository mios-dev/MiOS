# AI-hint: GENERATED Quadlet container 'mios-llm-light' (WS-7 pods-as-SSOT). DO NOT EDIT -- regenerate via tools/generate-pod-quadlets.py from [containers.mios-llm-light] in mios.toml.
# /usr/share/containers/systemd/mios-llm-light.container

[Unit]
After=network-online.target
ConditionPathExists=/usr/share/mios/llamacpp/models/.ready
Description='MiOS' LLM-Light (llama.cpp multi-model + KV-paging lane, served via the upstream llama-swap proxy, FOSS)
Wants=network-online.target

[Container]
AddDevice=${MIOS_GPU_DEVICE:-nvidia.com/gpu=all}
ContainerName=mios-llm-light
Entrypoint=/app/llama-swap
Environment=HOME=/var/lib/mios/llamacpp
Environment=LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/cuda/lib64
EnvironmentFile=/etc/mios/install.env
Exec=--config /app/config.yaml --listen 0.0.0.0:${MIOS_PORT_LLM_LIGHT:-11450}
Group=${MIOS_LLAMACPP_GID:-827}
Image=${MIOS_LLM_LIGHT_IMAGE:-ghcr.io/mostlygeek/llama-swap:cuda}
Label=org.opencontainers.image.title=mios-llm-light
Label=org.opencontainers.image.documentation=https://github.com/mostlygeek/llama-swap
Pod=mios-ai.pod
User=${MIOS_LLAMACPP_UID:-827}
Volume=/usr/share/mios/llamacpp/models:/models:ro,Z
Volume=/usr/share/mios/llamacpp/mios-llm-light.yaml:/app/config.yaml:ro,Z
Volume=${MIOS_LLAMACPP_SLOT_DIR:-/var/lib/mios/llamacpp/slots}:${MIOS_LLAMACPP_SLOT_DIR:-/var/lib/mios/llamacpp/slots}:Z

[Install]
WantedBy=multi-user.target default.target

[Service]
Delegate=yes
Restart=on-failure
RestartSec=10s
TimeoutStartSec=180s
