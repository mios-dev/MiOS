# AI-hint: GENERATED Quadlet container 'mios-llm-heavy-alt' (WS-7 pods-as-SSOT). DO NOT EDIT -- regenerate via tools/generate-pod-quadlets.py from [containers.mios-llm-heavy-alt] in mios.toml.
# /usr/share/containers/systemd/mios-llm-heavy-alt.container

[Unit]
After=network-online.target mios-cdi-detect.service
ConditionPathExists=/usr/share/mios/vllm/model/config.json
Description='MiOS' SGLang heavy lane (OpenAI /v1, HiCache CPU KV-offload; gated)
Wants=network-online.target

[Container]
AddDevice=nvidia.com/gpu=all
ContainerName=mios-llm-heavy-alt
Environment=HF_HUB_OFFLINE=1
Environment=TRANSFORMERS_OFFLINE=1
Environment=DO_NOT_TRACK=1
Environment=HF_HOME=/tmp/.cache
Environment=XDG_CACHE_HOME=/tmp/.cache
Environment=GLOO_SOCKET_IFNAME=lo
Environment=NCCL_SOCKET_IFNAME=lo
Environment=HOME=/tmp
Exec=--model /models --served-model-name mios-heavy --host 0.0.0.0 --port ${MIOS_PORT_SGLANG} --mem-fraction-static 0.85 --max-model-len 262144 --kv-cache-dtype fp8 --tool-call-parser qwen25 --enable-hierarchical-cache --enable-unified-radix-tree
Group=815
Image=mios-llm-heavy-alt.image
Label=org.opencontainers.image.title=mios-llm-heavy-alt
Label=org.opencontainers.image.url=http://localhost:11442/v1/models
Label=io.podman_desktop.openInBrowser=http://localhost:11442/v1/models
Pod=mios-ai.pod
User=815
Volume=/usr/share/mios/vllm/model:/models:ro,Z

[Install]
WantedBy=multi-user.target default.target

[Service]
Delegate=yes
EnvironmentFile=/etc/mios/install.env
Restart=on-failure
RestartSec=15
TimeoutStartSec=600s
