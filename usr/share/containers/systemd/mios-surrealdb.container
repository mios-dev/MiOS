# AI-hint: Systemd unit file defining the SurrealDB container to serve as the unified multi-model (graph, vector, KV) "context layer" and single source of truth for cross-agent state and shared data.
# AI-related: /etc/mios/mios.toml, mios-surrealdb, mios-ceph, mios-services, mios-daemon, network-online.target, multi-user.target, default.target, localhost:8000, localhost:8080
# /etc/containers/systemd/mios-surrealdb.container
# 'MiOS' shared agent state DB. Operator directive 2026-05-18:
# "dont we need a true db services(container) to host local DBs(!!?)"
# + "wouldn't all this just be AI fabrications and hallucinations
# otherwise??!" -- yes. Cross-agent state was scattered across
# isolated SQLite files (owui/webui.db, hermes/state.db,
# hermes/kanban.db, hermes/response_store.db) + JSON scratchpads;
# nothing the agents could query in lockstep for ground truth.
#
# SurrealDB 3.0 picked over pgvector/Qdrant/SQLite-per-component for:
#   * multi-model: doc + graph + KV + vector + time-series in ONE
#     ACID engine (no separate Neo4j / Redis / Postgres / Chroma to
#     run alongside)
#   * single Rust binary, sub-100MB image, sub-second cold start
#   * explicit "context layer for AI agents" upstream framing
#   * production refs (Samsung / Verizon / Tencent per 2026 docs)
#   * OpenAI-friendly: SurrealQL + REST + WebSocket; tool_call
#     args map to record IDs cleanly
#
# Day-0 / bootc: data persists under /var/lib/mios/surrealdb/
# (created by usr/lib/tmpfiles.d/mios-surrealdb.conf at boot);
# image is OCI-published surrealdb/surrealdb:latest; no /etc writes
# required for the default config.

[Unit]
Description='MiOS' SurrealDB (shared agent state -- context layer for AI agents)
After=network-online.target
Wants=network-online.target

[Container]
# Image / Port / Network / User placeholders rendered by automation/15-render-quadlets.sh.
# The SSOT is mios.toml: [image.sidecars].surrealdb, [ports].surrealdb,
# [services.surrealdb].{uid,gid}, [surrealdb].{user,pass,backend,data_dir}.
Image=${MIOS_SURREALDB_IMAGE:-docker.io/surrealdb/surrealdb:latest}
ContainerName=mios-surrealdb
# Host networking, matching ollama's pattern. Bridge networks +
# PublishPort hit a podman-WSL port-forwarder quirk where host:8000
# wasn't binding even though `podman port` reported the mapping.
# Host-net is fine for an infrastructure service (no isolation
# loss that matters at the loopback layer) and gives every MiOS
# AI surface a reliable http://localhost:8000 -- mirroring the
# README rule for the inference endpoint at localhost:8080/v1.
Network=host

# Persistent data dir. SurrealDB writes the surrealkv:// store here;
# durability survives container restarts + image upgrades. Path
# resolved from [surrealdb].data_dir in mios.toml.
Volume=${MIOS_DB_DATA_DIR:-/var/lib/mios/surrealdb}:${MIOS_DB_DATA_DIR:-/var/lib/mios/surrealdb}:Z

# Identity from mios.toml [services.surrealdb] (uid 821 -- 819
# reserved for mios-ceph; pinned in usr/lib/sysusers.d/50-mios-services.conf
# alongside the rest of the 810-829 service-account range). Matches
# the chown of the data dir done by usr/lib/tmpfiles.d/mios-surrealdb.conf.
User=${MIOS_SURREALDB_UID:-821}
Group=${MIOS_SURREALDB_GID:-821}

# Default root credentials -- LOCAL-ONLY. Loopback-bound via PublishPort
# (or host-net here); operator overrides creds via [surrealdb].user/pass
# in /etc/mios/mios.toml or a Quadlet drop-in. For Day-0 self-host the
# local-only defaults match every other MiOS service.
Environment=SURREAL_USER=${MIOS_DB_USER:-root}
Environment=SURREAL_PASS=${MIOS_DB_PASS:-root}
Environment=SURREAL_LOG=info

# Bind 0.0.0.0:<port> so both host (operator + pipe + mios-daemon) AND
# the mios.network bridge (containers, future agents) reach the same endpoint.
# Port from [ports].surrealdb; backend uri from [surrealdb].backend
# (SurrealDB 3.0+ uses `surrealkv:` -- the legacy `file:` scheme was
# dropped; single-file on-disk durability under data_dir/mios.skv).
Exec=start --bind 0.0.0.0:${MIOS_PORT_SURREALDB:-8000} --user ${MIOS_DB_USER:-root} --pass ${MIOS_DB_PASS:-root} ${MIOS_DB_BACKEND:-surrealkv:///var/lib/mios/surrealdb/mios.skv}

# OCI labels for Podman Desktop browse-in-browser.
Label=org.opencontainers.image.title=mios-surrealdb
Label=org.opencontainers.image.url=http://localhost:8000/
Label=org.opencontainers.image.documentation=https://surrealdb.com/docs
Label=io.podman_desktop.openInBrowser=http://localhost:8000/

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=120s
Delegate=yes

[Install]
WantedBy=multi-user.target default.target
