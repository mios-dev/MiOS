# AI-hint: Quadlet configuration for the mios-llm-light container on Windows, providing a GPU-accelerated multi-model inference backend for the MiOS Hermes node via host networking and CDI passthrough on port 11450.
# AI-related: mios-llm-light, mios-ai-node, mios-win, network-online.target, multi-user.target, default.target, localhost:11450

[Unit]
Description=MiOS LLM Light Server (Windows AI Node — GPU/CPU lane)
After=network-online.target
Wants=network-online.target
ConditionPathExists=/var/lib/mios/llamacpp/models/.ready

[Container]
Image=ghcr.io/mostlygeek/llama-swap:cuda
ContainerName=mios-llm-light
Network=host
AddDevice=nvidia.com/gpu=all

# Volumes mapping to local FHS paths
Volume=/var/lib/mios/llamacpp/models:/models:ro,Z
Volume=/var/lib/mios/llamacpp/mios-llm-light.yaml:/app/config.yaml:ro,Z
Volume=/var/lib/mios/llamacpp/slots:/var/lib/mios/llamacpp/slots:Z

Environment=HOME=/var/lib/mios/llamacpp
Environment=LD_LIBRARY_PATH=/usr/lib/wsl/lib:/usr/local/cuda/lib64
Entrypoint=/app/llama-swap
Exec=--config /app/config.yaml --listen 0.0.0.0:11450

Label=org.opencontainers.image.title=mios-llm-light
Label=org.opencontainers.image.url=http://localhost:11450/
Label=io.podman_desktop.openInBrowser=http://localhost:11450/

[Service]
Restart=on-failure
RestartSec=10
Delegate=yes

[Install]
WantedBy=multi-user.target default.target
