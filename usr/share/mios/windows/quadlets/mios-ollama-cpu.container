# mios-ollama-cpu.container -- Windows AI Node variant
# CPU light-lane: micro-LLMs + embeddings.  Port :11435.
# Mirrors usr/share/containers/systemd/mios-ollama-cpu.container.
# Shares the model store with mios-ollama so pulled models are visible
# to both instances without duplication.

[Unit]
Description=MiOS Ollama CPU Light Lane (Windows AI Node)
After=network-online.target

[Container]
Image=docker.io/ollama/ollama:latest
ContainerName=mios-ollama-cpu
# Host networking -- avoids the WSL2 port-forwarder quirk where a bridge
# + PublishPort binding never reliably surfaces on the host interface.
# Matches the mios-ollama-cpu pattern on MiOS-DEV.
Network=host
AutoUpdate=registry

# CPU-only -- no AddDevice.  Keeps the dGPU fully available for mios-ollama.
Environment=OLLAMA_HOST=0.0.0.0:11435
Environment=OLLAMA_ORIGINS=*
# Shared model store with the GPU instance.
Environment=OLLAMA_MODELS=/var/lib/ollama/models
Environment=HOME=/var/lib/ollama-cpu
Environment=OLLAMA_NUM_PARALLEL=4
Environment=OLLAMA_MAX_LOADED_MODELS=4

Volume=/var/lib/ollama:/var/lib/ollama:Z
Volume=/var/lib/ollama-cpu:/var/lib/ollama-cpu:Z

Label=org.opencontainers.image.title=mios-ollama-cpu
Label=org.opencontainers.image.url=http://localhost:11435/

[Service]
Restart=on-failure
RestartSec=10
Delegate=yes

[Install]
WantedBy=multi-user.target default.target
