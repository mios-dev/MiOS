{
    // Windows Terminal user settings MiOS must preserve wholesale. The MiOS
    // json-merge owns ONLY the "MiOS" scheme (array-merge-by-key on the top-level
    // `schemes` array) + profiles.defaults.colorScheme; every OTHER key -- the
    // operator's foreign top-level keys AND their own "Campbell" scheme -- must
    // survive. This JSONC base exercises line comments and a `//` inside a string
    // value (the docs URL), which the string-aware JSONC strip must not mangle.
    "$help": "https://aka.ms/terminal-documentation",
    "copyOnSelect": true,
    "launchMode": "maximized",
    "profiles": {
        "defaults": {
            "font": {
                "face": "Cascadia Code"
            }
        },
        "list": [
            {
                "commandline": "pwsh.exe",
                "name": "PowerShell"
            }
        ]
    },
    "schemes": [
        {
            "name": "Campbell",
            "background": "#0C0C0C",
            "foreground": "#CCCCCC",
            "black": "#0C0C0C",
            "red": "#C50F1F",
            "green": "#13A10E",
            "yellow": "#C19C00",
            "blue": "#0037DA",
            "purple": "#881798",
            "cyan": "#3A96DD",
            "white": "#CCCCCC",
            "brightBlack": "#767676",
            "brightRed": "#E74856",
            "brightGreen": "#16C60C",
            "brightYellow": "#F9F1A5",
            "brightBlue": "#3B78FF",
            "brightPurple": "#B4009E",
            "brightCyan": "#61D6D6",
            "brightWhite": "#F2F2F2"
        }
    ]
}
