{
    "control":[
        { "VTOY_DEFAULT_MENU_MODE": "0" },
        { "VTOY_TREE_VIEW_MENU_STYLE": "1" },
        { "VTOY_DEFAULT_SEARCH_ROOT": "/" },
        { "VTOY_WIN11_BYPASS_CHECK": "1" },
        { "VTOY_LINUX_REMOUNT": "1" },
        { "VTOY_SECONDARY_BOOT_MENU": "1" }
    ],
    "theme":{
        "file": "/ventoy/theme/uefi/theme.txt",
        "gfxmode": "1920x1080,1280x1024,1024x768",
        "ventoy_left": "5%",
        "ventoy_top": "0%",
        "ventoy_color": "#F35C15"
    },
    "theme_legacy":{
        "file": "/ventoy/theme/legacy/theme.txt",
        "gfxmode": "1024x768",
        "ventoy_left": "5%",
        "ventoy_top": "0",
        "ventoy_color": "#1A407F"
    },
    "theme_uefi":{
        "file": "/ventoy/theme/uefi/theme.txt",
        "gfxmode": "1920x1080,1280x1024,1024x768",
        "ventoy_left": "5%",
        "ventoy_top": "0%",
        "ventoy_color": "#F35C15"
    },
    "menu_alias": [
        { "image": "/MiOS-PE/MiOS_PE.wim", "alias": "MiOS-PE Mini Windows (Rescue & Recovery Suite)" },
        { "image": "/Live_Operating_Systems/MiOS-Live-Chat.iso", "alias": "MiOS Live-Chat AI (Ephemeral Live System)" },
        { "image": "/Live_Operating_Systems/Fedora-Server.iso", "alias": "Deploy MiOS Linux (Fedora Server + MiOS Overlay)" },
        { "image": "/Live_Operating_Systems/MiOS-Xbox.iso", "alias": "Deploy MiOS-Xbox (Windows Gaming Edition - CompactOS)" },
        { "image": "/Live_Operating_Systems/Mini_Windows/MiOS_PE.wim", "alias": "MiOS-PE Mini Windows (Live Rescue & Imaging Environment)" },
        { "image": "/Live_Operating_Systems/Mini_Windows/10.Win10PE.wim", "alias": "MiOS-PE Windows 10 Live Environment (Mini Windows)" },
        { "image": "/Live_Operating_Systems/Mini_Windows/11.Win11PE.wim", "alias": "MiOS-PE Windows 11 Live Environment (Mini Windows)" },
        { "image": "/Live_Operating_Systems/MiOS_PE.wim", "alias": "MiOS-PE Mini Windows (Live Environment)" },
        { "image": "/Live_Operating_Systems/SystemRescue/SystemRescue.iso", "alias": "SystemRescue Arch Linux (Diagnostics & Disk Tools)" }
    ],
    "menu_class": [
        { "key": "MiOS-PE", "class": "windows" },
        { "key": "MiOS-Live-Chat", "class": "linux" },
        { "key": "Fedora", "class": "fedora" },
        { "key": "MiOS-Xbox", "class": "windows" },
        { "key": "MiOS_PE", "class": "windows" },
        { "key": "Win10PE", "class": "windows" },
        { "key": "Win11PE", "class": "windows" },
        { "key": "Mini_Windows", "class": "windows" },
        { "key": "SystemRescue", "class": "arch" }
    ],
    "conf_replace_legacy":[
        {
            "iso": "/Live_Operating_Systems/SystemRescue/SystemRescue.iso",
            "org": "/sysresccd/boot/syslinux/sysresccd_sys.cfg",
            "new": "/ventoy/sysrescue_syslinux.cfg"
        }
    ],
    "conf_replace_uefi":[
        {
            "iso": "/Live_Operating_Systems/SystemRescue/SystemRescue.iso",
            "org": "/boot/grub/grubsrcd.cfg",
            "new": "/ventoy/sysrescue_grub.cfg"
        }
    ],
    "kickstart":[
        {
            "image": "/Live_Operating_Systems/Fedora-Server.iso",
            "template": "/ventoy/mios-kickstart.cfg"
        }
    ]
}
