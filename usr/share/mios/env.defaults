# /usr/share/mios/env.defaults — Vendor environment defaults.
#
# Resolution order (first non-empty wins, sourced by /etc/profile.d/mios-env.sh):
#   1. ~/.config/mios/env                  per-user
#   2. /etc/mios/install.env               host (written by bootstrap install.sh)
#   3. /etc/mios/env.d/*.env               admin/distro drop-ins (alphabetical)
#   4. /usr/share/mios/env.defaults        vendor defaults (THIS FILE)
#
# Legacy: a `.env.mios` placed in $HOME by mios-bootstrap is sourced before
# this file for backwards compatibility, but is deprecated. New installs
# write to /etc/mios/install.env.

# Account convention.
MIOS_DEFAULT_USER="mios"
MIOS_DEFAULT_HOST="mios"

# Inference (LAW 5: localhost OpenAI-compatible only).
MIOS_AI_ENDPOINT="http://localhost:8080/v1"
MIOS_AI_MODEL="default"

# Image / branch metadata.
MIOS_REPO_URL="https://github.com/mios-dev/mios"
MIOS_BOOTSTRAP_REPO_URL="https://github.com/mios-dev/mios-bootstrap"
MIOS_IMAGE_NAME="ghcr.io/mios-dev/mios"
MIOS_IMAGE_TAG="latest"
MIOS_BRANCH="main"

# Build-side defaults read by Justfile.
MIOS_BASE_IMAGE="ghcr.io/ublue-os/ucore-hci:stable-nvidia"
MIOS_LOCAL_TAG="localhost/mios:latest"
MIOS_BIB_IMAGE="quay.io/centos-bootc/bootc-image-builder:latest"
