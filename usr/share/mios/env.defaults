# /usr/share/mios/env.defaults -- MiOS vendor environment defaults.
#
# Resolution order (first non-empty wins):
#   1. ~/.config/mios/env              per-user
#   2. /etc/mios/install.env           host (written by bootstrap)
#   3. /etc/mios/env.d/*.env           admin drop-ins (alphabetical)
#   4. /usr/share/mios/env.defaults    vendor defaults (THIS FILE)
#
# All MIOS_* variables defined here are the single authoritative source.
# To change a version, port, path, or default -- edit this file.
# Scripts source this file; do not hardcode these values elsewhere.

# ── Identity ──────────────────────────────────────────────────────────────────
MIOS_VERSION="0.2.4"
MIOS_DEFAULT_USER="mios"
MIOS_DEFAULT_HOST="mios"
MIOS_DEFAULT_SHELL="/bin/bash"
MIOS_DEFAULT_GROUPS="wheel,libvirt,kvm,video,render,input,dialout,docker"
MIOS_DEFAULT_TIMEZONE="UTC"
MIOS_DEFAULT_LOCALE="en_US.UTF-8"
MIOS_DEFAULT_KEYBOARD="us"

# ── Repos & image refs ────────────────────────────────────────────────────────
MIOS_REPO_URL="https://github.com/mios-dev/mios"
MIOS_BOOTSTRAP_REPO_URL="https://github.com/mios-dev/mios-bootstrap"
MIOS_IMAGE_NAME="ghcr.io/mios-dev/mios"
MIOS_IMAGE_TAG="latest"
MIOS_IMAGE_REF="ghcr.io/mios-dev/mios:latest"
MIOS_BRANCH="main"

# ── Base + builder images ─────────────────────────────────────────────────────
MIOS_BASE_IMAGE="ghcr.io/ublue-os/ucore-hci:stable-nvidia"
MIOS_LOCAL_TAG="localhost/mios:latest"
MIOS_BIB_IMAGE="quay.io/centos-bootc/bootc-image-builder:latest"
MIOS_BIB_ALPINE_IMAGE="docker.io/library/alpine:latest"

# ── Sidecar container versions ────────────────────────────────────────────────
# Change these values to update sidecar images system-wide.
MIOS_LOCALAI_VERSION="v2.20.0"
MIOS_LOCALAI_IMAGE="localai/localai:v2.20.0"
MIOS_K3S_VERSION="v1.32.1-k3s1"
MIOS_K3S_IMAGE="rancher/k3s:v1.32.1-k3s1"
MIOS_CEPH_VERSION="v19"
MIOS_CEPH_IMAGE="quay.io/ceph/ceph:v19"
MIOS_FORGE_VERSION="12"
MIOS_FORGE_IMAGE="codeberg.org/forgejo/forgejo:12"
MIOS_FORGE_HTTP_PORT="3000"
MIOS_FORGE_SSH_PORT="2222"
MIOS_SEARXNG_VERSION="latest"
MIOS_SEARXNG_IMAGE="docker.io/searxng/searxng:latest"
MIOS_SEARXNG_PORT="8888"
MIOS_SEARXNG_USER="mios-searxng"
MIOS_SEARXNG_UID="818"
MIOS_SEARXNG_GID="818"

# ── AI inference (LAW 5: localhost OpenAI-compatible only) ────────────────────
# Default model set researched for the 12 GB system-RAM workstation
# baseline (CPU-only inference, ~8 GB available to the model):
#   qwen2.5-coder:7b   primary chat/code (Q4_K_M ~4.7 GB on disk)
#   nomic-embed-text   embeddings (~270 MB)
# Both are baked into /usr/share/ollama/models at build time by
# automation/37-ollama-prep.sh (override with MIOS_OLLAMA_BAKE_MODELS).
# See [ai] in /usr/share/mios/mios.toml for the canonical reference and
# the override semantics.
MIOS_AI_ENDPOINT="http://localhost:8080/v1"
MIOS_AI_MODEL="qwen2.5-coder:7b"
MIOS_AI_EMBED_MODEL="nomic-embed-text"
MIOS_AI_KEY=""
MIOS_AI_PORT="8080"
MIOS_AI_BAKE_MODELS="qwen2.5-coder:7b,nomic-embed-text"
MIOS_AI_RAM_FLOOR_GB="12"
MIOS_AI_SEED_DIR="/usr/share/ollama/models"
MIOS_AI_RUNTIME_DIR="/var/lib/ollama/models"

# ── Network ───────────────────────────────────────────────────────────────────
MIOS_QUADLET_NETWORK="mios.network"
MIOS_QUADLET_SUBNET="10.89.0.0/24"
MIOS_SSH_PORT="22"
MIOS_COCKPIT_PORT="9090"
MIOS_K3S_API_PORT="6443"
MIOS_FIREWALLD_ZONE="drop"

# ── Runtime paths ─────────────────────────────────────────────────────────────
MIOS_AI_DIR="/usr/share/mios/ai"
MIOS_AI_MODELS_DIR="/srv/ai/models"
MIOS_AI_MCP_DIR="/srv/ai/mcp"
MIOS_AI_SCRATCH_DIR="/var/lib/mios/ai/scratch"
MIOS_AI_MEMORY_DIR="/var/lib/mios/ai/memory"
MIOS_AI_JOURNAL="/var/lib/mios/ai/journal.md"
MIOS_INSTALL_ENV="/etc/mios/install.env"
MIOS_PROFILE_TOML_VENDOR="/usr/share/mios/profile.toml"
MIOS_PROFILE_TOML_HOST="/etc/mios/profile.toml"
MIOS_WSLBOOT_DONE="/var/lib/mios/.wsl-firstboot-done"

# ── Build configuration ───────────────────────────────────────────────────────
MIOS_RECHUNK_MAX_LAYERS="67"
# SSOT for [packages.<section>].pkgs and every other build/runtime knob.
# As of 2026-05-05 the legacy PACKAGES.md fenced-block manifest is removed
# from the runtime path; mios.toml is the only source consulted by
# automation/lib/packages.sh. PACKAGES.md remains under
# usr/share/doc/mios/reference/ as human-readable documentation only.
MIOS_TOML="/usr/share/mios/mios.toml"

# ── WSL2 / Windows installer ──────────────────────────────────────────────────
MIOS_WSL_DISTRO="MiOS"
MIOS_BUILDER_DISTRO="MiOS-DEV"
# Dedicated host partition for MiOS-DEV. The Windows installer shrinks C: by
# MIOS_DATA_DISK_MB and creates an NTFS partition (label MIOS-DEV) on
# MIOS_DATA_DISK_LETTER, then junctions %LOCALAPPDATA%\containers\podman\machine
# onto it BEFORE `podman machine init` so the VHDX (which carries the dev VM's
# ext4 root) is born on the new drive. Set MIOS_SKIP_DATA_DISK=1 to disable.
MIOS_DATA_DISK_MB="262144"
MIOS_DATA_DISK_LETTER="M"
MIOS_SKIP_DATA_DISK=""
