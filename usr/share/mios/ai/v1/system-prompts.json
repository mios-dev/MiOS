{
  "object": "mios.system-prompts.registry",
  "version": "v1",
  "manifest_path": "/usr/share/mios/ai/v1/system-prompts.json",
  "endpoint": "http://localhost:8642/v1",
  "served_by": "mios-hermes.container",
  "resolution_order": [
    "${MIOS_AI_SYSTEM_PROMPT}",
    "~/.config/mios/system-prompt.md",
    "/etc/mios/ai/system-prompt.md",
    "/usr/share/mios/ai/system.md"
  ],
  "data": [
    {
      "name": "system",
      "role": "default-agent-prompt",
      "path": "/usr/share/mios/ai/system.md",
      "scope": "vendor",
      "precedence": 4
    },
    {
      "name": "audit",
      "role": "read-only-audit-mode",
      "path": "/usr/share/mios/ai/audit-prompt.md",
      "scope": "vendor",
      "swap_for": "system"
    },
    {
      "name": "engineer",
      "role": "engineering-task-prompt",
      "path": "/etc/mios/system-prompts/mios-engineer.md",
      "scope": "host",
      "swap_for": "system"
    },
    {
      "name": "reviewer",
      "role": "code-review-prompt",
      "path": "/etc/mios/system-prompts/mios-reviewer.md",
      "scope": "host",
      "swap_for": "system"
    },
    {
      "name": "troubleshoot",
      "role": "diagnostic-prompt",
      "path": "/etc/mios/system-prompts/mios-troubleshoot.md",
      "scope": "host",
      "swap_for": "system"
    }
  ]
}
