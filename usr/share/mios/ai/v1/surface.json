{
  "object": "mios.api.surface",
  "version": "v1",
  "spec_ref": "https://platform.openai.com/docs/api-reference",
  "manifest_path": "/usr/share/mios/ai/v1/surface.json",
  "base_url": "http://localhost:8642/v1",
  "served_by": "mios-hermes.container",
  "backed_by": "ollama.container",
  "auth": {
    "scheme": "Bearer",
    "header": "Authorization",
    "env": "MIOS_AI_KEY",
    "source": "/etc/mios/hermes/api.env"
  },
  "groups": [
    {
      "name": "Models",
      "endpoints": [
        {"method": "GET",  "path": "/v1/models",         "spec_ref": "https://platform.openai.com/docs/api-reference/models/list",     "manifest": "/usr/share/mios/ai/v1/models.json"},
        {"method": "GET",  "path": "/v1/models/{model}", "spec_ref": "https://platform.openai.com/docs/api-reference/models/retrieve"}
      ]
    },
    {
      "name": "Chat Completions",
      "endpoints": [
        {"method": "POST", "path": "/v1/chat/completions", "spec_ref": "https://platform.openai.com/docs/api-reference/chat/create", "streaming": true, "tools": true, "json_mode": true, "json_schema": true}
      ]
    },
    {
      "name": "Completions (legacy)",
      "endpoints": [
        {"method": "POST", "path": "/v1/completions", "spec_ref": "https://platform.openai.com/docs/api-reference/completions/create", "deprecated": true, "successor": "/v1/chat/completions or /v1/responses"}
      ]
    },
    {
      "name": "Responses",
      "endpoints": [
        {"method": "POST",   "path": "/v1/responses",                           "spec_ref": "https://platform.openai.com/docs/api-reference/responses/create", "streaming": true, "stateful": true, "tools": true, "mcp": true},
        {"method": "GET",    "path": "/v1/responses/{response_id}",             "spec_ref": "https://platform.openai.com/docs/api-reference/responses/get"},
        {"method": "DELETE", "path": "/v1/responses/{response_id}",             "spec_ref": "https://platform.openai.com/docs/api-reference/responses/delete"},
        {"method": "GET",    "path": "/v1/responses/{response_id}/input_items", "spec_ref": "https://platform.openai.com/docs/api-reference/responses/input-items"},
        {"method": "POST",   "path": "/v1/responses/{response_id}/cancel",      "spec_ref": "https://platform.openai.com/docs/api-reference/responses/cancel"}
      ]
    },
    {
      "name": "Embeddings",
      "endpoints": [
        {"method": "POST", "path": "/v1/embeddings", "spec_ref": "https://platform.openai.com/docs/api-reference/embeddings/create"}
      ]
    },
    {
      "name": "MCP",
      "endpoints": [
        {"method": "GET", "path": "/v1/mcp", "spec_ref": "https://modelcontextprotocol.io/specification", "manifest": "/usr/share/mios/ai/v1/mcp.json"}
      ]
    },
    {
      "name": "Tools",
      "endpoints": [
        {"method": "GET", "path": "/v1/tools", "manifest": "/usr/share/mios/ai/v1/tools.json"}
      ]
    }
  ]
}
