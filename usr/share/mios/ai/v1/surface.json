{
  "object": "mios.api.surface",
  "version": "v1",
  "spec_ref": "https://platform.openai.com/docs/api-reference",
  "manifest_path": "/usr/share/mios/ai/v1/surface.json",
  "base_url": "http://localhost:8640/v1",
  "served_by": "mios-agent-pipe.service",
  "served_by_note": "MiOS-Agent (agent-pipe) is the canonical entry. It refines the user prompt on a CPU micro-LLM, routes to the registered sub-agent (Hermes for general orchestration, opencode for coding, mios-daemon-agent for log/journal followups, ...), and polishes the reply. Sub-agent raw output is wrapped in <details type=\"reasoning\"> for OWUI dropdowns.",
  "backed_by": "mios-hermes.service (default sub-agent)",
  "auth": {
    "scheme": "Bearer",
    "header": "Authorization",
    "env": "MIOS_AI_KEY",
    "source": "/etc/mios/hermes/api.env",
    "passport_signing": {
      "enabled": true,
      "scheme": "Ed25519",
      "key_root": "/var/lib/mios/passports",
      "manifest_path": "/usr/share/mios/ai/v1/agents.json"
    }
  },
  "ports": {
    "agent_pipe": {"port": 8640, "service": "mios-agent-pipe.service",          "role": "canonical /v1 entry"},
    "hermes":     {"port": 8642, "service": "hermes-agent.service",             "role": "default sub-agent (general orchestration)"},
    "hermes_dashboard": {"port": 9119, "service": "hermes-dashboard.service",   "role": "sessions/skills/stats web UI"},
    "llm_light":  {"port": 11450, "service": "mios-llm-light.service",          "role": "llama.cpp multi-model + KV-paging inference lane"},
    "pgvector":   {"port": 5432,  "service": "mios-pgvector.service",           "role": "PostgreSQL database + pgvector vector store for shared agent state (sessions, tool_call, event, kanban_shadow, scratch, agent_metric)"},
    "open_webui": {"port": 3030,  "service": "mios-open-webui.service",         "role": "browser front-end; pipes prompts to :8640"},
    "searxng":    {"port": 8888,  "service": "mios-searxng.service",            "role": "local SearXNG; web_search backend"},
    "ttyd_bash":      {"port": 7681, "service": "mios-ttyd-bash.service",       "role": "browser pty -- Linux bash"},
    "ttyd_powershell":{"port": 7682, "service": "mios-ttyd-powershell.service", "role": "browser pty -- Windows PowerShell"}
  },
  "groups": [
    {
      "name": "Models",
      "endpoints": [
        {"method": "GET",  "path": "/v1/models",         "spec_ref": "https://platform.openai.com/docs/api-reference/models/list",     "manifest": "/usr/share/mios/ai/v1/models.json"},
        {"method": "GET",  "path": "/v1/models/{model}", "spec_ref": "https://platform.openai.com/docs/api-reference/models/retrieve"}
      ]
    },
    {
      "name": "Chat Completions",
      "endpoints": [
        {"method": "POST", "path": "/v1/chat/completions", "spec_ref": "https://platform.openai.com/docs/api-reference/chat/create", "streaming": true, "tools": true, "json_mode": true, "json_schema": true}
      ]
    },
    {
      "name": "Responses",
      "endpoints": [
        {"method": "POST",   "path": "/v1/responses",                           "spec_ref": "https://platform.openai.com/docs/api-reference/responses/create", "streaming": true, "stateful": true, "tools": true, "mcp": true},
        {"method": "GET",    "path": "/v1/responses/{response_id}",             "spec_ref": "https://platform.openai.com/docs/api-reference/responses/get"},
        {"method": "DELETE", "path": "/v1/responses/{response_id}",             "spec_ref": "https://platform.openai.com/docs/api-reference/responses/delete"},
        {"method": "GET",    "path": "/v1/responses/{response_id}/input_items", "spec_ref": "https://platform.openai.com/docs/api-reference/responses/input-items"},
        {"method": "POST",   "path": "/v1/responses/{response_id}/cancel",      "spec_ref": "https://platform.openai.com/docs/api-reference/responses/cancel"}
      ]
    },
    {
      "name": "Embeddings",
      "endpoints": [
        {"method": "POST", "path": "/v1/embeddings", "spec_ref": "https://platform.openai.com/docs/api-reference/embeddings/create"}
      ]
    },
    {
      "name": "Health",
      "endpoints": [
        {"method": "GET", "path": "/health", "manifest_note": "agent-pipe health: agents loaded, refine model, polish model, satisfaction loop state"}
      ]
    },
    {
      "name": "MCP",
      "endpoints": [
        {"method": "GET", "path": "/v1/mcp", "spec_ref": "https://modelcontextprotocol.io/specification", "manifest": "/usr/share/mios/ai/v1/mcp.json"}
      ]
    },
    {
      "name": "Tools",
      "endpoints": [
        {"method": "GET", "path": "/v1/tools", "manifest": "/usr/share/mios/ai/v1/tools.json"}
      ]
    }
  ]
}
