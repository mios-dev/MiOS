# AI-hint: Containerfile to build the unified localhost/mios-cuda image (WS-MIOSSYS).
# AI-related: usr/share/mios/cuda/Containerfile, automation/57-mios-sys-build.sh
ARG BASE_IMAGE=ghcr.io/ublue-os/ucore-hci:stable-nvidia

# --- Llama-swap source (the light-LLM-lane binaries -- ghcr, small) ---
# The vLLM + SGLang "source" stages were REMOVED. They pulled the ~47GB
# docker.io/vllm/vllm-openai + docker.io/lmsysorg/sglang whale images ONLY to
# COPY /usr/local -> /opt/{vllm,sglang}-venv, but NOTHING consumed those venvs:
# the heavy LLM lanes run the vLLM/SGLang CONTAINER images directly via their
# Quadlets (mios-llm-heavy / -alt, firstboot-pulled -- see mios.toml
# [build.bake].firstboot_tokens). Baking them re-pulled the whales at BUILD time
# -> disk overrun + Docker Hub rate limit on CI runners, and bloated mios-cuda
# with dead venvs. Removed to keep the whales strictly firstboot-tier.
FROM ghcr.io/mostlygeek/llama-swap:cuda AS llamaswap-src

# --- Final/Main CUDA Base Image Stage ---
FROM ${BASE_IMAGE}

# Install CUDA packages and runtime dependencies
RUN dnf install -y \
      python3 \
      python3-pip \
      python3-devel \
      && dnf clean all

# Copy llama-swap and llama-server binaries
COPY --from=llamaswap-src /usr/bin/llama-server /usr/bin/llama-server
COPY --from=llamaswap-src /usr/bin/llama-swap /usr/bin/llama-swap

# Create /app directory and set up symlinks to match upstream paths expected by configs
RUN mkdir -p /app \
    && ln -sf /usr/bin/llama-server /app/llama-server \
    && ln -sf /usr/bin/llama-swap /app/llama-swap
