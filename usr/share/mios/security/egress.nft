# AI-hint: GENERATED nftables egress firewall for the MiOS agent (#54). DO NOT EDIT -- regenerate via tools/generate-egress-firewall.py. OFF: informational ruleset; applying it changes nothing.
# Apply (operator step): nft -f usr/share/mios/security/egress.nft   |   Remove: nft delete table inet mios_egress
# mode=off  agent-user=mios-ai  always-allowed: loopback + tailnet 100.64.0.0/10 + WSL gateway 172.16.0.0/12 + [security.egress].allow
table inet mios_egress {
    chain output {
        type filter hook output priority filter; policy accept;
        meta skuid != "mios-ai" accept
        oifname "lo" accept
        ip daddr 127.0.0.0/8 accept
        ip6 daddr ::1 accept
        ip daddr 100.64.0.0/10 accept
        ip daddr 172.16.0.0/12 accept
        accept   # mode=off -> no-op even if applied
    }
}
