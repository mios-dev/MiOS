# /usr/share/mios/distrobox/aichat/Containerfile
#
# AI CLI agents in a Distrobox container, per the project's
# "irreducible substrate" law (Architectural Law 1: VM | Container |
# Flatpak only; no application binaries on the host substrate). This
# replaces the transitional /usr/bin/aichat + /usr/bin/aichat-ng
# install in automation/37-aichat.sh -- the same release tarballs are
# unpacked inside the container instead, then exported to the host
# PATH via distrobox's `exported_bins` mechanism.
#
# Build inputs (all default to :latest per project tag policy):
#   ARG AICHAT_TAG     - pin upstream sigoden/aichat release (defaults
#                        to the most recent verified release).
#   ARG AICHAT_NG_TAG  - pin upstream blob42/aichat-ng release.
#
# Build via:
#   .build Quadlet at /usr/share/containers/systemd/mios-aichat.build
#   (declarative; podman-systemd realizes it on first daemon-reload).
# OR manually:
#   podman build -t localhost/mios/aichat:latest \
#                --build-arg AICHAT_TAG=v0.27.0 \
#                /usr/share/mios/distrobox/aichat
FROM registry.fedoraproject.org/fedora-toolbox:latest

ARG AICHAT_TAG=v0.27.0
ARG AICHAT_NG_TAG=v0.31.0
ARG TARGETARCH=amd64

LABEL org.opencontainers.image.title="mios-aichat"
LABEL org.opencontainers.image.description="aichat + aichat-ng Distrobox layer for MiOS"
LABEL org.opencontainers.image.source="https://github.com/mios-dev/mios"
LABEL org.opencontainers.image.licenses="Apache-2.0"
# Distrobox-friendly hint -- the host integration script reads this
# label to decide which binaries to export to the user's PATH.
LABEL org.mios.distrobox.exported_bins="aichat,aichat-ng"

# Toolchain needed only inside the container (host substrate stays clean).
RUN dnf -y install --setopt=install_weak_deps=False --skip-unavailable \
        ca-certificates curl tar xz jq \
    && dnf clean all

# aichat -- official OpenAI-API-compatible CLI (Rust, statically linked
# against musl in upstream's release tarball).
RUN set -eux; \
    arch_suffix=x86_64-unknown-linux-musl; \
    [ "$TARGETARCH" = "arm64" ] && arch_suffix=aarch64-unknown-linux-musl; \
    asset="aichat-${AICHAT_TAG}-${arch_suffix}.tar.gz"; \
    base="https://github.com/sigoden/aichat/releases/download/${AICHAT_TAG}"; \
    curl -fsSL "${base}/${asset}" -o /tmp/aichat.tar.gz; \
    tar -xzf /tmp/aichat.tar.gz -C /usr/local/bin/ aichat; \
    chmod +x /usr/local/bin/aichat; \
    rm -f /tmp/aichat.tar.gz; \
    /usr/local/bin/aichat --version

# aichat-ng -- community fork with extra agent features.
RUN set -eux; \
    arch_suffix=x86_64-unknown-linux-musl; \
    [ "$TARGETARCH" = "arm64" ] && arch_suffix=aarch64-unknown-linux-musl; \
    asset="aichat-ng-${AICHAT_NG_TAG}-${arch_suffix}.tar.gz"; \
    base="https://github.com/blob42/aichat-ng/releases/download/${AICHAT_NG_TAG}"; \
    curl -fsSL "${base}/${asset}" -o /tmp/aichat-ng.tar.gz; \
    tar -xzf /tmp/aichat-ng.tar.gz -C /usr/local/bin/ aichat-ng; \
    chmod +x /usr/local/bin/aichat-ng; \
    rm -f /tmp/aichat-ng.tar.gz; \
    /usr/local/bin/aichat-ng --version

# Default config that mirrors /etc/aichat/config.yaml on the host. The
# host's config wins when present (distrobox bind-mounts /etc), but
# this gives operators a working default if they run aichat inside the
# container directly via `distrobox enter mios-aichat`.
COPY config.yaml /etc/aichat/config.yaml

# Distrobox export marker -- host-side `mios-distrobox-init.sh`
# reads /usr/share/distrobox/exports for each container and creates
# wrapper shims under ~/.local/bin.
RUN mkdir -p /usr/share/distrobox \
    && printf 'aichat\naichat-ng\n' > /usr/share/distrobox/exports

CMD ["/bin/bash"]
