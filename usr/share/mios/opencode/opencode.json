{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/mios-opencode:latest",
  "small_model": "ollama/mios-opencode:latest",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiOS-Inference (Ollama)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "mios-opencode:latest": {
          "name": "MiOS-OpenCode (coding role; FROM qwen2.5-coder:7b)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (MiOS opencode small)"
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen 2.5 Coder 14B (MiOS opencode mid)"
        },
        "qwen3-coder:30b": {
          "name": "Qwen 3 Coder 30B (MiOS opencode big)"
        }
      }
    }
  }
}
