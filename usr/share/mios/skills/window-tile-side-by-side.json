{
  "name": "window-tile-side-by-side",
  "description": "Tile two windows side-by-side: window matching `left` at (0,0) sized `half_width`x`height`, window matching `right` at (`half_width`,0) same size.",
  "source": "import",
  "status": "promoted",
  "body": {
    "steps": [
      {"verb": "focus_window",    "args": {"title": "$left",  "position": "as-is"}},
      {"verb": "position_window", "args": {"title": "$left",  "x": 0,                  "y": 0}},
      {"verb": "resize_window",   "args": {"title": "$left",  "width": "$half_width",  "height": "$height"}},
      {"verb": "focus_window",    "args": {"title": "$right", "position": "as-is"}},
      {"verb": "position_window", "args": {"title": "$right", "x": "$half_width",      "y": 0}},
      {"verb": "resize_window",   "args": {"title": "$right", "width": "$half_width",  "height": "$height"}}
    ],
    "params": ["left", "right", "half_width", "height"]
  }
}
