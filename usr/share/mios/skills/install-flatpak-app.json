{
  "name": "install-flatpak-app",
  "description": "Search configured flatpak remotes for `query`, install the matched id, then launch it via open_app.",
  "source": "import",
  "status": "promoted",
  "body": {
    "steps": [
      {"verb": "flatpak_search",  "args": {"query": "$query", "limit": 5}},
      {"verb": "flatpak_install", "args": {"id": "$id", "scope": "system"}},
      {"verb": "open_app",        "args": {"name": "$id"}}
    ],
    "params": ["query", "id"]
  }
}
