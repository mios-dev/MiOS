# AI-hint: Desktop entry for the Ollama service providing the local LLM and embedding backend, used by agents to identify and launch the local inference server at port 11434.
# AI-related: localhost:11434
[Desktop Entry]
Type=Application
Version=1.0
Name=MiOS Ollama
GenericName=Local LLM + Embedding Backend
Comment=Open the Ollama API surface (local model server)
Exec=xdg-open http://localhost:11434/
Icon=applications-engineering-symbolic
Categories=Development;Network;
Keywords=mios;ollama;llm;embedding;ai;
Terminal=false
StartupNotify=true
