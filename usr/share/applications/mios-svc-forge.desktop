# AI-hint: Desktop entry for the MiOS Forge (Forgejo) service, providing a launcher to open the local Git repository management web interface at http://localhost:3000/ via the system's default browser.
# AI-related: localhost:3000
[Desktop Entry]
Type=Application
Version=1.0
Name=MiOS Forge
GenericName=Self-Hosted Git Forge (Forgejo)
Comment=Open the local Forgejo git forge at http://localhost:3000/
Exec=xdg-open http://localhost:3000/
Icon=text-x-generic-symbolic
Categories=Development;RevisionControl;Network;
Keywords=mios;forge;forgejo;git;gitea;repo;
Terminal=false
StartupNotify=true
