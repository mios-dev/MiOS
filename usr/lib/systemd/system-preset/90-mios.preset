# 'MiOS' systemd preset
# "enable" = on boot; "disable" = off. Role-specific services are NOT here;
# mios-role.service enables/disables them at runtime based on role.conf.

# --- Always-on core ---
# WSLg-only: chmod /mnt/wslg/runtime-dir to 0700 BEFORE weston starts,
# unblocking VAIL (shared-memory) mode. No-ops on non-WSLg
# substrates via ConditionPathIsDirectory.
enable mios-wslg-permissions-fix.service
# Boot-time chmod -R go+rX on the additionalimagestores under
# /usr/lib/containers/storage so unprivileged podman / flatpak / etc.
# can read it. Belt-and-suspenders for stale OCI images that pre-date
# the Containerfile bake-step chmod (commit a85925d). No-op when perms
# are already correct.
enable mios-additionalimagestores-perms.service
# Boot-time `firewall-cmd --add-port` for every MiOS service port.
# Belt-and-suspenders against stale OCI images / failed install-time
# 25-firewall-ports.sh runs that leave firewalld without the ports
# open, silently breaking ALL Windows->WSL bridging (3030/8642/8888/
# 9090). Idempotent.
enable mios-firewall-ports.service
enable sshd.service
enable NetworkManager.service
enable podman.socket
enable podman-auto-update.timer
enable libvirtd.socket
enable virtnetworkd.socket
enable virtqemud.socket
enable virtstoraged.socket
enable virtnodedevd.socket
enable virtnwfilterd.socket
enable virtsecretd.socket
enable virtproxyd.socket
enable uupd.timer
enable nvidia-cdi-refresh.path
enable nvidia-cdi-refresh.service
enable nvidia-persistenced.service
enable firewalld.service
enable chronyd.service
enable systemd-resolved.service
enable pmcd.service
enable pmlogger.service
enable pmproxy.service
enable bootloader-update.service
enable mios-role.service
enable mios-gpu-detect.service
enable mios-selinux-init.service
enable mios-sriov-init.service
enable mios-cdi-detect.service
enable mios-libvirtd-setup.service
enable mios-grd-setup.service
# Hyper-V Enhanced Session bring-up: hv_sock module + hv-kvp-daemon +
# hv-vss-daemon + hv-fcopy-daemon + xrdp on the VMBus vsock transport.
# ConditionVirtualization=microsoft inside the unit gates the actual
# work to Hyper-V hosts; on every other deployment shape (bare-metal,
# WSL2, QEMU, VirtualBox) the unit no-ops at the systemd condition
# check. Safe to enable everywhere.
enable mios-hyperv-enhanced.service
enable systemd-sysext.service
enable systemd-confext.service
enable mios-dashboard-issue.service
enable mios-dashboard-issue.timer
enable mios-bootc-switch.path
enable gnome-remote-desktop.service
enable mios-firstboot.target
# /=git auto-init: turns / into a git working tree of the operator's
# Forgejo mios.git repo on first boot, after mios-forge-firstboot has
# created the admin user. Idempotent (sentinel = /.git presence).
enable mios-git-root-init.service
enable greenboot-healthcheck.service
enable greenboot-grub2-set-counter.service
enable greenboot-grub2-set-success.service
enable greenboot-rpm-ostree-grub2-check-fallback.service
enable greenboot-status.service
enable redboot-auto-reboot.service
enable cockpit.socket
enable mios-searxng.service
enable mios-hermes-firstboot.service
enable hermes-agent.service
enable mios-open-webui.service
enable mios-code-server.service
# Forge bootstrap: admin user + initial repo + runner registration token
# all minted on first boot. mios-forgejo-runner reads the token and
# self-registers; without firstboot enabled the runner stays inactive
# (ConditionPathExists=/etc/mios/forge/runner-token never satisfied).
enable mios-forge.service
enable mios-forge-firstboot.service
enable mios-forgejo-runner-firstboot.service
enable mios-forgejo-runner.service
# user@1000.service starts the per-user systemd manager + user D-Bus
# session bus for the 'mios' user (uid 1000, pinned in
# /usr/lib/sysusers.d/10-mios.conf). Normally systemd-logind reads
# /var/lib/systemd/linger/mios and starts this; on WSL2 logind is
# ConditionVirtualization=!wsl-gated, so we enable the template
# directly so the user bus exists regardless of logind. This is what
# eliminates the boot-time "Failed to connect to system scope bus
# via local transport" error from `wsl -d MiOS` and lets `wsl -- foo`
# reach the user D-Bus.
enable user@1000.service
enable usbguard.service
enable auditd.service
enable crowdsec.service
enable crowdsec-firewall-bouncer.service
enable nftables.service
enable mios-mcp.service
enable redis.service
enable cloud-init.service
enable cloud-final.service
enable qemu-guest-agent.service

# --- WSL2 fallback & initialization (ConditionVirtualization=wsl gated) ---
# mios-wsl-early MUST stay first: it makes / rshared and creates
# /dev/{net/tun,fuse} before any unit with sandboxing or rootless
# podman fires. Without it, cockpit fails 226/NAMESPACE and every
# Quadlet fails fuse-overlayfs/slirp4netns at boot.
enable mios-wsl-early.service
enable mios-wsl-firstboot.service
enable mios-wsl-init.service
enable mios-wsl-runtime-dir.service
# (dbus-daemon-wsl.service was removed entirely -- dbus-broker now runs
# on WSL via 10-mios-no-audit.conf, and the legacy /usr/bin/dbus-daemon
# binary is not shipped on Fedora CoreOS 44.)

# --- First-boot AI model pull (sentinel-guarded) ---
# Build-time embedding fails because the OCI build's final /var
# cleanup deletes /var/lib/ollama. The first-boot service pulls the
# default model set into the persistent /var post-deploy.
enable mios-ollama-firstboot.service

# --- Disabled in favor of uupd ---
disable bootc-fetch-apply-updates.timer
disable rpm-ostreed-automatic.timer

# --- Broken with composefs on F42+ ---
disable systemd-remount-fs.service

# --- Role-gated: default-off; mios-role.service turns on as appropriate ---
disable libvirtd.service
disable libvirtd-ro.socket
disable libvirtd-admin.socket
disable virtnetworkd.service
disable virtnodedevd.service
disable virtqemud.service
disable virtstoraged.service
disable gdm.service
disable k3s.service
disable k3s-agent.service
disable corosync.service
disable pacemaker.service
disable ceph-mon@.service
disable ceph-osd@.service

# --- Optional / Fail-silent (default disabled) ---
enable fapolicyd.service
disable tailscaled.service
disable mios-pxe-hub.service
disable waydroid-container.service
disable smb.service
disable nmb.service
disable nfs-server.service
disable rpcbind.service
disable libvirt-guests.service
disable mios-ha-bootstrap.service
disable osbuild-composer.service
disable osbuild-worker@1.service
disable multipathd.service
disable cloud-init-local.service
disable cloud-config.service
