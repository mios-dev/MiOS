[Unit]
Description='MiOS' Gateway Agent Service (FastAPI smolagents Engine)
# R8: NOT ordered After=mios-ai-firstboot.service. The Hermes gateway needs the VENV
# (baked into the image) + pgvector, NOT the boot-time model fetch; firstboot restarts
# this unit once models land, so blocking it behind the download only held the plane hostage.
After=network-online.target mios-pgvector.service
Wants=network-online.target mios-pgvector.service

[Service]
Type=simple
User=mios-ai
Group=mios-ai
WorkingDirectory=/usr/lib/mios/gateway-agent
Environment=HOME=/var/lib/mios/hermes
EnvironmentFile=-/etc/mios/install.env
ExecStart=/usr/lib/mios/agents/.venv/bin/python3 -u /usr/lib/mios/gateway-agent/server.py
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
