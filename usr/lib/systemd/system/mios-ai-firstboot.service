# AI-hint: Systemd unit that executes the mios-ai-firstboot script to provision the AI agent virtual environment and download llama.cpp GGUF models if the .ai-firstboot-done sentinel is missing.
# AI-related: 38-hermes-agent.sh, /usr/libexec/mios/mios-ai-firstboot, mios-ai-firstboot, mios-dev, mios-llm-light.service, mios-llm-light.service, mios-llm-light.service, network-online.target
[Unit]
Description='MiOS' AI first-boot provisioning (agent venv + llama.cpp GGUFs)
Documentation=https://github.com/mios-dev/mios
# Completes the build-time AI setup on deployments that didn't bake it (the
# overlay-provisioned dev VM, WSL imports, etc.). 38-hermes-agent.sh's header
# explicitly anticipates this: "a firstboot retry can complete it later".
# Needs network (pip + model pull) and a running ollama (the GGUF blob source).
After=network-online.target
Wants=network-online.target
# The script writes the sentinel ONLY when both the venv and the GGUFs are
# present, so a network-less first boot simply retries on the next one.
ConditionPathExists=!/var/lib/mios/.ai-firstboot-done
# Retry is owned by mios-ai-firstboot.timer (OnBootSec + OnUnitInactiveSec), NOT
# an in-unit Restart=on-failure / StartLimitBurst storm. The script degrades open
# (exit 0) on a partial provision, so the unit shows success and the timer simply
# re-fires it on its cadence until the sentinel above is written.

[Service]
Type=oneshot
RemainAfterExit=yes
# Cap a hung fetch (multi-GB model download) at 10min so it can't wedge the unit
# forever; the timer re-fires the run afterwards. (Was 2400s.)
TimeoutStartSec=600
# The script reads MIOS_LLAMACPP_BAKE_MODELS (the GGUF download spec) +
# MIOS_AI_* from the env bridge. Without this, a fresh systemd boot has an
# EMPTY environment -> bake_models reads empty -> "GGUFs not baked" -> the
# llm-light lane stays inert forever. The leading '-' makes it optional so
# the unit still starts (and retries) if the bridge isn't generated yet.
# install-robustness 2026-06-21.
EnvironmentFile=-/etc/mios/install.env
ExecStart=/usr/libexec/mios/mios-ai-firstboot

[Install]
WantedBy=multi-user.target
