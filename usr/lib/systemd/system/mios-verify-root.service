[Unit]
Description=MiOS Root Filesystem Verification
ConditionVirtualization=!container
Documentation=file:///usr/share/doc/mios/COMPOSEFS-VERIFICATION.md
DefaultDependencies=no
Before=greenboot-healthcheck.service basic.target local-fs.target
After=ostree-remount.service
ConditionPathExists=/run/ostree-booted

[Service]
Type=oneshot
ExecStart=/usr/libexec/mios/verify-root.sh
RemainAfterExit=yes

# Hardening -- this unit runs very early and touches no writable state.
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateNetwork=yes
NoNewPrivileges=yes
CapabilityBoundingSet=
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
LockPersonality=yes
PrivateDevices=yes
BindReadOnlyPaths=/usr /etc /run/ostree-booted

[Install]
WantedBy=local-fs.target
