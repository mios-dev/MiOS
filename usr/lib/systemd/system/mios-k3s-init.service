# AI-hint: Systemd unit that seeds K3s with MiOS-specific manifests by copying files from /usr/share/mios/k3s-manifests to the K3s server datastore during boot.
# AI-related: /usr/share/mios/k3s-manifests, /usr/share/mios/k3s-manifests/, k3s.service, k3s.container, multi-user.target
[Unit]
Description='MiOS' K3s Manifest Seeder
Before=k3s.service
ConditionPathExists=/usr/share/mios/k3s-manifests
# Pure file-copy oneshot -- no kernel/hardware coupling. Run on every
# shape including WSL (k3s.container itself stays !wsl-gated; this
# seeder is harmless if k3s ultimately doesn't start).
ConditionVirtualization=|!container
ConditionVirtualization=|wsl

[Service]
Type=oneshot
RemainAfterExit=yes

# Copy the immutable manifests into the persistent datastore
ExecStart=/bin/bash -c "cp -a /usr/share/mios/k3s-manifests/*.yaml /var/lib/rancher/k3s/server/manifests/ 2>/dev/null || true"
ExecStartPost=/bin/chmod 0600 /var/lib/rancher/k3s/server/manifests/*.yaml

[Install]
WantedBy=multi-user.target
