[Unit]
Description=MiOS first-boot libvirtd wiring
ConditionPathExists=!/var/lib/mios/libvirtd-setup.done
ConditionVirtualization=no
After=libvirtd.service
Wants=libvirtd.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/libexec/mios/libvirtd-firstboot
ExecStartPost=/usr/bin/install -Dm0644 /dev/null /var/lib/mios/libvirtd-setup.done

[Install]
WantedBy=mios-firstboot.target