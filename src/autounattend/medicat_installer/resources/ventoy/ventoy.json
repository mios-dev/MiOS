{
    "control":[
        { "VTOY_DEFAULT_MENU_MODE": "1" },
        { "VTOY_TREE_VIEW_MENU_STYLE": "1" },
        { "VTOY_WIN11_BYPASS_CHECK": "1" },
        { "VTOY_DEFAULT_IMAGE": "/Live_Operating_Systems/Mini_Windows/MiOS_PE.wim" },
        { "VTOY_MENU_TIMEOUT": "5" },
        { "VTOY_LINUX_REMOUNT": "1" },
        { "VTOY_SECONDARY_BOOT_MENU": "0" }
    ],
    "theme":{
        "gfxmode": "1024x768"
    },
    "theme_legacy":{
        "file": "/ventoy/theme/legacy/theme.txt",
        "gfxmode": "1024x768",
        "ventoy_left": "0%",
        "ventoy_top": "0",
        "ventoy_color": "#1A407F"
    },
    "theme_uefi":{
        "file": "/ventoy/theme/uefi/theme.txt",
        "gfxmode": "1024x768",
        "ventoy_left": "0%",
        "ventoy_top": "0%",
        "ventoy_color": "#1A407F"
    },
    "theme_ia32":{
        "gfxmode": "1024x768"
    },
    "theme_aa64":{
        "gfxmode": "1024x768"
    },
    "theme_mips":{
        "gfxmode": "1024x768"
    },
    "conf_replace_legacy":[
        {
            "iso": "/Live_Operating_Systems/SystemRescue/SystemRescue.iso",
            "org": "/sysresccd/boot/syslinux/sysresccd_sys.cfg",
            "new": "/ventoy/sysrescue_syslinux.cfg"
        }
    ],
    "conf_replace_uefi":[
        {
            "iso": "/Live_Operating_Systems/SystemRescue/SystemRescue.iso",
            "org": "/boot/grub/grubsrcd.cfg",
            "new": "/ventoy/sysrescue_grub.cfg"
        }
    ],
    "kickstart":[
        {
            "image": "/Live_Operating_Systems/Fedora-Server.iso",
            "template": "/ventoy/mios-kickstart.cfg"
        }
    ]
}

